<?xml version="1.0" encoding="UTF-8"?>
<Defs>
    <!--Sacrifice-related body parts-->

    <!--Bodhisattva heart (sacrifice)-->
    <!--Effect: blood-colored thorns behind head-->
    <!--Halo — tremor, reduce armor, damage taken x3-->

    <!--Crimson eyes-->
    <!--Nightmare gaze, small area mental breakdown-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_CrimsonEyes</defName>
        <label>crimson eyes</label>
        <labelNoun>an crimson eyes</labelNoun>
        <!--Shining with crimson light, almost identical to the stripes you saw on that strange monolith-->
        <description>Shining with crimson light, it is almost identical to the stripes you saw on that strange
            monolith.</description>
        <defaultInstallPart>Eye</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <abilities>
            <li>NzRI_Zd_NightmareGaze</li>
        </abilities>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!--Strange tongue-->
    <!--Terror scream, range fear-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_StrangeTongue</defName>
        <label>strange tongue</label>
        <labelNoun>an strange tongue</labelNoun>
        <!--Covered with strange patterns, twisted like a snake's tongue, with faint eyeballs connected to it-->
        <description>It is covered with strange patterns, twisted like a snake's tongue, and there are faint
            eyeballs connected to it.</description>
        <defaultInstallPart>Tongue</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <abilities>
            <li>NzRI_Zd_TerrorScream</li>
        </abilities>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!--Hypertrophy liver-->
    <!--Spit out a flesh beast-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_HypertrophyLiver</defName>
        <label>hypertrophy liver</label>
        <labelNoun>an strange tongue</labelNoun>
        <!--Occasional dull bloating pain-->
        <description>#in development</description>
        <defaultInstallPart>Liver</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <abilities>
            <!-- TODO -->
            <!-- <li>Zd_TouchingHead</li> -->
        </abilities>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!--Abscess arm-->
    <!--Attacks cause nausea-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_AbscessArm</defName>
        <label>abscess arm</label>
        <labelNoun>an abscess arm</labelNoun>
        <!--Your arm is covered with pustules, with other parts in a semi-rotten state-->
        <description>There are pustules on your arm, and other parts are also in a semi-rotten state.</description>
        <defaultInstallPart>Shoulder</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <comps>
            <li Class="HediffCompProperties_VerbGiver">
                <tools>
                    <li>
                        <label>fist</label>
                        <capacities>
                            <li>Blunt</li>
                        </capacities>
                        <extraMeleeDamages>
                            <li>
                                <def>AcidBurn</def>
                                <amount>27</amount>
                            </li>
                            <li>
                                <def>NzRI_Dm_PustuleStrike</def>
                                <amount>27</amount>
                            </li>
                        </extraMeleeDamages>
                        <power>41</power>
                        <armorPenetration>2.0</armorPenetration>
                        <cooldownTime>1.25</cooldownTime>
                        <soundMeleeHit>MeleeHit_BionicPunch</soundMeleeHit>
                        <soundMeleeMiss>MeleeMiss_BionicPunch</soundMeleeMiss>
                    </li>
                </tools>
            </li>
        </comps>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!--Coiled arm-->
    <!--High cutting damage-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_CoiledArm</defName>
        <label>coiled arms</label>
        <labelNoun>an vajra arm</labelNoun>
        <!--A real tentacle that rapidly alternates between hardness and softness. Outside the world of 'DaNuo', it seems the response of the 'Five Wisdom Tathagatas' was intercepted by something terrible-->
        <description>A real tentacle, quickly moving between hardness and softness, it seems that the response of
            the 'Five Wisdom Tathagatas' to the 'DaNuo' has been intercepted by something terrible.</description>
        <defaultInstallPart>Shoulder</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <abilities>
            <!--Slash-->
            <li>NzRI_Zd_TentacleSlash</li>
            <!--Stab-->
            <li>NzRI_Zd_TentacleStab</li>
        </abilities>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <comps>
            <li Class="HediffCompProperties_VerbGiver">
                <tools>
                    <li>
                        <label>fist</label>
                        <capacities>
                            <li>Blunt</li>
                        </capacities>
                        <power>42</power>
                        <armorPenetration>1.5</armorPenetration>
                        <cooldownTime>0.75</cooldownTime>
                        <soundMeleeHit>MeleeHit_BionicPunch</soundMeleeHit>
                        <soundMeleeMiss>MeleeMiss_BionicPunch</soundMeleeMiss>
                    </li>
                </tools>
            </li>
        </comps>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!--Twisted leg-->
    <!--Dragging-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_TwistedLeg</defName>
        <label>twisted leg</label>
        <labelNoun>an twisted leg</labelNoun>
        <!--This leg is twisted and disordered, nearly boneless like a tentacle, yet surprisingly tough and flexible-->
        <description>One of the legs is twisted and disordered, almost boneless, like tentacles, but
            it is particularly tough and flexible.</description>
        <defaultInstallPart>Leg</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
        <abilities>
            <li>NzRI_Zd_Drag</li>
        </abilities>
    </HediffDef>

    <!--Withered leg-->
    <!--Surrounding leg cut-->
    <HediffDef ParentName="ZdBodyPartBase">
        <defName>NzRI_Zd_WitheredLeg</defName>
        <label>withered leg</label>
        <labelNoun>an withered leg</labelNoun>
        <!--This leg is black, thin, and withered yet powerfully strong. Covered in ugly scars and wrinkles, it emits a stench of rotten flesh, with a strange fiber material bearing both organic and metallic properties-->
        <description>This leg is black, thin, and withered, but it is particularly strong and powerful. It is covered
            with ugly scars and wrinkles, and it emits a stench of rotten flesh. There is also a strange fiber
            material with both organic and metallic properties.</description>
        <defaultInstallPart>Leg</defaultInstallPart>
        <tags>
            <li>NzRI_ZhengDe_BodyPart</li>
            <li>NzRI_ZhengDe_Sacrifice</li>
        </tags>
        <stages>
            <li>
                <statFactors>
                    <NzRI_ZhengDePowerMultiplier>1.3</NzRI_ZhengDePowerMultiplier>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.50</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
        <abilities>
            <li>NzRI_Zd_LegSweep</li>
        </abilities>
    </HediffDef>
</Defs>