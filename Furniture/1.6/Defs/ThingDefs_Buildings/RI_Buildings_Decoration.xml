	<!--======================= 餐厅装饰 ==============================-->

	<!--吊柜-->
	<ThingDef ParentName="RI_Ming_DecorationBase">
		<defName>RI_Building_WallCupboard</defName>
		<label>Wall cupboard</label>
		<description>A cupboard for storing bowls and chopsticks.</description>
		<graphicData>
			<texPath>Things/Building/Decoration/RI_Building_WallCupboard</texPath>
			<drawSize>(2.15,2.15)</drawSize>
		</graphicData>
		<uiIconPath>Things/Building/Decoration/RI_Building_WallCupboard</uiIconPath>
		<uiIconScale>2</uiIconScale>

		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>20</costStuffCount>

		<statBases>
			<Beauty>3</Beauty>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToBuild>600</WorkToBuild>
			<Flammability>1</Flammability>
			<Mass>2</Mass>
		</statBases>
	</ThingDef>

