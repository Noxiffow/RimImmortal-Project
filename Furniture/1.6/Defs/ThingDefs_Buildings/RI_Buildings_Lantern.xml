<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef Name="RI_Furniture_LanternBase" ParentName="RI_Furniture_BuildingBase" Abstract="True">
		<category>Building</category>
		<graphicData>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>0</pathCost>
		<tickerType>Normal</tickerType>
		<drawerType>RealtimeOnly</drawerType>
		<fillPercent>0.15</fillPercent>
		<selectable>true</selectable>
		<soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
		<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		<clearBuildingArea>false</clearBuildingArea>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsFurniture</li>
		</thingCategories>
	</ThingDef>

	<!--Red lantern (lit)-->
	<ThingDef ParentName="RI_Furniture_LanternBase">
		<defName>RI_Building_RedLantern_Light</defName>
		<label>Red lantern</label>
		<description>A red lantern, emit light and looks festive.</description>
		<graphicData>
			<texPath>Things/Building/Furniture/Lantern/TW_CNY_RedLanternLight</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawRotated>true</drawRotated>
			<drawSize>(1.2,1.2)</drawSize>
		</graphicData>
		<uiIconPath>Things/Building/Furniture/Lantern/TW_CNY_RedLanternLight</uiIconPath>
		<uiIconScale>1.2</uiIconScale>
		<rotatable>true</rotatable>
		<constructEffect>ConstructWood</constructEffect>
		<statBases>
			<Beauty>5</Beauty>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Flammability>0.5</Flammability>
			<Mass>1</Mass>
		</statBases>
		<techLevel>Medieval</techLevel>
		<costList>
			<Steel>15</Steel>
		</costList>
		<building>
			<isEdifice>false</isEdifice>
		</building>
		<comps>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Glower">
				<glowRadius>7</glowRadius>
				<glowColor>(253,62,59,0)</glowColor>
			</li>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>2.0</fuelConsumptionRate>
				<fuelCapacity>20.0</fuelCapacity>
				<fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
						<li MayRequire="RI.RimImmortal.Living">RI_Resource_RawBamboo</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>1</initialFuelPercent>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
		</comps>
		<researchPrerequisites>
			<li>RI_Research_FestivalFurniture</li>
		</researchPrerequisites>
	</ThingDef>

	<!--Modern red lantern (electric)-->
	<ThingDef ParentName="RI_Furniture_LanternBase">
		<defName>RI_Building_RedLantern_Electric</defName>
		<label>Modern red lantern</label>
		<description>A modern lantern, with a light bulb installed inside, requires electricity.</description>
		<graphicData>
			<texPath>Things/Building/Furniture/Lantern/TW_CNY_RedLanternLight</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawRotated>true</drawRotated>
			<drawSize>(1.2,1.2)</drawSize>
		</graphicData>
		<uiIconPath>Things/Building/Furniture/Lantern/TW_CNY_RedLanternLight</uiIconPath>
		<uiIconScale>1.2</uiIconScale>
		<rotatable>true</rotatable>
		<constructEffect>ConstructWood</constructEffect>
		<statBases>
			<Beauty>5</Beauty>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Flammability>0.5</Flammability>
			<Mass>1</Mass>
		</statBases>
		<techLevel>Medieval</techLevel>
		<costList>
			<Steel>15</Steel>
		</costList>
		<building>
			<isEdifice>false</isEdifice>
		</building>
		<comps>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Glower">
				<glowRadius>12</glowRadius>
				<glowColor>(253,62,59,0)</glowColor>
				<colorPickerEnabled>true</colorPickerEnabled>
				<darklightToggle>false</darklightToggle>
			</li>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>50</basePowerConsumption>
			</li>
		</comps>
		<researchPrerequisites>
			<li>RI_Research_ModernChineseFurniture</li>
		</researchPrerequisites>
	</ThingDef>

</Defs>
