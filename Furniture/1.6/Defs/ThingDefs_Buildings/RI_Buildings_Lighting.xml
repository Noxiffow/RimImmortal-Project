<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Ming-style lighting base-->
	<ThingDef Name="RI_LightMing_Base" ParentName="RI_Furniture_BuildingBase" Abstract="True">
		<category>Building</category>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsFurniture</li>
		</thingCategories>
		<techLevel>Medieval</techLevel>
		<passability>PassThroughOnly</passability>
		<graphicData>
			<damageData>
				<rect>(0.35,0.35,0.3,0.3)</rect>
			</damageData>
		</graphicData>
		<statBases>
			<Flammability>0.5</Flammability>
		</statBases>
		<selectable>true</selectable>
		<pathCost>5</pathCost>
		<defaultPlacingRot>South</defaultPlacingRot>
		<researchPrerequisites>
			<li>RI_Research_Lighting</li>
		</researchPrerequisites>
		<tickerType>Normal</tickerType>
		<drawerType>RealtimeOnly</drawerType>
		<fillPercent>0.15</fillPercent>
		<placeWorkers>
			<li>PlaceWorker_GlowRadius</li>
			<li>PlaceWorker_Heater</li>
			<li>PlaceWorker_MeditationOffsetBuildingsNear</li>
		</placeWorkers>
		<comps>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>2.0</fuelConsumptionRate>
				<fuelCapacity>20.0</fuelCapacity>
				<fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
						<li MayRequire="RI.RimImmortal.Living">RI_Resource_RawBamboo</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>1</initialFuelPercent>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>3.5</heatPerSecond>
				<heatPushMaxTemperature>20</heatPushMaxTemperature>
			</li>
			<li Class="CompProperties_MeditationFocus">
				<statDef>MeditationFocusStrength</statDef>
				<focusTypes>
					<li>Flame</li>
				</focusTypes>
				<offsets>
					<li Class="FocusStrengthOffset_Lit">
						<offset>0.1</offset>
					</li>
					<li Class="FocusStrengthOffset_BuildingDefsLit">
						<defs>
							<li>Campfire</li>
							<li>TorchLamp</li>
							<li>TorchWallLamp</li>
							<li MayRequire="Ludeon.RimWorld.Royalty">Brazier</li>
							<li MayRequire="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Ideology">DarklightBrazier</li>
							<li MayRequire="Ludeon.RimWorld.Ideology">Darktorch</li>
							<li MayRequire="Ludeon.RimWorld.Ideology">DarktorchFungus</li>
						</defs>
						<offsetPerBuilding>0.01</offsetPerBuilding>
						<radius>9.9</radius>
						<maxBuildings>8</maxBuildings>
						<explanationKey>MeditationFocusPerFlame</explanationKey>
						<explanationKeyAbstract>MeditationFocusPerFlameAbstract</explanationKeyAbstract>
						<drawRingRadius>false</drawRingRadius>
					</li>
				</offsets>
			</li>
		</comps>
		<soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
		<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		<clearBuildingArea>false</clearBuildingArea>
		<inspectorTabs>
			<li>ITab_Art</li>
		</inspectorTabs>
		<building>
			<isEdifice>false</isEdifice>
			<artificialForMeditationPurposes>false</artificialForMeditationPurposes>
		</building>
	</ThingDef>

	<!--Lamps without open flames-->

	<!--Hood lamp-->
	<ThingDef ParentName="RI_LightMing_Base">
		<defName>RI_Building_OpenworkCoveredLamp</defName>
		<label>Hood lamp</label>
		<description>A hood lamp designed to prevent the flame from spreading. The ornate, hollowed-out patterns on the cover create a dreamlike atmosphere—clearly a piece of great value.</description>
		<graphicData>
			<texPath>Things/Building/Torch/RI_Building_OpenworkCoveredLamp</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.2,1.2)</drawSize>
			<drawRotated>false</drawRotated>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Mass>1</Mass>
			<Beauty>5</Beauty>
		</statBases>

		<costStuffCount>20</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>

		<comps>
			<li Class="CompProperties_Glower">
				<glowRadius>9</glowRadius>
				<glowColor>(252,187,113,0)</glowColor>
			</li>
		</comps>
	</ThingDef>

	<!--Palace maid lamp-->
	<ThingDef ParentName="RI_LightMing_Base">
		<defName>RI_Building_PalaceMaidLamp</defName>
		<label>Palace maid lamp</label>
		<description>A finely crafted lamp in the form of a lifelike palace maid kneeling with a lantern in hand. The smoke vent is cleverly concealed within her sleeve, and the lamp itself features a movable opening that can be toggled to turn it off.\n\nThis lamp is a rare treasure, affordable only to nobles and royals.</description>
		<graphicData>
			<texPath>Things/Building/Torch/RI_Building_PalaceMaidLamp</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(1.2,1.2)</drawSize>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Mass>1</Mass>
			<Beauty>5</Beauty>
		</statBases>

		<costStuffCount>20</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>

		<comps>
			<li Class="CompProperties_Glower">
				<glowRadius>9</glowRadius>
				<glowColor>(252,187,113,0)</glowColor>
			</li>
		</comps>
	</ThingDef>

