			<WorkToBuild>200</WorkToBuild>
			<Mass>0.3</Mass>
			<Beauty>1</Beauty>
		</statBases>

		<costStuffCount>10</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>

		<comps>
			<li Class="CompProperties_Glower">
