<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--======================= Floor tile decorations ==============================-->

	<!--Floor decoration dropdown-->
	<DesignatorDropdownGroupDef>
		<defName>RI_DropdownGroup_PatternFloor</defName>
	</DesignatorDropdownGroupDef>

	<!--Lotus pattern tile-->
	<ThingDef ParentName="RI_BuildingFloor_Base">
		<defName>RI_Building_LotusPatternFloor</defName>
		<label>Lotus pattern tile</label>
		<graphicData>
			<texPath>Things/Building/FloorCoverings/RI_Building_LotusPatternFloor</texPath>
			<drawSize>(6,6)</drawSize>
		</graphicData>
		<costStuffCount>20</costStuffCount>
		<size>(3,3)</size>
		<statBases>
			<Beauty>15</Beauty>
			<WorkToBuild>1000</WorkToBuild>
			<Mass>100</Mass>
		</statBases>
		<uiIconPath>Things/Building/FloorCoverings/RI_Building_LotusPatternFloor</uiIconPath>
		<uiIconScale>1</uiIconScale>
	</ThingDef>

