	<TerrainDef Abstract="True" ParentName="FloorBase" Name="RI_Floor_StaggeredFineTile_Base">
		<renderPrecedence>220</renderPrecedence>
		<description>Roughly-cut stone tiles. These are not beautiful, but they make good surfaces for roads and outdoor walkways. Deconstructing flagstone yields no resources.</description>
		<texturePath>Terrain/Surfaces/RI_Floor_StaggeredFineTile</texturePath>
		<pollutionShaderType MayRequire="Ludeon.RimWorld.Biotech">TerrainFadeRoughLinearBurn</pollutionShaderType>
