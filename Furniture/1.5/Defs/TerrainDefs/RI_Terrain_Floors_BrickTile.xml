<Defs>
	
	<!--太阳纹地砖-->
	<!--Sun-patterned tile-->
	<TerrainDef Abstract="True" ParentName="FloorBase" Name="RI_Floor_SunPatternedTile_Base">
		<renderPrecedence>220</renderPrecedence>
		<description>Carefully-cut and fit stone tiles for a castle feeling. They are pretty to look at, but they take a long time to lay.</description>
		<texturePath>Terrain/Surfaces/RI_Floor_SunPatternedTile</texturePath>
		<pollutionShaderType MayRequire="Ludeon.RimWorld.Biotech">TerrainFadeRoughLinearBurn</pollutionShaderType>
		<pollutionOverlayTexturePath>Terrain/Surfaces/PollutionFloorSmooth</pollutionOverlayTexturePath>
		<pollutionColor>(1, 1, 1, 1)</pollutionColor>
		<isPaintable>true</isPaintable>
		<statBases>
			<WorkToBuild>1700</WorkToBuild>
			<Beauty>3</Beauty>
			<CleaningTimeFactor>0.7</CleaningTimeFactor>
