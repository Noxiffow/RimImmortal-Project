		<costList>
			<Steel>40</Steel>
		</costList>
		<statBases>
			<Mass>4</Mass>
		</statBases>
		<techHediffsTags>
			<li>Advanced</li>
		</techHediffsTags>
	</ThingDef>

	<!--钉舌hediff-->
	<HediffDef ParentName="RI_base_AddedBodyPartBase">
		<defName>RI_Hediff_NailTongue</defName>
		<label>nail tongue</label>
		<labelNoun>a nail tongue</labelNoun>
		<description>Steel spikes driven through the tongue, permanently embedded.</description>
		<spawnThingOnRemoved>RI_ZombieBodyPart_NailTongue</spawnThingOnRemoved>
		<addedPartProps>
			<solid>true</solid>
			<!-- 核心需求：减少说话能力 -->
			<!-- 舌头的效率直接影响说话。0.5代表50%效率 -->
			<partEfficiency>0.50</partEfficiency>
		</addedPartProps>
		<!-- 如果想不仅影响效率，还想额外扣减，可以用 capMods，但调整 partEfficiency 是最原版的做法 -->
	</HediffDef>

