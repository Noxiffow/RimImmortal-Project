	<!--封魔钉hediff-->
	<HediffDef ParentName="RI_base_AddedBodyPartBase">
		<defName>RI_Hediff_DemonBindingNail</defName>
		<label>demon-binding nail</label>
		<labelNoun>demon sealing nails</labelNoun>
		<description>A bronze nail driven into the spine and inscribed with specialized talismans. Slows the onset of bloodthirsty states in revenant corpses.</description>
		<!-- 设为 false 避免自动治疗尝试移除它，或者视为义肢 -->
		<maxSeverity>6.0</maxSeverity>
		<initialSeverity>1.0</initialSeverity>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<stages>
			<!-- 1根钉子 -->
			<li>
				<minSeverity>1</minSeverity>
				<label>x1</label>
				<statOffsets>
					<PsychicSensitivity>-0.15</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.05</offset>
					</li>
				</capMods>
			</li>
			<!-- 2根钉子 -->
			<li>
				<minSeverity>2</minSeverity>
				<label>x2</label>
				<statOffsets>
					<PsychicSensitivity>-0.30</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
			<!-- 3根钉子 -->
			<li>
				<minSeverity>3</minSeverity>
				<label>x3</label>
				<statOffsets>
					<PsychicSensitivity>-0.45</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.15</offset>
					</li>
				</capMods>
			</li>
			<!-- 4根钉子 -->
			<li>
				<minSeverity>4</minSeverity>
				<label>x4</label>
				<statOffsets>
					<PsychicSensitivity>-0.60</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.20</offset>
					</li>
				</capMods>
			</li>
			<!-- 5根钉子 -->
			<li>
				<minSeverity>5</minSeverity>
				<label>x5</label>
				<statOffsets>
					<PsychicSensitivity>-0.75</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.25</offset>
					</li>
				</capMods>
			</li>
			<!-- 6根钉子 -->
			<li>
				<minSeverity>6</minSeverity>
				<label>x6 (Max)</label>
				<statOffsets>
					<PsychicSensitivity>-0.90</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.30</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<!-- 拆除时返还多少个？这个比较难用 XML 完美控制返还数量，
         原版 logic 通常只能返还 1 个。
         如果需要精确返还所有钉子，需要写额外的 C# 移除逻辑。
         这里我们简单处理，拆除返还 1 个 -->
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.00</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
		<spawnThingOnRemoved>RI_ZombieBodyPart_DemonBindingNail</spawnThingOnRemoved>
	</HediffDef>

