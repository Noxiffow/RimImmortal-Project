	<!--钢牙-->
	<ThingDef ParentName="RI_Base_FlashBodyPart">
		<defName>RI_ZombieBodyPart_SteelTeeth</defName>
		<label>steel teeth</label>
		<description>Teeth forged from steel. Extremely sharp and durable.</description>
		<graphicData>
			<texPath>Things/Item/Health/RI_ZombieBodyPart_SteelTeeth</texPath>
		</graphicData>
		<descriptionHyperlinks>
			<RecipeDef>RI_Surgery_InstallSteelTeeth</RecipeDef>
		</descriptionHyperlinks>
		<thingSetMakerTags>
			<li>RewardStandardLowFreq</li>
		</thingSetMakerTags>
