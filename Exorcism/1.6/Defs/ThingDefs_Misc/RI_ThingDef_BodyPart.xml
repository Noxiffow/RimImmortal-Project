			<Mass>4</Mass>
		</statBases>
		<techHediffsTags>
			<li>Advanced</li>
			<li>AdvancedWeapon</li>
		</techHediffsTags>
	</ThingDef>

	<!--钢牙hediff-->
	<HediffDef ParentName="RI_base_AddedBodyPartBase">
		<defName>RI_Hediff_SteelTeeth</defName>
		<label>steel teeth</label>
		<labelNoun>a steel teeth</labelNoun>
		<description>Teeth forged from steel. Extremely sharp and durable.</description>
		<spawnThingOnRemoved>RI_ZombieBodyPart_SteelTeeth</spawnThingOnRemoved>
		<addedPartProps>
			<solid>true</solid>
			<!-- 基础效率100%，不影响说话(除非我们在capMods里扣) -->
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<stages>
			<li>
				<capMods>
					<!-- 核心需求：增加进食效率 -->
					<li>
						<capacity>Eating</capacity>
						<offset>0.20</offset>
						<!-- +20% 进食效率 -->
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
					<li>
						<label>steel bite</label>
						<capacities>
							<li>Bite</li>
						</capacities>
						<power>17</power>
						<!-- 原版人类牙齿只有8.2 -->
						<cooldownTime>2.0</cooldownTime>
						<soundMeleeHit>Pawn_Melee_HumanBite_Hit</soundMeleeHit>
						<soundMeleeMiss>Pawn_Melee_HumanBite_Miss</soundMeleeMiss>
					</li>
				</tools>
			</li>
		</comps>
	</HediffDef>

