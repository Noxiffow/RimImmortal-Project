<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!--==========================道士服饰==========================-->
	<!--道士服饰前置-->
	<ThingDef Name="RI_Base_DaoistApparelMakeable" ParentName="ApparelBase" Abstract="True">
		<thingCategories>
			<li>RI_Category_DaoistApparel</li>
		</thingCategories>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
			<defaultIngredientFilter>
				<categories>
					<li>Root</li>
				</categories>
				<disallowedThingDefs>
					<li>Gold</li>
					<li>Silver</li>
					<li>Plasteel</li>
					<li>Jade</li>
					<li>Uranium</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
					<li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
				</disallowedThingDefs>
			</defaultIngredientFilter>
		</recipeMaker>
		<apparel>
			<tags>
				<li>RI_Tag_Daoist</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel" />
		<tradeTags>
			<li>RI_TradeTag_DaoistApparel</li>
		</tradeTags>
		<!--日常刷新概率-->
		<!--<generateCommonality>0</generateCommonality>-->
	</ThingDef>
	<!--道门裤-->
	<ThingDef ParentName="RI_Base_DaoistApparelMakeable">
		<defName>RI_Apparel_DaoistPants</defName>
		<label>Daoist pants</label>
		<description>Carefully stitched Daoist pants with gaiters for easy movement.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/Pants/RI_Apparel_DaoistPants</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!--制作-->
		<recipeMaker>
			<researchPrerequisites>
				<li>RI_ExorcismResearch_DaoInherit</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<displayPriority>302</displayPriority>
		</recipeMaker>
		<!--材料-->
		<costList>
			<Cloth>30</Cloth>
		</costList>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<WorkToMake>1800</WorkToMake>
			<Mass>0.5</Mass>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.4</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.15</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>OnSkin</li>
			</layers>
		</apparel>
	</ThingDef>
	<!--三清领道袍-->
	<ThingDef ParentName="RI_Base_DaoistApparelMakeable">
		<defName>RI_Apparel_DaoistShirt</defName>
		<label>Daoist robe</label>
		<description>A Daoist robe without any belts or fastenings. Its collar bears three layers of patterns, symbolizing the "The Three Pristine Ones".\n\nThis collar is a unique upright design, and only Daoists who have formally received knowledge from their master within the Sect are qualified to wear it.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistShirt/RI_Apparel_DaoistShirt</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!--制作-->
		<recipeMaker>
			<researchPrerequisites>
				<li>RI_ExorcismResearch_DaoInherit</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<displayPriority>301</displayPriority>
		</recipeMaker>
		<costStuffCount>50</costStuffCount>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<statBases>
			<MaxHitPoints>350</MaxHitPoints>
			<WorkToMake>2000</WorkToMake>
			<Mass>0.35</Mass>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.3</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.10</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistShirt/RI_Apparel_DaoistShirt</wornGraphicPath>
			<layers>
				<li>OnSkin</li>
			</layers>
		</apparel>
	</ThingDef>
	<!--道士冠-->
	<ThingDef ParentName="RI_Base_DaoistApparelMakeable">
		<defName>RI_Apparel_DaoistCrown</defName>
		<label>Daoist crown</label>
		<description>An artistically terrifying war mask. It hides the wearer's face and makes them more confident.</description>
		<techLevel>Neolithic</techLevel>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistCrown/RI_Apparel_DaoistCrown</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<uiIconScale>1.15</uiIconScale>
		<!--材料-->
		<costList>
			<Cloth>30</Cloth>
		</costList>
		<statBases>
			<WorkToMake>3000</WorkToMake>
			<MaxHitPoints>80</MaxHitPoints>
			<Mass>1.4</Mass>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.15</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.05</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<PainShockThreshold>0.10</PainShockThreshold>
		</equippedStatOffsets>
		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistCrown/RI_Apparel_DaoistCrown</wornGraphicPath>
			<!--和发型同时显示-->
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
			<layers>
				<li>Overhead</li>
			</layers>
		</apparel>
	</ThingDef>
