	<!--镇邪念珠-->
	<ThingDef ParentName="RI_Base_DaoistApparelMakeable">
		<defName>RI_Apparel_DaoistPrayerBeads</defName>
		<label>exorcism prayer beads</label>
		<description>The coming and going of the true thread, its twists and turns, its ascent and descent, and the exchange between humanity and heaven — all of these may be called a zhou tian (cosmic cycle).\n\nHandling the beads helps to calm the mind and gather the spirit. The practice of Daoists wearing prayer beads dates back to early times. Such strands typically consist of 81 or 108 beads, including a larger head bead. Upon reaching the head bead, one should reverse direction and continue, symbolizing the cyclical flow of the zhou tian.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistPrayerBeads/RI_Apparel_DaoistPrayerBeads</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!--制作-->
		<recipeMaker>
			<researchPrerequisites>
				<li>RI_ExorcismResearch_DaoInherit</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<displayPriority>303</displayPriority>
		</recipeMaker>
		<costStuffCount>50</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<statBases>
			<WorkToMake>38000</WorkToMake>
			<MaxHitPoints>230</MaxHitPoints>
			<Mass>1.2</Mass>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.1</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.1</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>0.5</EquipDelay>
		</statBases>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<!--特效-->
		<equippedStatOffsets>
			<RI_CurseImmunity>0.4</RI_CurseImmunity>
		</equippedStatOffsets>
		<tradeTags>
			<li>RI_TradeTag_DaoistApparel</li>
		</tradeTags>
		<apparel>
			<bodyPartGroups>
				<li>Neck</li>
				<li>Shoulders</li>
			</bodyPartGroups>
			<tags>
				<li>RI_Tag_Daoist</li>
			</tags>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_DaoistPrayerBeads/RI_Apparel_DaoistPrayerBeads</wornGraphicPath>
			<layers>
				<li>Shell</li>
			</layers>
		</apparel>
	</ThingDef>
