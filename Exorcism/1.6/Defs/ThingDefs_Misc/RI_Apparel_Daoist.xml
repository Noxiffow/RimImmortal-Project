	<!--护身符-->
	<ThingDef ParentName="RI_Base_DaoistApparelMakeable">
		<defName>RI_CurseWardTalisman</defName>
		<label>辟邪铜镜</label>
		<description>可抵御诅咒侵蚀的辟邪铜镜。诅咒越强，铜镜耐久损耗越快。</description>
		<thingClass>Apparel</thingClass>
		<category>Item</category>
		<thingCategories>
			<li>ApparelUtility</li>
		</thingCategories>
		<graphicData>
			<texPath>Things/Item/RI_CurseWardTalisman</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<altitudeLayer>Item</altitudeLayer>
		<drawerType>MapMeshOnly</drawerType>
		<alwaysHaulable>true</alwaysHaulable>
		<rotatable>false</rotatable>
		<stackLimit>1</stackLimit>
		<useHitPoints>true</useHitPoints>
		<tickerType>Normal</tickerType>
		<apparel>
			<wearPerDay>0</wearPerDay>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<careIfWornByCorpse>false</careIfWornByCorpse>
			<careIfDamaged>false</careIfDamaged>
			<bodyPartGroups>
				<li>Torso</li>
			</bodyPartGroups>
			<layers>
				<li>RI_CurseWardLayer</li>
			</layers>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
		</apparel>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<Mass>0.01</Mass>
			<Flammability>0</Flammability>
			<MarketValue>120</MarketValue>
			<DeteriorationRate>0</DeteriorationRate>
		</statBases>
		<comps>
			<li Class="CompProperties_Forbiddable" />
			<li Class="RimZombieGirl.CompProperties_CurseWardTalismanDurability">
				<tickInterval>2500</tickInterval>
				<baseHpLossPerCheck>1</baseHpLossPerCheck>
				<curseScalePer500>12.0</curseScalePer500>
				<decayOnlyWhenHeldByPawn>true</decayOnlyWhenHeldByPawn>
			</li>
		</comps>

		<costList>
			<RI_Resource_InkJade>20</RI_Resource_InkJade>
			<RI_Resource_ErosionBronze>40</RI_Resource_ErosionBronze>
		</costList>
	</ThingDef>

	<ApparelLayerDef>
		<defName>RI_CurseWardLayer</defName>
		<label>curse ward layer</label>
		<drawOrder>215</drawOrder>
	</ApparelLayerDef>

</Defs>