		<!--
				<explosionSound>Explosion_EMP</explosionSound>
			</li>
		</comps>-->
	</ThingDef>

	<!-- ================= 2. 雷电子弹 ================= -->
	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_WindThunder</defName>
		<label>lightning bolt</label>
		<graphicData>
			<!-- 建议找一个闪电形状的贴图 -->
			<texPath>Things/Projectile/RI_Bullet_WindThunder</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>2.5</drawSize>
		</graphicData>
		<projectile>
			<damageDef>RI_Damage_LightningShot</damageDef>
			<damageAmountBase>15</damageAmountBase>
