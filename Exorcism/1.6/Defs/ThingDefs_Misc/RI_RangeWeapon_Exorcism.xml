		</projectile>
	</ThingDef>

	<!--天火镇邪旗-->
	<ThingDef ParentName="BaseGunWithQuality">
		<defName>RI_RangeWeapon_HeavenlyFireFlag</defName>
		<label>天火镇邪旗</label>
		<description>一面绣有烈日符咒的长旗。挥舞时，旗面震荡空气产生炙热的红色声波，能够点燃敌人的灵魂。</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_RangeWeapon_HeavenlyFireFlag</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<soundInteract>Interact_BeatFire</soundInteract>
		<tickerType>Normal</tickerType>
		<techLevel>Industrial</techLevel>
		<weaponTags>
			<li>RI_Tags_DaoistFlag</li>
		</weaponTags>
		<thingCategories>
			<li>RI_Category_DaoistWeapons</li>
		</thingCategories>
		<tradeTags>
			<li>WeaponRanged</li>
		</tradeTags>
		<comps>
			<li Class="CompProperties_Biocodable"/>
		</comps>

		<statBases>
			<WorkToMake>35000</WorkToMake>
			<Mass>2.5</Mass>
			<AccuracyTouch>0.9</AccuracyTouch>
			<AccuracyShort>0.8</AccuracyShort>
			<AccuracyMedium>0.7</AccuracyMedium>
			<AccuracyLong>0.6</AccuracyLong>
			<RangedWeapon_Cooldown>1.8</RangedWeapon_Cooldown>
		</statBases>

		<costList>
			<Cloth>60</Cloth>
			<RI_Resource_CharmPaper>20</RI_Resource_CharmPaper>
			<RI_Resource_ErosionBronze>20</RI_Resource_ErosionBronze>
			<Gold>5</Gold>
		</costList>
		<recipeMaker>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
		</recipeMaker>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
			<researchPrerequisite>RI_Research_BetterExorcismInstrument</researchPrerequisite>
		</recipeMaker>

		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_FireWave</defaultProjectile>
				<warmupTime>1.0</warmupTime>
				<range>38</range>
				<ticksBetweenBurstShots>8</ticksBetweenBurstShots>
				<!-- 4连射 -->
				<burstShotCount>4</burstShotCount>
				<soundCast>Shot_ChargeBlaster</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>15</muzzleFlashScale>
			</li>
		</verbs>

		<!-- ★★★ 复用之前的框架：对邪祟伤害加成 ★★★ -->
		<modExtensions>
			<li Class="RI_Frame_ZombieLife.AntiZombieWeaponExtension">
				<targetTag>Zombie</targetTag>
				<damageMultiplier>1.8</damageMultiplier>
				<!-- 对僵尸类造成 180% 伤害 -->
			</li>
		</modExtensions>

		<tools>
			<li>
				<label>flagpole</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

	<!--火焰-->
	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_FireWave</defName>
		<label>heavenly fire wave</label>
		<graphicData>
			<!-- 建议用一个圆弧形或波纹状的贴图 -->
			<texPath>Things/Projectile/RI_Bullet_FireArrowCharm</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<!-- 发光效果 -->
			<!-- 明亮的橙黄色 -->
			<drawSize>(3,3)</drawSize>
			<!-- ★ 核心：让子弹看起来像扩散的声波 ★ -->
		</graphicData>
		<projectile>
			<damageDef>RI_Damage_HeavenlyFire</damageDef>
			<damageAmountBase>21</damageAmountBase>
			<!-- 单发伤害较高 -->
			<speed>45</speed>
			<!-- 声波飞行速度略慢，增加压迫感 -->
		</projectile>
	</ThingDef>

	<!-- ================= 1. 伤害类型 (链接 C#) ================= -->
	<DamageDef ParentName="StunBase">
		<defName>RI_Damage_LightningShot</defName>
		<label>lightning shot</label>
		<!-- 引用我们写的 C# Worker -->
		<workerClass>RI_Frame_ZombieLife.DamageWorker_LightningShot</workerClass>
		<externalViolence>true</externalViolence>
		<deathMessage>{0} was electrocuted by wind thunder drum.</deathMessage>
		<externalViolenceForMechanoids>true</externalViolenceForMechanoids>
		<hediff>Crush</hediff>
		<defaultDamage>50</defaultDamage>
		<!-- 造成烧伤效果 -->
		<hediffSolid>Crack</hediffSolid>
		<explosionSnowMeltAmount>0</explosionSnowMeltAmount>
		<explosionCellFleck>BlastEMP</explosionCellFleck>
		<explosionColorEdge>(0.8, 0.8, 0.8, 0.8)</explosionColorEdge>
		<explosionInteriorFleck>ElectricalSpark</explosionInteriorFleck>
		<impactSoundType>Electric</impactSoundType>
		<armorCategory>Blunt</armorCategory>
		<!-- 能量伤害 -->
		<!--emp stun效果-->
		<causeStun>true</causeStun>
		<stunResistStat MayRequireAnyOf="Ludeon.RimWorld.Biotech,Ludeon.RimWorld.Anomaly">EMPResistance</stunResistStat>
		<stunAdaptationTicks>5000</stunAdaptationTicks>
	</DamageDef>

	<!-- 风雷鼓 -->
	<ThingDef ParentName="BaseWeapon">
		<defName>RI_RangeWeapon_WindThunderDrum</defName>
		<label>wind thunder drum</label>
		<description>很强的鼓</description>
		<techLevel>Industrial</techLevel>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_RangeWeapon_WindThunderDrum</texPath>
			<!-- 请替换你的鼓贴图 -->
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<tickerType>Normal</tickerType>
		<!-- ★★★ 负面效果：降低移速 ★★★ -->
		<equippedStatOffsets>
			<MoveSpeed>-0.40</MoveSpeed>
			<!-- 降低 0.4 格/秒 -->
		</equippedStatOffsets>
		<!--旋转-->
		<equippedAngleOffset>0</equippedAngleOffset>

		<statBases>
			<WorkToMake>40000</WorkToMake>
			<Mass>5.0</Mass>
			<!-- 比较重 -->
			<AccuracyTouch>0.9</AccuracyTouch>
			<AccuracyShort>0.9</AccuracyShort>
			<AccuracyMedium>0.9</AccuracyMedium>
			<AccuracyLong>0.9</AccuracyLong>
			<RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
		</statBases>

		<costList>
			<Cloth>50</Cloth>
			<RI_Resource_ErosionBronze>30</RI_Resource_ErosionBronze>
			<RI_Resource_InkJade>10</RI_Resource_InkJade>
		</costList>

		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
			<researchPrerequisite>RI_Research_BetterExorcismInstrument</researchPrerequisite>
		</recipeMaker>
		
		<thingCategories>
			<li>RI_Category_DaoistWeapons</li>
		</thingCategories>
		<!-- 远程射击参数 -->
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_WindThunder</defaultProjectile>
				<warmupTime>1.0</warmupTime>
				<range>23</range>
				<soundCast>RI_Sound_ThunderDrumA</soundCast>
				<!--三连射-->
				<burstShotCount>3</burstShotCount>
				<ticksBetweenBurstShots>18</ticksBetweenBurstShots>
				<!-- 可以换成雷声 -->
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>20</muzzleFlashScale>
			</li>
		</verbs>
		<!--近战鼓槌-->
		<tools>
			<li>
				<label>drum stick</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>7</power>
				<!-- 伤害很低 -->
				<cooldownTime>2</cooldownTime>
				<!-- 攻速很慢 -->
			</li>
		</tools>

		<!-- 技能 -->
		<comps>
			<li Class="CompProperties_EquippableAbility">
				<abilityDef>RI_ZombieAbility_WindThunder</abilityDef>
			</li>
		</comps>

		<!--<comps>
			-->
		<!-- ★★★ 主动技能组件 ★★★ -->
