<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--====================道士远程武器====================-->

	<!--八卦旗-->
	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>RI_RangeWeapon_DetainGhostFlag</defName>
		<label>BaGua flag</label>
		<description>八卦旗，道门的一种法器。挥动旗帜可以引动天地正气化作金色光球射向敌人，令其神魂震荡无法动弹。同时可以令周围的队友进入更专注的状态。</description>

		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_RangeWeapon_DetainGhostFlag</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.3</drawSize>
		</graphicData>

		<uiIconScale>1.3</uiIconScale>
		<soundInteract>Interact_Grenade</soundInteract>
		<!-- 改为更柔和的挥舞声 -->
		<tickerType>Normal</tickerType>
		<techLevel>Industrial</techLevel>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<Mass>1.5</Mass>
			<RangedWeapon_Cooldown>1.8</RangedWeapon_Cooldown>
			<!-- 稍微调快一点 -->
			<AccuracyTouch>1</AccuracyTouch>
			<AccuracyShort>1</AccuracyShort>
			<AccuracyMedium>0.9</AccuracyMedium>
			<AccuracyLong>0.9</AccuracyLong>
		</statBases>

		<costList>
			<Cloth>30</Cloth>
			<RI_Resource_CharmPaper>10</RI_Resource_CharmPaper>
			<RI_Resource_ErosionBronze>10</RI_Resource_ErosionBronze>
		</costList>

		<recipeMaker>
			<researchPrerequisite>RI_ExorcismResearch_ExorcismInstrument</researchPrerequisite>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>

		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<!-- ★ 改为枪械射击逻辑 -->
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_GoldenSphere</defaultProjectile>
				<!-- 指向金色光球 -->
				<warmupTime>1.2</warmupTime>
				<range>18</range>
				<!-- 射程大幅提升，不再是手榴弹那种短距离 -->
				<soundCast>RI_Sound_Bell</soundCast>
				<!-- 保留你的铃铛音效 -->
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>12</muzzleFlashScale>
			</li>
		</verbs>
		<!--技能-->
		<comps>
			<li Class="CompProperties_EquippableAbility">
				<abilityDef>RI_ZombieAbility_DetainGhostFlag</abilityDef>
			</li>
		</comps>

		<weaponTags>
			<li>RI_Tags_DaoistFlag</li>
		</weaponTags>
		<thingCategories>
			<li>RI_Category_DaoistWeapons</li>
		</thingCategories>
	</ThingDef>

	<!--八卦旗子弹-->
	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_GoldenSphere</defName>
		<label>金色光球</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_GoldenSphere</texPath>
			<!-- 借用电荷弹贴图 -->
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>(1.5,1.5)</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Blunt</damageDef>
			<damageAmountBase>12</damageAmountBase>
			<speed>70</speed>
		</projectile>
	</ThingDef>

	<!--三清铃-->
	<ThingDef ParentName="BaseMakeableGrenade">
		<defName>RI_RangeWeapon_SanQingBell</defName>
		<label>SanQing bell</label>
		<description>Originally a ritual instrument used in sacrificial rites, the SanQing bell was believed to summon divine forces and exorcism. As time passed, its function gradually shifted, eventually evolving into a specialized artifact designed to break defenses.\n\nThe bell’s body is engraved with talisman and fitted with a specially crafted clapper within. When gently shaken, the clapper strikes the talisman patterns, producing an unusual, ordered tone rather than an ordinary chime. This sound wave can be directed toward a target, inducing resonance within its internal structure, progressively destabilizing its equilibrium and causing defensive systems to falter—or even collapse entirely.</description>
		<tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_RangeWeapon_SanQingBell</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<uiIconScale>1.3</uiIconScale>
		<soundInteract>Interact_Grenade</soundInteract>
		<techLevel>Industrial</techLevel>
		<statBases>
			<Mass>1</Mass>
			<RangedWeapon_Cooldown>2.3</RangedWeapon_Cooldown>
			<AccuracyTouch>0.99</AccuracyTouch>
			<AccuracyShort>0.9</AccuracyShort>
			<AccuracyMedium>0.8</AccuracyMedium>
			<AccuracyLong>0.7</AccuracyLong>
			<WorkToMake>12000</WorkToMake>
		</statBases>
		<costList>
			<RI_Resource_ErosionBronze>70</RI_Resource_ErosionBronze>
		</costList>
		<recipeMaker>
			<researchPrerequisite>RI_ExorcismResearch_ExorcismInstrument</researchPrerequisite>
			<recipeUsers>
				<li>RI_Building_ExorcismInstrumentBench</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<weaponTags>
			<li>RI_Tags_DaoBestWeapon</li>
		</weaponTags>
		<thingCategories>
			<li>RI_Category_DaoistWeapons</li>
		</thingCategories>
		<smeltable>true</smeltable>
		<verbs>
			<li>
				<label>release disruptive chime</label>
				<verbClass>Verb_LaunchProjectile</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<range>14</range>
				<!--<forcedMiss>true</forcedMiss>-->
				<warmupTime>1.5</warmupTime>
				<noiseRadius>4</noiseRadius>
				<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
				<soundCast>RI_Sound_Bell</soundCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<defaultProjectile>RI_Bullet_SanQingBell</defaultProjectile>
				<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>
		<comps>
			<li Class="CompProperties_EquippableAbility">
				<abilityDef>RI_ZombieAbility_SanQing</abilityDef>
			</li>
			<!-- <li Class="CompProperties_Explosive">
				<wickTicks>0</wickTicks>
				<explosiveRadius>30.9</explosiveRadius>
				<explodeOnKilled>true</explodeOnKilled>
				<explosiveDamageType>RI_MechBandShockwave</explosiveDamageType>
				<propagationSpeed>0.5</propagationSpeed>
				<chanceNeverExplodeFromDamage>1</chanceNeverExplodeFromDamage>
				<extraInspectStringKey>MechStunPulseWarning</extraInspectStringKey>
			</li> -->
		</comps>
	</ThingDef>

	<!--三清铃子弹-->
	<ThingDef ParentName="RI_Base_DaoistCharmBullet">
		<defName>RI_Bullet_SanQingBell</defName>
		<label>disruptive chime</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_SanQingBell</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>3.5</drawSize>
		</graphicData>
		<projectile>
			<damageDef>RI_ZombieMelee_SanQingBell</damageDef>
			<damageAmountBase>1</damageAmountBase>
			<stoppingPower>1</stoppingPower>
			<speed>60</speed>
		</projectile>
	</ThingDef>

	<!-- 三清铃技能子弹 -->
	<ThingDef ParentName="BaseBullet">
		<defName>RI_Projectile_SanQingBell</defName>
		<label>SanQing bell shockwave</label>
		<thingClass>RimZombieGirl.RI_Projectile_SanQingBell</thingClass>
