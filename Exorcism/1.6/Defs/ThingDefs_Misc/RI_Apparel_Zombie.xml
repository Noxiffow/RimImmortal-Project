	<!--镇魄符-->
	<ThingDef ParentName="RI_Zombie_MakeableHat_Base">
		<defName>RI_ZombieApparel_SealCharm</defName>
		<label>soul-suppression charm</label>
		<description>A talisman affixed to the forehead of a necrocorpse. It carries uncanny effects capable of suppressing the necro.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_SealCharm/RI_ZombieApparel_SealCharm</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<techLevel>Medieval</techLevel>

		<!--原料-->
		<costList>
			<RI_Resource_CharmPaper>10</RI_Resource_CharmPaper>
			<HemogenPack>2</HemogenPack>
		</costList>

		<statBases>
			<WorkToMake>1000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>0.1</Mass>
			<StuffEffectMultiplierArmor>0.05</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>0.5</EquipDelay>
		</statBases>

		<apparel>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_SealCharm/RI_ZombieApparel_SealCharm</wornGraphicPath>
			<!--和发型同时显示-->
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
		</apparel>
		<recipeMaker>
			<displayPriority>200</displayPriority>
			<researchPrerequisite>RI_ExorcismResearch_NecrosapiensAlchemy</researchPrerequisite>
		</recipeMaker>
		<!--特殊效果-->
		<equippedStatOffsets>
			<SocialImpact>-0.05</SocialImpact>
		</equippedStatOffsets>
	</ThingDef>

	<!--绷带套装-->

	<!--绷带头-->
	<ThingDef ParentName="RI_Zombie_MakeableHat_Base">
		<defName>RI_ZombieApparel_BandageHead</defName>
		<label>bandage head</label>
		<description>A simple strip of cloth worn around the head, mainly used to maintain visual consistency with the body wrappings.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_BandageHead/RI_ZombieApparel_BandageHead</texPath>
		</graphicData>
		<techLevel>Medieval</techLevel>

		<!--原料-->
		<costList>
			<Cloth>20</Cloth>
		</costList>

		<statBases>
			<WorkToMake>1000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>0.1</Mass>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
			<ArmorRating_Heat>0</ArmorRating_Heat>
			<Insulation_Cold>1</Insulation_Cold>
			<EquipDelay>0.5</EquipDelay>
		</statBases>

		<apparel>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_BandageHead/RI_ZombieApparel_BandageHead</wornGraphicPath>
			<!--和发型同时显示-->
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
		</apparel>
		<recipeMaker>
			<displayPriority>200</displayPriority>
			<researchPrerequisite>RI_ExorcismResearch_NecrosapiensAlchemy</researchPrerequisite>
		</recipeMaker>
		<equippedStatOffsets>
			<SocialImpact>-0.3</SocialImpact>
		</equippedStatOffsets>
	</ThingDef>

	<!--僵尸绷带-->
	<ThingDef ParentName="RI_Base_ZombieApparelMake">
		<defName>RI_ZombieApparel_BandageBody</defName>
		<label>charm bandage</label>
		<description>Several strips of cloth wrapped around the body, barely covering one’s privacy. A warding talisman is affixed to the front, slightly suppressing the bloodlust of a necro.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_BandageBody/RI_ZombieApparel_ZombieBandage</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<techLevel>Medieval</techLevel>

		<!--原料-->
		<costList>
			<Cloth>40</Cloth>
			<RI_Resource_CharmPaper>10</RI_Resource_CharmPaper>
		</costList>

		<statBases>
			<WorkToMake>9000</WorkToMake>
			<MaxHitPoints>200</MaxHitPoints>
			<Mass>1</Mass>
			<Flammability>1</Flammability>
			<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Heat>0</ArmorRating_Heat>
			<Insulation_Cold>3</Insulation_Cold>
			<EquipDelay>1</EquipDelay>
		</statBases>
		<!--特殊效果-->
		<equippedStatOffsets>
			<MoveSpeed>0.05</MoveSpeed>
		</equippedStatOffsets>
		<thingCategories>
			<li>RI_Category_NecroApparel</li>
		</thingCategories>
		<recipeMaker>
			<researchPrerequisite>RI_ExorcismResearch_NecrosapiensAlchemy</researchPrerequisite>
			<skillRequirements>
				<Crafting>2</Crafting>
			</skillRequirements>
			<displayPriority>220</displayPriority>
		</recipeMaker>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_ZombieApparel_BandageBody/RI_ZombieApparel_ZombieBandage</wornGraphicPath>
			<layers>
				<li>Middle</li>
			</layers>
			<tags>
				<li>IndustrialMilitaryBasic</li>
			</tags>
			<!--<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>-->
		</apparel>
	</ThingDef>

