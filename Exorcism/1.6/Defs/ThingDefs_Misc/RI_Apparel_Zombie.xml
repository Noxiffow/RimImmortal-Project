<Defs>

	<!--===============僵尸衣服===============-->
	<!--前置-->
	<ThingDef Name="RI_Base_ZombieApparelMake" ParentName="ApparelBase" Abstract="True">
		<!--可以卖掉-->
		<tradeability>Sellable</tradeability>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<recipeUsers>
				<li>RI_Building_AberrantWorkbench</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
			<defaultIngredientFilter>
				<categories>
					<li>Root</li>
				</categories>
				<disallowedThingDefs>
					<li>Gold</li>
					<li>Silver</li>
					<li>Plasteel</li>
					<li>Jade</li>
					<li>Uranium</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
					<li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
				</disallowedThingDefs>
			</defaultIngredientFilter>
		</recipeMaker>
		<tradeTags>
			<li>RI_Tag_ZombieClothing</li>
		</tradeTags>
		<!-- 只允许僵尸穿戴 -->
		<modExtensions>
			<li Class="RimZombieGirl.ZombieGeneApparelDef">
				<forcedBodyTypes>
					<li>RI_ExorcismBodyType_Female</li>
					<li>RI_ExorcismBodyType_Male</li>
					<li>RI_ExorcismBodyType_Thin</li>
				</forcedBodyTypes>
				<allowedBodyTypes></allowedBodyTypes>
				<forcedHeadTypes></forcedHeadTypes>
				<allowedHeadTypes></allowedHeadTypes>
			</li>
		</modExtensions>
	</ThingDef>

