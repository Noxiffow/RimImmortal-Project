<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--墨玉矿-->
	<ThingDef ParentName="RockBase">
		<defName>RI_Building_MineableInkJade</defName>
		<label>Ink jade</label>
		<description>A vein of ink jade that radiates an eerie, chilling aura.</description>
		<graphicData>
			<texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<color>(61,99,89)</color>
			<colorTwo>(92,156,139)</colorTwo>
		</graphicData>
		<statBases>
			<MaxHitPoints>1100</MaxHitPoints>
		</statBases>
		<building>
			<isResourceRock>true</isResourceRock>
			<mineableThing>RI_Resource_InkJade</mineableThing>
			<mineableYield>15</mineableYield>
			<mineableScatterCommonality>0.5</mineableScatterCommonality>
			<mineableScatterLumpSizeRange>2~5</mineableScatterLumpSizeRange>
			<veinMineable>true</veinMineable>
		</building>
	</ThingDef>

	<!--压埋的风磨铜-->
	<ThingDef ParentName="RockBase">
		<defName>RI_Building_MineableErosionBronze</defName>
		<label>Compacted erosion bronze</label>
		<description>Ancient erosion bronze objects long buried underground, which can be mined and used to craft items that ward off evil.</description>
		<graphicData>
			<texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<color>(128,120,78)</color>
			<colorTwo>(191,178,109)</colorTwo>
		</graphicData>
		<statBases>
			<MaxHitPoints>1200</MaxHitPoints>
		</statBases>
		<building>
			<isResourceRock>true</isResourceRock>
			<mineableThing>RI_Resource_ErosionBronze</mineableThing>
			<mineableYield>40</mineableYield>
			<mineableScatterCommonality>1.00</mineableScatterCommonality>
			<mineableScatterLumpSizeRange>5~9</mineableScatterLumpSizeRange>
			<veinMineable>true</veinMineable>
		</building>
	</ThingDef>

	<!--坟树-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_DeathTree</defName>
		<label>Grave tree</label>
		<description>A withered tree found only around graveyards. People hang paper coin and white cloth from its branches—as if by doing so, they could fulfill their filial duty without stepping into the tomb grounds.</description>
		<rotatable>false</rotatable>
		<noRightClickDraftAttack>true</noRightClickDraftAttack>
		<graphicData>
			<texPath>Things/Building/Misc/RI_Building_DeathTree</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>(4.5,4.5)</drawSize>
			<shadowData>
				<volume>(0.5, 0.5, 0.5)</volume>
			</shadowData>
		</graphicData>
		<size>(2,2)</size>
		<fillPercent>0.30</fillPercent>
		<altitudeLayer>Building</altitudeLayer>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Flammability>1.2</Flammability>
		</statBases>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<building>
			<canLandGravshipOn>true</canLandGravshipOn>
			<isInert>true</isInert>
		</building>
	</ThingDef>

</Defs>
