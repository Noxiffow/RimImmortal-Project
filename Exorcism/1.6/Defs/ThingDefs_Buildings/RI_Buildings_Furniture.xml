  <!--鬼火烛台-->
  <ThingDef ParentName="RI_HorrorLightBase">
    <defName>RI_Building_GreenTorch</defName>
    <label>Ghost fire candle</label>
    <description>A candlestick lit with a faint, eerie ghost fire, terrifying.</description>
    <graphicData>
      <texPath>Things/Building/Misc/RI_Building_GreenTorch</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1.6,1.6)</drawSize>
      <drawRotated>false</drawRotated>
      <damageData>
        <rect>(0.35,0.35,0.3,0.3)</rect>
      </damageData>
    </graphicData>
    <statBases>
      <Mass>0.5</Mass>
    </statBases>
    <!--制作-->
    <costList>
      <Skull>1</Skull>
      <RI_Resource_ErosionBronze>5</RI_Resource_ErosionBronze>
      <RI_Resource_CorpseOil>5</RI_Resource_CorpseOil>
    </costList>
    <!--图标-->
    <uiIconPath>Things/Building/Misc/RI_Building_GreenTorch_Icon</uiIconPath>
    <uiIconScale>1.2</uiIconScale>
    <uiOrder>3980</uiOrder>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>6</glowRadius>
        <glowColor>(35,204,132,0)</glowColor>
      </li>
      <!--鬼火-->
      <li Class="FireOnTorch.CompProperties_FireOverlayCustom">
        <GraphicData>
          <texPath>Things/Special/RI_GreenFlame</texPath>
          <graphicClass>Graphic_Flicker</graphicClass>
          <shaderType>TransparentPostLight</shaderType>
        </GraphicData>
        <fireSize>0.02</fireSize>
        <finalFireSize>0.02</finalFireSize>
        <offset>(0,0,0.8)</offset>
      </li>
      <!--燃料-->
      <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>0.5</fuelConsumptionRate>
        <fuelCapacity>10</fuelCapacity>
        <fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
        <fuelFilter>
          <thingDefs>
            <li>RI_Resource_CorpseOil</li>
          </thingDefs>
        </fuelFilter>
        <initialFuelPercent>0</initialFuelPercent>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
      </li>
    </comps>
  </ThingDef>
