  <!--邪血储存器-->
  <ThingDef ParentName="BuildingBase">
    <defName>RI_Building_EvilBloodStorage</defName>
    <label>Aberrant blood storage</label>
    <description>A container for storing concentrated aberrant blood, storage can keep blood not corruption.</description>
    <graphicData>
      <texPath>Things/Building/Misc/RI_Building_EvilBloodStorage</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.3,2.3)</drawSize>
      <shadowData>
        <volume>(0.76,0.3,0.15)</volume>
        <offset>(0,0,-0.39)</offset>
      </shadowData>
    </graphicData>
    <!--制作-->
    <costList>
      <RI_Resource_ConcentrateAberrantBlood>100</RI_Resource_ConcentrateAberrantBlood>
    </costList>
    <!--图标-->
    <uiIconPath>Things/Building/Misc/RI_Building_EvilBloodStorage_Icon</uiIconPath>
    <uiIconScale>1.65</uiIconScale>
    <uiOrder>3982</uiOrder>
    <comps>
      <!--草堆框架-->
      <li Class="RI_Frame_HayStack.CompProperties_HayStack">
        <uiLabel>open up</uiLabel>
        <uiDesc>Disassemble the storage structure immediately and recycle all materials.</uiDesc>
        <refundPercentage>1.0</refundPercentage>
        <uiIconPath>UI/Designators/Deconstruct</uiIconPath>
        <finishSound>Designate_PlaceBuilding</finishSound>
        <dropContents>true</dropContents>
      </li>
    </comps>
    <designationCategory>Biotech</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    <selectable>true</selectable>
    <!--拆除掉落资源-->
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <resourcesFractionWhenDeconstructed>0.5</resourcesFractionWhenDeconstructed>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
    <!--研究-->
    <researchPrerequisites>
      <li>RI_ExorcismResearch_NecrosapiensAlchemy</li>
    </researchPrerequisites>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>5</Mass>
      <WorkToBuild>400</WorkToBuild>
    </statBases>
    <fillPercent>0.25</fillPercent>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <rotatable>false</rotatable>
    <building>
      <isInert>true</isInert>
      <ai_chillDestination>false</ai_chillDestination>
      <canLandGravshipOn>true</canLandGravshipOn>
    </building>
  </ThingDef>
  <!--坟-->
  <ThingDef ParentName="BuildingBase">
    <defName>RI_Building_Tomb</defName>
    <label>tomb</label>
    <description>A decent final resting place. Colonists will visit full graves to gain meditative joy.</description>
    <thingClass>Building_Grave</thingClass>
    <containedPawnsSelectable>true</containedPawnsSelectable>
    <graphicData>
      <texPath>Things/Building/Misc/RI_Building_Tomb/RI_Building_Tomb</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,4)</drawSize>
    </graphicData>
    <altitudeLayer>FloorEmplacement</altitudeLayer>
    <useHitPoints>true</useHitPoints>
    <size>(1,2)</size>
    <tickerType>Rare</tickerType>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <WorkToBuild>2400</WorkToBuild>
      <MaxHitPoints>250</MaxHitPoints>
      <Flammability>1.0</Flammability>
      <MeditationFocusStrength>0.10</MeditationFocusStrength>
      <Beauty>0</Beauty>
    </statBases>
    <stuffCategories>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>30</costStuffCount>
    <passability>Standable</passability>
    <defaultPlacingRot>South</defaultPlacingRot>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <expandHomeArea>false</expandHomeArea>
      <isInert>true</isInert>
      <preventDeteriorationInside>true</preventDeteriorationInside>
      <haulToContainerDuration>500</haulToContainerDuration>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <isEscapableContainer>true</isEscapableContainer>
      <fullGraveGraphicData>
        <texPath>Things/Building/Misc/RI_Building_Tomb/RI_Building_Tomb</texPath>
        <graphicClass>Graphic_Multi</graphicClass>
        <drawSize>(4,4)</drawSize>
      </fullGraveGraphicData>
      <fixedStorageSettings>
        <filter>
          <categories>
            <li>Corpses</li>
          </categories>
          <disallowedCategories>
            <li MayRequire="Ludeon.RimWorld.Odyssey">CorpsesDrone</li>
          </disallowedCategories>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <categories>
            <li>CorpsesHumanlike</li>
          </categories>
        </filter>
      </defaultStorageSettings>
      <buildingTags>
        <li>RitualFocus</li>
      </buildingTags>
    </building>
    <inspectorTabs>
      <li>ITab_Storage</li>
    </inspectorTabs>
    <terrainAffordanceNeeded>Diggable</terrainAffordanceNeeded>
    <designationCategory>Misc</designationCategory>
    <uiOrder>2050</uiOrder>
    <comps>
      <li Class="CompProperties_AssignableToPawn">
        <drawAssignmentOverlay>false</drawAssignmentOverlay>
        <compClass>CompAssignableToPawn_Grave</compClass>
      </li>
      <li Class="CompProperties_MeditationFocus">
        <statDef>MeditationFocusStrength</statDef>
        <focusTypes>
          <li>Morbid</li>
        </focusTypes>
        <offsets>
          <li Class="FocusStrengthOffset_GraveFull">
            <offset>0.10</offset>
          </li>
          <li Class="FocusStrengthOffset_GraveCorpseRelationship">
            <offset>0.10</offset>
          </li>
          <li Class="FocusStrengthOffset_NearbyGraves">
            <defs>
              <li>Grave</li>
              <li>Sarcophagus</li>
            </defs>
            <offsetPerBuilding>0.01</offsetPerBuilding>
            <radius>9.9</radius>
            <maxBuildings>4</maxBuildings>
            <focusPerFullGrave>0.01</focusPerFullGrave>
            <explanationKey>MeditationFocusPerGrave</explanationKey>
            <explanationKeyAbstract>MeditationFocusPerGraveAbstract</explanationKeyAbstract>
          </li>
        </offsets>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_MeditationOffsetBuildingsNear</li>
    </placeWorkers>
    <ritualFocus>
      <spectateDistance>1</spectateDistance>
      <allowedSpectateSides>Vertical</allowedSpectateSides>
    </ritualFocus>
  </ThingDef>
