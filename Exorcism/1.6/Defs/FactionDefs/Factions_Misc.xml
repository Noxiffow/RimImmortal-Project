<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!--邪异——派系-->
	<FactionDef ParentName="FactionBase">
		<defName>RI_Faction_Aberrant</defName>
		<label>Aberrant</label>
		<description>They descended one day, bringing nightmares with them. — The Book of a Hundred Evils\n\nThese beings cannot be classified under any known branch of biology. They include the reanimated dead, creatures of legend, horrific beasts, and even inexplicable supernatural phenomena. For this reason, they are collectively called the Aberrant.\n\nDespite their vast differences, Aberrant creatures do not turn on one another. Scholars speculate their origin may lie in a form of psychic phenomenon. Whatever the truth, they spread from world to world, leaving trails of uncanny and terrifying events in their wake.</description>
		<pawnSingular>Aberrant creature</pawnSingular>
		<pawnsPlural>Aberrant creatures</pawnsPlural>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<fixedName>Aberrant</fixedName>
		<factionIconPath>World/WorldObjects/Expanding/RI_Faction_Aberrant</factionIconPath>
		<colorSpectrum>
			<li>(0.42, 0.65, 0.55)</li>
		</colorSpectrum>
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(300,  0)</li>
				<li>(700,  1)</li>
				<li>(1400, 1.8)</li>
				<li>(2800, 2.2)</li>
				<li>(4000, 2.6)</li>
			</points>
		</raidCommonalityFromPointsCurve>
		<humanlikeFaction>false</humanlikeFaction>
		<hidden>true</hidden>
		<autoFlee>false</autoFlee>
		<canUseAvoidGrid>false</canUseAvoidGrid>
		<techLevel>Animal</techLevel>
		<earliestRaidDays>10</earliestRaidDays>
		<permanentEnemy>true</permanentEnemy>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<allowedArrivalTemperatureRange>-10~75</allowedArrivalTemperatureRange>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>1000</configurationListOrderPriority>
		<!--邪异组成队伍-->
		<pawnGroupMakers>
			<li>
				<!--寻常袭击——低级邪异队伍-->
				<kindDef>Combat</kindDef>
				<options>
					<RI_EvilCreature_HeadSpider>2</RI_EvilCreature_HeadSpider>
					<RI_EvilCreature_Zombie>5</RI_EvilCreature_Zombie>
					<RI_EvilCreature_ZombieArmor>2</RI_EvilCreature_ZombieArmor>
					<RI_EvilCreature_ZombieBoomer>2</RI_EvilCreature_ZombieBoomer>
				</options>
			</li>
			<li>
				<!--寻常袭击——人头蜘蛛海-->
				<kindDef>Combat</kindDef>
				<options>
					<RI_EvilCreature_HeadSpider>1</RI_EvilCreature_HeadSpider>
				</options>
			</li>
			<li>
				<!--寻常袭击——蜘蛛-->
				<kindDef>Combat</kindDef>
				<options>
					<RI_EvilCreature_SuperBigSpider>2</RI_EvilCreature_SuperBigSpider>
				</options>
			</li>
			<li>
				<!--高级袭击-->
				<kindDef>Combat</kindDef>
				<options>
					<RI_EvilCreature_Zombie>5</RI_EvilCreature_Zombie>
					<RI_EvilCreature_DeadShoot>3</RI_EvilCreature_DeadShoot>
					<RI_EvilCreature_ZombieArmor>2</RI_EvilCreature_ZombieArmor>
					<RI_EvilCreature_ZombieBoomer>2</RI_EvilCreature_ZombieBoomer>
				</options>
			</li>
		</pawnGroupMakers>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0,35)</li>
				<li>(70, 50)</li>
				<li>(800, 100)</li>
				<li>(1300, 150)</li>
				<li>(100000, 10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
	</FactionDef>
	<!--道门-->
	<FactionDef ParentName="FactionBase">
		<defName>RI_Faction_Dao</defName>
		<label>Daoist sect</label>
		<pawnSingular>Daoist</pawnSingular>
		<pawnsPlural>Daoists</pawnsPlural>
		<categoryTag>Ancient</categoryTag>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
