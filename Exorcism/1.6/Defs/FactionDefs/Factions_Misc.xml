		<!--Pawn组成-->
		<pawnGroupMakers>
			<li>
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
					<RI_DaoPawn_Priest>7</RI_DaoPawn_Priest>
					<RI_DaoPawn_Disciple>14</RI_DaoPawn_Disciple>
					<RI_DaoPawn_Alchemist>3</RI_DaoPawn_Alchemist>
