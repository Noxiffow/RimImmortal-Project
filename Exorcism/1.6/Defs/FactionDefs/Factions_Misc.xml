				</options>
			</li>
			<li>
				<kindDef>RI_Dao_FriendlyRaid</kindDef>
				<commonality>100</commonality>
				<options>
					<RI_DaoPawn_Priest>7</RI_DaoPawn_Priest>
					<RI_DaoPawn_Disciple>14</RI_DaoPawn_Disciple>
					<RI_DaoPawn_Alchemist>3</RI_DaoPawn_Alchemist>
					<RI_DaoPawn_Patriarch>2</RI_DaoPawn_Patriarch>
				</options>
			</li>
			<li>
				<kindDef>Peaceful</kindDef>
				<options>
					<RI_DaoPawn_Priest>2</RI_DaoPawn_Priest>
					<RI_DaoPawn_Disciple>4</RI_DaoPawn_Disciple>
					<RI_DaoPawn_Acolyte>3</RI_DaoPawn_Acolyte>
				</options>
			</li>
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<RI_DaoPawn_Priest>1</RI_DaoPawn_Priest>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
					<Dromedary>5</Dromedary>
					<Alpaca>2</Alpaca>
				</carriers>
				<guards>
					<RI_DaoPawn_Disciple>6</RI_DaoPawn_Disciple>
					<RI_DaoPawn_Priest>2</RI_DaoPawn_Priest>
				</guards>
			</li>
			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<RI_DaoPawn_Acolyte>20</RI_DaoPawn_Acolyte>
					<RI_DaoPawn_Disciple>15</RI_DaoPawn_Disciple>
					<RI_DaoPawn_Priest>6</RI_DaoPawn_Priest>
					<RI_DaoPawn_Alchemist>3</RI_DaoPawn_Alchemist>
