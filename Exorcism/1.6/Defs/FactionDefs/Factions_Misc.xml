		<raidsForbidden>true</raidsForbidden>
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 0)</li>
			</points>
		</raidCommonalityFromPointsCurve>
		<messageDefendersAttacking>Daoists are attacking.</messageDefendersAttacking>
		<baseTraderKinds>
			<li>Base_Outlander_Standard</li>
		</baseTraderKinds>
