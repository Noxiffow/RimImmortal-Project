		<baseCost>500</baseCost>
		<techLevel>Medieval</techLevel>
		<researchViewX>3</researchViewX>
		<researchViewY>1.4</researchViewY>
		<prerequisites>
			<li>RI_ExorcismResearch_ExorcismBasic</li>
		</prerequisites>
	</ResearchProjectDef>

