		<description>Heaven and earth hold righteous Qi, flowing in myriad forms.\n\nAberrants threaten the world, and Daoist techniques are studied to restrain them.</description>
		<baseCost>100</baseCost>
		<techLevel>Medieval</techLevel>
		<researchViewX>0</researchViewX>
		<researchViewY>1.4</researchViewY>
	</ResearchProjectDef>

