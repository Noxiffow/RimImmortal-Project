<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 人面蜘蛛的body -->
	<BodyDef Name = "RI_EvilCreature_HeadSpider_BodyDef">
		<defName>RI_EvilCreature_HeadSpider_BodyDef</defName>
		<label>EvilCreature Head Spider</label>
		<corePart>
			<def>RI_EvilCreature_HeadSpider_Torso</def>
			<height>Middle</height>
			<!-- 这里应该是高度的意思-->
			<depth>Outside</depth>
			<groups>
        		<li>Torso</li>
      		</groups>
			<!-- 这里应该是覆盖范围，这里就是覆盖在最外层-->
			<parts>
				<li>
					<def>Stomach</def>
					<!-- 胃-->
					<coverage>0.01</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>Heart</def>
					<!-- 心脏-->
					<coverage>0.01</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>Pronotum</def>
					<coverage>0.1</coverage>
					<height>Top</height>
					<parts>
						<li>
							<def>RI_EvilCreature_HeadSpider_Head</def>
							<coverage>0.01</coverage>
							<groups>
								<li>HeadAttackTool</li>
							</groups>
							<parts>
								<li>
									<def>Brain</def>
									<coverage>0.01</coverage>
									<depth>Inside</depth>
								</li>
								<li>
									<def>RI_EvilCreature_HeadSpider_Eye</def>
									<customLabel>left eye</customLabel>
									<coverage>0.01</coverage>
								</li>
								<li>
									<def>RI_EvilCreature_HeadSpider_Eye</def>
									<customLabel>right eye</customLabel>
									<coverage>0.01</coverage>
								</li>
								<li>
									<def>Ear</def>
									<customLabel>left ear</customLabel>
									<coverage>0.01</coverage>
									<flipGraphic>true</flipGraphic>
									<groups>
										<li>UpperHead</li>
										<li>FullHead</li>
									</groups>
								</li>
								<li>
									<def>Ear</def>
									<customLabel>right ear</customLabel>
									<coverage>0.01</coverage>
									<groups>
										<li>UpperHead</li>
										<li>FullHead</li>
									</groups>
								</li>
								<li>
									<def>Jaw</def>
									<coverage>0.01</coverage>
									<groups>
										<li>Mouth</li>
									</groups>
								</li>
							</parts>
						</li>
					</parts>
				</li>
				<li>
					<def>RI_EvilCreature_HeadSpider_Leg</def>
					<customLabel>front left leg</customLabel>
					<coverage>0.05</coverage>
					<height>Bottom</height>
					<groups>
						<li>LeftHand</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_HeadSpider_Leg</def>
					<customLabel>front right leg</customLabel>
					<coverage>0.05</coverage>
					<height>Bottom</height>
					<groups>
						<li>RightHand</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_HeadSpider_Leg</def>
					<customLabel>rear left leg</customLabel>
					<coverage>0.05</coverage>
					<height>Bottom</height>
					<groups>
						<li>FrontLeftLeg</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_HeadSpider_Leg</def>
					<customLabel>rear right leg</customLabel>
					<coverage>0.05</coverage>
					<height>Bottom</height>
					<groups>
						<li>FrontRightLeg</li>
					</groups>
				</li>
			</parts>
		</corePart>
	</BodyDef>

