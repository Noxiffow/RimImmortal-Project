					<coverage>0.1</coverage>
					<height>Bottom</height>
					<groups>
						<li>RI_MiddleBehindRightLeg</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_WormMother_Leg</def>
					<customLabel>rear right leg</customLabel>
					<coverage>0.1</coverage>
					<height>Bottom</height>
					<groups>
						<li>RI_MiddleBehindLeftLeg</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_WormMother_Leg</def>
					<customLabel>rear right leg</customLabel>
					<coverage>0.1</coverage>
					<height>Bottom</height>
					<groups>
						<li>RI_BehindLeftLeg</li>
					</groups>
				</li>
				<li>
					<def>RI_EvilCreature_WormMother_Leg</def>
					<customLabel>rear right leg</customLabel>
					<coverage>0.1</coverage>
					<height>Bottom</height>
					<groups>
						<li>RI_BehindRightLeg</li>
					</groups>
				</li>
			</parts>
		</corePart>
	</BodyDef>


</Defs>
