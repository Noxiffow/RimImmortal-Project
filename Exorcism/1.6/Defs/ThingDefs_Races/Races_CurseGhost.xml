	<MutantDef ParentName="BaseCorpsePuppetEntity">
		<defName>RI_CurseGhost_Mutant</defName>
		<label>恶鬼</label>
		<description>恶鬼</description>
		<!--控制贴图显示的，不要删除-->
		<hediff>CurseGhost</hediff>
		<thinkTree>Ghoul</thinkTree>
		<thinkTreeConstant>GhoulConstant</thinkTreeConstant>
		<showJobReport>true</showJobReport>
		<disableApparel>false</disableApparel>
		<whitelistedFloatMenuProviders>
			<li>FloatMenuOptionProvider_DraftedAttack</li>
			<li>FloatMenuOptionProvider_DraftedMove</li>
			<!--<li>FloatMenuOptionProvider_Ingest</li>-->
			<li>FloatMenuOptionProvider_EnterMapPortal</li>
			<li>FloatMenuOptionProvider_FromThing</li>
			<!--<li>FloatMenuOptionProvider_Equip</li>-->
			<!--<li>FloatMenuOptionProvider_Wear</li>-->
		</whitelistedFloatMenuProviders>
		<!--变成僵尸-->
		<relativeTurnedThought>BecameGhoul</relativeTurnedThought>
		<allowedDevelopmentalStages>Adult</allowedDevelopmentalStages>
		<!--<needWhitelist><li>Food</li></needWhitelist>-->
		<!--<overrideFoodType>true</overrideFoodType>-->
		<!--<foodType>CarnivoreAnimalStrict</foodType>-->
		<!--<allowEatingCorpses>true</allowEatingCorpses>-->
		<deathOnDownedChance>1</deathOnDownedChance>
		<disablesGenes>
			<li MayRequire="Ludeon.RimWorld.Biotech">Furskin</li>
		</disablesGenes>
		<!--<abilityWhitelist><li>MetalbloodInjection</li></abilityWhitelist>-->
		<deathLetter>One of your ghosts has died.</deathLetter>
		<!-- Sounds -->
		<soundAttackChance>0.25</soundAttackChance>
		<soundCall>Pawn_Ghoul_Call</soundCall>
		<soundAttack>Pawn_Ghoul_Attack</soundAttack>
		<soundWounded>Pawn_Ghoul_Pain</soundWounded>
		<soundDeath>Pawn_Ghoul_Killed</soundDeath>
		<!-- Rendering -->
		<!--<skinColorOverride>(0.58, 0.62, 0.55)</skinColorOverride>
		<hairColorOverride>(0.65, 0.65, 0.65)</hairColorOverride>-->
		<bodyTypeGraphicPaths>
			<Male>Things/Pawn/Humanlike/Bodies/Naked_Male</Male>
			<Female>Things/Pawn/Humanlike/Bodies/Naked_Female</Female>
			<Hulk>Things/Pawn/Humanlike/Bodies/Naked_Hulk</Hulk>
			<Fat>Things/Pawn/Humanlike/Bodies/Naked_Fat</Fat>
			<Thin>Things/Pawn/Humanlike/Bodies/Naked_Thin</Thin>
			<Child>Things/Pawn/Humanlike/Bodies/Naked_Thin</Child>
		</bodyTypeGraphicPaths>
		<!--<forcedHeadTypes><li>Ghoul_Normal</li></forcedHeadTypes>-->
		<!--<hairTagFilter><whitelist>true</whitelist></hairTagFilter>-->
		<!--<beardTagFilter><whitelist>true</whitelist></beardTagFilter>-->
		<tools>
			<li>
				<label>teeth</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>8.2</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.5</chanceFactor>
				<soundMeleeHit>Pawn_Melee_HumanBite_Hit</soundMeleeHit>
				<soundMeleeMiss>Pawn_Melee_HumanBite_Miss</soundMeleeMiss>
			</li>
			<li>
				<label>left claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<chanceFactor>1.5</chanceFactor>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
				<soundMeleeHit>Pawn_Ghoul_Scratch</soundMeleeHit>
				<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			</li>
			<li>
				<label>right claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<chanceFactor>1.5</chanceFactor>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
				<soundMeleeHit>Pawn_Ghoul_Scratch</soundMeleeHit>
				<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			</li>
		</tools>
