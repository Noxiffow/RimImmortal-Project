	<ThingDef ParentName="RI_Base_EvilCreatureSpider">
		<defName>RI_EvilCreature_WormMother_Race</defName>
		<label>worm mother</label>
		<description>Grade D Aberrant, Low Threat Level.\n\nThe human head on the Human-Head Spider is not real but a form of mimicry. These massive spiders dwell in ancient battlefields and graveyards, gradually evolving to resemble human heads over time.\n\nSingle Human-head Spider is easy for an ordinary person to kill, but they often move in swarms, posing a threat that should not be underestimated.</description>
		<statBases>
			<MoveSpeed>3.1</MoveSpeed>
			<!-- 移动速度-->
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<!-- 护甲-->
			<ArmorRating_Sharp>0.75</ArmorRating_Sharp>
			<!-- 护甲-->
			<MarketValue>1400</MarketValue>
			<!-- 市场价值-->
		</statBases>
		<tools>
			<!--攻击方式：第一对足，头撞-->
			<li>
				<label>first pair of legs</label>
				<labelNoLocation>legs</labelNoLocation>
				<capacities>
					<li>Scratch</li>
					<!-- 伤害类型-->
				</capacities>
				<power>18</power>
				<cooldownTime>1.4</cooldownTime>
				<linkedBodyPartsGroup>FrontRightLeg</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
			<li>
				<label>first pair of legs</label>
				<labelNoLocation>legs</labelNoLocation>
				<capacities>
					<li>Scratch</li>
					<!-- 伤害类型-->
				</capacities>
				<power>18</power>
				<cooldownTime>1.4</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>25</power>
				<cooldownTime>2.5</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.5</chanceFactor>
			</li>
		</tools>
		<comps>
			<li Class="RimZombieGirl.CompProperties_RaceGiveHediff">
				<hediffDef>RI_WormMotherHediff</hediffDef>
			</li>
