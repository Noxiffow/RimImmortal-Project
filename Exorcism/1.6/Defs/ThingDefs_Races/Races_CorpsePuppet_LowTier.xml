	<!-- ======================= 僵尸马 =============================== -->

	<ThingDef ParentName="RI_Base_CorpseCreatureBase">
		<defName>RI_CorpseCreature_ZombieHorse_Race</defName>
		<label>zombie horse</label>
		<description>A horse-shaped corpse creature. Unlike a normal horse, it never tires and can run faster. When no better means of transportation is available, evil practitioners often seek to create a zombie horse.</description>
		<statBases>
			<MoveSpeed>7.5</MoveSpeed>
			<MarketValue>700</MarketValue>
			<ComfyTemperatureMin>-35</ComfyTemperatureMin>
			<ComfyTemperatureMax>45</ComfyTemperatureMax>
			<FilthRate>1</FilthRate>
			<CaravanRidingSpeedFactor>1.9</CaravanRidingSpeedFactor>
			<Wildness>0</Wildness>
		</statBases>
		<uiIconScale>1.1</uiIconScale>
		<race>
			<herdAnimal>true</herdAnimal>
			<body>QuadrupedAnimalWithHooves</body>
			<baseBodySize>2.4</baseBodySize>
			<baseHealthScale>1.75</baseHealthScale>
			<baseHungerRate>0.535</baseHungerRate>
			<foodType>CarnivoreAnimal</foodType>
			<gestationPeriodDays>6.66</gestationPeriodDays>
			<trainability>Advanced</trainability>
			<packAnimal>true</packAnimal>
			<lifeExpectancy>30</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalAdult</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Horse_Wounded</soundWounded>
					<soundDeath>Pawn_Horse_Death</soundDeath>
					<soundCall>Pawn_Horse_Call</soundCall>
					<soundAngry>Pawn_Horse_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
			<headPosPerRotation>
				<li>(0.0, 0, 0.33)</li>
				<li>(0.31, 0, 0.21)</li>
				<li>(0.0, 0, 0.08)</li>
				<li>(-0.31, 0, 0.21)</li>
			</headPosPerRotation>
		</race>
		<tools>
			<li>
				<label>left hoof</label>
				<labelNoLocation>hoof</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right hoof</label>
				<labelNoLocation>hoof</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>FrontRightLeg</linkedBodyPartsGroup>
			</li>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.5</chanceFactor>
			</li>
		</tools>
	</ThingDef>

