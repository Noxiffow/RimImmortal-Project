<Defs>

	<!-- ======================= 纸人 =============================== -->

	<ThingDef ParentName="RI_Base_CorpseCreatureBase">
		<defName>RI_CorpseCreature_PaperDoll_Race</defName>
		<label>paper doll</label>
		<description>A humanoid figure made of paper and stuffed with straw, animated through dark rituals. Paper dolls can only perform simple cleaning tasks.\n\nThey are extremely vulnerable to fire.</description>
		<statBases>
			<MoveSpeed>3.2</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<MarketValue>100</MarketValue>
			<FilthRate>1</FilthRate>
		</statBases>
		<!--<comps>
			<li Class="CompProperties_Milkable">
				<milkDef>Milk</milkDef>
				<milkIntervalDays>1</milkIntervalDays>
				<milkAmount>14</milkAmount>
			</li>
		</comps>-->
		<race>
			<!--血迹，肉类型-->
			<fleshType>Mechanoid</fleshType>
			<bloodDef>RI_Filth_AberrantBlood</bloodDef>
			<body>Human</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>2.4</baseBodySize>
			<baseHungerRate>0.535</baseHungerRate>
			<baseHealthScale>1.5</baseHealthScale>
			<foodType>None</foodType>
			<trainability>Advanced</trainability>
			<lifeExpectancy>22</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalAdult</def>
					<minAge>0</minAge>
					<!--<soundWounded>Pawn_Muffalo_Wounded</soundWounded>
					<soundDeath>Pawn_Muffalo_Death</soundDeath>
					<soundCall>Pawn_Muffalo_Call</soundCall>
					<soundAngry>Pawn_Muffalo_Angry</soundAngry>-->
				</li>
			</lifeStageAges>
			<!--<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>-->
			<!--纸人工作-->
			<trainableTags>
				<li>PaperManWork</li>
				<li>Work</li>
			</trainableTags>
			<untrainableTags>
				<li>Combat</li>
				<li>Help</li>
			</untrainableTags>
		</race>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<!--<chanceFactor>0.2</chanceFactor>-->
			</li>
		</tools>
		<!--屠宰产物-->
		<butcherProducts>
			<RI_Resource_CharmPaper>2</RI_Resource_CharmPaper>
		</butcherProducts>
	</ThingDef>

