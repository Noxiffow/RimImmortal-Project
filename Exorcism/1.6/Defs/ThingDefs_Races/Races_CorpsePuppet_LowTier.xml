		</tags>
	</TrainableDef>

	<!--缝合尸-->
	<ThingDef ParentName="RI_Base_CorpseCreatureBase">
		<defName>RI_CorpseCreature_PatchMan_Race</defName>
		<label>patch man</label>
		<description>A grotesque creation stitched together from corpse fragments. Its body resembles a torn sack of rags, moving in unnatural, twisted motions while emitting mournful wails.\n\nThis creature is a loyal assistant. Though clumsy and inefficient, it can handle basic hauling and menial labor.</description>
		<statBases>
			<MoveSpeed>3.2</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<MarketValue>100</MarketValue>
			<FilthRate>1</FilthRate>
		</statBases>
		<race>
			<body>Human</body>
			<baseBodySize>1.3</baseBodySize>
			<baseHungerRate>0</baseHungerRate>
			<baseHealthScale>1.5</baseHealthScale>
			<foodType>None</foodType>
			<trainability>Advanced</trainability>
			<lifeExpectancy>10</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalAdult</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Muffalo_Wounded</soundWounded>
					<soundDeath>Pawn_Muffalo_Death</soundDeath>
					<soundCall>Pawn_Muffalo_Call</soundCall>
					<soundAngry>Pawn_Muffalo_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
		</race>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<!--<chanceFactor>0.2</chanceFactor>-->
			</li>
		</tools>
	</ThingDef>

