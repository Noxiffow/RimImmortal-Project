	<TrainableDef>
		<defName>RI_Clean</defName>
		<label>clean</label>
		<description>The paperman will randomly clean the floor.</description>
		<!--TODO:图标缺失-->
		<icon>UI/Icons/Trainables/RI_Clean</icon>
