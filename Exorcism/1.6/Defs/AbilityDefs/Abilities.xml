	<!-- 火焰呼吸 -->
	<AbilityDef>
		<defName>RI_ZombieAbility_GhostFireBurst</defName>
		<label>Ghost fire spit</label>
		<!-- 经由一种相比 Impid 更好的，基于生物技术优化过的腺体，喷洒出高温易燃的液体。以迅速点燃目标 -->
		<description>o</description>
		<iconPath>UI/Abilities/RI_ZombieAbility_GhostFireBurst</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<warmupStartSound>FireSpew_Warmup</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>5.9</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>FireSpew_Resolve</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="RimZombieGirl.CompProperties_AbilitySpew">
				<compClass>RimZombieGirl.CompAbilityEffect_Spew</compClass>
				<damageType>Flame</damageType>
				<damageAmount>17</damageAmount>
				<armorPenetration>1.0</armorPenetration>
				<range>5.9</range>
				<lineWidthEnd>4.3</lineWidthEnd>
				<!-- <rangeStat>NzFlm_SkillRangeMultiplierHalf</rangeStat> -->
				<filthDef>Filth_FlammableBile</filthDef>
				<effecterDef>Fire_Spew</effecterDef>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
		</comps>
	</AbilityDef>
