<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<AbilityCategoryDef>
		<defName>Zombie</defName>
		<displayOrder>1020</displayOrder>
	</AbilityCategoryDef>
	<!--扑咬-->
	<AbilityDef>
		<defName>RI_ZombieAbility_BiteOn</defName>
		<label>Bite on</label>
		<description>Rushing towards and biting the target.</description>
		<iconPath>UI/Abilities/RI_ZombieAbility_BiteOn</iconPath>
		<cooldownTicksRange>60</cooldownTicksRange>
		<hostile>true</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<ai_IsOffensive>true</ai_IsOffensive>
		<aiCanUse>true</aiCanUse>
		<category>Zombie</category>
		<statBases>
			<Ability_Duration>15</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>RimZombieGirl.Verb_CastAbilityJumpExt</verbClass>
			<!-- <verbClass>Verb_CastAbilityJump</verbClass> -->
			<warmupTime>0.5</warmupTime>
			<range>4.9</range>
			<label>jump</label>
			<violent>true</violent>
			<forceNormalTimeSpeed>false</forceNormalTimeSpeed>
			<requireLineOfSight>true</requireLineOfSight>
			<soundCast>Longjump_Jump</soundCast>
			<soundLanding>Longjump_Land</soundLanding>
			<targetParams>
				<canTargetLocations>false</canTargetLocations>
				<canTargetPawns>true</canTargetPawns>
				<canTargetBuildings>false</canTargetBuildings>
			</targetParams>
		</verbProperties>
		<!-- <jobDef>CastJump</jobDef> -->
		<comps>
			<li Class="RimZombieGirl.CompProperties_Bite">
				<damageMin>7</damageMin>
				<damageMax>13</damageMax>
				<armorPenetration>0.5</armorPenetration>
				<chanceMin>1</chanceMin>
				<chanceMax>2</chanceMax>
			</li>
		</comps>
	</AbilityDef>
	<!--遁地术-->
	<AbilityDef>
		<defName>Zg_DirtTeleport</defName>
		<label>dirt teleport</label>
		<description>Drill into the earth and out of the target position.</description>
