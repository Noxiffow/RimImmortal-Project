				<canTargetBuildings>false</canTargetBuildings>
			</targetParams>
			<!-- 放技能读条时目标处的声音和特效, 可空 -->
			<!-- <soundCast>播放声音</soundCast> -->
			<!-- <warmupEffecter>起始特效</warmupEffecter> -->
