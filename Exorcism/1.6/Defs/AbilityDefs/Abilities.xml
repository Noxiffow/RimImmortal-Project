		<thingClass>RimZombieGirl.Projectile_HediffOnly</thingClass>
		<graphicData>
			<texPath>Things/Projectile/PiercingSpine</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(0, 1, 0.6, 1)</color>
