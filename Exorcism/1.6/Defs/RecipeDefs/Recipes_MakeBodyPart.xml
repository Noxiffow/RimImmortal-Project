				<filter>
					<thingDefs>
						<li>RI_Resource_ErosionBronze</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_CharmPaper</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_InkJade</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_ErosionBronze</li>
				<li>RI_Resource_CharmPaper</li>
				<li>RI_Resource_InkJade</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_ZombieBodyPart_DemonBindingNail>1</RI_ZombieBodyPart_DemonBindingNail>
		</products>
	</RecipeDef>

	<!--=========================高级植入体=========================-->

	<!--合成邪血心脏-->
	<RecipeDef ParentName="RI_Base_MakeZombieImplant">
		<defName>RI_Recipe_MakeAberrantBloodHeart</defName>
		<label>make aberrant blood heart</label>
		<description>Infuse concentrated aberrant blood into the circulatory system and seal it with charms to create an aberrant organ.</description>
		<jobString>making aberrant blood heart</jobString>
		<researchPrerequisite>RI_ExorcismResearch_NecrosapiensOrgan</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_ConcentrateAberrantBlood</li>
					</thingDefs>
				</filter>
				<count>15</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_CharmPaper</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Heart</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_ConcentrateAberrantBlood</li>
				<li>RI_Resource_CharmPaper</li>
				<li>Heart</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_ZombieBodyPart_AberrantBloodHeart>1</RI_ZombieBodyPart_AberrantBloodHeart>
		</products>
	</RecipeDef>

