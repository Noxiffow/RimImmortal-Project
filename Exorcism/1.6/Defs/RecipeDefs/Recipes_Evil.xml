	<!--分解邪祟-->
	<RecipeDef>
		<defName>RI_Recipe_SplitAberrant</defName>
		<label>Split aberrant</label>
		<description>Decompose the aberrant's corpse to obtain materials.</description>
		<workerCounterClass>RecipeWorkerCounter_ButcherAnimals</workerCounterClass>
		<jobString>Spliting</jobString>
		<workAmount>450</workAmount>
		<workSpeedStat>ButcheryFleshSpeed</workSpeedStat>
		<workSkill>Crafting</workSkill>
		<efficiencyStat>ButcheryFleshEfficiency</efficiencyStat>
		<effectWorking>ButcherFlesh</effectWorking>
		<soundWorking>Recipe_ButcherCorpseFlesh</soundWorking>
		<interruptIfIngredientIsRotting>true</interruptIfIngredientIsRotting>
		<!--改进-->
		<uiIconThing>Meat_Muffalo</uiIconThing>
		<forceHiddenSpecialFilters>
			<li>AllowFresh</li>
		</forceHiddenSpecialFilters>
		<recipeUsers>
			<li>ButcherSpot</li>
			<li>TableButcher</li>
			<li>RI_Building_AberrantWorkbench</li>
			<!-- 屠宰，邪术台制作 -->
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>RI_Corpses_Aberrant</li>
					</categories>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<specialProducts>
			<li>Butchery</li>
		</specialProducts>
		<fixedIngredientFilter>
			<categories>
				<li>RI_Corpses_Aberrant</li>
			</categories>
			<specialFiltersToDisallow>
				<li>AllowRotten</li>
			</specialFiltersToDisallow>
		</fixedIngredientFilter>
		<defaultIngredientFilter>
			<categories>
				<li>RI_Corpses_Aberrant</li>
			</categories>
		</defaultIngredientFilter>
	</RecipeDef>

	<!--炼制血魄丹-->
	<RecipeDef>
		<defName>RI_Recipe_MakeBloodPill</defName>
		<label>炼制血魄丹</label>
		<description>利用大量的邪血与皮革纤维，浓缩提炼而成的血丹，蕴含诅咒。</description>
		<jobString>正在炼制血丹</jobString>
		<workAmount>3000</workAmount>
		<workSpeedStat>DrugCookingSpeed</workSpeedStat>
		<workSkill>Crafting</workSkill>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_CookMeal</soundWorking>
		<recipeUsers>
			<li>RI_Building_AberrantWorkbench</li>
			<!-- 邪术台制作 -->
		</recipeUsers>
		<skillRequirements>
			<Medicine>7</Medicine>
		</skillRequirements>
		<researchPrerequisite>RI_ExorcismResearch_NecrosapiensAlchemy</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_ConcentrateAberrantBlood</li>
						<!-- 邪血 -->
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>HemogenPack</li>
						<!-- 原版血包 -->
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>Leathers</li>
						<!-- 各类皮革分类 -->
					</categories>
				</filter>
				<count>50</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_ConcentrateAberrantBlood</li>
				<li>HemogenPack</li>
			</thingDefs>
			<categories>
				<li>Leathers</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_BloodElixir>1</RI_Resource_BloodElixir>
		</products>
	</RecipeDef>

	<!--合成异构肉-->
	<RecipeDef>
		<defName>RI_Recipe_MakeHeteromorphMeat</defName>
		<label>合成异构肉</label>
		<description>将人肉与其他生物组织在阴脂的粘合下强行拼接，形成充满诅咒的肉块。</description>
		<jobString>正在合成异构肉</jobString>
		<workAmount>1800</workAmount>
		<workSpeedStat>CookSpeed</workSpeedStat>
		<workSkill>Cooking</workSkill>
		<effectWorking>ButcherFlesh</effectWorking>
		<soundWorking>Recipe_ButcherCorpseFlesh</soundWorking>
		<researchPrerequisite>RI_ExorcismResearch_NecrosapiensAlchemy</researchPrerequisite>
		<recipeUsers>
			<li>RI_Building_AberrantWorkbench</li>
			<!-- 邪术台制作 -->
		</recipeUsers>
		<skillRequirements>
			<Medicine>8</Medicine>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Human</li>
					</thingDefs>
				</filter>
				<count>400</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>MeatRaw</li>
						<!-- 其它所有肉类 -->
					</categories>
					<disallowedThingDefs>
						<li>Meat_Human</li>
						<!-- 过滤器排除掉人肉，以免重复消耗 -->
					</disallowedThingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_CorpseOil</li>
						<!-- 阴脂 -->
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Meat_Human</li>
				<li>RI_Resource_CorpseOil</li>
			</thingDefs>
			<categories>
				<li>MeatRaw</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_UpgradeMeat>1</RI_Resource_UpgradeMeat>
		</products>
	</RecipeDef>

