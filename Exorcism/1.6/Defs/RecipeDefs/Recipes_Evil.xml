<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--制造邪术零件-->
	<RecipeDef>
		<defName>RI_Recipe_MakeEvilComponent</defName>
		<label>make aberrant components</label>
		<description>Make aberrant components from human flesh.</description>
		<jobString>making aberrant components</jobString>
		<workAmount>1200</workAmount>
		<workSpeedStat>CookSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workSkill>Crafting</workSkill>
		<displayPriority>1440</displayPriority>
		<researchPrerequisite>RI_ExorcismResearch_AberrantTechnology</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Human</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_ErosionBronze</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<products>
			<RI_Resource_AberrantComponents>1</RI_Resource_AberrantComponents>
		</products>
	</RecipeDef>

