<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--=======================炼制尸傀=======================-->
	<RecipeDef Name="RI_ZombieBase_MakeCorpseCreature" Abstract="True">
		<effectWorking>RI_Effecter_MakeCorpse</effectWorking>
		<soundWorking>Recipe_Surgery</soundWorking>
		<workSkill>Medicine</workSkill>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
	</RecipeDef>

	<!--炼制纸人-->
	<RecipeDef ParentName="RI_ZombieBase_MakeCorpseCreature">
		<defName>RI_Recipe_CreatePaperDoll</defName>
		<label>produce paper doll</label>
		<description>Use ordinary blood to synthesize concentrated aberrant blood.</description>
		<jobString>producing paper doll</jobString>
		<workAmount>500</workAmount>
		<skillRequirements>
			<Crafting>2</Crafting>
		</skillRequirements>
		<unfinishedThingDef>RI_Unfinished_PaperMan</unfinishedThingDef>
		<researchPrerequisite>RI_ExorcismResearch_ElementaryCorpseCreature</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_CharmPaper</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Hay</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_CharmPaper</li>
				<li>Hay</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_SpawnEgg_PaperDoll>1</RI_SpawnEgg_PaperDoll>
		</products>
	</RecipeDef>

	<!--炼制缝合尸-->
	<RecipeDef ParentName="RI_ZombieBase_MakeCorpseCreature">
		<defName>RI_Recipe_CreatePatchMan</defName>
		<label>produce patch man</label>
		<description>Use ordinary blood to synthesize concentrated aberrant blood.</description>
		<jobString>producing patch man</jobString>
		<workAmount>1200</workAmount>
		<skillRequirements>
			<Medicine>3</Medicine>
			<Crafting>2</Crafting>
		</skillRequirements>
		<researchPrerequisite>RI_ExorcismResearch_ElementaryCorpseCreature</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Leather_Patch</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Human</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Leather_Patch</li>
				<li>Meat_Human</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_SpawnEgg_PatchMan>1</RI_SpawnEgg_PatchMan>
		</products>
	</RecipeDef>

