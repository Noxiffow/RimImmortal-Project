	<!--植入封魔钉-->
	<RecipeDef ParentName="RI_Base_ZombieSurgeryInstall">
		<defName>RI_Surgery_InstallSealingNail</defName>
		<label>implant demon-binding nail</label>
		<description>Implant a sealing nail. Can be stacked.</description>

		<!-- 特殊融合版worker -->
		<workerClass>RI_Frame_ZombieLife.Recipe_InstallStackableZombieImplant</workerClass>
		<jobString>installing demon-binding nail</jobString>
		<workAmount>1500</workAmount>
		<skillRequirements>
			<Medicine>5</Medicine>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_ZombieBodyPart_DemonBindingNail</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_ZombieBodyPart_DemonBindingNail</li>
			</thingDefs>
		</fixedIngredientFilter>

		<appliedOnFixedBodyParts>
			<li>Spine</li>
		</appliedOnFixedBodyParts>
		<!-- ★★★ 2. 告诉框架这是什么 Hediff ★★★ -->
		<addsHediff>RI_Hediff_DemonBindingNail</addsHediff>
		<!-- ★★★ 3. 配置最大堆叠数 ★★★ -->
		<modExtensions>
			<li Class="RI_Frame_StackableImplant.StackableImplantExtension">
				<maxStacks>6</maxStacks>
			</li>
		</modExtensions>
	</RecipeDef>

