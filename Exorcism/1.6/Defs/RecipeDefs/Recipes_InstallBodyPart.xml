	<!-- ================= 安装铁牙 ================= -->
	<RecipeDef ParentName="RI_Base_ZombieSurgeryInstall">
		<defName>RI_Surgery_InstallSteelTeeth</defName>
		<label>install steel teeth</label>
		<description>Install steel teeth.</description>
		<workerClass>Recipe_InstallArtificialBodyPart</workerClass>
		<jobString>installing iron teeth</jobString>
		<workAmount>1000</workAmount>
		<skillRequirements>
			<Medicine>2</Medicine>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_ZombieBodyPart_SteelTeeth</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_ZombieBodyPart_SteelTeeth</li>
			</thingDefs>
		</fixedIngredientFilter>
		<!-- 对应人体部位: Jaw (下颚) -->
		<appliedOnFixedBodyParts>
			<li>Jaw</li>
		</appliedOnFixedBodyParts>
		<!-- 对应的 Hediff -->
		<addsHediff>RI_Hediff_SteelTeeth</addsHediff>
	</RecipeDef>

