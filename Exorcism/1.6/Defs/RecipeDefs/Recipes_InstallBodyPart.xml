<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--植入冥尸器官Base-->
	<RecipeDef Name="RI_Base_ZombieSurgeryInstall" ParentName="SurgeryFlesh" Abstract="True">
		<workAmount>2000</workAmount>
		<developmentalStageFilter>Child, Adult</developmentalStageFilter>
		<skillRequirements>
			<Medicine>5</Medicine>
		</skillRequirements>
		<!--僵尸植入手术worker-->
		<workerClass>RI_Frame_ZombieLife.Recipe_InstallZombieImplant</workerClass>
		<modExtensions>
			<li Class="RI_Frame_ZombieLife.RecipeExtension_GeneCheck">
				<!-- 只有拥有僵尸核心基因的人，才能在手术列表里看到这个手术 -->
				<!--<requiredGene>RI_ZombieCore_Aspect_DeadButNotDead</requiredGene>-->
				<!-- 限制异种类型 -->
				<requiredXenotype>RI_ExorcismXenotype_Necrosapiens</requiredXenotype>
			</li>
		</modExtensions>
		<recipeUsers>
			<li>Human</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>Medicine</li>
					</categories>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>Medicine</li>
			</categories>
		</fixedIngredientFilter>
	</RecipeDef>

	<!--植入邪血心脏-->
	<RecipeDef ParentName="RI_Base_ZombieSurgeryInstall">
		<defName>RI_Surgery_InstallAberrantBloodHeart</defName>
		<label>Install aberrant blood heart</label>
		<description>Implant the aberrant blood heart; only the Necrosapiens can endure such an organ.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_ZombieBodyPart_AberrantBloodHeart</ThingDef>
			<HediffDef>RI_Hediff_AberrantBloodLung</HediffDef>
		</descriptionHyperlinks>
		<jobString>Installing aberrant blood heart</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_ZombieBodyPart_AberrantBloodHeart</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_ZombieBodyPart_AberrantBloodHeart</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Heart</li>
		</appliedOnFixedBodyParts>
		<addsHediff>RI_Hediff_AberrantBloodHeart</addsHediff>
	</RecipeDef>

