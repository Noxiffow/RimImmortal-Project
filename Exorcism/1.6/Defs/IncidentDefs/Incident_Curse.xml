		<letterLabel>Spiders!</letterLabel>
		<letterText>A group of giant spiders have burrowed up from the deep earth! They are hungry and attacking anything that moves.</letterText>
		<letterDef>ThreatBig</letterDef>
		<baseChance>1.0</baseChance>
		-->
  <!-- 发生几率 -->
  <!--
		<minRefireDays>15</minRefireDays>
		-->
  <!-- 两次发生的最小间隔 -->
  <!--
		<pointsScaleable>true</pointsScaleable>
		-->
  <!-- 难度随玩家财富增长 -->
  <!--
		<tale>Infestation</tale>
	</IncidentDef>-->
  <!--蜘蛛！-->
  <RI_Framework_IncidentFrame.IncidentDef_Burrow>
    <defName>RI_Incident_SpiderBurrow</defName>
    <label>spider</label>
    <workerClass>RI_Framework_IncidentFrame.IncidentWorker_Burrow</workerClass>
    <category>ThreatBig</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <!-- 框架特有配置 -->
    <DiggingpawnKind>RI_EvilCreature_SuperBigSpider</DiggingpawnKind>
    <minCount>1</minCount>
    <maxCount>5</maxCount>
    <arrivalSound>Hive_Spawn</arrivalSound>
    <!-- 基础配置 -->
    <letterLabel>Spider!</letterLabel>
    <letterText>Spider!</letterText>
    <letterDef>ThreatBig</letterDef>
    <baseChance>0.05</baseChance>
  </RI_Framework_IncidentFrame.IncidentDef_Burrow>
  <RI_Framework_IncidentFrame.IncidentDef_Burrow>
    <defName>RI_ZombieFleshLured</defName>
    <label>冥尸加入</label>
    <workerClass>TW_Framework_IncidentFrame.IncidentWorker_ZombieFleshLured</workerClass>
    <category>Misc</category>
    <!-- 设为杂项事件，不会消耗大的袭击冷却 -->
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <!-- 这里填你现有的冥娘 PawnKindDef -->
    <pawnKind>RI_Pawn_Zombie</pawnKind>
    <minCount>1</minCount>
    <maxCount>1</maxCount>
    <!-- 视觉效果：钻地时冒点血，很有感觉 -->
    <fleckDef>BloodSplash</fleckDef>
    <letterLabel>冥尸加入</letterLabel>
    <letterText>一位被新鲜血肉气息吸引的冥尸从地下钻了出来。它们似乎属于{0}，只要不干扰它们，它们应该不会攻击。</letterText>
    <letterDef>NeutralEvent</letterDef>
    <baseChance>0.01</baseChance>
  </RI_Framework_IncidentFrame.IncidentDef_Burrow>
</Defs>