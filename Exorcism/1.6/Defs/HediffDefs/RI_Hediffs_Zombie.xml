	<!--所有邪祟生物隐藏hediff-->
	<HediffDef ParentName="RI_Base_CorpseCreatureHediff">
		<defName>RI_Hediff_UndeadCreature</defName>
		<label>undead</label>
		<description>#</description>
		<stages>
			<li>
				<statFactors>
					<!--心灵敏感度-->
					<PsychicSensitivity>0</PsychicSensitivity>
					<!--学习效率-->
					<StudyEfficiency>0</StudyEfficiency>
					<!--愈合效率-->
					<InjuryHealingFactor>0</InjuryHealingFactor>
				</statFactors>
				<statOffsets>
					<ComfyTemperatureMin>-10</ComfyTemperatureMin>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
					<ToxicResistance>0.75</ToxicResistance>
					<ToxicEnvironmentResistance>0.75</ToxicEnvironmentResistance>
				</statOffsets>
				<!--不会疼痛-->
				<painFactor>0</painFactor>
				<makeImmuneTo>
					<li>Flu</li>
					<li>BadBack</li>
				</makeImmuneTo>
				<disablesNeeds>
					<li>Rest</li>
					<li>Comfort</li>
					<li>Beauty</li>
					<li>Outdoors</li>
				</disablesNeeds>
			</li>
		</stages>
	</HediffDef>
	
