	<!-- 僵尸的Hediff -->

	<HediffDef>
		<defName>RI_Hediff_ZombieBloodCore</defName>
		<label>死而不僵</label>
		<description>AA</description>
		<hediffClass>RimZombieGirl.Hediff_DeadButNotDead</hediffClass>
		<everCurableByItem>false</everCurableByItem>
		<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0</painFactor>
				<statFactors>
					<MoveSpeed>0.5</MoveSpeed>
					<MaxNutrition>2</MaxNutrition>
					<PsychicSensitivity>0</PsychicSensitivity>
					<PainShockThreshold>100</PainShockThreshold>
					<EatingSpeed>5</EatingSpeed>
				</statFactors>
				<statOffsets>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
					<ArmorRating_Heat>-1.0</ArmorRating_Heat>
					<ComfyTemperatureMin>-40</ComfyTemperatureMin>
					<ComfyTemperatureMax>40</ComfyTemperatureMax>
					<InjuryHealingFactor>0.2</InjuryHealingFactor>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Talking</capacity>
						<postFactor>0</postFactor>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_AttachPoints" />
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>RI_MeatHunger</defName>
		<label>meat hunger</label>
		<description>#</description>
		<everCurableByItem>false</everCurableByItem>
		<maxSeverity>1</maxSeverity>
		<alwaysShowSeverity>true</alwaysShowSeverity>
		<stages>
			<li>
				<becomeVisible>false</becomeVisible>
			</li>
			<li>
				<minSeverity>0.1</minSeverity>
				<label>initial</label>
				<statOffsets>
					<RI_Zombie_Stat_SuppressDownRate>0.3</RI_Zombie_Stat_SuppressDownRate>
				</statOffsets>
			</li>
			<li>
				<minSeverity>0.5</minSeverity>
				<label>moderate</label>
				<statOffsets>
					<RI_Zombie_Stat_SuppressDownRate>0.6</RI_Zombie_Stat_SuppressDownRate>
				</statOffsets>
			</li>
			<li>
				<minSeverity>0.8</minSeverity>
				<label>extreme</label>
				<statOffsets>
					<RI_Zombie_Stat_SuppressDownRate>0.9</RI_Zombie_Stat_SuppressDownRate>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<!--邪恶僵尸类的通用hediff-->
	<!--活死人-->
	<HediffDef>
		<defName>RI_Hediff_WalkingDead</defName>
		<label>walking dead</label>
		<description>This creature is biologically dead but reanimated by anomalous forces. It feels no pain, needs no sleep, and desires only flesh.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.59, 0.44, 0.70)</defaultLabelColor>
		<isBad>false</isBad>

		<!-- 设为不可治愈 -->
		<tendable>false</tendable>
		<makesSickThought>false</makesSickThought>
		<stages>
			<li>
				<!-- 核心属性：移除疼痛 -->
				<painFactor>0</painFactor>
				<restFallFactor>0</restFallFactor>
				<!-- 其他僵尸特性 -->
				<foodPoisoningChanceFactor>0</foodPoisoningChanceFactor>
				<!-- 吃腐肉不中毒 -->
				<statOffsets>
					<PsychicSensitivity>-2</PsychicSensitivity>
					<!-- 免疫心灵波 -->
					<ToxicResistance>1</ToxicResistance>
					<!-- 免疫毒气 -->
					<ComfyTemperatureMin>-20</ComfyTemperatureMin>
					<!-- 不怕冷 -->
					<ComfyTemperatureMax>70</ComfyTemperatureMax>
					<!-- 不怕热 -->
					<ImmunityGainSpeed>2.0</ImmunityGainSpeed>
					<!-- 极高免疫力 -->
					<SocialImpact>-5</SocialImpact>
					<!-- 无法社交 -->
					<GlobalLearningFactor>-5</GlobalLearningFactor>
					<!-- 无法学习 -->
					<WorkSpeedGlobal>-5</WorkSpeedGlobal>
					<!-- 动作僵硬，稍微慢点 -->
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<HediffDef ParentName="InjuryBase">
		<defName>RI_He_BloodCurse</defName>
		<label>blood curse</label>
		<labelNoun>an blood curse wound</labelNoun>
		<hediffClass>RimZombieGirl.Hediff_BloodCurse</hediffClass>
		<description>A wound caused by a blood curse.</description>
		<comps></comps>
		<injuryProps>
			<painPerSeverity>0.01</painPerSeverity>
			<averagePainPerSeverityPermanent>0.005</averagePainPerSeverityPermanent>
			<bleedRate>0.03</bleedRate>
			<canMerge>false</canMerge>
			<destroyedLabel>Spiked off</destroyedLabel>
			<destroyedOutLabel>Spiked out</destroyedOutLabel>
		</injuryProps>
	</HediffDef>
	
