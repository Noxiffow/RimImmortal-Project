<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--血月狂乱-->
  <HediffDef>
    <defName>RI_BerserkBuff</defName>
    <label>blood moon frenzy</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Under the bloody moonlight, the curse spreads across the land, driving the aberrants into madness.</description>
    <isBad>true</isBad>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>0.5</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.3</offset>
          </li>
        </capMods>
        <statOffsets>
          <MeleeHitChance>0.2</MeleeHitChance>
          <MeleeDodgeChance>0.2</MeleeDodgeChance>
          <!--<MeleeDamageMultiplier>1.5</MeleeDamageMultiplier>-->
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
  <!--诅咒：不安，侵蚀，失控，缠身-->
  <HediffDef>
    <defName>RI_CurseHediff</defName>
    <label>curse</label>
    <description>The curse inflicts dreadful effects upon all living beings.As time passes, its influence grows stronger, eventually leading to death.\n\nThe curse induces cellular degeneration, triggering various diseases and psychological disorders — extreme caution is advised.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <initialSeverity>0.1</initialSeverity>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <stages>
      <li>
        <label>Disturbance</label>
        <minSeverity>0.1</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Erosion</label>
        <minSeverity>0.3</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.2</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.2</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.2</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Derangement</label>
        <minSeverity>0.6</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.3</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.2</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.45</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Haunting</label>
        <minSeverity>0.8</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.5</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.4</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.75</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>-0.5</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="RimZombieGirl.HediffCompProperties_CurseProgress" />
      <!-- 随机触发噩梦、呕吐、悲伤徘徊 -->
      <li Class="RimZombieGirl.HediffCompProperties_CurseNightmare" />
      <li Class="RimZombieGirl.HediffCompProperties_CurseVomit" />
      <li Class="RimZombieGirl.HediffCompProperties_CurseSadWander" />
      <!-- 随机引发疾病 -->
      <li Class="RimZombieGirl.HediffCompProperties_CurseDisease" />
    </comps>
  </HediffDef>
  <!--血肉变异-->
  <HediffDef>
    <defName>RI_FleshMutation</defName>
    <label>血肉变异</label>
    <description>诅咒侵蚀血肉并重塑器官与肢体。宿主获得异常强化，但会承受极端痛苦与精神压迫。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>false</scenarioCanAdd>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <chronic>false</chronic>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.02</initialSeverity>
    <comps>
      <li Class="RimZombieGirl.HediffCompProperties_FleshMutationProgress" />
    </comps>
    <stages>
      <li>
        <label>初变</label>
        <minSeverity>0.00</minSeverity>
        <painOffset>0.05</painOffset>
        <partEfficiencyOffset>0.05</partEfficiencyOffset>
      </li>
      <li>
        <label>增殖</label>
        <minSeverity>0.30</minSeverity>
        <painOffset>0.07</painOffset>
        <partEfficiencyOffset>0.07</partEfficiencyOffset>
      </li>
      <li>
        <label>异化</label>
        <minSeverity>0.55</minSeverity>
        <painOffset>0.10</painOffset>
        <painFactor>1.05</painFactor>
        <partEfficiencyOffset>0.10</partEfficiencyOffset>
      </li>
      <li>
        <label>灾变</label>
        <minSeverity>0.90</minSeverity>
        <painOffset>0.30</painOffset>
        <painFactor>1.2</painFactor>
        <partEfficiencyOffset>0.20</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>
</Defs>