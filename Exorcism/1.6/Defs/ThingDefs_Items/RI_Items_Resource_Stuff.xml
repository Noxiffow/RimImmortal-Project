	<!--血丹-->
	<ThingDef ParentName="ResourceBase">
		<defName>RI_Resource_BloodElixir</defName>
		<label>blood elixir</label>
		<description>冥尸从【冥血】进化到【魇肉】的必备素材，需要提前吃下后，躺入炼冥棺的血池中进化。</description>
		<thingClass>ThingWithComps</thingClass>
