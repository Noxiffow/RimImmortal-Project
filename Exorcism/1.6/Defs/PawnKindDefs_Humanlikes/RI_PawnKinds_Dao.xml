<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--===========道门派系pawn===========-->
	<PawnKindDef Name="RI_DaoPawn_Base" Abstract="True">
		<race>Human</race>
		<!--<nameMaker>RI_NameRule_NamerPersonChinese</nameMaker>
		<nameMakerFemale>RI_NameRule_NamerPersonChineseFemale</nameMakerFemale>-->
		<chemicalAddictionChance>0.1</chemicalAddictionChance>
		<!-- 防止因为环境温度导致不穿衣服 -->
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>
		<apparelIgnorePollution MayRequire="Ludeon.RimWorld.Biotech">true</apparelIgnorePollution>
		<!-- 增加强制穿头盔的几率 -->
		<apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
		<combatEnhancingDrugsChance>0.01</combatEnhancingDrugsChance>
		<combatEnhancingDrugsCount>1~2</combatEnhancingDrugsCount>
		<defaultFactionType>RI_Faction_Dao</defaultFactionType>
		<backstoryCryptosleepCommonality>1</backstoryCryptosleepCommonality>
		<biocodeWeaponChance>0.2</biocodeWeaponChance>
		<requiredWorkTags>
			<li>Violent</li>
		</requiredWorkTags>
		<!--自带营养值-->
		<invNutrition>5</invNutrition>
		<!--背景故事-->
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>RI_BackstoryCategory_Daoist</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<!--禁止特性-->
		<disallowedTraits>
			<li>Greedy</li>
			<li>Jealous</li>
			<li>CreepyBreathing</li>
			<li>Pyromaniac</li>
		</disallowedTraits>
		<!--假体-->
		<techHediffsChance>0.05</techHediffsChance>
		<techHediffsMoney>100~200</techHediffsMoney>
		<techHediffsTags>
			<li>Poor</li>
		</techHediffsTags>
		<!--俘虏抗性-->
		<initialWillRange>3</initialWillRange>
		<initialResistanceRange>10~15</initialResistanceRange>
	</PawnKindDef>

	<!--道童-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_Acolyte</defName>
		<label>Dao acolyte</label>
		<combatPower>30</combatPower>
		<!--年龄-->
		<minGenerationAge>7</minGenerationAge>
		<maxGenerationAge>15</maxGenerationAge>
		<!--衣服-->
		<apparelMoney>10~3000</apparelMoney>
		<apparelTags>
			<li>RI_Tag_Daoist</li>
		</apparelTags>
		<apparelRequired>
			<li>Apparel_Pants</li>
			<li>Apparel_BasicShirt</li>
		</apparelRequired>
		<!--武器-->
		<weaponMoney>500~1000</weaponMoney>
		<weaponTags>
			<li>MedievalMeleeDecent</li>
		</weaponTags>
	</PawnKindDef>

	<!--道门弟子-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_Disciple</defName>
		<label>Dao disciple</label>
		<combatPower>50</combatPower>
		<!--年龄-->
		<minGenerationAge>10</minGenerationAge>
		<maxGenerationAge>25</maxGenerationAge>
		<!--衣服-->
		<apparelColor>(49,44,77)</apparelColor>
		<apparelMoney>20~3000</apparelMoney>
		<apparelTags>
			<li>IndustrialBasic</li>
			<li>IndustrialAdvanced</li>
		</apparelTags>
		<!--<apparelRequired>
			<li>Apparel_Pants</li>
			<li>Apparel_BasicShirt</li>
			<li>RI_Apparel_DaoistCrown</li>
		</apparelRequired>-->
		<!--武器-->
		<weaponMoney>800~3000</weaponMoney>
		<weaponTags>
			<li>SimpleGun</li>
		</weaponTags>
		<!--携带的资源-->
		<inventoryOptions>
			<skipChance>0.85</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>1</min>
						<max>3</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>

	<!--道士-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_Priest</defName>
		<label>Daoist</label>
		<combatPower>70</combatPower>

		<minGenerationAge>20</minGenerationAge>
		<maxGenerationAge>50</maxGenerationAge>

		<!--<apparelColor>(49,44,77)</apparelColor>-->
		<!-- 1. 调高预算上限，防止买不起衣服 -->
		<apparelMoney>20~10000</apparelMoney>

		<apparelTags>
			<li>RI_Tag_Daoist</li>
		</apparelTags>

		<!-- 3. 防止因为环境温度导致不穿衣服 -->
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>

		<apparelRequired>
			<li>RI_Apparel_DaoistCrown</li>
			<li>RI_Apparel_DaoistPants</li>
			<li>RI_Apparel_DaoistShirt</li>
		</apparelRequired>

		<weaponMoney>800~5000</weaponMoney>
		<weaponTags>
			<li>RI_Tags_DaoMeleeWeapon</li>
			<li>RI_Tags_DaoistCharm</li>
		</weaponTags>

		<inventoryOptions>
			<skipChance>0.5</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>RI_Resource_CharmPaper</thingDef>
					<countRange>
						<min>3</min>
						<max>5</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>
	
	<!--云游道士-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_TravelPriest</defName>
		<label>travel Daoist</label>
		<combatPower>60</combatPower>
		<!--年龄-->
		<minGenerationAge>20</minGenerationAge>
		<maxGenerationAge>50</maxGenerationAge>
		<!--衣服-->
		<!--<apparelColor>(49,44,77)</apparelColor>-->
		<apparelMoney>50~8000</apparelMoney>
		<apparelTags>
			<li>IndustrialMilitaryBasic</li>
			<li>IndustrialMilitaryAdvanced</li>
		</apparelTags>
		<apparelRequired>
			<li>Apparel_FlakPants</li>
			<li>Apparel_FlakVest</li>
			<li>RI_Apparel_DaoistShirt</li>
			<li>RI_Apparel_DaoistPrayerBeads</li>
			<li>RI_Apparel_DaoistCrown</li>
		</apparelRequired>
		<!--武器-->
		<weaponMoney>800~7000</weaponMoney>
		<weaponTags>
			<li>IndustrialGunAdvanced</li>
		</weaponTags>
		<!--携带物资-->
		<inventoryOptions>
			<skipChance>0.5</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>RI_Resource_CharmPaper</thingDef>
					<countRange>
						<min>3</min>
						<max>5</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>

	<!--炼师-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_Alchemist</defName>
		<label>Dao alchemist</label>
		<combatPower>40</combatPower>
		<!--年龄-->
		<minGenerationAge>30</minGenerationAge>
		<maxGenerationAge>50</maxGenerationAge>
		<!--衣服-->
		<!--<apparelColor>(49,44,77)</apparelColor>-->
		<apparelMoney>30~6000</apparelMoney>
		<apparelTags>
			<li>RI_Tag_Daoist</li>
		</apparelTags>
		<apparelRequired>
			<li>RI_Apparel_DaoistCrown</li>
			<li>RI_Apparel_DaoistPants</li>
			<li>RI_Apparel_DaoistShirt</li>
		</apparelRequired>
		<!--武器-->
		<weaponMoney>900~4000</weaponMoney>
		<weaponTags>
			<li>RI_Tags_DaoistCharm</li>
		</weaponTags>
		<!--携带的资源-->
		<inventoryOptions>
			<skipChance>0.75</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>3</min>
						<max>7</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>

	<!--祖师-->
	<PawnKindDef ParentName="RI_DaoPawn_Base">
		<defName>RI_DaoPawn_Patriarch</defName>
		<label>Dao patriarch</label>
		<combatPower>40</combatPower>
		<!--年龄-->
		<minGenerationAge>50</minGenerationAge>
		<maxGenerationAge>75</maxGenerationAge>
		<!--衣服-->
		<!--<apparelColor>(49,44,77)</apparelColor>-->
		<apparelMoney>50~12000</apparelMoney>
		<apparelTags>
			<li>RI_Tag_Daoist</li>
		</apparelTags>
		<apparelRequired>
			<li>RI_Apparel_ExorcismCrown</li>
			<li>RI_Apparel_DaoistArmorPants</li>
			<li>RI_Apparel_DaoistShirt</li>
			<li>RI_Apparel_CurseProtectArmor</li>
		</apparelRequired>
		<!--武器-->
		<weaponMoney>900~9000</weaponMoney>
		<weaponTags>
			<li>RI_Tags_DaoBestWeapon</li>
		</weaponTags>
		<!--携带的资源-->
		<inventoryOptions>
			<skipChance>0.5</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>MedicineIndustrial</thingDef>
					<countRange>
						<min>2</min>
						<max>5</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>


</Defs>