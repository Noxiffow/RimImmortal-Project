  <RI_OpportunitySite_BigRock.root.nodes.GenerateSite.singleSitePartRules.slateRef>
    <rulesStrings>
      <li>root->巨石所在之地</li>
    </rulesStrings>
  </RI_OpportunitySite_BigRock.root.nodes.GenerateSite.singleSitePartRules.slateRef>
