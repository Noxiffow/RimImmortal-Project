<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--===========普通散修（没有灵芽的）——前置===========-->
	<PawnKindDef Name="RI_FreemanNoRoot_Base" Abstract="True">
		<race>Human</race>
		<nameMaker>RI_NameRule_NamerPersonChinese</nameMaker>
		<nameMakerFemale>RI_NameRule_NamerPersonChineseFemale</nameMakerFemale>
		<chemicalAddictionChance>0.1</chemicalAddictionChance>
		<apparelIgnoreSeasons>false</apparelIgnoreSeasons>
		<apparelIgnorePollution MayRequire="Ludeon.RimWorld.Biotech">false</apparelIgnorePollution>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<combatEnhancingDrugsChance>0.05</combatEnhancingDrugsChance>
		<combatEnhancingDrugsCount>1~2</combatEnhancingDrugsCount>
		<defaultFactionType>RI_Faction_FreeCultivators</defaultFactionType>
		<backstoryCryptosleepCommonality>1</backstoryCryptosleepCommonality>
		<biocodeWeaponChance>0</biocodeWeaponChance>
		<requiredWorkTags>
			<li>Violent</li>
		</requiredWorkTags>

		<!--背景故事-->
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>Tribal</li>
				</categories>
			</li>
		</backstoryFiltersOverride>

		<!--禁止特性-->
		<disallowedTraits>
			<li>Greedy</li>
			<li>Jealous</li>
			<li>CreepyBreathing</li>
			<li>Pyromaniac</li>
			<li>PsychicSensitivity</li>
		</disallowedTraits>

		<!--假体-->
		<techHediffsChance>0.05</techHediffsChance>
		<techHediffsMoney>100~200</techHediffsMoney>
		<techHediffsTags>
			<li>Poor</li>
		</techHediffsTags>

		<!--俘虏抗性-->
		<initialWillRange>5</initialWillRange>
		<initialResistanceRange>10~15</initialResistanceRange>

	</PawnKindDef>

	<!--===========普通人散修===========-->

	<!--乞丐-->
	<PawnKindDef ParentName="RI_FreemanNoRoot_Base">
