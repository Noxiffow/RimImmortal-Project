<?xml version="1.0" encoding="UTF-8"?>
<Defs>


<!--===控制境界修为，hediff的disappearsAfterTicks最好不一样，以最后消失的为最终修为===-->

    <HediffDef>
		<defName>RI_LV10_PhysicalStrengthen</defName>
		<description>此人是炼体登仙修为</description>
		<label>修为：炼体登仙</label>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.7, 1.0, 0.7)</defaultLabelColor>
		<stages>
			<li>
				<becomeVisible>false</becomeVisible>
				<!--隐藏hediff-->
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>1</disappearsAfterTicks>
				<!--必须，这个功能是hediff消失时触发的-->
			</li>
			<li Class="RI_Transfer.HediffCompProperties_RI_Transfer">
				<IsTransfer>False</IsTransfer>
				<!--判断是不是转职，为true就是保留原来的修为，下面的level将不生效，可以删掉-->
				<level>10</level>
				<!--修改其境界，如果IsTransfer是true，那这个设置就不需要了-->
				<HaveRoute>true</HaveRoute>
				<!--是否添加法门，实现转职的必要设置-->
				<RouteDef>PhysicalStrengthen</RouteDef>
				<!--添加法门的种类，写route的defname-->
			</li>
		</comps>
	</HediffDef>

