	<!--制作丹辅-->
	<RecipeDef ParentName="RI_RecipeBase_Medical">
		<defName>Make_DrugBase</defName>
		<label>Make Drug base</label>
		<description>Extracts from some food ingredients that can become drug base.</description>
		<jobString>Making Drug base</jobString>
		<workAmount>1400</workAmount>
		<ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
		<recipeUsers>
			<li>RI_Building_ElixirsWorkbench</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>FoodRaw</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<products>
			<RI_Resource_DrugBase>5</RI_Resource_DrugBase>
		</products>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
			<specialFiltersToDisallow>
				<li>AllowPlantFood</li>
			</specialFiltersToDisallow>
		</fixedIngredientFilter>
		<defaultIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
		</defaultIngredientFilter>
	</RecipeDef>
	
