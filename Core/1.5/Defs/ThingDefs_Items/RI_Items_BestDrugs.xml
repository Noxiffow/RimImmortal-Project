<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--=================高级丹药前置=================-->
	<ThingDef Name="RI_BestDrug_Base" Abstract="True">
		<recipeMaker>
			<researchPrerequisite>RI_Cauldrons</researchPrerequisite>
		</recipeMaker>
		<thingClass>ThingWithComps</thingClass>
		<category>Item</category>
		<drawerType>MapMeshOnly</drawerType>
		<useHitPoints>true</useHitPoints>
		<healthAffectsPrice>false</healthAffectsPrice>
		<selectable>true</selectable>
		<rotatable>false</rotatable>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>1.0</Flammability>
			<DeteriorationRate>2</DeteriorationRate>
			<Beauty>1</Beauty>
		</statBases>
		<altitudeLayer>Item</altitudeLayer>
		<stackLimit>10</stackLimit>
		<thingCategories>
			<li>RI_Category_Drugs</li>
		</thingCategories>
		<alwaysHaulable>true</alwaysHaulable>
		<comps>
			<li Class="CompProperties_Forbiddable" />
		</comps>
		<pathCost>14</pathCost>
		<burnableByRecipe>true</burnableByRecipe>
		<resourceReadoutPriority>Last</resourceReadoutPriority>
		<drawGUIOverlay>true</drawGUIOverlay>
		<allowedArchonexusCount>-1</allowedArchonexusCount>
		<ingestible>
			<preferability>NeverForNutrition</preferability>
			<maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
			<defaultNumToIngestAtOnce>1</defaultNumToIngestAtOnce>
			<chairSearchRadius>8</chairSearchRadius>
		</ingestible>
		<storedConceptLearnOpportunity>DrugPolicies</storedConceptLearnOpportunity>
		<orderedTakeGroup>Drug</orderedTakeGroup>
	</ThingDef>

	<!-- ==========================【一品】理髓丹========================== -->
	<ThingDef ParentName="RI_BestDrug_Base">
		<defName>RI_Drug_MedullaOblongataElixir</defName>
		<label>【First-rate】Medulla oblongata elixir</label>
		<description>First-rate elixir, can quickly heal wound and repair a permanent scar at the same time. Medulla oblongata elixir is a very tempting treasure in any society, because of its powerful drug effect, attracting countless people to fight for it. And many pharmacists are also in order to refine this elixirs to embark on the road of cultivation. Although healing wounds does not solve all problems, it does save the lives of many seriously injured patients.</description>
		<graphicData>
			<texPath>Things/Item/Drugs/Elixir/RI_Drug_MedullaOblongataElixir</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Nutrition>0</Nutrition>
			<WorkToMake>1500</WorkToMake>
			<MarketValue>650</MarketValue>
			<Mass>0.1</Mass>
		</statBases>
		<ingestible>
			<foodType>Processed, Fluid</foodType>
			<baseIngestTicks>80</baseIngestTicks>
			<ingestSound>Ingest_Inject</ingestSound>
			<preferability>NeverForNutrition</preferability>
			<ingestCommandString>Eat {0}</ingestCommandString>
			<ingestReportString>Eating {0}</ingestReportString>
			<useEatingSpeedStat>false</useEatingSpeedStat>
			<chairSearchRadius>0</chairSearchRadius>
			<drugCategory>Medical</drugCategory>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>RI_RepairAwayHediff</hediffDef>
					<severity>1.00</severity>
					<doToGeneratedPawnIfAddicted>true</doToGeneratedPawnIfAddicted>
				</li>
			</outcomeDoers>
		</ingestible>
		<costList>
			<WoodLog>1</WoodLog>
		</costList>
		<comps>
			<li Class="CompProperties_Drug">
				<listOrder>210</listOrder>
				<teetotalerCanConsume>true</teetotalerCanConsume>
			</li>
		</comps>
		<recipeMaker>
			<soundWorking>Recipe_Drug</soundWorking>
		</recipeMaker>
	</ThingDef>

