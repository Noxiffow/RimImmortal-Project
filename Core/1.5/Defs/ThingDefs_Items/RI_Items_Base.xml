<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--药材基础，以后mod新加的材料用这个前置-->
	<ThingDef Abstract="True" Name="RI_Base_MedicalResource" ParentName="ResourceBase">
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<possessionCount>1</possessionCount>
		<stackLimit>75</stackLimit>
		<statBases>
			<Nutrition>0.1</Nutrition>
			<FoodPoisonChanceFixedHuman>0.5</FoodPoisonChanceFixedHuman>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<DeteriorationRate>10</DeteriorationRate>
			<Mass>0.05</Mass>
		</statBases>
		<thingCategories>
			<li>RI_Category_DrugsMaterials</li>
		</thingCategories>
		<ingestible>
			<preferability>DesperateOnly</preferability>
			<tasteThought>RI_Thought_AteHerb</tasteThought>
			<ingestEffect>EatVegetarian</ingestEffect>
			<ingestSound>RawVegetable_Eat</ingestSound>
			<foodType>Plant</foodType>
		</ingestible>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>30</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<soundInteract>Grain_Drop</soundInteract>
		<soundDrop>Grain_Drop</soundDrop>
		<!--落地音效得改-->
		<tickerType>Rare</tickerType>
		<healthAffectsPrice>false</healthAffectsPrice>
		<socialPropernessMatters>true</socialPropernessMatters>
		<allowedArchonexusCount>50</allowedArchonexusCount>
		<tradeability>Sellable</tradeability>
	</ThingDef>

	<StatDef>
		<defName>RI_MassCarryCapacity</defName>
		<label>额外负重</label>
		<description>额外负重</description>
		<category>BasicsPawn</category>
		<defaultBaseValue>0</defaultBaseValue>
		<!--Pawn开始的时候默认的额外负重值-->
		<minValue>0</minValue>
		<!--下限-->
		<toStringStyle>FloatTwoOrThree</toStringStyle>
		<formatString>{0} kg</formatString>
		<formatStringUnfinalized>{0} kg</formatStringUnfinalized>
		<parts>
			<li Class="StatPart_Quality">
				<!--在statBase时生效，比如衣服里statBase加上这个，其品质影响stat的值-->
				<factorAwful>0.5</factorAwful>
				<factorPoor>0.8</factorPoor>
				<factorNormal>1</factorNormal>
				<factorGood>1.2</factorGood>
				<factorExcellent>1.5</factorExcellent>
				<factorMasterwork>1.7</factorMasterwork>
				<factorLegendary>2</factorLegendary>
			</li>
		</parts>
	</StatDef>

	<!--携带的分类-->
	<!--仪式必备品-->
	<OrderedTakeGroupDef>
		<defName>RitualRequireThing</defName>
		<label>Ritual required</label>
	</OrderedTakeGroupDef>


</Defs>