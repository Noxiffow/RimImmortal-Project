<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--炼丹炉-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_LittleCauldrons</defName>
		<label>Cauldron</label>
		<description>A small, portable cauldron. This cauldron can be used to refine lower products of herbal medicine.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/Cauldrons/RI_Building_LittleCauldrons</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(1.3,1.3)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>false</castEdgeShadows>
		<staticSunShadowHeight>0.10</staticSunShadowHeight>

		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>45</costStuffCount>

		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<MarketValue>1200</MarketValue>
			<WorkToBuild>200</WorkToBuild>
			<MaxHitPoints>280</MaxHitPoints>
			<Flammability>0.5</Flammability>
		</statBases>
		<size>(1,1)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2110</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<comps>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>160.0</fuelConsumptionRate>
				<fuelCapacity>50.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</fuelFilter>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>3</heatPerSecond>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>2.5</glowRadius>
				<glowColor>(224,180,4,0)</glowColor>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>RI_Building_MedicinalMaterialShelf</li>
				</linkableFacilities>
			</li>
		</comps>
		<building>
			<paintable>true</paintable>
			<isMealSource>true</isMealSource>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<heatPerTickWhileWorking>0.10</heatPerTickWhileWorking>
		</building>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_BasicElixirs</li>
		</researchPrerequisites>
	</ThingDef>

	<!--太乙炼丹炉-->
