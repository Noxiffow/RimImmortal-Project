<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef Name="RI_PlanterBox" Abstract="True" ParentName="BuildingBase">
		<thingClass>Building_PlantGrower</thingClass>
		<graphicData>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<altitudeLayer>LowPlant</altitudeLayer>
		<defaultPlacingRot>East</defaultPlacingRot>
		<passability>PassThroughOnly</passability>
		<pathCost>30</pathCost>
		<fillPercent>0.30</fillPercent>
		<canOverlapZones>false</canOverlapZones>
		<constructionSkillPrerequisite>3</constructionSkillPrerequisite>
		<statBases>
			<Flammability>0.5</Flammability>
			<Cleanliness>-3</Cleanliness>
		</statBases>
		<fertility>1.5</fertility>
		<building>
			<defaultPlantToGrow>Plant_Rice</defaultPlantToGrow>
			<sowTag>Hydroponic</sowTag>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
		</building>
		<tickerType>Rare</tickerType>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
		</comps>
		<researchPrerequisites>
			<li>RI_FertileSoil</li>
		</researchPrerequisites>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
	</ThingDef>

	<ThingDef ParentName="RI_PlanterBox">
		<defName>RI_Building_PlanterBoxA</defName>
		<label>Planter box (1x3)</label>
		<description>A 1x3 size planting box that can grow medicinal herbs.</description>
		<graphicData>
			<texPath>Things/Building/HerbPlanterBox/RI_Building_HerbPlanterBoxA</texPath>
			<drawSize>(1.15,3.15)</drawSize>
		</graphicData>
		<size>(1,3)</size>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>400</WorkToBuild>
			<Mass>6</Mass>
		</statBases>

		<stuffCategories>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>60</costStuffCount>
	</ThingDef>

	<ThingDef ParentName="RI_PlanterBox">
		<defName>RI_Building_PlanterBoxB</defName>
		<label>Planter box (2x3)</label>
		<description>A 2x3 size planting box that can grow medicinal herbs.</description>
		<graphicData>
			<texPath>Things/Building/HerbPlanterBox/RI_Building_HerbPlanterBoxB</texPath>
			<drawSize>(2.1,3.2)</drawSize>
		</graphicData>
		<size>(2,3)</size>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<WorkToBuild>600</WorkToBuild>
			<Mass>12</Mass>
		</statBases>

		<stuffCategories>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>120</costStuffCount>
	</ThingDef>

	<ThingDef ParentName="RI_PlanterBox">
		<defName>RI_Building_PlanterBox</defName>
		<label>Planter box (1x1)</label>
		<description>A 1x1 size planting box that can grow medicinal herbs.</description>
		<graphicData>
			<texPath>Things/Building/HerbPlanterBox/RI_Building_HerbPlanterBoxC</texPath>
			<drawSize>(1.15,1.15)</drawSize>
		</graphicData>
		<size>(1,1)</size>
		<statBases>
			<MaxHitPoints>120</MaxHitPoints>
			<WorkToBuild>200</WorkToBuild>
			<Mass>2</Mass>
		</statBases>

		<stuffCategories>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>20</costStuffCount>
	</ThingDef>

</Defs>