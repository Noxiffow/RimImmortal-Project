<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingDef ParentName="BuildingBase">
		<defName>RI_SpiritualRock</defName>
		<label>Spiritual rock</label>
		<description>A large rock embedded with Spiritual crystal allows Qi to slowly permeate the surrounding air, which is refreshing and can slightly increase the speed of cultivation.\n\nMood and Qi growth rates cannot be superimposed by placing multiple Spiritual rocks.</description>
		<graphicData>
			<texPath>Things/Building/SpiritualRock</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>(1.8, 1.8)</drawSize>
			<shadowData>
				<volume>(0.3, 0.6, 0.3)</volume>
				<offset>(0.0, 0.0, -0.1)</offset>
			</shadowData>
			<damageData>
				<rect>(0,0.75,1.0,0.5)</rect>
			</damageData>
		</graphicData>
		<uiIconScale>0.85</uiIconScale>
		<thingCategories>
			<li>BuildingsSpecial</li>
		</thingCategories>
		
		<costStuffCount>150</costStuffCount>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costList>
			<RI_Resource_LiquidJade>3</RI_Resource_LiquidJade>
			<RI_Resource_SpiritualCrystal>10</RI_Resource_SpiritualCrystal>
		</costList>
		
		<comps>
			<li Class="CompProperties_MoteEmitter">
				<mote>Mote_PsychicEmanatorEffect</mote>
				<emissionInterval>350</emissionInterval>
			</li>
		</comps>
		<altitudeLayer>Building</altitudeLayer>
		<building>
			<destroySound>BuildingDestroyed_Metal_Medium</destroySound>
		</building>
		<statBases>
			<MarketValue>2400</MarketValue>
			<MaxHitPoints>1000</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>15</Beauty>
			<Mass>50</Mass>
			<WorkToBuild>2000</WorkToBuild>
		</statBases>
		<thingSetMakerTags>
			<li>RewardStandardCore</li>
		</thingSetMakerTags>
		<fillPercent>0.2</fillPercent>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<pathCost>30</pathCost>
		<passability>PassThroughOnly</passability>
		<rotatable>false</rotatable>
		<canOverlapZones>false</canOverlapZones>
		<minifiedDef>MinifiedThing</minifiedDef>
		<specialDisplayRadius>14.9</specialDisplayRadius>
		<tradeability>Sellable</tradeability>
		<tickerType>Normal</tickerType>
