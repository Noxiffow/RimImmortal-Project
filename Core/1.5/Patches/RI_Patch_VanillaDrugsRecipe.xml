			<li>RI_Building_ElixirsWorkbench</li>
		</value>
	</Operation>

	<!--薄片-->
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="Flake"]/recipeMaker/recipeUsers</xpath>
