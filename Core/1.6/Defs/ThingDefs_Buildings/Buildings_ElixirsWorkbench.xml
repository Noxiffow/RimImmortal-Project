<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--制药工作台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_ElixirsWorkbench</defName>
		<label>Elixirs workbench</label>
		<description>A table for preparing some medicinal materials and herb powders.\n\nAfter researching brewing and psy-leaf products, corresponding items can be crafted at the Elixirs workbench.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/ElixirsWorkbench/RI_Building_ElixirsWorkbench</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(3.33,1.2)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<costStuffCount>50</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
		</stuffCategories>
		<costList>
			<Steel>20</Steel>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>3000</WorkToBuild>
			<MaxHitPoints>150</MaxHitPoints>
			<Flammability>1.0</Flammability>
		</statBases>
		<!--炼药工作台替代原版部分工作台-->
		<recipes>
			<li>Make_Wort</li>
		</recipes>
		<size>(3,1)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<paintable>true</paintable>
			<!--需要的房间类型-->
			<workTableRoomRole>RI_Room_ElixirsRoom</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
		<comps>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>RI_Building_MedicinalMaterialShelf</li>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_BasicElixirs</li>
		</researchPrerequisites>
	</ThingDef>

	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_MedicinalMaterialShelf</defName>
		<label>Medicinal material cabinet</label>
		<description>A special cabinet for storing herbs, with many small drawers on it. It can improve work efficiency by placing it near the elixirs workbench.</description>
		<graphicData>
			<texPath>Things/Building/MedicinalMaterialShelf/RI_Building_MedicinalMaterialShelf</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,3)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.35</staticSunShadowHeight>
		<fillPercent>0.5</fillPercent>
		<canOverlapZones>false</canOverlapZones>
		<pathCost>42</pathCost>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToBuild>1800</WorkToBuild>
			<Mass>20</Mass>
			<Flammability>0.5</Flammability>
		</statBases>
		<size>(2,1)</size>
		<costStuffCount>50</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
		</stuffCategories>
		<building>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
		</building>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
			<li>RI_BasicElixirs</li>
		</researchPrerequisites>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<minifiedDef>MinifiedThing</minifiedDef>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<comps>
			<li Class="CompProperties_Facility">
				<statOffsets>
					<WorkTableWorkSpeedFactor>0.05</WorkTableWorkSpeedFactor>
				</statOffsets>
				<maxSimultaneous>4</maxSimultaneous>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
		</placeWorkers>
	</ThingDef>

</Defs>