<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--经书研究台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_StudyDesk</defName>
		<label>Reading research desk</label>
		<description>A desk dedicated to study initial approach book, can also be used as an ordinary research desk.</description>
		<descriptionHyperlinks>
			<!--核心三本书-->
			<ThingDef>RI_BookB</ThingDef>
			<ThingDef>RI_BookC</ThingDef>
			<ThingDef>RI_BookA</ThingDef>
			<!--炼器-->
			<ThingDef MayRequire="RI.RimImmortal.Forge">RI_BookD</ThingDef>
			<!--五行-->
			<ThingDef MayRequire="RI.RimImmortal.FiveElements">RI_Book_FireElement</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Building/Production/ResearchBench/RI_Building_StudyDesk</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(5.05,3.4)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<thingClass>Building_ResearchBench</thingClass>
		<size>(3,2)</size>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>75</costStuffCount>
		<costList>
			<Steel>25</Steel>
		</costList>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>2500</WorkToBuild>
			<Flammability>1.0</Flammability>
			<ResearchSpeedFactor>0.8</ResearchSpeedFactor>
		</statBases>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
			<li>PlaceWorker_DrawLinesToBookcasesInRoom</li>
		</placeWorkers>
		<fillPercent>0.5</fillPercent>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2600</uiOrder>
		<surfaceType>Item</surfaceType>
		<building>
			<paintable>true</paintable>
			<workTableRoomRole>Laboratory</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
		<comps Inherit="False">
			<li Class="CompProperties_ReportWorkSpeed">
				<workSpeedStat>ResearchSpeedFactor</workSpeedStat>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li MayRequire="RI.RimImmortal.Furniture">RI_Building_TallShelf</li>
				</linkableFacilities>
			</li>
		</comps>
	</ThingDef>

	<!--高科技研究台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_HiTechResearchDesk</defName>
		<label>Hi-tech research desk</label>
		<description>After mastering electric power and early computer technology, the cultivators also use the computer as an analytical tool to study more effects of Qi, and can perform some preliminary testing work on the documents and various raw materials.\n\nHi-tech research desk can also use to study initial approach book and skill book.</description>
		<descriptionHyperlinks>
			<!--核心三本书-->
			<ThingDef>RI_BookB</ThingDef>
			<ThingDef>RI_BookC</ThingDef>
			<ThingDef>RI_BookA</ThingDef>
			<!--炼器-->
			<ThingDef MayRequire="RI.RimImmortal.Forge">RI_BookD</ThingDef>
			<!--五行-->
			<ThingDef MayRequire="RI.RimImmortal.FiveElements">RI_Book_FireElement</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_HiTechResearchDesk</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(7.5,3.2)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<thingClass>Building_ResearchBench</thingClass>
		<size>(5,2)</size>
		<minifiedDef />
		<thingCategories Inherit="false" />
		<costList>
			<Steel>150</Steel>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
			<ComponentIndustrial>10</ComponentIndustrial>
		</costList>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>5000</WorkToBuild>
			<Flammability>0.5</Flammability>
			<ResearchSpeedFactor>1.0</ResearchSpeedFactor>
		</statBases>
		<comps Inherit="False">
			<li Class="CompProperties_ReportWorkSpeed">
				<workSpeedStat>ResearchSpeedFactor</workSpeedStat>
			</li>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>250</basePowerConsumption>
				<shortCircuitInRain>true</shortCircuitInRain>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li MayRequire="RI.RimImmortal.Forge">RI_Building_SpiritAnalyzer</li>
				</linkableFacilities>
			</li>
		</comps>
		<fillPercent>0.5</fillPercent>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2610</uiOrder>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
			<li>PlaceWorker_DrawLinesToBookcasesInRoom</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_SpiritMechineTech</li>
		</researchPrerequisites>
		<building>
			<paintable>true</paintable>
			<workTableRoomRole>Laboratory</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
	</ThingDef>

</Defs>