	<!-- 乌麻针 -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_AnestheticNeedle</defName>
		<label>Anesthetic needle</label>
		<description>&lt;color=#28BD75&gt;This technique is learned by the Core-formation rank of the Medicine Path\n\n&lt;/color&gt;Qi cost: 60\n\nShoot an anesthetic needle.\n\nThe Dark Anesthetic Needle is a technique requiring cultivators of the Medical Path to prepare a unique anesthetic medicine, nurturing it with Qi until they can skillfully launch it as a flying needle.\n\nIt embodies the dual nature of medicine — capable of saving lives, yet equally capable of taking them.</description>
		<iconPath>UI/Abilities/ElixirsStrengthen/RI_Ability_AnestheticNeedle</iconPath>
		<cooldownTicksRange>10000</cooldownTicksRange>
		<!--冷却-->
		<aiCanUse>true</aiCanUse>
		<!--不征兆就不显示-->
		<displayGizmoWhileUndrafted>False</displayGizmoWhileUndrafted>
		<hostile>true</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>0.2</warmupTime>
			<range>20</range>
			<targetParams>
				<canTargetSelf>False</canTargetSelf>
				<canTargetPawns>True</canTargetPawns>
				<canTargetAnimals>True</canTargetAnimals>
				<canTargetMechs>False</canTargetMechs>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityLaunchProjectile">
				<projectileDef>RI_Porj_AnestheticNeedle</projectileDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-60</rEnergy>
			</li>
		</comps>
	</AbilityDef>

