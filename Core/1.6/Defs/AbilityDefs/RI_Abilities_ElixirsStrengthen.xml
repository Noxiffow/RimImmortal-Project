	<!--结丹境界——推拿术-->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_Massage</defName>
		<label>Massage hand</label>
		<description>&lt;color=#28BD75&gt;This technique is learned by the Foundation rank of the Medicine Path\n\n&lt;/color&gt;Qi cost: 50\n\nThis technique originates from ancient massage arts. By stimulating acupoints and channeling healing Qi into them, it accelerates wound recovery and enhances physical functions.\n\nIt is said that doctors of higher rank can massage meridians and muscles from a distance using Qi alone. However, most choose not to do so, perhaps out of concern that it may weaken the effectiveness of the treatment.</description>
		<iconPath>UI/Abilities/ElixirsStrengthen/RI_Ability_Massage</iconPath>
		<cooldownTicksRange>10000</cooldownTicksRange>
		<!--冷却时间-->
		<jobDef>CastAbilityOnThingMelee</jobDef>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_EntropyGain>0</Ability_EntropyGain>
			<Ability_PsyfocusCost>0</Ability_PsyfocusCost>
			<Ability_Duration>500</Ability_Duration>
		</statBases>
		<verbProperties>
			<violent>false</violent>
			<warmupTime>0.5</warmupTime>
			<range>50</range>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
				<canTargetAnimals>True</canTargetAnimals>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>RI_ManipulationHediff</hediffDef>
				<psychic>True</psychic>
				<replaceExisting>True</replaceExisting>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCasting">
				<moteCastDef>RI_Ability_Massage_Mote</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteSinging">
