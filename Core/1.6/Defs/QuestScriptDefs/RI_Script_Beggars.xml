<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--过路人任务-->
	<QuestScriptDef>
		<defName>RI_Beggars</defName>
		<isRootSpecial>true</isRootSpecial>
		<autoAccept>true</autoAccept>
		<defaultCharity>false</defaultCharity>
		<affectedByPopulation>true</affectedByPopulation>
		<hideInvolvedFactionsInfo>true</hideInvolvedFactionsInfo>
		<questNameRules>
			<rulesStrings>
				<li>questName->Eager passers</li>
				<li>questName->Hurried passers</li>
				<li>questName->A group of passers</li>
				<li>questName->A few passers</li>
				<li>questName->Weary passers</li>
			</rulesStrings>
		</questNameRules>
		<questDescriptionRules>
			<rulesStrings>
				<li>groupLabelSingle->passer</li>
				<li>groupLabelPlural->passers</li>
				<li>groupLabelPlural(allChildren==true,priority=1)->children</li>
				<li>groupLabelSingle(childCount>=1,priority=1)->child</li>
				<li>travelerInfo(beggarCount==1)->This [groupLabelSingle] is</li>
				<li>travelerInfo(beggarCount>=2)->These [groupLabelPlural] are</li>
				<li>beggingForInfo->for x[requestedThingCount] [requestedThing_label]</li>
				<li>traverObjective(beggarCount==1)->[beggars0_objective]</li>
				<li>traverObjective(beggarCount>=2)->them</li>
				<li>questDescription->A group of people, temporarily gathered from various backgrounds, passed by. The leader of the group stepped forward slowly and spoke respectfully:\n\n"Esteemed fellow, we are but passers-by, seeking the Heavenly Immortal’s edict, but the path ahead seems uncertain, and we are in urgent need of travel funds. We have some soft jade, which is beneficial to cultivation. Might we exchange it for some silver?"\n\nHis tone was earnest, and his eyes gleamed with intensity.\n\nSeveral passers requested 700 silver in exchange for a small amount of soft jade. This was not a small sum, but the soft jade was indeed a rare material.</li>
				<li>questDescription->A group of passers paused as they passed through the area, and the leader stepped forward, cupping his hands in a respectful greeting:\n\n"Esteemed fellow, we are on our way to a cultivator’s gathering, intending to purchase several Foundation Establishment Pills for the younger generation of our family, to aid in their cultivation on the road ahead. However, our funds are lacking, and it is difficult to proceed."\nHe took out a few pieces of soft jade and continued:\n\n"These pieces of soft jade are few in number, but they are rare materials. May I ask, would you be willing to exchange them for silver?"\n\nSeveral passers were asking for 700 silver in exchange for a small amount of soft jade. This was not a small sum, but the soft jade was indeed a rare and valuable material.</li>
			</rulesStrings>
		</questDescriptionRules>
		<questContentRules>
			<rulesStrings>
				<li>letterLabelBeggarsBetrayed->Passer quest</li>
				<li>letterTextBeggarsBetrayed->Passer quest content</li>
			</rulesStrings>
		</questContentRules>
		<root Class="WhoXiuXian.QuestNode_RI_Beggars" />
	</QuestScriptDef>

	<!--荒冢任务-->
	<QuestScriptDef>
		<defName>RI_AbandonedGrave_Standard</defName>
		<rootSelectionWeight>0</rootSelectionWeight>
		<defaultChallengeRating>1</defaultChallengeRating>
		<isRootSpecial>true</isRootSpecial>
		<questNameRules>
			<rulesStrings>
				<li>questName->Hidden abandoned grave</li>
				<li>questName->Dilapidated abandoned grave</li>
				<li>questName->Deserted abandoned grave</li>
			</rulesStrings>
		</questNameRules>
		<questDescriptionRules>
			<rulesStrings>
				<li>questDescription->You receive news that a strange wave of Qi energy has erupted from an abandoned grave not far from here.\n\nThe corpses inside the abandoned grave must carry valuable treasures, which are sure to aid in our development.</li>
				<li>questDescription->A wave of Qi energy erupts from an uninhabited abandoned grave not far from here, as if guiding you toward it.\n\nThe corpses inside the abandoned grave must carry valuable treasures, which are sure to aid in our development.</li>
			</rulesStrings>
		</questDescriptionRules>
		<root Class="QuestNode_Sequence">
			<nodes>
				<li Class="QuestNode_SubScript">
					<def>Util_RandomizePointsChallengeRating</def>
					<parms>
						<pointsFactorTwoStar>1.5</pointsFactorTwoStar>
						<pointsFactorThreeStar>2</pointsFactorThreeStar>
					</parms>
				</li>
				<li Class="QuestNode_SubScript">
					<def>Util_GetDefaultRewardValueFromPoints</def>
				</li>
				<li Class="QuestNode_SubScript">
					<def>Util_AdjustPointsForDistantFight</def>
				</li>
				<li Class="QuestNode_GetMap" />
				<li Class="QuestNode_IsSet">
					<name>asker</name>
					<elseNode Class="QuestNode_RandomNode">
						<nodes>
							<li Class="QuestNode_Set">
								<name>askerIsNull</name>
								<value>true</value>
								<selectionWeight>0.4</selectionWeight>
							</li>
						</nodes>
					</elseNode>
				</li>
				<li Class="QuestNode_GetSiteTile">
					<storeAs>siteTile</storeAs>
					<preferCloserTiles>true</preferCloserTiles>
				</li>
				<!-- <li Class="QuestNode_ViolentQuestsAllowed">
          <node Class="QuestNode_Set">
            <name>siteThreatChance</name>
            <value>0.85</value>
          </node>
          <elseNode Class="QuestNode_Set">
            <name>siteThreatChance</name>
            <value>0</value>
          </elseNode>
        </li> -->
				<li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
					<storeAs>sitePartDefs</storeAs>
					<storeFactionAs>siteFaction</storeFactionAs>
					<sitePartsTags>
						<li>
							<tag>RI_AbandonedGraveSitePart</tag>
						</li>
					</sitePartsTags>
				</li>
				<li Class="QuestNode_GetDefaultSitePartsParams">
					<tile>$siteTile</tile>
					<faction>$siteFaction</faction>
					<sitePartDefs>$sitePartDefs</sitePartDefs>
					<storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
				</li>
				<li Class="QuestNode_SubScript">
					<def>Util_GenerateSite</def>
					<parms>
						<hiddenSitePartsPossible>true</hiddenSitePartsPossible>
					</parms>
				</li>
				<li Class="QuestNode_SpawnWorldObjects">
					<worldObjects>$site</worldObjects>
				</li>
				<li Class="QuestNode_WorldObjectTimeout">
					<worldObject>$site</worldObject>
					<isQuestTimeout>true</isQuestTimeout>
					<delayTicks>$(randInt(12,28)*60000)</delayTicks>
					<inSignalDisable>site.MapGenerated</inSignalDisable>
					<node Class="QuestNode_Sequence">
						<nodes>
							<li Class="QuestNode_Letter">
								<label TKey="LetterLabelQuestExpired">Quest expired: [resolvedQuestName]</label>
								<text TKey="LetterTextQuestExpired">Someone has already gotten there before us and taken the treasures from the abandoned grave.</text>
							</li>
							<li Class="QuestNode_End">
								<outcome>Fail</outcome>
							</li>
						</nodes>
					</node>
				</li>
				<li Class="QuestNode_NoWorldObject">
					<worldObject>$site</worldObject>
					<node Class="QuestNode_End"></node>
				</li>
			</nodes>
		</root>
	</QuestScriptDef>

	<!--被追捕的修炼者-->
	<QuestScriptDef>
		<defName>RI_BeHuntedWandererJoinsQuest</defName>
		<autoAccept>true</autoAccept>
		<defaultHidden>true</defaultHidden>
		<isRootSpecial>true</isRootSpecial>
		<successHistoryEvent MayRequire="Ludeon.RimWorld.Ideology">CharityFulfilled_WandererJoins</successHistoryEvent>
		<failedOrExpiredHistoryEvent MayRequire="Ludeon.RimWorld.Ideology">CharityRefused_WandererJoins</failedOrExpiredHistoryEvent>
		<questNameRules>
			<rulesStrings>
				<li>questName->The pursued cultivator</li>
			</rulesStrings>
		</questNameRules>
		<questDescriptionRules>
			<rulesStrings>
				<li>questDescription->A pursued cultivator begs for your protection, but a group of chasing cultivators is close behind, and they will kill anyone who stands in their way!</li>
			</rulesStrings>
		</questDescriptionRules>
		<root Class="WhoXiuXian.QuestNode_RI_Root_WandererJoin_WalkIn">
		</root>
	</QuestScriptDef>


	<!--=====================萌螈联动内容=====================-->

	<!--萌螈药商路过-->
	<QuestScriptDef MayRequire="HenTaiLoliTeam.Axolotl">
		<defName>RI_AxoMedicineShopper</defName>
		<rootSelectionWeight>3</rootSelectionWeight>
		<defaultChallengeRating>1</defaultChallengeRating>
		<autoAccept>true</autoAccept>
		<defaultCharity>false</defaultCharity>
		<affectedByPopulation>true</affectedByPopulation>
		<hideInvolvedFactionsInfo>true</hideInvolvedFactionsInfo>
		<questNameRules>
			<rulesStrings>
				<li>questName->Moe Lotl alchemist passing</li>
			</rulesStrings>
		</questNameRules>
		<questDescriptionRules>
			<rulesStrings>
				<li>groupLabelSingle->alchemist</li>
				<li>groupLabelPlural->alchemists</li>
				<li>groupLabelPlural(allChildren==true,priority=1)->children</li>
				<li>groupLabelSingle(childCount>=1,priority=1)->child</li>
				<li>travelerInfo(beggarCount==1)->This [groupLabelSingle] is</li>
				<li>travelerInfo(beggarCount>=2)->These [groupLabelPlural] are</li>
				<li>beggingForInfo->for x[requestedThingCount] [requestedThing_label]</li>
				<li>traverObjective(beggarCount==1)->[beggars0_objective]</li>
				<li>traverObjective(beggarCount>=2)->them</li>
				<li>questDescription->A small, slender, and adorable Moe Lotl alchemist passed by. She took off her hood and said:\n\n"I happen to have a batch of freshly concocted pills that I can sell to you at a low price."\n\nHer body was slick and emanated a sweet fragrance.</li>
			</rulesStrings>
		</questDescriptionRules>
		<questContentRules>
			<rulesStrings>
				<li>letterLabelBeggarsBetrayed->Moe Lotl alchemist quest</li>
				<li>letterTextBeggarsBetrayed->Moe Lotl alchemist quest content</li>
			</rulesStrings>
		</questContentRules>
		<root Class="WhoXiuXian.QuestNode_RI_AxoMedicineShopper" />
	</QuestScriptDef>

	
	<!--萌螈王朝袭击-->
	<IncidentDef MayRequire="HenTaiLoliTeam.Axolotl">
		<defName>RI_RaidLotProtectors</defName>
		<label>Moe Lotl raid</label>
		<category>ThreatBig</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>WhoXiuXian.Incidents.RI_IncidentWorker_RaidLotProtectors</workerClass>
		<letterDef>ThreatBig</letterDef>
		<baseChance>0</baseChance>
		<minRefireDays>10</minRefireDays>
		<pointsScaleable>true</pointsScaleable>
		<minThreatPoints>0</minThreatPoints>
		<letterLabel>Moe Lotl raid</letterLabel>
		<letterText>The Dynasty of the Moe Lotl heard about the existence of cultivators, so they sent a troop to investigate and test the waters.</letterText>
		<tale>Raid</tale>
	</IncidentDef>

</Defs>