			<li>
				<grains>
					<li Class="AudioGrain_Clip">
						<clipPath>Ingest/RI_Sound_EatPill</clipPath>
					</li>
				</grains>
				<volumeRange>35~40</volumeRange>
				<pitchRange>0.8~1.2</pitchRange>
				<distRange>0~51.86047</distRange>
				<sustainLoop>False</sustainLoop>
			</li>
		</subSounds>
	</SoundDef>

