<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--药材放地上的音效-->
	<SoundDef>
		<defName>RI_Sound_DropHerb</defName>
		<context>MapOnly</context>
		<maxSimultaneous>1</maxSimultaneous>
		<subSounds>
			<li>
				<grains>
					<li Class="AudioGrain_Clip">
						<clipPath>Drop/RI_Sound_DropHerb</clipPath>
					</li>
				</grains>
				<volumeRange>25~25</volumeRange>
				<pitchRange>0.9311765~1.091765</pitchRange>
			</li>
		</subSounds>
	</SoundDef>

	<!--吃药音效-->
