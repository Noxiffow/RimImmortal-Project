<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--持宝人开局-->
	<ScenarioDef ParentName="ScenarioBase">
		<defName>CultivationOfImmortals</defName>
		<label>Treasure-holder</label>
		<description>While traveling among the stars, you stumbled upon a mysterious ancient scroll and a Spiritual Roots, which you thought you could trade for a good price, but what you didn't expect was to be hunted down and killed by people from all walks of life, so much so that you had to run away to this edge-of-the-planet. Even so, the enemy still clung on and surrounded you. You drink the wine in the pot in order to strengthen your courage, and after a sound night of fighting, you are brought to this strange land by the horse in a coma ......\n\nNote: This script is designed for the introductory players of the Edge Immortal Path, so that you can experience the process of cultivation from the ground up.</description>
		<scenario>
			<summary>A wandering man who escaped pursuit carries a treasure that can open the path to cultivation.</summary>
			<playerFaction>
				<factionDef>PlayerColony</factionDef>
			</playerFaction>
			<parts>
				<!-- Game start dialog -->
				<li Class="ScenPart_GameStartDialog">
					<def>GameStartDialog</def>
					<text>You awaken to the sound of hooves and bumps, your hangover and bruises giving you a splitting headache, and you reflexively feel for your bag, reassured by the Spiritual Roots and an ancient volume lying quietly inside. \n\nThis is the edge of the land, maybe the people who are after you will give up on this, but you'll soon be faced with an even bigger dilemma, that of survival. \n\nThe good thing is, you still have a horse to keep you company.</text>
				</li>

				<!-- Config pages -->
				<!--<li Class="ScenPart_ConfigPage_ConfigureStartingPawns_KindDefs">
					<def>ConfigurePawnsKindDefs</def>
					<pawnChoiceCount>8</pawnChoiceCount>
					<leftBehindPawnKind>RI_Pawn_Seeker</leftBehindPawnKind>
					<kindCounts>
						<li>
							<kindDef>RI_Pawn_Seeker</kindDef>
							<count>1</count>
							<requiredAtStart>true</requiredAtStart>
						</li>
					</kindCounts>
				</li>-->

				<!-- Config pages -->
				<li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
					<def>ConfigPage_ConfigureStartingPawns</def>
					<pawnCount>1</pawnCount>
					<pawnChoiceCount>8</pawnChoiceCount>
				</li>

				<!-- Player starting stuff spawn method-->
				<li Class="ScenPart_PlayerPawnsArriveMethod">
					<def>PlayerPawnsArriveMethod</def>
					<method>Standing</method>
				</li>
				<!-- Player starting things -->
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>MealSurvivalPack</thingDef>
					<count>25</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>MedicineIndustrial</thingDef>
					<count>15</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>RI_BookB</thingDef>
					<count>1</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Beer</thingDef>
					<count>3</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Gun_HeavySMG</thingDef>
					<count>1</count>
				</li>
				<!--上品灵芽-->
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>EnergyRootHigh</thingDef>
					<count>1</count>
				</li>
				<!--筑基丹-->
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>RI_Drug_FoundationBuildingElixir</thingDef>
					<count>1</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>ComponentIndustrial</thingDef>
					<count>30</count>
				</li>
				<li Class="ScenPart_StartingAnimal">
					<def>StartingAnimal</def>
					<animalKind>Horse</animalKind>
					<count>1</count>
					<bondToRandomPlayerPawnChance>1</bondToRandomPlayerPawnChance>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>RI_ImmortalStart</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>Smithing</project>
				</li>
				<li Class="ScenPart_ForcedHediff">
					<def>ForcedHediff</def>
					<chance>1</chance>
					<context>PlayerStarter</context>
					<hediff>Hangover</hediff>
					<severityRange>0.02~0.05</severityRange>
				</li>

				<!-- Scatter some things near player start -->
				<li Class="ScenPart_ScatterThingsAnywhere">
					<def>ScatterThingsAnywhere</def>
					<thingDef>Steel</thingDef>
					<count>450</count>
				</li>
				<li Class="ScenPart_ScatterThingsAnywhere">
					<def>ScatterThingsAnywhere</def>
					<thingDef>WoodLog</thingDef>
					<count>350</count>
				</li>

				<li Class="ScenPart_CreateIncident">
					<def>CreateIncident</def>
					<incident>RI_MakeLINGMAI</incident>
					<intervalDays>32.45815</intervalDays>
					<minDays>3</minDays>
					<maxDays>5</maxDays>
				</li>

			</parts>
		</scenario>
	</ScenarioDef>

</Defs>