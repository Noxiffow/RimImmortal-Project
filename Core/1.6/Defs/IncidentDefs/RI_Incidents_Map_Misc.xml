	<!--过路人-->
	<IncidentDef>
		<defName>RI_Incident_Beggars</defName>
		<label>Passenger</label>
		<category>Misc</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<letterLabel>Passenger arrive</letterLabel>
		<questScriptDef>RI_Beggars</questScriptDef>
		<workerClass>IncidentWorker_GiveQuest</workerClass>
		<baseChance>2</baseChance>
		<requireColonistsPresent>True</requireColonistsPresent>
	</IncidentDef>

	<!--灵气潮汐-涨潮-->
	<IncidentDef>
		<defName>RI_EnergyDecline</defName>
		<label>Qi tide flood period</label>
		<category>Misc</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>WhoXiuXian.RI_IncidentWorker_EnergyDecline</workerClass>
		<gameCondition>EnergyGrowth</gameCondition>
		<baseChance>0.8</baseChance>
		<minRefireDays>15</minRefireDays>
		<durationDays>5~9</durationDays>
	</IncidentDef>

	<!--灵气潮汐-退潮-->
	<IncidentDef>
		<defName>RI_EnergyGrowth</defName>
		<label>Qi tide ebb period</label>
		<category>Misc</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>WhoXiuXian.RI_IncidentWorker_EnergyGrowth</workerClass>
		<gameCondition>EnergyDecline</gameCondition>
		<baseChance>1.2</baseChance>
		<minRefireDays>15</minRefireDays>
		<durationDays>7~11</durationDays>
	</IncidentDef>

	<!--修士加入-->
	<IncidentDef>
		<defName>RI_Incident_CultivatorJoin</defName>
		<label>Cultivator join</label>
		<category>Special</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>IncidentWorker_WandererJoin</workerClass>
		<letterLabel>Cultivator join</letterLabel>
		<letterText>A wandering cultivator join.</letterText>
		<baseChance>1</baseChance>
		<minRefireDays>50</minRefireDays>
		<minGreatestPopulation>1</minGreatestPopulation>
		<pawnKind>RI_Pawn_Seeker</pawnKind>
		<!--<pawnFixedGender>Male</pawnFixedGender>-->
		<pawnMustBeCapableOfViolence>true</pawnMustBeCapableOfViolence>
	</IncidentDef>

	<!--青冥树自然生长-->
	<IncidentDef>
		<defName>RI_Incident_QingMing</defName>
		<label>青冥树自然生长</label>
		<category>Misc</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>WhoXiuXian.IncidentWorker_QingMingSprout</workerClass>
		<baseChance>1.0</baseChance>
		<letterLabel>Grow QingMing</letterLabel>
		<letterText>青冥树自然生长。</letterText>
		<letterDef>PositiveEvent</letterDef>
		<allowedBiomes>
			<li>TropicalRainforest</li>
			<li>TropicalSwamp</li>
			<li>TemperateForest</li>
			<li>TemperateSwamp</li>
			<li>BorealForest</li>
			<li>AridShrubland</li>
			<!--芳草桃源-->
			<li MayRequire="RI.RimImmortal.Biome">RI_Biome_PeachBlossomGarden</li>
		</allowedBiomes>
	</IncidentDef>

</Defs>