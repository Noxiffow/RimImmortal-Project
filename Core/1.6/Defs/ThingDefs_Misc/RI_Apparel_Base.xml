<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--仙路衣物的前置文件-->

	<!--===================== 衣服&帽子前置 =====================-->

	<ThingDef Name="RI_AllApparel_Base" ParentName="ApparelBase" Abstract="True">
		<tickerType>Normal</tickerType>
		<uiIconScale>1</uiIconScale>
		<techLevel>Medieval</techLevel>
		<!--贴图-->
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<!--服装特性-->
		<apparel>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
			<canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
		</apparel>
		<!--贸易tag-->
		<tradeTags>
			<li>Clothing</li>
		</tradeTags>
		<!--不让npc刷新-->
		<generateAllowChance>0</generateAllowChance>
		<generateCommonality>0.01</generateCommonality>
	</ThingDef>

	<!--服装前置——基础衣服前置，用的RI_AllApparel_Base-->
	<ThingDef Name="RI_BasicApparel_Base" ParentName="RI_AllApparel_Base" Abstract="True">
		<!--储存-->
		<thingCategories>
			<li>RI_Category_NormalClothing</li>
		</thingCategories>
		<!--制作清单-->
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<recipeUsers>
				<li>ElectricTailoringBench</li>
				<li>HandTailoringBench</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
			<defaultIngredientFilter>
				<categories>
					<li>Root</li>
				</categories>
				<disallowedThingDefs>
					<li>Gold</li>
					<li>Silver</li>
					<li>Plasteel</li>
					<li>Jade</li>
					<li>Uranium</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
				</disallowedThingDefs>
			</defaultIngredientFilter>
		</recipeMaker>
	</ThingDef>

	<!--服装前置——没有布料皮料，基础服饰-->
	<ThingDef Name="RI_ApparelNostuffCategories_Base" ParentName="RI_AllApparel_Base" Abstract="True">
