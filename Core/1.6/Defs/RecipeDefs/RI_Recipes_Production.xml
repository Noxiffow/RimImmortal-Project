<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<RecipeDef Name="RI_RecipeBase_Medical" Abstract="True">
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workSkill>Crafting</workSkill>
		<researchPrerequisite>RI_BasicElixirs</researchPrerequisite>
	</RecipeDef>

	<!--制作象牙粉-->
	<RecipeDef ParentName="RI_RecipeBase_Medical">
		<defName>RI_MakeElephantTuskPowder</defName>
		<label>Make Elephant tusk powder</label>
		<description>Grind the elephant tusk into powder.</description>
		<jobString>Making Elephant tusk powder</jobString>
		<workAmount>1400</workAmount>
		<recipeUsers>
			<li>RI_Building_ElixirsWorkbench</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElephantTusk</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElephantTusk</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_ElephantTuskPowder>10</RI_Resource_ElephantTuskPowder>
		</products>
	</RecipeDef>

