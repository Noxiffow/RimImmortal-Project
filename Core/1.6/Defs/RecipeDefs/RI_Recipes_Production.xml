	<!--移除灵芽的手术-->
	<RecipeDef ParentName="SurgeryRemoveImplantBase">
		<workerClass>WhoXiuXian.RI_Recipe_RemoveRoot</workerClass>
		<defName>RemoveEnergyRoot</defName>
		<label>Cut spiritual root</label>
		<description>The spiritual root are removed and extracted.</description>
		<descriptionHyperlinks>
			<ThingDef>EnergyRoot</ThingDef>
			<HediffDef>Hediff_RI_EnergyRoot</HediffDef>
		</descriptionHyperlinks>
		<jobString>Removing EnergyRoot.</jobString>
		<removesHediff>Hediff_RI_EnergyRoot</removesHediff>
	</RecipeDef>

	<!--制作滴血令-->
	<RecipeDef>
		<defName>RI_Recipe_MakeBloodMarkFromLeather</defName>
		<label>make blood mark</label>
		<description>Making blood mark.</description>
		<workAmount>1000</workAmount>
		<jobString>Making blood mark.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Tailor</effectWorking>
		<soundWorking>Recipe_Tailor</soundWorking>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.5</workSkillLearnFactor>

		<!-- 可用设施 -->
		<recipeUsers>
			<li>CraftingSpot</li>
			<li>TableSculpting</li>
		</recipeUsers>

		<!-- 原料 -->
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>Leathers</li>
					</categories>
					<disallowedThingDefs>
						<li>Leather_Thrumbo</li>
						<li MayRequire="Ludeon.RimWorld.Odyssey">Leather_AlphaThrumbo</li>
					</disallowedThingDefs>
				</filter>
				<count>30</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>Leathers</li>
			</categories>
		</fixedIngredientFilter>

		<!-- 成品 -->
		<products>
			<RI_Thing_SpecialRaidCaller>1</RI_Thing_SpecialRaidCaller>
		</products>

		<!-- 技术 / 前置要求 -->
		<skillRequirements />
		<researchPrerequisite />
	</RecipeDef>

</Defs>
