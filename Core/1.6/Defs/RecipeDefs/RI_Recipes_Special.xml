		<jobString>Making Marrow-washing nectar</jobString>
		<workAmount>5000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Things_JadeLiquid</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_SpiritFire</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_LingZhi</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_LiquidJade</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_GoldSand</li>
