<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 这个是在供案上合成的前置，注意，只有在供案上才继承这个，或者你如果需要
	 下面的配方在别的地方也能使用，那就需要自己继承修改或者自己复制一份配方在别出使用（特别是做扩展的）
	 因为这里会单独设置一个工作影响因素，祠堂清洁度 -->
	<RecipeDef Name="RI_RecipeBase_Prayer" Abstract="True">
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Cremate</soundWorking>
		<workSkill>Crafting</workSkill>
		<researchPrerequisite>RI_Research_ImmortalWorship</researchPrerequisite>
		<!-- <efficiencyStat>RI_PrayerAltarFactor</efficiencyStat> -->
	</RecipeDef>

	<!--青玉仙露-->
	<RecipeDef ParentName="RI_RecipeBase_Prayer">
		<defName>RI_Recipe_MakeJadeLiquid</defName>
		<label>Make QingMing jade wine</label>
		<description>A medicinal wine obtained by grinding QingMing marrow and stirring it with some plant juices and fermenting it briefly.</description>
		<jobString>Making QingMing jade wine</jobString>
		<workAmount>3400</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_QingMingMarrow</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>MedicineHerbal</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_SpiritualCrystal</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<products>
			<RI_Things_JadeLiquid>1</RI_Things_JadeLiquid>
		</products>
	</RecipeDef>

	<!-- 制作洗髓玉液 -->
