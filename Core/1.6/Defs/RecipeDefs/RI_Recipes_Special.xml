				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<products>
			<RI_Things_JadeLiquidPro>1</RI_Things_JadeLiquidPro>
		</products>
	</RecipeDef>

	<!--合成纯阳真气-->
