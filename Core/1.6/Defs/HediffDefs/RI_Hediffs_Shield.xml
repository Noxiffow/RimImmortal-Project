<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<HediffDef>
		<defName>RI_ShieldHediff_Test</defName>
		<label>Test shield</label>
		<description>Installed Explosive Reactive Armor</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(1, 1, 1)</defaultLabelColor>
		<isBad>false</isBad>
		<comps>
			<!--死亡后消失-->
			<li Class="HediffCompProperties_DisappearsOnDeath" />
			<!--护盾comp-->
			<li Class="WhoXiuXian.Shield.HediffCompProperties_RIShield">
				<compClass>WhoXiuXian.Shield.HediffComp_RIShield</compClass>
				<!--执行护盾的类型-->
				<hitSound/>
				<!--受击音效，默认为泰南的护盾腰带的受击音效-->
				<hitFleck/>
				<!--受击fleck，默认为泰南的护盾腰带的受击特效-->
				<brokenSound/>
				<!--破盾音效,默认不播放，泰南的护盾腰带碎盾音效是EnergyShield_Reset-->
				<brokenFleck/>
				<!--破盾fleck，默认不播放，泰南的护盾腰带碎盾特效是ExplosionFlash-->
				<baseEnergy>100</baseEnergy>
				<!--基础盾容-->
				<changeByRootLevel>True</changeByRootLevel>
				<!-- 是否随着境界增长 -->
				<energyLoosePerDamage>1</energyLoosePerDamage>
				<!--每点伤害损失多少盾容-->
				<bubbleMatPath/>
				<!--护盾泡泡的材质路径，默认为泰南的护盾腰带的泡泡-->
				<keepDisplaying/>
				<!--是否一直绘制护盾泡泡，false则只在征召绘制，默认为false-->
				<gizmoLabel>护盾</gizmoLabel>
				<!--gizmo的标签-->
				<gizmoTip>护盾容量</gizmoTip>
				<!--gizmo的tip描述-->
				<ShaderTypeDef>MoteGlow</ShaderTypeDef>
				<!--着色器类型，默认为Transparent-->
				<drawBubbleSize>2.0</drawBubbleSize>
				<!--绘制泡泡大小-->
				<rotateRandonly>false</rotateRandonly>
				<!--材质随机旋转，默认开-->
			</li>
		</comps>
	</HediffDef>

	<!--====================散修们刷出来的护盾（前置）====================-->

	<!--普通刷出来的修炼者的自带护盾-->
	<HediffDef Name="RI_FreeCultivatorShield_Hediff_Base" Abstract="True">
		<description>A spherical shield that protects the entire body, formed from qi. It can withstand attacks from ranged weapons, but cannot stop melee attacks.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(1, 1, 1)</defaultLabelColor>
		<isBad>false</isBad>
		<comps>
			<!--死亡后消失-->
			<li Class="HediffCompProperties_DisappearsOnDeath" />
			<!--一段时间后消失-->
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>6000~12000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
	</HediffDef>

