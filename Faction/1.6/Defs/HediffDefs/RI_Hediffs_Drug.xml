	<!--================================== Grade 2 ==================================-->

	<!--QiLin restoration pill effect-->
	<HediffDef ParentName="RI_DrugHediff_Base">
		<defName>RI_Hediff_QiLinRestorationPill</defName>
		<label>Effect of QiLin restoration pill</label>
		<description>Heals a scar and grants long-lasting regenerative ability.</description>
		<comps>
			<li Class="HediffCompProperties_HealPermanentWounds" />
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<!--15 days-->
				<disappearsAfterTicks>1800000</disappearsAfterTicks>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<InjuryHealingFactor>0.5</InjuryHealingFactor>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<!--================================== Grade 1 ==================================-->

	<!--Effect of taking Oblivion Soul-Purging Elixir — delete cultivation method!-->
	<HediffDef>
		<defName>RI_Hediff_DeleteIA</defName>
		<description>Delete cultivation method</description>
		<label>Delete cultivation method</label>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.7, 1.0, 0.7)</defaultLabelColor>
		<stages>
			<li>
				<becomeVisible>false</becomeVisible>
				<!--Hidden hediff-->
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>1</disappearsAfterTicks>
				<!--Required — this function triggers when the hediff disappears-->
			</li>
			<li Class="RI_Transfer.HediffCompProperties_RI_Transfer">
				<IsTransfer>true</IsTransfer>
				<!--Determines if this is a class transfer; if true, the original cultivation is preserved and the level setting below will not take effect and can be deleted-->
				<level>8</level>
				<!--Modify its realm; if IsTransfer is true, this setting is not needed-->
				<HaveRoute>true</HaveRoute>
				<!--Whether to perform a cultivation method operation — required setting for class transfer-->
				<AddRoute>false</AddRoute>
				<!--Default is true; set false to forget the current method without adding a new one-->
				<RouteDef>Base</RouteDef>
				<!--Type of cultivation method to add — write the route defname-->
			</li>
		</comps>
	</HediffDef>

	<!--LingLong moonlight elixir effect-->
	<HediffDef ParentName="RI_DrugHediff_Base">
		<defName>RI_Hediff_LingLongMoonlightElixir</defName>
		<label>Effect of LingLong moonlight elixir</label>
		<description>LingLong Fruit is rich in the qi of heaven and earth, allowing the body to harmonize with nature and greatly increasing the chance of a successful upgrade.</description>
		<comps>
			<li Class="HediffCompProperties_HealPermanentWounds" />
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<!--15 days-->
				<disappearsAfterTicks>180000</disappearsAfterTicks>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<InjuryHealingFactor>0.5</InjuryHealingFactor>
					<GI_EnergyGainEff>0.25</GI_EnergyGainEff>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.2</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

	<!--Condensed spiritual liquid effect-->
	<HediffDef ParentName="RI_DrugHediff_Base">
		<defName>RI_Hediff_CondensedSpiritualLiquidHediff</defName>
		<label>Effect of condensed spiritual liquid</label>
		<description>Directly restore some Qi and automatically restore Qi over a period of time.</description>
		<comps>
			<li>
				<compClass>WhoXiuXian.HediffComp_RI_CultivateMoreEnergyHediff</compClass>
			</li>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<disappearsAfterTicks>15000</disappearsAfterTicks>
			</li>
		</comps>
	</HediffDef>

	<!--LingLong regeneration-->
	<HediffDef MayRequire="Ludeon.RimWorld.Anomaly">
		<defName>RI_Hediff_LingLongRegeneration</defName>
		<label>LingLong regeneration</label>
		<description>The spiritual energy of Linglong fruit condenses into a nourishing essence, seeping into the body to mend flesh and heal wounds.</description>
		<isBad>false</isBad>
		<defaultLabelColor>(0.49,1,0.48)</defaultLabelColor>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<!--15 days-->
				<disappearsAfterTicks>60000</disappearsAfterTicks>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<ImmunityGainSpeed>1</ImmunityGainSpeed>
				</statOffsets>
				<regeneration>100</regeneration>
			</li>
		</stages>
	</HediffDef>

</Defs>