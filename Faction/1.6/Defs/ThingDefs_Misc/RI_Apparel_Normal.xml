<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--芙蓉冠-->
	<ThingDef ParentName="ArmorHelmetMakeableBase">
		<defName>RI_Apparel_FlonneCrown</defName>
		<label>Flonne crown</label>
		<description>The crown sculpted into the shape of a flonne flower is quite exquisite.\n\nThis type of crown is usually reserved for individuals of high rank and power, but that doesn't stop it from being secretly spread among the common folk as a fashion trend.</description>
		<techLevel>Medieval</techLevel>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_FlonneCrown/RI_Apparel_FlonneCrown</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<uiIconScale>1.4</uiIconScale>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>30</costStuffCount>
		<!--贸易标签-->
		<tradeTags>
			<li>RI_ThirdRateArmor_Tag</li>
		</tradeTags>
		<statBases>
			<WorkToMake>5000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>0.3</Mass>
			<StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>2</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>2</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>0.5</EquipDelay>
		</statBases>
		<recipeMaker>
			<researchPrerequisite>RI_Research_BasicClothing</researchPrerequisite>
			<recipeUsers>
				<li>HandTailoringBench</li>
				<li>ElectricTailoringBench</li>
			</recipeUsers>
			<displayPriority>200</displayPriority>
		</recipeMaker>
		<equippedStatOffsets>
			<SocialImpact>0.1</SocialImpact>
		</equippedStatOffsets>
		<apparel>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_FlonneCrown/RI_Apparel_FlonneCrown</wornGraphicPath>
			<layers>
				<li>Overhead</li>
			</layers>
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
		</apparel>
	</ThingDef>

