	<!--仙门斗篷-->
	<ThingDef ParentName="RI_BasicApparel_Base">
		<defName>RI_Apparel_LightRobe</defName>
		<label>Light robe</label>
		<description>A large, thick cloak, with excellent craftsmanship and attention to detail.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_LightRobe/RI_Apparel_LightRobe</texPath>
		</graphicData>

		<costStuffCount>60</costStuffCount>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>

		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToMake>3000</WorkToMake>
			<Mass>2.5</Mass>
			<EquipDelay>3</EquipDelay>
			<StuffEffectMultiplierArmor>0.65</StuffEffectMultiplierArmor>
			<Insulation_Cold>10</Insulation_Cold>
			<Insulation_Heat>5</Insulation_Heat>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_LightRobe/RI_Apparel_LightRobe</wornGraphicPath>
			<layers>
				<li>Shell</li>
			</layers>
			<tags>
				<li>RI_Tag_ApparelBasic</li>
			</tags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel" />
		<!--贸易标签-->
		<tradeTags>
			<li>RI_ThirdRateArmor_Tag</li>
		</tradeTags>
		<recipeMaker>
			<displayPriority>7</displayPriority>
			<researchPrerequisite>RI_Research_BasicClothing</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	
	<!--制式交领短衫-->
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>RI_Apparel_BasicSectShirt</defName>
		<label>Sect collar shirt</label>
		<description>A short shirt issued by sects. It is simplified on the basis of traditional clothing. The fabric is specially thickened where it is easy to wear, such as the collar and the corner, and the two sides of the clothes have openings to facilitate activities.</description>
		<recipeMaker>
			<researchPrerequisite>RI_Research_BasicClothing</researchPrerequisite>
			<displayPriority>205</displayPriority>
		</recipeMaker>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_BasicSectShirt/RI_Apparel_BasicSectShirt</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<costStuffCount>50</costStuffCount>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<thingCategories>
			<li>ApparelMisc</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToMake>2000</WorkToMake>
			<Mass>0.3</Mass>
			<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.2</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_BasicSectShirt/RI_Apparel_BasicSectShirt</wornGraphicPath>
			<layers>
				<li>OnSkin</li>
			</layers>
			<tags>
				<li>RI_Tag_ApparelBasic</li>
			</tags>
			<defaultOutfitTags>
				<li>Worker</li>
				<li>Soldier</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel" />
		<!--贸易标签-->
		<tradeTags>
			<li>RI_ThirdRateArmor_Tag</li>
		</tradeTags>
	</ThingDef>

</Defs>