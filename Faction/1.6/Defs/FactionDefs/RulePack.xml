<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- =============================== 正道 派系名字 =============================== -->
	<RulePackDef>
		<defName>RI_Namer_JusticeSect</defName>
		<rulePack>
			<rulesFiles>
				<li>FactionLast->Names/FactionName_Last</li>
				<li>JusticeFaction->Names/JusticeFactionName_First</li>
			</rulesFiles>
			<rulesStrings>
				<li>r_name(p=10)->[JusticeFaction][FactionLast]</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

	<!-- =============================== 外道 派系名字 =============================== -->
	<RulePackDef>
		<defName>RI_Namer_EvilSect</defName>
