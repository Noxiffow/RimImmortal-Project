<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<FactionDef ParentName="FactionBase">
		<defName>RI_Faction_EvilSect</defName>
		<label>Outer sect</label>
		<categoryTag>Outer sect</categoryTag>
		<description>A cross-galaxy outer sect, founded by a group of evil cultivators seeking immortality. The sect predominantly worships the Thran and actively expands its territory by any means necessary.\n\nThe disciples of the heretical sect are indoctrinated with evil doctrines from a young age to wear down their morality. Afterward, they are led by core members and the sect leader to raid surrounding areas.\n\nDue to its numerous nefarious deeds, the heretical sect is despised by most factions. However, once one joins, they can increase their cultivation efficiency by earning contribution points.</description>
		<pawnSingular>Cultivator</pawnSingular>
		<pawnsPlural>Cultivators</pawnsPlural>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>Master</leaderTitle>
		<!--头衔点数——贡献点-->
		<royalFavorLabel>Contribution</royalFavorLabel>
		<royalFavorIconPath>UI/Icons/RI_Faction_SectContribution</royalFavorIconPath>
		<leaderForceGenerateNewPawn>true</leaderForceGenerateNewPawn>
		<factionIconPath>World/WorldObjects/Expanding/RI_Faction_EvilSect</factionIconPath>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<colorSpectrum>
			<li>(0.65, 0.25, 0.27)</li>
		</colorSpectrum>
		<techLevel>Ultra</techLevel>
		<!--命名-->
		<factionNameMaker>RI_Namer_EvilSect</factionNameMaker>
		<settlementNameMaker>RI_Namer_SectSettlementPack</settlementNameMaker>

		<!--文化-->
		<requiredMemes>
			<li>RI_Meme_EvilWays</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Collectivist</li>
		</requiredMemes>
		<allowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Collectivist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Loyalist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">HumanPrimacy</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">MaleSupremacy</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">FemaleSupremacy</li>
		</allowedMemes>
		<structureMemeWeights>
			<RI_Structure_QiOriginFaith>1</RI_Structure_QiOriginFaith>
		</structureMemeWeights>
		<!--风格-->
		<allowedCultures>
			<li>RI_Qi_Culture</li>
		</allowedCultures>

		<!--异种-->
		<xenotypeSet>
			
		</xenotypeSet>

		<naturalEnemy>true</naturalEnemy>

		<!--背景故事-->
		<backstoryFilters>
			<li>
				<categories>
					<li>RI_BackStory_Sect</li>
				</categories>
				<commonality>0.9</commonality>
			</li>
			<li>
				<categories>
					<li>RI_BackStory_Special</li>
				</categories>
				<commonality>0.1</commonality>
			</li>
		</backstoryFilters>

		<!--服饰-->
		<apparelStuffFilter>
			<stuffCategoriesToAllow>
				<li>Metallic</li>
				<li>Fabric</li>
			</stuffCategoriesToAllow>
		</apparelStuffFilter>
		<!--温度-->
		<allowedArrivalTemperatureRange>-50~60</allowedArrivalTemperatureRange>
		<!--头衔-->
		<fixedLeaderKinds>
			<li>RI_Pawn_SectLeader</li>
		</fixedLeaderKinds>
		<royalTitleTags>
			<li>RI_Sect_Title</li>
		</royalTitleTags>

		<!--商队-->
		<baseTraderKinds>
			<li>RI_Base_JusticeSect_Standard</li>
		</baseTraderKinds>
		<visitorTraderKinds Inherit="false">
            <li>RI_Sect_Caravan_TraderVisitor</li>
        </visitorTraderKinds>
		<caravanTraderKinds>
			<li>RI_Sect_Caravan_ShadowTrader</li>
			<li>RI_Sect_Caravan_SlaveTraffickingCaravan</li>
			<li>RI_Sect_Caravan_BookTrader</li>
			<li>RI_Sect_Caravan_ContributionPatrolCollector</li>
		</caravanTraderKinds>

		<!--袭击-->
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 1)</li>
				<!--Constant 1 at all points levels-->
			</points>
		</raidCommonalityFromPointsCurve>
		<raidLootMaker>EmpireRaidLootMaker</raidLootMaker>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(500, 100)</li>
				<!-- Can always use relatively strong pawns, because empire doesn't really have weak ones -->
				<li>(1000, 150)</li>
				<li>(2000, 250)</li>
				<li>(2001, 10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>

		<pawnGroupMakers>
			<!-- 商队 -->
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<RI_Pawn_NormalEvilMember>1</RI_Pawn_NormalEvilMember>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
					<Dromedary>5</Dromedary>
				</carriers>
				<guards>
					<RI_Pawn_SectBeginner>20</RI_Pawn_SectBeginner>
					<RI_Pawn_NormalEvilMember>10</RI_Pawn_NormalEvilMember>
					<RI_Pawn_CadreMember>5</RI_Pawn_CadreMember>
				</guards>
			</li>
			<li>
				<!-- 普通修仙者袭击 -->
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
					<RI_Pawn_SectBeginner>20</RI_Pawn_SectBeginner>
					<RI_Pawn_NormalEvilMember>20</RI_Pawn_NormalEvilMember>
					<RI_Pawn_CadreMember>10</RI_Pawn_CadreMember>
					<RI_Pawn_MiddleManager>5</RI_Pawn_MiddleManager>
					<RI_Pawn_SectLeader>1</RI_Pawn_SectLeader><!--leader必须出现在袭击的group里面，不然会报红字-->
				</options>
			</li>
			<li>
				<!-- Base defense, mainly ranged with melee mix-ins -->
				<kindDef>Settlement</kindDef>
				<options>
					<RI_Pawn_SectBeginner>20</RI_Pawn_SectBeginner>
					<RI_Pawn_NormalEvilMember>20</RI_Pawn_NormalEvilMember>
					<RI_Pawn_CadreMember>10</RI_Pawn_CadreMember>
					<RI_Pawn_MiddleManager>5</RI_Pawn_MiddleManager>
					<RI_Pawn_SectLeader>1</RI_Pawn_SectLeader>
				</options>
			</li>
		</pawnGroupMakers>

		<royalTitleInheritanceWorkerClass>RoyalTitleInheritanceWorker</royalTitleInheritanceWorkerClass>
		<royalTitleInheritanceRelations>
			<li>Child</li>
		</royalTitleInheritanceRelations>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>70</configurationListOrderPriority>
		<disallowedRaidAgeRestrictions>
			<li MayRequire="Ludeon.RimWorld.Biotech">Children</li>
		</disallowedRaidAgeRestrictions>
		<dropPodActive>ActiveDropPod_RI_Sect_Faction</dropPodActive>
		<dropPodIncoming>DropPodIncoming_RI_Sect_Faction</dropPodIncoming>
	</FactionDef>

</Defs>