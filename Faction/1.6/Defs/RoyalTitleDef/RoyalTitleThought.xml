<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- ============================= Thoughts related to royal titles ============================= -->

	<ThoughtDef>
		<defName>RI_Thought_BeMaster</defName>
		<durationDays>30</durationDays>
		<thoughtClass>Thought_MemoryRoyalTitle</thoughtClass>
		<stages>
			<li>
				<label>Became Sect Master</label>
				<description>I am now the Sect Master</description>
				<baseMoodEffect>30</baseMoodEffect>
			</li>
		</stages>
		<ignoreIllegalLabelCharacterConfigError>true</ignoreIllegalLabelCharacterConfigError>
	</ThoughtDef>

	<ThoughtDef>
		<defName>RI_Sect_GainedTitle</defName>
		<durationDays>30</durationDays>
		<thoughtClass>Thought_MemoryRoyalTitle</thoughtClass>
		<nullifyingTraits>

		</nullifyingTraits>
		<stages>
			<li>
				<label>Gained {TITLE} title</label>
				<description>I am now a member of {TITLE}, bringing me closer to the path of immortality!</description>
				<baseMoodEffect>30</baseMoodEffect>
			</li>
		</stages>
		<ignoreIllegalLabelCharacterConfigError>true</ignoreIllegalLabelCharacterConfigError>
	</ThoughtDef>

	<ThoughtDef>
		<defName>RI_Sect_LostTitle</defName>
		<durationDays>15</durationDays>
		<thoughtClass>Thought_MemoryRoyalTitle</thoughtClass>
		<nullifyingTraits>

		</nullifyingTraits>
		<stages>
			<li>
				<label>Lost {TITLE} title</label>
				<description>I am no longer {TITLE} — how infuriating!</description>
				<baseMoodEffect>-15</baseMoodEffect>
			</li>
		</stages>
		<ignoreIllegalLabelCharacterConfigError>true</ignoreIllegalLabelCharacterConfigError>
	</ThoughtDef>

	<ThoughtDef>
		<defName>RI_Sect_GainedTitle_B</defName>
		<durationDays>30</durationDays>
		<thoughtClass>Thought_MemoryRoyalTitle</thoughtClass>
		<nullifyingTraits>

		</nullifyingTraits>
		<stages>
			<li>
				<label>Gained {TITLE} title</label>
				<description>In other words... am I now the core of the sect? Am I a true cultivator now? Am I?!</description>
				<baseMoodEffect>30</baseMoodEffect>
			</li>
		</stages>
		<ignoreIllegalLabelCharacterConfigError>true</ignoreIllegalLabelCharacterConfigError>
	</ThoughtDef>

</Defs>