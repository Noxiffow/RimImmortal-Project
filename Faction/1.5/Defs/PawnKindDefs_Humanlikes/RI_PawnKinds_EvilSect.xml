<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--外道宗门pawn的base-->
	<PawnKindDef Abstract="True" Name="RI_EvilSectPawn_Base">
		<race>Human</race>
		<isFighter>true</isFighter>
		<nameMaker>NamerPersonImmortal</nameMaker>
		<nameMakerFemale>NamerPersonImmortalFemale</nameMakerFemale>
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>
		<apparelIgnorePollution MayRequire="Ludeon.RimWorld.Biotech">true</apparelIgnorePollution>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<forceNormalGearQuality>true</forceNormalGearQuality>
		<humanPregnancyChance>0.01</humanPregnancyChance>
		<!--外道派系-->
		<defaultFactionType>RI_Faction_EvilSect</defaultFactionType>
		<chemicalAddictionChance>0.05</chemicalAddictionChance>
		<biocodeWeaponChance>0.5</biocodeWeaponChance>
		<combatEnhancingDrugsChance>0.05</combatEnhancingDrugsChance>
		<combatEnhancingDrugsCount>1~2</combatEnhancingDrugsCount>
		<backstoryCryptosleepCommonality>0.05</backstoryCryptosleepCommonality>

		<!--背景故事-->
		<!--<backstoryFiltersOverride>
			<li>
				<categories>
					<li>RI_BackStory_Child_Special</li>
					<li>RI_BackStory_Child_Sect</li>
					<li>RI_BackStory_Adult_Special</li>
					<li>RI_BackStory_Adult_EvilCultivator</li>
					<li>RI_BackStory_Adult_EvilSect</li>
				</categories>
			</li>
		</backstoryFiltersOverride>-->

		<!--禁止特性-->
		<disallowedTraits>
			<li>Nudist</li>
			<li>Brawler</li>
		</disallowedTraits>

		<!--假体-->
		<techHediffsChance>0.05</techHediffsChance>
		<techHediffsMoney>100~200</techHediffsMoney>
		<techHediffsTags>
			<li>Poor</li>
		</techHediffsTags>
		
		<!--携带物资-->
		<inventoryOptions>
			<skipChance>0.5</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef MayRequire="RI.RimImmortal.Forge">RI_BlindBox_Bag</thingDef>
					<countRange>
						<min>1</min>
						<max>1</max>
					</countRange>
				</li>
				<li>
					<thingDef>RI_Resource_SpiritualCrystal</thingDef>
					<countRange>
						<min>1</min>
						<max>3</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
		
		<!--俘虏抗性-->
		<initialWillRange>5</initialWillRange>
		<initialResistanceRange>10~15</initialResistanceRange>
	</PawnKindDef>

	<!--外道入门-->
	<PawnKindDef ParentName="RI_EvilSectPawn_Base">
		<defName>RI_Pawn_SectBeginner</defName>
		<label>Beginner</label>
		<!--战斗力~-->
		<combatPower>80</combatPower>
		<!--年龄-->
		<minGenerationAge>15</minGenerationAge>
		<maxGenerationAge>40</maxGenerationAge>
		<!--衣服-->
		<apparelMoney>800~1500</apparelMoney>
		<apparelTags>
			<li>RI_Apparel_BasicCloth</li>
		</apparelTags>
		<apparelRequired>
			<li>RI_Apparel_BasicSectShirt</li>
			<li>RI_Apparel_ExerciseApparel</li>
			<li>RI_Apparel_CultivatorPants</li>
		</apparelRequired>
		<!--武器-->
		<weaponMoney>800~1500</weaponMoney>
		<weaponTags>
			<li>RI_MagicalWeapon</li>
			<li>RI_JadeBambooWeapons_Base</li>
		</weaponTags>
		<!--附带hediff（控制境界和开局自带buff）-->
		<startingHediffs>
			<li>
				<def>Hediff_RI_EnergyRoot</def>
				<chance>0.2</chance>
				<severity>0.5</severity>
			</li>
			<li>
				<def>RI_LV2_Base</def>
				<chance>1</chance>
				<severity>1</severity>
			</li>
		</startingHediffs>
		<!--携带食物-->
		<invNutrition>2.55</invNutrition>
		<invFoodDef>Pemmican</invFoodDef>
	</PawnKindDef>

