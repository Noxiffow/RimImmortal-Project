			<li>
				<categories>
					<li>RI_Pawn_FreeCultivator</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		
		<!--衣服-->
		<apparelMoney>6000~10000</apparelMoney>
		<apparelTags>
			<li>RI_Tag_ApparelBasic</li>
		</apparelTags>
		<apparelRequired>
			<li>RI_Apparel_CultivatorUnderwear</li>
			<li>RI_Apparel_ExerciseApparel</li>
			<li MayRequire="RI.RimImmortal.Forge">RI_Apparel_GoldBestHelmet_Mask</li>
