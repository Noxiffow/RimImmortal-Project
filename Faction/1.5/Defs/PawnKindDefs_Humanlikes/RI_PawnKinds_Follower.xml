		<nameMaker>NamerPersonImmortal</nameMaker>
		<nameMakerFemale>NamerPersonImmortalFemale</nameMakerFemale>
		<combatPower>600</combatPower>
		<backstoryCryptosleepCommonality>1</backstoryCryptosleepCommonality>
