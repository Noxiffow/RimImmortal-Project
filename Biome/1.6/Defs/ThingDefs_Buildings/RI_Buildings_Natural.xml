	<!--古修建筑遗迹——装了仙路才会掉灵石-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_AncientCultivatorRuinsA</defName>
		<label>ancient cultivator building ruin</label>
		<description>The architectural remains left by ancient cultivators were forged with heavy steel.</description>
		<category>Building</category>
		<graphicData>
			<texPath>Things/Building/Misc/RI_Building_AncientCultivatorRuinsA</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>(3.5,3.5)</drawSize>
			<damageData>
				<rect>(0.1,0.1,1.8,1.8)</rect>
			</damageData>
			<shadowData>
				<volume>(0.7,0.5,0.7)</volume>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.50</fillPercent>
		<size>(1,1)</size>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>2</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<RI_Resource_SpiritualCrystal MayRequire="RI.RimImmortal.Core">3</RI_Resource_SpiritualCrystal>
			<Steel>25</Steel>
		</killedLeavings>
		<costList>
			<RI_Resource_SpiritualCrystal MayRequire="RI.RimImmortal.Core">6</RI_Resource_SpiritualCrystal>
			<Steel>50</Steel>
		</costList>
		<building>
			<claimable>false</claimable>
			<alwaysDeconstructible>true</alwaysDeconstructible>
		</building>
		<selectable>true</selectable>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<drawerType>MapMeshOnly</drawerType>
		<repairEffect>ConstructMetal</repairEffect>
		<filthLeaving>Filth_RubbleBuilding</filthLeaving>
		<comps>
			<li Class="CompProperties_InspectString">
				<inspectString>Deconstruct for valuable resources.</inspectString>
			</li>
		</comps>
	</ThingDef>

