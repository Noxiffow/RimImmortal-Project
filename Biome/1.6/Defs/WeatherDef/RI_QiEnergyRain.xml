<?xml version="1.0" encoding="utf-8"?>
<Defs>
	
	<!--Spiritual radiance rain weather-->
	<WeatherDef MayRequire="RI.RimImmortal.Core">
		<defName>RI_QiEnergyRain</defName>
		<label>spiritual radiance rain</label>
		<isBad>true</isBad>
		<description>A natural phenomenon born from an abundance of qi energy, where rain infused with qi falls from the sky, each droplet shimmering with radiant light.</description>
		<temperatureRange>5~999</temperatureRange>
		<windSpeedFactor>1.2</windSpeedFactor>
		<favorability>Neutral</favorability>
		<perceivePriority>1</perceivePriority>
		<weatherThought>RI_Thought_QiEnergyRain</weatherThought>
		<!-- Extra conditions limiting occurrence to specific biomes -->
		<!-- <repeatable>false</repeatable> -->
		<canOccurInAmbientHorror>false</canOccurInAmbientHorror>
		<accuracyMultiplier>0.5</accuracyMultiplier>
		<!-- Fog effect -->
		<rainRate>1</rainRate>
		<!-- Rain effect -->
		<moveSpeedMultiplier>0.9</moveSpeedMultiplier>
		<ambientSounds>
			<li>Ambient_Wind_Fog</li>
			<li>Ambient_Rain</li>
		</ambientSounds>
		<overlayClasses>
			<!-- Combined fog and rain visuals -->
			<!--<li>WeatherOverlay_Fog</li>-->
			<!--<li>WeatherOverlay_Rain</li>-->
			<li>RI_PeachBlossomLand.WeatherOverlay_QiEnergyRain</li>
		</overlayClasses>
		<commonalityRainfallFactor>
			<!-- Rainfall factor influence -->
			<points>
				<li>(0, 0)</li>
				<li>(1300, 1)</li>
			</points>
		</commonalityRainfallFactor>
		<!-- Sky color settings -->
		<skyColorsDay>
			<sky>(0.8, 0.8, 0.8)</sky>
			<shadow>(0.92, 0.92, 0.92)</shadow>
			<overlay>(0.7, 0.7, 0.7)</overlay>
			<saturation>0.9</saturation>
		</skyColorsDay>
		<skyColorsDusk>
			<sky>(1, 1, 1)</sky>
			<shadow>(0.92, 0.92, 0.92)</shadow>
			<overlay>(0.6, 0.6, 0.6)</overlay>
			<saturation>0.9</saturation>
		</skyColorsDusk>
		<skyColorsNightEdge>
			<sky>(0.35, 0.40, 0.45)</sky>
			<shadow>(0.92, 0.92, 0.92)</shadow>
			<overlay>(0.5, 0.5, 0.5)</overlay>
			<saturation>0.9</saturation>
		</skyColorsNightEdge>
		<skyColorsNightMid>
			<sky>(0.35, 0.40, 0.45)</sky>
			<shadow>(0.92, 0.92, 0.92)</shadow>
			<overlay>(0.5, 0.5, 0.5)</overlay>
			<saturation>0.9</saturation>
		</skyColorsNightMid>
	</WeatherDef>
	
</Defs>