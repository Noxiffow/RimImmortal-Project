	<!--Immortal peach-->
	<ThingDef ParentName="OrganicProductBase">
		<defName>RI_Things_ImmortalPeach</defName>
		<label>immortal peach</label>
		<description>The Immortal peach is a rare and precious fruit, smooth and lustrous in appearance, with a sweetness like honey. Its most remarkable effect is rejuvenation: consuming it makes the eater younger by roughly one year.\n\nThis life-extending property does not defy fate, but works by using the spiritual energy contained within the fruit to mend the body, allowing the flesh to return to a younger state. For this reason, it is especially valuable to the elderly and infirm, and is typically seen only at high-end auctions.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Special/RI_Things_ImmortalPeach</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<Nutrition>1</Nutrition>
			<FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman>
		</statBases>
		<socialPropernessMatters>true</socialPropernessMatters>
		<allowedArchonexusCount>50</allowedArchonexusCount>
		<thingCategories>
			<li>RI_Category_ImmortalThings</li>
		</thingCategories>
		<statBases>
			<MarketValue>300</MarketValue>
			<Mass>0.2</Mass>
		</statBases>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>1.6</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<ingestible>
			<preferability>NeverForNutrition</preferability>
			<foodType>VegetableOrFruit</foodType>
			<ingestEffect>EatVegetarian</ingestEffect>
			<ingestSound>RawVegetable_Eat</ingestSound>
			<outcomeDoers>
				<li Class="RI_PeachBlossomLand.IngestibleOutcomeDoer_ReduceAge">
					<years>1</years>
				</li>
			</outcomeDoers>
		</ingestible>
	</ThingDef>
