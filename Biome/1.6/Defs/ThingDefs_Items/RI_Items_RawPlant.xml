	<!--Phantom gold lotus resource-->
	<ThingDef ParentName="ResourceBase">
		<defName>RI_Resource_PhantomGoldLotus</defName>
		<label>phantom gold lotus</label>
		<description>The Phantom Gold Lotus prefers shade and grows in deep forests and streamside wetlands. Its petals are golden, and the stamens carry a faint, lingering fragrance.\n\nThe blossom possesses mild hallucinogenic properties. In some cultures, people burn the petals and inhale the drifting fumes to seek omens or visions. In the cultivation world, alchemists refine the Phantom Gold Lotus into calming and pain-relieving pills, saving countless lives.\n\nYet this flower also has a darker side. Its active essence can be processed into Mijin Sand, a highly addictive hallucinogen that has ruined families and destroyed lives.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RawMedical/RI_Resource_PhantomGoldLotus</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>38</MarketValue>
			<Nutrition>0.1</Nutrition>
			<FoodPoisonChanceFixedHuman>0.5</FoodPoisonChanceFixedHuman>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<DeteriorationRate>10</DeteriorationRate>
			<Mass>0.05</Mass>
		</statBases>
		<possessionCount>1</possessionCount>
		<stackLimit>75</stackLimit>
		<thingCategories>
			<li>RI_Category_DrugsMaterials</li>
		</thingCategories>
		<ingestible>
			<preferability>DesperateOnly</preferability>
			<tasteThought>RI_Thought_AteHerb</tasteThought>
			<ingestEffect>EatVegetarian</ingestEffect>
			<ingestSound>RawVegetable_Eat</ingestSound>
			<foodType>Plant</foodType>
		</ingestible>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>30</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<soundInteract>Grain_Drop</soundInteract>
		<soundDrop>Grain_Drop</soundDrop>
		<!--TODO: fix drop sound-->
		<tickerType>Rare</tickerType>
		<healthAffectsPrice>false</healthAffectsPrice>
		<socialPropernessMatters>true</socialPropernessMatters>
		<allowedArchonexusCount>50</allowedArchonexusCount>
		<tradeability>Sellable</tradeability>
	</ThingDef>

