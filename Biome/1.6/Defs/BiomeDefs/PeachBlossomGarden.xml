		</biomeMapConditions>
		<preventGenSteps>
			<li MayRequire="Ludeon.RimWorld.Royalty">AnimaTrees</li>
		</preventGenSteps>-->
		<extraGenSteps>
			<li>SteamGeysers</li>
			<li>RI_GenStep_AncientCultivatorRuins</li>
			<!-- <li>GeothermalVents</li> -->
		</extraGenSteps>
	</BiomeDef>

</Defs>