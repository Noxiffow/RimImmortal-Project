<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Ancient cultivator ruins scatter step -->
	<GenStepDef>
		<defName>RI_GenStep_AncientCultivatorRuins</defName>
		<order>450</order>
		<genStep Class="RI_PeachBlossomLand.GenStep_PlaceItem">
			<!-- Items to scatter and their weights -->
			<itemsToScatter>
				<li Class="RI_PeachBlossomLand.ThingItem">
					<def>RI_Building_AncientCultivatorRuinsA</def>
					<score>10</score>
					<count>20~30</count>
					<!-- Place 10–20 -->
				</li>
				<li Class="RI_PeachBlossomLand.ThingItem">
					<def>RI_Building_AncientCultivatorLampRuinsA</def>
					<score>15</score>
					<count>10~25</count>
					<!-- Place 50–100 -->
				</li>
				<!--<li Class="RI_PeachBlossomLand.ThingItem">
                    <def>Steel</def>
                    <score>20</score>
                    <count>25</count> -->
				<!-- Steel: fixed placement of 25 -->
				<!--
                </li>
                <li Class="RI_PeachBlossomLand.ThingItem">
                    <def>ComponentIndustrial</def>
                    <score>10</score>
                    -->
				<!-- No count field — uses default 1-5 -->
				<!--
                </li>-->
				<!--<li Class="RI_PeachBlossomLand.ThingItem" MayRequire="Ludeon.RimWorld.Odyssey">
                    <def>GravEngine</def>
                    <score>10</score>
                    -->
				<!-- Test: place building -->
				<!--
                </li>-->
			</itemsToScatter>

			<!-- Item scatter control parameters -->
			<stackCountRange>1~3</stackCountRange>
			<!-- Deprecated: originally controlled stack count; now handled per-item by count field -->
			<minDistanceBetweenItems>2</minDistanceBetweenItems>
			<!-- Minimum distance between items to prevent clustering -->
			<maxItemsInRadius>5</maxItemsInRadius>
			<!-- Max items of the same type within the check radius -->
			<itemCountCheckRadius>5</itemCountCheckRadius>
			<!-- Search radius when checking item count -->
			<placementChance>0.8</placementChance>
			<!-- Item placement chance (0-1) — controls rarity -->

			<!-- Base scatter parameters -->
			<thingDef>Gold</thingDef>
			<!-- Placeholder — do not modify; actual items defined in itemsToScatter -->
			<createUsedRect>true</createUsedRect>
			<!-- Whether to mark used area to block other generators -->
			<allowInWaterBiome>false</allowInWaterBiome>
			<!-- Whether generation is allowed in water biomes -->
			<minSpacing>3</minSpacing>
			<!-- Minimum spacing between scatter positions -->
			<extraNoBuildEdgeDist>2</extraNoBuildEdgeDist>
			<!-- Extra no-build distance from map edges -->
			<!-- Controls total scatter count -->
			<countPer10kCellsRange>11~28</countPer10kCellsRange>
			<!-- Items generated per 10,000 map cells -->
			<clearSpaceSize>3</clearSpaceSize>
			<!-- Area cleared before placing an item -->
			<terrainValidationRadius>2</terrainValidationRadius>
			<!-- Radius for terrain validation -->
			<terrainValidationDisallowed>
				<!-- Terrain types where generation is disallowed -->
				<li>WaterShallow</li>
				<!-- Shallow water -->
				<li>WaterDeep</li>
				<!-- Deep water -->
				<li>Marsh</li>
				<!-- Marsh -->
			</terrainValidationDisallowed>

			<!-- Validators — ensure items can be placed correctly -->
			<validators>
				<li Class="ScattererValidator_Buildable">
					<!-- Validate whether the location is buildable -->
					<radius>2</radius>
					<!-- Check radius -->
					<affordance>Light</affordance>
					<!-- Required affordance: Light = lightweight foundation -->
				</li>
				<li Class="ScattererValidator_NoNonNaturalEdifices">
					<!-- Ensure no non-natural edifices nearby -->
					<radius>2</radius>
					<!-- Check radius -->
				</li>
				<li Class="ScattererValidator_AvoidSpecialThings" />
				<!-- Avoid special things -->
			</validators>
		</genStep>
	</GenStepDef>
</Defs>