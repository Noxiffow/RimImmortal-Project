	<!-- ============== Lu Shu ================ -->
	<ThingDef ParentName="AnimalThingBase">
		<defName>RI_Animal_LuShu</defName>
		<label>Lu Shu</label>
		<devNote>Lu Shu</devNote>
		<description>“On Mount Niuyang there is a beast. It resembles a horse with a white head, bears patterns like those of a tiger, and has a red tail. Its cry sounds like a chant. Its name is Lu Shu, and wearing its talisman is said to bring prosperity to one’s descendants.”\n\nLu Shu is a small, even-toed ungulate with beautiful markings and remarkable speed. They usually live and move in small groups led by a single male Lu Shu.\n\nLu Shu can be milked, and once domesticated, they may be used as pack animals. However, their carrying capacity is limited, making them unsuitable for long-distance travel.</description>
		<statBases>
			<MoveSpeed>7.5</MoveSpeed>
			<MarketValue>650</MarketValue>
			<ComfyTemperatureMin>-15</ComfyTemperatureMin>
			<ComfyTemperatureMax>50</ComfyTemperatureMax>
			<FilthRate>13</FilthRate>
			<CaravanRidingSpeedFactor>2.4</CaravanRidingSpeedFactor>
			<Wildness>0.6</Wildness>
		</statBases>
		<uiIconScale>0.9</uiIconScale>
		<!--Milkable-->
		<comps>
			<li Class="CompProperties_Milkable">
				<milkDef>Milk</milkDef>
				<milkIntervalDays>2</milkIntervalDays>
				<milkAmount>10</milkAmount>
			</li>
		</comps>
		<race>
			<herdAnimal>true</herdAnimal>
			<body>QuadrupedAnimalWithHooves</body>
			<baseBodySize>2.3</baseBodySize>
			<baseHealthScale>1.8</baseHealthScale>
			<baseHungerRate>0.7</baseHungerRate>
			<foodType>VegetarianRoughAnimal</foodType>
			<leatherDef>Leather_Plain</leatherDef>
			<gestationPeriodDays>6.66</gestationPeriodDays>
			<roamMtbDays>2</roamMtbDays>
