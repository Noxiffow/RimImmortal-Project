	<!-- ============== Lei cat ================ -->
	<ThingDef ParentName="AnimalThingBase">
		<defName>RI_Animal_LeiCat</defName>
		<label>Lei cat</label>
		<description>The Lei Cat resembles a slightly larger domestic cat. It has longer fur on its head, a nimble body, and smooth, supple fur marked with dark patterns.\n\nThese animals are solitary by nature and are only occasionally spotted in the mountains and wilderness. Local residents refer to similar creatures as “Xiangmao” (literally “fragrant-furred”).</description>
		<statBases>
			<!-- Move speed: slightly faster than a domestic cat -->
			<MoveSpeed>5.2</MoveSpeed>
			<MarketValue>270</MarketValue>
			<!-- High market value — a rare pet -->
			<ComfyTemperatureMin>-12</ComfyTemperatureMin>
			<ComfyTemperatureMax>40</ComfyTemperatureMax>
			<Wildness>0</Wildness>
		</statBases>
		<race>
			<body>QuadrupedAnimalWithPawsAndTail</body>
			<!--Predator-->
			<predator>true</predator>
			<maxPreyBodySize>0.4</maxPreyBodySize>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>0.6</baseBodySize>
			<baseHungerRate>0.2</baseHungerRate>
			<baseHealthScale>0.6</baseHealthScale>
			<foodType>CarnivoreAnimal, OvivoreAnimal</foodType>
			<leatherDef>Leather_Light</leatherDef>
			<!-- Lower nuzzleMtbHours = more frequent nuzzling. 8 = once per 8 game hours — boosts mood often! -->
			<nuzzleMtbHours>8</nuzzleMtbHours>
			<petness>1</petness>
			<!-- Not trainable -->
			<trainability>None</trainability>
			<lifeExpectancy>18</lifeExpectancy>
			<!-- Life stage attribute changes -->
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.3</minAge>
					<soundWounded>Pawn_Cat_Injured</soundWounded>
					<!-- Reuses vanilla cat sounds -->
					<soundDeath>Pawn_Cat_Death</soundDeath>
					<soundCall>Pawn_Cat_Call</soundCall>
					<soundAngry>Pawn_Cat_Angry</soundAngry>
				</li>
			</lifeStageAges>

			<!-- Animal-specific sounds and effects -->
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
		</race>
		<tools>
			<!-- Animal melee attacks: scratch and bite -->
			<li>
				<label>left claw</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>7</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right claw</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>7</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
			</li>
			<li>
				<label>teeth</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
		</tools>
		<tradeTags>
			<li>AnimalPet</li>
		</tradeTags>
	</ThingDef>


