<Defs>

	<!-- ============== Li Li ================ -->
	<ThingDef ParentName="AnimalThingBase">
		<defName>RI_Animal_LiLi</defName>
		<label>Li Li</label>
		<devNote>sheep-1</devNote>
		<description>“There is a beast known as Li Li. It resembles a pig, has prominent claws, and its cry sounds like a dog’s bark. When it appears, extensive earthworks are sure to follow.”\n\nLi Li is a small pig-like creature with a timid nature, feeding on insects in the soil as well as melons and fruits. It has sharp claws and a strong instinct for burrowing, spending most of its life in tunnels it digs itself. Whenever humans engage in large-scale construction, Li Li are driven out by the disturbance, bursting from the ground and fleeing in panic.\n\nIn some cultures, Li Li have been trained to assist in digging and mining, a practice that has drawn strong condemnation from animal protection groups.</description>
		<statBases>
			<MoveSpeed>3.5</MoveSpeed>
			<MarketValue>400</MarketValue>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<ComfyTemperatureMax>50</ComfyTemperatureMax>
			<FilthRate>8</FilthRate>
			<Wildness>0.5</Wildness>
		</statBases>
		<tools>
			<li>
				<label>left claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>8.4</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>8.4</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
			</li>
		</tools>
		<race>
			<!--Herd animal-->
			<herdAnimal>true</herdAnimal>
			<petness>0.50</petness>
			<!--Nuzzle interval-->
			<nuzzleMtbHours>24</nuzzleMtbHours>
			<baseBodySize>2.6</baseBodySize>
			<baseHealthScale>2.7</baseHealthScale>
			<baseHungerRate>0.7</baseHungerRate>
			<foodType>VegetarianRoughAnimal</foodType>
			<body>QuadrupedAnimalWithPaws</body>
			<leatherDef>Leather_Light</leatherDef>
			<roamMtbDays>2</roamMtbDays>
			<gestationPeriodDays>5.661</gestationPeriodDays>
			<waterCellCost>10</waterCellCost>
			<trainability>Advanced</trainability>
			<!--Special trainables-->
			<specialTrainables>
				<li MayRequire="Ludeon.RimWorld.Odyssey">Dig</li>
			</specialTrainables>
			<!--Uses this meat type-->
			<useMeatFrom>Pig</useMeatFrom>
			<litterSizeCurve>
				<points>
					<li>(0.5, 0)</li>
					<li>(1, 1)</li>
					<li>(1.5, 1)</li>
					<li>(2, 0)</li>
				</points>
			</litterSizeCurve>
			<lifeExpectancy>21</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.2</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.3333</minAge>
					<soundWounded>Pawn_Alphabeaver_Wounded</soundWounded>
					<soundDeath>Pawn_Alphabeaver_Death</soundDeath>
					<soundCall>Pawn_Alphabeaver_Call</soundCall>
					<soundAngry>Pawn_Alphabeaver_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<headPosPerRotation>
				<li>(0.0, 0, 0.25)</li>
				<li>(0.26, 0, 0.1)</li>
				<li>(0, 0, 0)</li>
				<li>(-0.26, 0, 0.1)</li>
			</headPosPerRotation>
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
		</tradeTags>
	</ThingDef>
