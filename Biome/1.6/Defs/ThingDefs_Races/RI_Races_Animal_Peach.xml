	<ThingDef ParentName="AnimalThingBase">
		<defName>RI_Animal_XuanTurtle</defName>
		<label>Xuan turtle</label>
		<devNote>misc</devNote>
		<description>“The Xuan turtle resembles a tortoise, yet bears the head of a bird and the tail of a viper. Its name is Xuan turtle; its sounds like wood being split. Wearing it wards off deafness, and it may also serve as a foundation.”\n\nXuan turtles favor quiet stretches of forest streams and still waters. Far more aggressive than ordinary turtles, their sharp, curved beaks can easily tear flesh, while their powerful limbs allow them to traverse rugged terrain and even climb rock faces. Xuan turtles are averse to heat; during summer, their flattened bodies slip into crevices between streambed stones to escape the high temperatures.</description>
		<statBases>
			<MoveSpeed>2.8</MoveSpeed>
			<MarketValue>700</MarketValue>
			<ArmorRating_Blunt>0.55</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.85</ArmorRating_Sharp>
			<ComfyTemperatureMin>-5</ComfyTemperatureMin>
			<ComfyTemperatureMax>40</ComfyTemperatureMax>
			<Wildness>0.7</Wildness>
		</statBases>
		<uiIconScale>1.25</uiIconScale>
		<tools>
			<li>
				<label>beak</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2.3</cooldownTime>
				<linkedBodyPartsGroup>TurtleBeakAttackTool</linkedBodyPartsGroup>
			</li>
		</tools>
		<!--Lays eggs-->
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>RI_Thing_EggXuanTurtleUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>RI_Thing_EggXuanTurtleFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>7</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~3</eggCountRange>
			</li>
			<li Class="RI_PeachBlossomLand.ThingComps.CompProperties_XuanTurtleLotusDance" />
		</comps>
		<race>
			<body>TurtleLike</body>
			<baseBodySize>0.7</baseBodySize>
			<baseHungerRate>0.1</baseHungerRate>
			<baseHealthScale>0.7</baseHealthScale>
			<foodType>OmnivoreRoughAnimal</foodType>
			<leatherDef>Leather_Lizard</leatherDef>
			<lifeExpectancy>180</lifeExpectancy>
			<trainability>Advanced</trainability>
			<specialTrainables>
				<li MayRequire="Ludeon.RimWorld.Odyssey">AttackTarget</li>
			</specialTrainables>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.15</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.2222</minAge>
					<soundWounded>Pawn_Tortoise_Wounded</soundWounded>
					<soundDeath>Pawn_Tortoise_Death</soundDeath>
					<soundCall>Pawn_Tortoise_Call</soundCall>
					<soundAngry>Pawn_Tortoise_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Reptile_Eat</soundEating>
			<headPosPerRotation>
				<li>(0.0, 0, 0.11)</li>
