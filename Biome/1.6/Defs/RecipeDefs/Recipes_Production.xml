	<!--芦荟搓医药-->
	<RecipeDef>
		<defName>RI_Recipe_MakeMedicineFromAloeVera</defName>
		<label>make medicine from aloe vera</label>
		<description>Extract the medicinal components from aloe vera and combine them with herbal medicine to produce medical.</description>
		<jobString>making medicine from aloe vera</jobString>
		<!--<effectWorking>Cremate</effectWorking>-->
		<soundWorking>Recipe_Cremate</soundWorking>
		<workAmount>2000</workAmount>
		<workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
		<workSkill>Intellectual</workSkill>
		<recipeUsers>
			<li>DrugLab</li>
			<li>RI_Building_ElixirsWorkbench</li>
		</recipeUsers>
		<researchPrerequisite>RI_InitialApproach_ElixirsStrengthen</researchPrerequisite>
		<skillRequirements>
			<Crafting>4</Crafting>
			<Intellectual>4</Intellectual>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_AloeVera</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>MedicineHerbal</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Cloth</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_AloeVera</li>
				<li>MedicineHerbal</li>
				<li>Cloth</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<MedicineIndustrial>1</MedicineIndustrial>
		</products>
	</RecipeDef>

