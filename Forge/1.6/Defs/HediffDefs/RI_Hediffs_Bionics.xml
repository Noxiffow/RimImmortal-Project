	<HediffDef ParentName="RI_addedPartAdvancedImplant">
		<defName>RI_Hediff_BlackSteelSpine</defName>
		<label>Black steel spine</label>
		<labelNoun>Black steel spine</labelNoun>
		<description>A prosthetic arm made of black steel.</description>
		<spawnThingOnRemoved>RI_Prostheses_BlackSteelSpine</spawnThingOnRemoved>
		<descriptionHyperlinks>
			<ThingDef>RI_Prostheses_BlackSteelSpine</ThingDef>
		</descriptionHyperlinks>
		<woundAnchorRange>0</woundAnchorRange>
		<displayWound>true</displayWound>
		<stages>
			<li>
				<statOffsets>
					<GI_EnergyGainEff>-0.5</GI_EnergyGainEff>
					<MeleeDodgeChance>10</MeleeDodgeChance>
					<MeleeHitChance>5</MeleeHitChance>
					<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
					<ArmorRating_Heat>0.1</ArmorRating_Heat>
				</statOffsets>
				<makeImmuneTo>
					<li>BadBack</li>
				</makeImmuneTo>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.3</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<addedPartProps>
			<betterThanNatural>true</betterThanNatural>
			<partEfficiency>2</partEfficiency>
			<solid>true</solid>
		</addedPartProps>
	</HediffDef>

	<!--Five Elements Series-->

	<!--Stomach-->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>RI_Hediff_EarthBionicStomach</defName>
		<label>Bionic stomach-Earth</label>
		<labelNoun>Bionic stomach-Earth</labelNoun>
		<description>An installed prosthetic heart. It contains an electric motor that pumps blood smoothly around the body. Users often report feeling tired, but it's better than the alternative.</description>
		<spawnThingOnRemoved>RI_Prostheses_EarthBionicStomach</spawnThingOnRemoved>
		<stages>
			<li>
				<statOffsets>
					<GI_EnergyGainEff>0.3</GI_EnergyGainEff>
				</statOffsets>
				<makeImmuneTo>
					<li>GutWorms</li>
				</makeImmuneTo>
				<foodPoisoningChanceFactor>0</foodPoisoningChanceFactor>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.5</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
	</HediffDef>

	<!--Core/Heart-->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>RI_Hediff_FireBionicHeart</defName>
		<label>Bionic heart-Fire</label>
		<labelNoun>Bionic heart-Fire</labelNoun>
		<description>An installed prosthetic heart. It contains an electric motor that pumps blood smoothly around the body. Users often report feeling tired, but it's better than the alternative.</description>
		<spawnThingOnRemoved>RI_Prostheses_FireBionicHeart</spawnThingOnRemoved>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>1.5</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.5</offset>
					</li>
				</capMods>
				<statOffsets>
					<GI_EnergyGainEff>0.25</GI_EnergyGainEff>
				</statOffsets>
				<makeImmuneTo>
					<li>HeartAttack</li>
					<li>HeartArteryBlockage</li>
				</makeImmuneTo>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>2.0</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
	</HediffDef>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>RI_Hediff_WaterBionicKidney</defName>
		<label>Bionic kidney-Water</label>
		<labelNoun>Bionic kidney-Water</labelNoun>
		<description>This ingenious bionic kidney can replace the original kidney and enhance the filtration system.</description>
		<spawnThingOnRemoved>RI_Prostheses_WaterBionicKidney</spawnThingOnRemoved>
		<!--<stages>
			<li>
				<makeImmuneTo>
					<li>ToxicBuildup</li>
				</makeImmuneTo>
			</li>
		</stages>-->
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>2.0</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
	</HediffDef>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>RI_Hediff_WoodBionicLiver</defName>
		<label>Bionic liver-Wood</label>
		<labelNoun>Bionic liver-Wood</labelNoun>
		<description>This exquisite bionic liver built by a clever machine can expel toxins from the body faster, wash the marrow and forge the body, and enhance immunity.</description>
		<spawnThingOnRemoved>RI_Prostheses_WoodBionicLiver</spawnThingOnRemoved>
		<stages>
			<li>
				<makeImmuneTo>
					<li>ToxicBuildup</li>
				</makeImmuneTo>
				<statOffsets>
					<ToxicResistance>0.7</ToxicResistance>
					<ToxicEnvironmentResistance>0.7</ToxicEnvironmentResistance>
				</statOffsets>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>2.0</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
	</HediffDef>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>RI_Hediff_MetalBionicLung</defName>
		<label>Bionic lung-Metal</label>
		<labelNoun>Bionic lung-Metal</labelNoun>
		<description>This exquisitely crafted artificial lung, created with divine skill and precision, can accommodate the spirit of heaven and earth, one breath and one breath, heaven and earth are connected.</description>
		<spawnThingOnRemoved>RI_Prostheses_MetalBionicLung</spawnThingOnRemoved>
		<stages>
			<li>
				<statOffsets>
					<GI_EnergyGainEff>0.15</GI_EnergyGainEff>
				</statOffsets>
				<makeImmuneTo>
					<li>Asthma</li>
					<li>LungRotExposure</li>
				</makeImmuneTo>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>2.0</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
	</HediffDef>

</Defs>