	<RecipeDef ParentName="RI_MakeBionicBase">
		<defName>Make_BlackSteelArm</defName>
		<label>make Black steel arm</label>
		<description>Make a Black steel arm.</description>
		<jobString>Making Black steel arm.</jobString>
		<researchPrerequisite>RI_BlackSteelSyntheticTechnology</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_DeviceCoreComponent</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_BlackSteel</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentSpacer</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_DeviceCoreComponent</li>
				<li>RI_Resource_BlackSteel</li>
				<li>ComponentSpacer</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Prostheses_BlackSteelArm>1</RI_Prostheses_BlackSteelArm>
		</products>
	</RecipeDef>

