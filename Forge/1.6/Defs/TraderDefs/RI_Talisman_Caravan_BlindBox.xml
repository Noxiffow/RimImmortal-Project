<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<TraderKindDef>
		<defName>RI_Talisman_Caravan_BlindBox</defName>
		<label>Treasure Finder</label>
		<commonality>2</commonality>
		<faction>OutlanderCivil</faction>
		<stockGenerators>
			<!-- Resources -->
			<li Class="StockGenerator_SingleDef">
				<thingDef>Silver</thingDef>
				<countRange>2000~3000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Gold</thingDef>
				<countRange>450~750</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Resource_SpiritualCrystal</thingDef>
				<countRange>8~12</countRange>
			</li>
			<!--Blind Box-->
			<li Class="StockGenerator_Tag">
				<tradeTag>RI_BlindBox_Tag</tradeTag>
				<!--Blind box caravan tag-->
				<thingDefCountRange>3~5</thingDefCountRange>
				<countRange>1~3</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Items_Quest_AncientComplex_Talismaker</thingDef>
				<countRange>-1~2</countRange>
				<!--50% probability of compass appearing-->
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Items_Quest_AncientComplexWithCasket_Talismaker</thingDef>
				<countRange>-8~1</countRange>
				<!--10% probability of ancient cultivator compass appearing-->
			</li>

			<!-- Buying -->
			<li Class="StockGenerator_BuyExpensiveSimple" />
			<li Class="StockGenerator_BuyTradeTag">
				<tag>Art</tag>
			</li>
			<li Class="StockGenerator_BuyTradeTag">
				<tag>MusicalInstrument</tag>
			</li>
			<li Class="StockGenerator_BuyTradeTag">
				<tag>PsylinkNeuroformer</tag>
			</li>
		</stockGenerators>
	</TraderKindDef>

	<TraderKindDef>
		<defName>Orbital_Immortals_BulkGoods</defName>
		<label>Free-cultivator space orbit merchant (Treasure Finder)</label>
		<commonality>1.5</commonality>
		<orbital>true</orbital>
		<stockGenerators>
			<!--Basic materials-->
			<li Class="StockGenerator_SingleDef">
				<thingDef>Silver</thingDef>
				<countRange>6000~12000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Resource_LiquidJade</thingDef>
				<countRange>10~20</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Resource_SpiritualCrystal</thingDef>
				<countRange>50~150</countRange>
			</li>
			<!-- Drugs -->
			<li Class="StockGenerator_Category">
				<categoryDef>RI_Category_Drugs</categoryDef>
				<thingDefCountRange>1~3</thingDefCountRange>
				<countRange>1~3</countRange>
			</li>
			<li Class="StockGenerator_Category">
				<categoryDef>RI_Category_DrugsMaterials</categoryDef>
				<thingDefCountRange>1~3</thingDefCountRange>
				<countRange>1~3</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Items_Quest_AncientGrave_Talismaker</thingDef>
				<countRange>0~1</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Items_Quest_AncientComplex_Talismaker</thingDef>
				<countRange>0~1</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_Items_Quest_AncientComplexWithCasket_Talismaker</thingDef>
				<countRange>0~1</countRange>
			</li>
			<!-- Boxes -->
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_BlindBox_InitialApproachBook</thingDef>
				<countRange>1~5</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_BlindBox_SkillBook</thingDef>
				<countRange>1~5</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_BlindBox_Weapon</thingDef>
				<countRange>1~5</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>RI_BlindBox_Armor</thingDef>
				<countRange>1~5</countRange>
			</li>
			<!-- Buying -->
			<li Class="StockGenerator_BuyExpensiveSimple" />
			<li Class="StockGenerator_BuyTradeTag">
				<tag>Art</tag>
			</li>
			<li Class="StockGenerator_BuyTradeTag">
				<tag>MusicalInstrument</tag>
			</li>

		</stockGenerators>
	</TraderKindDef>
</Defs>