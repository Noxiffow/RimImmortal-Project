<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--盲盒前置-->
	<ThingDef ParentName="ResourceBase" Name="RI_BlindBoxBase" Abstract="True">
		<graphicData>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<resourceReadoutPriority>Middle</resourceReadoutPriority>
		<soundInteract>Metal_Drop</soundInteract>
		<soundDrop>Metal_Drop</soundDrop>
		<stackLimit>1</stackLimit>
		<useHitPoints>true</useHitPoints>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<Mass>1</Mass>
			<Flammability>0.1</Flammability>
		</statBases>
		<thingCategories>
			<li>RI_Category_Relic</li>
		</thingCategories>
		<drawGUIOverlay>false</drawGUIOverlay>
		<techLevel>Medieval</techLevel>
		<tradeTags>
			<li>RI_BlindBox_Tag</li>
			<!--商队tag-->
		</tradeTags>
	</ThingDef>

	<!--玄妙石块（赌石？）-->
	<ThingDef ParentName="RI_BlindBoxBase">
		<defName>RI_BlindBox_Rock</defName>
		<label>Gambling stone</label>
		<description>A mysterious gambling stone, which can reveal some cultivation resources when examined.</description>
		<graphicData>
			<texPath>Things/Item/BlindBox/RI_BlindBox_Rock</texPath>
		</graphicData>
		<statBases>
			<MarketValue>2000</MarketValue>
		</statBases>
		<comps>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing">
				<thingDefList>
					<!--顶级，柔玉，灵石-->
					<li>RI_Resource_LiquidJade</li>
					<li>RI_Resource_LiquidJade</li>
					<li>RI_Resource_SpiritualCrystal</li>
					<li>RI_Resource_SpiritualCrystal</li>
					<li>RI_Resource_SpiritualCrystal</li>
					<li>RI_Resource_QingMingMarrow</li>
					<!--中级-->
					<li>Gold</li>
					<li>Jade</li>
					<li>Silver</li>
					<!--垃圾-->
					<li>Steel</li>
					<li>Steel</li>
				</thingDefList>
				<thingDefListNum>
					<!--顶级，柔玉，灵石-->
					<li>5</li>
					<li>7</li>
					<li>20</li>
					<li>30</li>
					<li>30</li>
					<li>1</li>
					<!--中级-->
					<li>20</li>
					<li>30</li>
					<li>100</li>
					<!--垃圾-->
					<li>5</li>
					<li>5</li>
				</thingDefListNum>
				<cost>5</cost>
				<completedLetterTitle>Expose the stone</completedLetterTitle>
				<completedLetterText>With Qi, you slowly opened the shell of this fragile relic, revealing its original appearance.</completedLetterText>
				<completedLetterDef>PositiveEvent</completedLetterDef>
			</li>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing_Batch"/>
		</comps>
	</ThingDef>

	<!--修士宝匣，给很多好东西哦-->
	<ThingDef ParentName="RI_BlindBoxBase">
		<defName>RI_BlindBox_CultivatorBox</defName>
		<label>Mysterious cultivator box</label>
		<description>An antique lacquer treasure box, contains precious cultivation materials.</description>
		<graphicData>
			<texPath>Things/Item/BlindBox/RI_BlindBox_CultivatorBox</texPath>
		</graphicData>
		<statBases>
			<MarketValue>4000</MarketValue>
		</statBases>
		<comps>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing">
				<thingDefList>
					<!--顶级资源，都是能放很久的-->
					<li>RI_Resource_OracleFragment</li>
					<li>RI_Resource_OracleFragment</li>
					<li>RI_Resource_OracleFragment</li>
					<li>RI_Things_JadeLiquid</li>
					<li>RI_Things_JadeLiquid</li>
					<li>RI_Things_JadeLiquidPro</li>
					<li>RI_Drug_FoundationBuildingElixir</li>
					<li>RI_Drug_FoundationBuildingElixir</li>
					<!--中级，只有柔玉-->
					<li>RI_Resource_LiquidJade</li>
					<li>RI_Resource_LiquidJade</li>
					<!--垃圾很少-->
					<li>RI_Resource_SpiritualCrystal</li>
				</thingDefList>
				<thingDefListNum>
					<!--顶级资源，都是能放很久的-->
					<li>1</li>
					<li>1</li>
					<li>2</li>
					<li>1</li>
					<li>2</li>
					<li>1</li>
					<li>1</li>
					<li>2</li>
					<!--中级，只有柔玉-->
					<li>8</li>
					<li>8</li>
					<!--垃圾很少-->
					<li>40</li>
				</thingDefListNum>
				<cost>5</cost>
				<completedLetterTitle>Expose the box</completedLetterTitle>
				<completedLetterText>With Qi, you slowly opened the shell of this fragile relic, revealing its original appearance.</completedLetterText>
				<completedLetterDef>PositiveEvent</completedLetterDef>
			</li>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing_Batch"/>
		</comps>
	</ThingDef>

</Defs>