<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Cultivation Method Book Blind Box-->
	<ThingDef ParentName="RI_BlindBoxBase">
		<defName>RI_BlindBox_InitialApproachBook</defName>
		<label>Mysterious initial approach book</label>
		<description>An ancient book that is unclear needs to be studied on a research table in order to discover what it actually is.</description>
		<graphicData>
			<texPath>Things/Item/BlindBox/InitialApproachBook</texPath>
		</graphicData>
		<statBases>
			<MarketValue>1500</MarketValue>
		</statBases>
		<comps>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing">
				<thingDefList>
					<!--Books-->
					<li>RI_BookA</li>
					<li>RI_BookB</li>
					<li>RI_BookC</li>
					<li>RI_BookD</li>
					<li MayRequire="RI.RimImmortal.FiveElements">RI_Book_FireElement</li>
					<!--<li MayRequire="RI.RimImmortal.FiveElements">RI_Book_WaterElement</li>
					<li MayRequire="RI.RimImmortal.FiveElements">RI_Book_EarthElement</li>
					<li MayRequire="RI.RimImmortal.FiveElements">RI_Book_WoodElement</li>
					<li MayRequire="RI.RimImmortal.FiveElements">RI_Book_MetalElement</li>-->
					<!--Guaranteed-->
					<li>Synthread</li>
				</thingDefList>
				<thingDefListNum>
					<!--Books-->
					<li>1</li>
					<li>1</li>
					<li>1</li>
					<li>1</li>
					<li>1</li>
					<!--Guaranteed-->
					<li>30</li>
				</thingDefListNum>
				<cost>5</cost>
				<completedLetterTitle>Expose the relic</completedLetterTitle>
				<completedLetterText>With Qi, you slowly opened the shell of this fragile relic, revealing its original appearance.</completedLetterText>
				<completedLetterDef>PositiveEvent</completedLetterDef>
			</li>
			<li Class="RI_Talisman.CompProperties_BlindBoxUsing_Batch"/>
		</comps>
	</ThingDef>

