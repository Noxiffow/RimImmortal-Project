	<!--铜钱吊坠-->
	<ThingDef ParentName="RI_Talisman_Base">
		<defName>RI_Talisman_CoinsPendant</defName>
		<label>Coin pendant【Third-rate】</label>
		<description>【Third-rate】Talisman.\n\nA red rope pendant with coins. The design source of the coin pendant is heard to be an ancient Taoist school handed down the talisman. They imprinted a kind of body protection exercises and spiritual stones called golden mantra on specially treated copper coins, so that ordinary people wearing copper coins can temporarily use a small part of the power of the body protection gold. After many years of iteration and upgrading, coin pendants have become synonymous with cheap shields, and are loved by many free-cultivators.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Talisman/RI_Talisman_CoinsPendant</texPath>
		</graphicData>
		<statBases>
			<Mass>0.2</Mass>
			<MarketValue>250</MarketValue>
			<MaxHitPoints>150</MaxHitPoints>
		</statBases>
		<comps>
			<li Class="CompProperties_ApparelReloadable">
				<hotKey>Misc4</hotKey>
				<soundReload>Standard_Reload</soundReload>
				<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
				<maxCharges>3</maxCharges>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>1</ammoCountPerCharge>
				<baseReloadTicks>60</baseReloadTicks>
				<chargeNoun>flare</chargeNoun>
			</li>
			<li Class="RI_Talisman_Item.CompProperties_ExOneHediff">
				<hediffDef>RI_ShieldHediff_CoinShield</hediffDef>
			</li>
		</comps>
		<verbs>
			<li>
				<verbClass>RI_Talisman_Item.Verb_RI_Talisman_GetHediff</verbClass>
				<label>Golden shield</label>
				<commandIcon>Ability/Talisman/RI_Talisman_CoinsPendant_Shield</commandIcon>
				<defaultProjectile>RI_BlankProjectile</defaultProjectile>
				<warmupTime>0.25</warmupTime>
				<range>1</range>
				<burstShotCount>1</burstShotCount>
				<onlyManualCast>true</onlyManualCast>
				<hasStandardCommand>true</hasStandardCommand>
				<targetable>true</targetable>
				<violent>false</violent>
				<targetParams>
					<canTargetPawns>true</canTargetPawns>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
			</li>
		</verbs>
		<thingSetMakerTags>
			<!--<li>RewardStandardQualitySuper</li>-->
			<li>RewardStandardLowFreq</li>
			<!--罕见任务奖励-->
		</thingSetMakerTags>
	</ThingDef>

