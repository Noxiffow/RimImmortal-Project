<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef Name="BaseRI_Puppet" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>800</MarketValue>
			<MoveSpeed>4</MoveSpeed>
			<ArmorRating_Blunt>0.10</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.20</ArmorRating_Sharp>
		</statBases>
		<race>
			<body>RI_Puppet_BodyDef</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<thinkTreeConstant>WarUrchinConstant</thinkTreeConstant>
			<baseBodySize>2</baseBodySize>
			<baseHealthScale>1</baseHealthScale>
		</race>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>

	<PawnKindDef Name="BaseRI_PuppetKind" ParentName="BaseMechanoidKind" Abstract="True">
		<weaponMoney>9999~9999</weaponMoney>
		<combatPower>100</combatPower>
		<weaponTags></weaponTags>
		<techHediffsChance>1</techHediffsChance>
		<techHediffsMoney>9999~9999</techHediffsMoney>
		<allowInMechClusters>false</allowInMechClusters>
	</PawnKindDef>

	<HediffDef>
		<defName>RI_PuppetFightHediff</defName>
		<label>Auto defence tech</label>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<everCurableByItem>false</everCurableByItem>
		<defaultLabelColor>(0, 255, 255)</defaultLabelColor>
		<description>An ancient martial art, modified and encoded into data stored in the golem's talisman components, that automatically blocks incoming attacks.</description>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
		<stages>
			<li>
				<statFactors>
					<IncomingDamageFactor>0.8</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>



	<!--Wooden Golem-->


	<ThingDef ParentName="BaseRI_Puppet">
		<defName>RI_WoodenPuppet</defName>
		<label>Wooden golem</label>
		<description>It is a simple wooden golem, slow in movement and very low in attack, mostly used as a sandbag for the disciples to exercise.</description>
		<statBases>
			<Flammability>0</Flammability>
			<MoveSpeed>2.5</MoveSpeed>
			<ArmorRating_Blunt>0.6</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
			<ArmorRating_Heat>0</ArmorRating_Heat>
		</statBases>
		<race>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Mech_Militor_Wounded</soundWounded>
					<soundDeath>Pawn_Mech_Militor_Death</soundDeath>
					<soundCall>Pawn_Mech_Militor_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<comps  Inherit="False">
			<li Class="RI_Puppet.CompProperties_HitDefend">
				<hediffToAdd>RI_PuppetFightHediff</hediffToAdd>
				<duration>60</duration>
			</li>
			<li Class="CompProperties_CanBeDormant" />
            <li Class="CompProperties_WakeUpDormant">
                <wakeUpOnDamage>true</wakeUpOnDamage>
                <wakeUpCheckRadius>30</wakeUpCheckRadius>
                <wakeUpSound>MechanoidsWakeUp</wakeUpSound>
            </li>
            <li Class="CompProperties_MechPowerCell">
                <totalPowerTicks>72000</totalPowerTicks>
            </li>
		</comps>
		<butcherProducts>
			<WoodLog>30</WoodLog>
		</butcherProducts>
		<tools>
			<li>
				<label>left fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5.0</power>
				<cooldownTime>4</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
			<li>
				<label>right fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5.0</power>
				<cooldownTime>4</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
		</tools>
	</ThingDef>

	<PawnKindDef ParentName="BaseRI_PuppetKind">
		<defName>RI_WoodenPuppet</defName>
		<label>Wooden golem</label>
		<race>RI_WoodenPuppet</race>
		<combatPower>100</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Pawn/Golem/WoodenGolem/RI_WoodenGolem</texPath>
