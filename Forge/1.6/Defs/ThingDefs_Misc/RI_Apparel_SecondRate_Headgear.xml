<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--古修盔-->
	<ThingDef ParentName="RI_BestMakeableHelmet_NostuffCategories_Base">
		<defName>RI_Apparel_AncientCultivatorHelmet</defName>
		<label>Ancient cultivator helmet</label>
		<description>Ancient cultivators crafted helmets from steel and spirit stones, which had powerful protective abilities. It seems that they embedded thin and delicate talisman inside the helmets, allowing them to protect psychic waves. Due to the passage of time, it is difficult to analyze the principles involved.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/Ancient/RI_Apparel_AncientCultivatorHelmet</texPath>
		</graphicData>

		<statBases>
			<MaxHitPoints>3000</MaxHitPoints>
			<MarketValue>250</MarketValue>
			<Mass>3</Mass>
			<Flammability>0.5</Flammability>
			<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>1</ArmorRating_Blunt>
			<ArmorRating_Heat>0.3</ArmorRating_Heat>
			<Insulation_Cold>15</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<tags>
				<li>RI_AncientCultivatorArmor</li>
			</tags>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/Ancient/RI_Apparel_AncientCultivatorHelmet</wornGraphicPath>
			<!--和发型同时显示-->
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
		</apparel>
		<equippedStatOffsets>
			<PsychicSensitivity>-1</PsychicSensitivity>
		</equippedStatOffsets>
				<!--贸易标签-->
		<tradeTags>
			<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
	</ThingDef>

	<!--柔玉抹额【三品】-->
	<ThingDef ParentName="RI_MakeableHatNostuffCategories_Base">
		<defName>RI_Apparel_LiquidJadeHeadband</defName>
		<label>Liquid jade headband【Third-rate】</label>
		<description>A headband with liquid jade and set in the center. This kind of headband can have a calming effect on the spirit and slightly increase the speed of cultivation.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/SoftJadeHeadband/RI_Apparel_SoftJadeHeadband</texPath>
		</graphicData>

		<!--原料-->
		<costList>
			<Cloth>50</Cloth>
			<RI_Resource_LiquidJade>3</RI_Resource_LiquidJade>
		</costList>

		<statBases>
			<MaxHitPoints>350</MaxHitPoints>
			<MarketValue>750</MarketValue>
			<Mass>0.2</Mass>
			<Flammability>1</Flammability>
			<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
			<Insulation_Cold>5</Insulation_Cold>
			<Insulation_Heat>5</Insulation_Heat>
			<EquipDelay>1</EquipDelay>
		</statBases>
		<apparel>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/SoftJadeHeadband/RI_Apparel_SoftJadeHeadband</wornGraphicPath>
			<!--和发型同时显示-->
			<renderSkipFlags>
				<li>None</li>
			</renderSkipFlags>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
		</apparel>
		<recipeMaker>
			<researchPrerequisite>RI_InitialApproach_ToolsStrengthen</researchPrerequisite>
			<displayPriority>170</displayPriority>
		</recipeMaker>
		<equippedStatOffsets>
			<PainShockThreshold>0.05</PainShockThreshold>
		</equippedStatOffsets>
		<!--贸易标签-->
		<tradeTags>
			<li>RI_SecondRateArmor_Tag</li>
		<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
	</ThingDef>

	<!--武曲纯阳巾【二品】-->
