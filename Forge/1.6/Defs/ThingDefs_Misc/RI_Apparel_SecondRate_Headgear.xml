	<!--鎏金天王盔-->
	<ThingDef ParentName="RI_MakeableHelmetNostuffCategories_Base">
		<defName>RI_Apparel_GoldBestHelmet</defName>
		<label>Gilded general helmet【Second-rate】</label>
		<description>【Second-rate】helmet\n\nA gilded helmet with a magnificent appearance, refined through the method of forge, exuding a faint aura of spiritual might.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/GoldBestHelmet/RI_Apparel_GoldBestHelmet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>

		<!--原料-->
		<costList>
			<Gold>5</Gold>
			<Plasteel>40</Plasteel>
			<RI_Resource_BlackSteel>5</RI_Resource_BlackSteel>
			<RI_Resource_DeviceCoreComponent>1</RI_Resource_DeviceCoreComponent>
		</costList>

		<recipeMaker>
			<researchPrerequisite>RI_Research_BetterWeapon</researchPrerequisite>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers>
				<li>RI_Building_EnergyForge</li>
				<li>RI_Building_SpiritForge</li>
			</recipeUsers>
		</recipeMaker>

		<statBases>
			<WorkToMake>8000</WorkToMake>
			<MaxHitPoints>600</MaxHitPoints>
			<Mass>1.5</Mass>
			<Flammability>0.4</Flammability>
			<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Heat>0.6</ArmorRating_Heat>
			<Insulation_Cold>15</Insulation_Cold>
			<Insulation_Heat>35</Insulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>

		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/GoldBestHelmet/RI_Apparel_GoldBestHelmet</wornGraphicPath>
			<tags>
				<li>RI_MegicArmor_Tag</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
		<!--特殊效果-->
		<equippedStatOffsets>
			<PainShockThreshold>0.1</PainShockThreshold>
			<MentalBreakThreshold>-0.05</MentalBreakThreshold>
			<ArrestSuccessChance>0.05</ArrestSuccessChance>
			<SuppressionPower MayRequire="Ludeon.RimWorld.Ideology">0.05</SuppressionPower>
		</equippedStatOffsets>
		<!--贸易标签-->
		<tradeTags>
			<li>RI_SecondRateArmor_Tag</li>
		<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
	</ThingDef>

