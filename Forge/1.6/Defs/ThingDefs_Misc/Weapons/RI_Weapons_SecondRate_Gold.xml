<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Celestial soldier style weapons — newly added-->

	<!--Gilt Dragon-Tiger Sword-->
	<ThingDef ParentName="RI_MagicalWeapon_Sharp_Base">
		<defName>RI_Weapon_GoldSword</defName>
		<label>Gilded dragon-tiger sword【Second-rate】</label>
		<description>【Second-rate】Melee weapon\n\nA gilded one-handed sword with a luxurious appearance, refined through the method of Forge, granting it formidable lethality.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/SecondRate/RI_Weapon_GoldSword</texPath>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>2</drawSize>
		</graphicData>

		<!--Raw Materials-->
		<costList>
			<RI_Resource_SpiritualCrystal>10</RI_Resource_SpiritualCrystal>
			<RI_Resource_DeviceCoreComponent>1</RI_Resource_DeviceCoreComponent>
			<Gold>5</Gold>
		</costList>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
			<li>Woody</li>
		</stuffCategories>
		<costStuffCount>70</costStuffCount>

		<statBases>
			<WorkToMake>15000</WorkToMake>
			<Mass>1.2</Mass>
		</statBases>
		<equippedAngleOffset>-25</equippedAngleOffset>
		<recipeMaker>
			<researchPrerequisite>RI_Research_BetterWeapon</researchPrerequisite>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers>
				<li>RI_Building_EnergyForge</li>
				<li>RI_Building_SpiritForge</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
			<displayPriority>410</displayPriority>
		</recipeMaker>
		<!--Tag-->
		<weaponTags>
			<li>RI_Tag_MagicalWeapon_Sword</li>
			<li>RI_Tag_MagicalWeapon_Second</li>
			<li>RI_Tag_GoldWeapon</li>
		</weaponTags>
		<!--Trade Tag-->
		<tradeTags>
			<li>RI_Weapon_Gold_Tag</li>
		    <li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
		<!--Weapon attack effect-->
		<tools>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>45</power>
				<cooldownTime>1.8</cooldownTime>
				<armorPenetration>0.25</armorPenetration>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_ArmorBreak</def>
						<amount>4</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

