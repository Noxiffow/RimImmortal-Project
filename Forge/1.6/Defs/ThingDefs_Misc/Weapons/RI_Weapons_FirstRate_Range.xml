<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<!--雷霆机枪-->
	<ThingDef ParentName="RI_MagicalWeapon_Range_Base">
		<defName>RI_Weapon_ThunderMinigun</defName>
		<label>Thunder minigun【First-rate】</label>
		<description>【First-rate】Range weapon\n\nA beaded machine gun, capable of attracting the force of angry thunder, fired a bullet with a weak electric charge, enough to tear through heavy armor. After loading the spiritual crystal, it can also shoot powerful lightning.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_ThunderMinigun</texPath>
			<drawSize>1.4</drawSize>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<statBases>
			<MarketValue>4800</MarketValue>
			<Mass>25.0</Mass>
			<AccuracyTouch>0.5</AccuracyTouch>
			<AccuracyShort>0.6</AccuracyShort>
			<AccuracyMedium>0.7</AccuracyMedium>
			<AccuracyLong>0.7</AccuracyLong>
			<RangedWeapon_Cooldown>3.5</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BestWeapon_Tag</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_ThunderMinigun</defaultProjectile>
				<warmupTime>1.5</warmupTime>
				<range>50</range>
				<soundCast>Shot_ChargeRifle</soundCast>
				<burstShotCount>15</burstShotCount>
				<ticksBetweenBurstShots>6</ticksBetweenBurstShots>
				<minRange>1</minRange>
			</li>
		</verbs>
		<tools>
			<li>
				<label>枪管</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_ThunderMinigun_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<drawSize>1.4</drawSize>
					<color>(0.8,0.8,0.8,0.9)</color>
				</graphicData>
			</li>
			<li Class="RI_Starch.RI_WeaponHediffComp.RI_CompProperties_WeaponHediff">
				<hediffDef>RI_Hediff_Weapon_ThunderMinigun</hediffDef>
			</li>
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_ThunderMinigun_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>ThunderMinigun</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>3</ammoCountPerCharge>
				<baseReloadTicks>210</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponMelee</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_ThunderMinigun</defName>
		<label>Thunder bullet</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_ThunderMinigun</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>23</damageAmountBase>
			<speed>75</speed>
			<armorPenetrationBase>0.7</armorPenetrationBase>
			<stoppingPower>0.5</stoppingPower>
			<shadowSize>0</shadowSize>
			<extraDamages>
				<li>
					<def>EMP</def>
					<amount>5</amount>
					<chance>0.25</chance>
				</li>
			</extraDamages>
		</projectile>
	</ThingDef>

	<FleckDef ParentName="RI_Fleck_Tail">
		<defName>RI_Fleck_Tail_ThunderMinigun_1</defName>
		<graphicData>
			<texPath>Effects/ThunderLordLance/ElectricalSpark</texPath>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>0.01</solidTime>

		<fadeOutTime>0.09</fadeOutTime>
		<growthRate>-1.6</growthRate>
	</FleckDef>

	<!--霜弓-->
	<ThingDef ParentName="RI_MagicalWeapon_Range_Base">
		<defName>RI_Weapon_WhiteApeBow</defName>
		<label>White ape bow【First-rate】</label>
		<description>【First-rate】Range weapon\n\nA longbow made from the spirit of sky and earth, using a thrumbo horn and mechanical structure as the bow body, each arrow carries a low temperature, which can gradually freeze the enemy.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_WhiteApeBow</texPath>
			<drawSize>1.3</drawSize>
		</graphicData>
		<soundInteract>Bow_Large</soundInteract>
		<statBases>
			<MarketValue>5800</MarketValue>
			<Mass>16.0</Mass>
			<AccuracyTouch>0.6</AccuracyTouch>
			<AccuracyShort>0.7</AccuracyShort>
			<AccuracyMedium>0.8</AccuracyMedium>
			<AccuracyLong>0.9</AccuracyLong>
			<RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BestWeapon_Tag</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Arrow_WhiteApeBow</defaultProjectile>
				<warmupTime>2.4</warmupTime>
				<range>70</range>
				<soundCast>Bow_Large</soundCast>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>1</ticksBetweenBurstShots>
				<minRange>3.5</minRange>
			</li>
		</verbs>
		<tools>
			<li>
				<label>bow</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_WhiteApeBow_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<color>(0.8,0.8,0.8,0.8)</color>
					<drawSize>1.3</drawSize>
				</graphicData>
			</li>
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_WhiteApeBow_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Frozen rain</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>3</ammoCountPerCharge>
				<baseReloadTicks>200</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
			<li Class="RI_Starch.RI_WeaponHediffComp.RI_CompProperties_WeaponHediff">
				<hediffDef>RI_Hediff_Weapon_WhiteApeBow</hediffDef>
			</li>
		</comps>
	</ThingDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseProjectileNeolithic">
		<defName>RI_Arrow_WhiteApeBow</defName>
		<label>White frost arrow</label>
		<graphicData>
			<drawSize>3</drawSize>
			<texPath>Things/Projectile/RI_Arrow_WhiteApeBow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>RI_Starch.RI_Projectile.RI_Projectile_Rot</thingClass>
		<projectile>
			<damageDef>Arrow</damageDef>
			<damageAmountBase>55</damageAmountBase>
			<stoppingPower>1.5</stoppingPower>
			<armorPenetrationBase>0.85</armorPenetrationBase>
			<speed>70</speed>
			<arcHeightFactor>3</arcHeightFactor>
			<shadowSize>0</shadowSize>
		</projectile>
		<fleck1>RI_Fleck_Tail_WhiteApeBow</fleck1>
		<frequency>-1</frequency>
		<scale1>0.3</scale1>
		<shaking1>0.15</shaking1>
		<color1>(0.9,0.9,0.9)</color1>
		<fleck>RI_Fleck_Tail</fleck>
		<scale>0.8</scale>
		<shaking>0.1</shaking>
		<color>(1,1,1,1)</color>
	</ThingDef>

	<!--白色拖尾-->
	<FleckDef ParentName="RI_Fleck_Tail">
		<defName>RI_Fleck_Tail_WhiteApeBow</defName>
		<graphicData>
			<texPath>Effects/WhiteApeBow/RI_tail_WhiteApeBow</texPath>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.08</fadeInTime>
		<solidTime>0.03</solidTime>
		<fadeOutTime>0.26</fadeOutTime>
		<growthRate>-1.2</growthRate>
	</FleckDef>
	
</Defs>

