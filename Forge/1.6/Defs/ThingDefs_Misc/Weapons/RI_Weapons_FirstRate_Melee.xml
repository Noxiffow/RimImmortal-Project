			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_ChiYouFlameHalberd</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.7</drawSize>
		</graphicData>
		<weaponTags>
			<li>RI_BestWeapon_Tag</li>
		</weaponTags>
		<ShockAngle>10</ShockAngle>
		<ShockLength>9</ShockLength>
		<ShockDamageDef>Flame</ShockDamageDef>
		<ShockPR>0.85</ShockPR>
		<ShockStun>0</ShockStun>
		<ShockAmount>10</ShockAmount>

		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<statBases>
			<MarketValue>4500</MarketValue>
			<!--<WorkToMake>10600</WorkToMake>-->
			<Mass>4.6</Mass>
		</statBases>
		<costList>
			<Steel>50</Steel>
		</costList>
		<equippedAngleOffset>-45</equippedAngleOffset>
		<tools>
			<li>
				<label>Halberd Blade</label>
				<capacities>
					<li>RI_Cut_ChiYouFlameHalberd</li>
				</capacities>
				<power>40</power>
				<cooldownTime>2.0</cooldownTime>
				<chanceFactor>9999</chanceFactor>
				<extraMeleeDamages>
					<li>
						<def>Flame</def>
						<amount>12</amount>
						<chance>0.7</chance>
					</li>
					<li>
						<def>RI_Damage_Puncture</def>
						<amount>5</amount>
						<chance>0.3</chance>
					</li>
				</extraMeleeDamages>
			</li>
			<li>
				<label>Halberd Tip</label>
				<capacities>
					<li>Stab</li>
					<li>RI_Cut_ChiYouFlameHalberd</li>
				</capacities>
				<power>30</power>
				<cooldownTime>1.8</cooldownTime>
				<chanceFactor>9929</chanceFactor>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_Puncture</def>
						<amount>5</amount>
						<chance>1</chance>

					</li>
					<li>
						<def>Flame</def>
						<amount>12</amount>
						<chance>0.7</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
		
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_ChiYouFlameHalberd_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<drawSize>1.7</drawSize>
					<color>(0.8,0.8,0.8,0.9)</color>
				</graphicData>
			</li>
			<li Class="RI_Starch.RI_WeaponHediffComp.RI_CompProperties_WeaponHediff">
				<hediffDef>RI_Hediff_ChiYouFlameHalberd</hediffDef>
			</li>
