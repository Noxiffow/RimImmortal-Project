<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef Name="RI_AncientWeaponBase" ParentName="BaseWeapon" Abstract="True">
		<smeltable>false</smeltable>
		<burnableByRecipe>false</burnableByRecipe>
		<weaponClasses>
			<li>Melee</li>
		</weaponClasses>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<possessionCount>1</possessionCount>
		<uiIconScale>1.5</uiIconScale>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<thingCategories>
			<li>RI_Category_Weapon</li>
		</thingCategories>
		<techLevel>Medieval</techLevel>
		<relicChance>0</relicChance>
		<weaponTags>
			<li>RI_AncientWeapon</li>
		</weaponTags>
		<inspectorTabs>
			<li>ITab_Art</li>
		</inspectorTabs>
		<!--贸易标签-->
		<tradeTags>
			<li>RI_AncientWeapon_Tag</li>
			<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
		<comps>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponMelee</nameMaker>
				<descriptionMaker>ArtDescription_WeaponMelee</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<!--古修动力拳套-->
	<ThingDef ParentName="RI_AncientWeaponBase">
		<defName>RI_Weapon_AncientPowerBoxing</defName>
		<label>Ancient power fist【Second-rate】</label>
		<description>【Second-rate】melee, attack the enemy will have a Vertigo effect.\n\nA pair of push-dagger with a faint Qi. A kind of push-dagger weapon made by thrumbo horn. Small and chic, but the attack speed is very fast, contains a powerful lethality.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_AncientPowerBoxing</texPath>
		</graphicData>
		<weaponClasses>
			<li>MeleeBlunt</li>
		</weaponClasses>
		<statBases>
			<MarketValue>2550</MarketValue>
			<Mass>3.5</Mass>
		</statBases>
		<equippedAngleOffset>0</equippedAngleOffset>
		<tools>
			<li>
				<label>head</label>
				<labelUsedInLogging>false</labelUsedInLogging>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>18</power>
				<cooldownTime>1</cooldownTime>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_Vertigo</def>
						<amount>4</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

	<!--古修匕首-->
	<ThingDef ParentName="RI_AncientWeaponBase">
		<defName>RI_Weapon_AncientDagger</defName>
		<label>Ancient dagger【Second-rate】</label>
		<description>【Second-rate】melee, attack the enemy will have a puncture effect.\n\nThe ancient cultivator used a dagger made of iron, the energy light fluttered, a glance can be seen to have a good lethality.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_AncientDagger</texPath>
		</graphicData>
		<weaponClasses>
			<li>MeleePiercer</li>
		</weaponClasses>
		<statBases>
			<MarketValue>2550</MarketValue>
			<Mass>3.5</Mass>
		</statBases>
		<equippedAngleOffset>-15</equippedAngleOffset>
		<tools>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>21</power>
				<cooldownTime>1</cooldownTime>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_Puncture</def>
						<amount>4</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>18</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

	<!--古修长刀-->
	<ThingDef ParentName="RI_AncientWeaponBase">
		<defName>RI_Weapon_AncientBlade</defName>
		<label>Ancient blade【Second-rate】</label>
		<description>【Second-rate】melee, attack the enemy will have a Armor Break effect.\n\nA blade made of iron used by the ancient cultivators is still very sharp, though it has been used for unknown years.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_AncientBlade</texPath>
			<drawSize>1.3,1.3</drawSize>
		</graphicData>
		<weaponClasses>
			<li>MeleePiercer</li>
		</weaponClasses>
		<statBases>
			<MarketValue>2550</MarketValue>
			<Mass>3.5</Mass>
		</statBases>
		<equippedAngleOffset>-15</equippedAngleOffset>
		<tools>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>25</power>
				<cooldownTime>1.8</cooldownTime>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_ArmorBreak</def>
						<amount>4</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

	<!--古修灵铳-->
	<ThingDef ParentName="RI_MagicalWeapon_Range_Base">
		<defName>RI_Weapon_AncientGun</defName>
		<label>Ancient rifle【Second-rate】</label>
		<description>【Second-rate】Range weapon\n\nA fire-blaster shaped like a dragon head with a laser firing system. The weapon was said to be a blunderbuss, but its caliber was closer to a cannonball, and it fired hot pellets that were terrifying to kill. At the same time, the weapon can adjust the muzzle to shoot a high-temperature laser through the energy array.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_AncientGun</texPath>
			<drawSize>1.3</drawSize>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<statBases>
			<MarketValue>3200</MarketValue>
			<Mass>4.0</Mass>
			<AccuracyTouch>0.7</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>1.00</AccuracyMedium>
			<AccuracyLong>1.00</AccuracyLong>
			<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BetterGuns_Tag</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_AncientGun</defaultProjectile>
				<warmupTime>2</warmupTime>
				<range>48</range>
				<soundCast>Shot_Autocannon</soundCast>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<minRange>1</minRange>
			</li>
		</verbs>
		<tools>
			<li>
				<label>枪托</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps>
			<li Class="RI_Starch.RI_WeaponHediffComp.RI_CompProperties_WeaponHediff">
				<hediffDef>RI_Hediff_AncientGun</hediffDef>
			</li>
		</comps>
	</ThingDef>

	<!--灵铳子弹-->
	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseBullet">
		<defName>RI_Bullet_AncientGun</defName>
		<label>Qi bullet</label>
		<graphicData>
			<texPath>Things/Projectile/RI_AncientBullet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>RI_Starch.RI_Projectile.RI_Projectile_Rot</thingClass>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>48</damageAmountBase>
			<speed>120</speed>
			<armorPenetrationBase>0.7</armorPenetrationBase>
			<stoppingPower>2</stoppingPower>
			<arcHeightFactor>0</arcHeightFactor>
			<shadowSize>0</shadowSize>
			<extraDamages>
				<li>
					<def>Flame</def>
					<amount>20</amount>
					<chance>0.3</chance>
				</li>
			</extraDamages>
		</projectile>
	</ThingDef>

</Defs>

