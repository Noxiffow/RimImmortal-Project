<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Short Rifle-->
	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>RI_Weapon_Harquebus</defName>
		<label>Triple shot harquebus【Third-rate】</label>
		<description>【Third-rate】range.\n\nAn archaic arquegun, but made of excellent material, capable of firing three rounds in a row.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/ThirdRate/RI_Weapon_Harquebus</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<weaponClasses>
			<li>Ranged</li>
			<li>RangedLight</li>
		</weaponClasses>
		<weaponTags>
			<li>RI_Tag_BasicGun</li>
			<li>RI_MagicalWeapon</li>
		</weaponTags>
		<tradeTags>
			<li>RI_ThirdWeapon_Tag</li>
		</tradeTags>
		<statBases>
			<WorkToMake>8000</WorkToMake>
			<Mass>3.5</Mass>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.90</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<Steel>60</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
		</costList>
		<recipeMaker>
			<recipeUsers>
				<li>FueledSmithy</li>
				<li>ElectricSmithy</li>
			</recipeUsers>
			<researchPrerequisite>RI_Research_CultivatorWeapon</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<displayPriority>500</displayPriority>
		</recipeMaker>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_Harquebus</defaultProjectile>
				<warmupTime>1.7</warmupTime>
				<burstShotCount>3</burstShotCount>
				<range>25</range>
				<soundCast>Shot_BoltActionRifle</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_Harquebus</defName>
		<label>Spiritual bullet</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>22</damageAmountBase>
			<stoppingPower>1.5</stoppingPower>
			<speed>70</speed>
		</projectile>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_Harquebus</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
	</ThingDef>

