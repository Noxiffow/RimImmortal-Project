		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/ThirdRate/RI_Weapon_BasicBow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
