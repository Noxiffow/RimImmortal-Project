	<!--Throwing Dart-->
	<ThingDef ParentName="BaseWeaponNeolithic">
		<defName>RI_Weapon_ThrowingKnife</defName>
		<label>Throwing knife【Third-rate】</label>
		<description>【Third-rate】range.\n\nA throwing knife embedded with a spiritual crystal to inflict more damage. This kind of assassinate weapon is despised by the upright man, but because of its practicality, many travelers will carry one or two throwing knives for self-defense.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/ThirdRate/RI_Weapon_ThrowingKnife</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_BeatFire</soundInteract>
		<costList>
			<Steel>70</Steel>
		</costList>
		<relicChance>0</relicChance>
		<statBases>
			<WorkToMake>7000</WorkToMake>
			<Mass>4</Mass>
			<AccuracyTouch>0.50</AccuracyTouch>
			<AccuracyShort>0.71</AccuracyShort>
			<AccuracyMedium>0.50</AccuracyMedium>
			<AccuracyLong>0.32</AccuracyLong>
			<RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_MagicalWeapon</li>
			<li>RI_Tag_BasicGun</li>
		</weaponTags>
		<weaponClasses>
			<li>Ranged</li>
		</weaponClasses>
		<recipeMaker>
			<recipeUsers>
				<li>FueledSmithy</li>
				<li>ElectricSmithy</li>
			</recipeUsers>
			<researchPrerequisite>RI_Research_CultivatorWeapon</researchPrerequisite>
			<skillRequirements>
				<Crafting>3</Crafting>
			</skillRequirements>
			<displayPriority>503</displayPriority>
		</recipeMaker>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Throwing_ThrowingKnife</defaultProjectile>
				<warmupTime>4</warmupTime>
				<range>18.9</range>
				<soundCast>Interact_BeatFire</soundCast>
				<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>
		<tools>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>15</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

	<ThingDef ParentName="BaseProjectileNeolithic">
