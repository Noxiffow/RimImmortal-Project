<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<!--Grade 2 ranged weapon prerequisite-->
	<ThingDef Name="RI_SecondWeapon_Range_Base" ParentName="RI_MagicalWeapon_Range_Base" Abstract="True">
		<tradeTags>
			<li>RI_SecondWeapon_Tag</li>
		</tradeTags>
	</ThingDef>

	<!--Dragon Cannon-->
	<ThingDef ParentName="RI_SecondWeapon_Range_Base">
		<defName>RI_Weapon_DragonCannon</defName>
		<label>Dragon cannon【Second-rate】</label>
		<description>【Second-rate】Range weapon\n\nA fire-blaster shaped like a dragon head with a laser firing system. The weapon was said to be a blunderbuss, but its caliber was closer to a cannonball, and it fired hot pellets that were terrifying to kill. At the same time, the weapon can adjust the muzzle to shoot a high-temperature laser through the energy array.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_DragonCannon</texPath>
			<drawSize>1.3</drawSize>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<statBases>
			<MarketValue>2900</MarketValue>
			<Mass>16.0</Mass>
			<AccuracyTouch>0.95</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.65</AccuracyLong>
			<RangedWeapon_Cooldown>2</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BetterGuns_Tag</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_DragonCannon</defaultProjectile>
				<warmupTime>2.5</warmupTime>
				<range>35</range>
				<soundCast>Shot_Autocannon</soundCast>
				<burstShotCount>3</burstShotCount>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<minRange>2</minRange>
			</li>
		</verbs>
		<tools>
			<li>
				<label>Cannon Barrel Strike</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_DragonCannon_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<color>(0.8,0.8,0.8,0.8)</color>
					<drawSize>1.3</drawSize>
				</graphicData>
			</li>

			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_DragonCannon_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Dragon Flame Blast</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>1</ammoCountPerCharge>
				<baseReloadTicks>180</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseBullet">
		<defName>RI_Bullet_DragonCannon</defName>
		<label>Dragon bullet</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_DragonCannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>RI_Starch.RI_Projectile.RI_Projectile_Rot</thingClass>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>20</damageAmountBase>
			<speed>55</speed>
			<armorPenetrationBase>0.3</armorPenetrationBase>
			<stoppingPower>0.5</stoppingPower>
			<arcHeightFactor>2</arcHeightFactor>
			<shadowSize>1</shadowSize>
			<extraDamages>
				<li>
					<def>Flame</def>
					<amount>10</amount>
					<chance>0.3</chance>
				</li>
			</extraDamages>
		</projectile>
		<fleck>RI_Fleck_Tail</fleck>
		<frequency>1</frequency>
		<scale>0.9</scale>
		<shaking>0</shaking>
	</ThingDef>

	<!--Fly Grenade-->
	<ThingDef ParentName="RI_SecondWeapon_Range_Base">
		<defName>RI_Weapon_FlyGrenade</defName>
		<label>Fly grenade【Second-rate】</label>
		<description>【Second-rate】Range weapon\n\nIt is said that the design of this weapon is inspired by the buzzing flies, and can shoot small grenades through a special barrel, crazy harassment of enemies, as annoying as flies.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_FlyGrenade</texPath>
		</graphicData>
		<soundInteract>Bow_Recurve</soundInteract>
		<statBases>
			<MarketValue>3200</MarketValue>
			<Mass>15.0</Mass>
			<AccuracyTouch>0.9</AccuracyTouch>
			<AccuracyShort>0.8</AccuracyShort>
			<AccuracyMedium>0.7</AccuracyMedium>
			<AccuracyLong>0.7</AccuracyLong>
			<RangedWeapon_Cooldown>0.8</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BetterGuns_Tag</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_LaunchProjectile</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<range>18</range>
				<forcedMissRadius>0.9</forcedMissRadius>
				<warmupTime>0.7</warmupTime>
				<noiseRadius>4</noiseRadius>
				<ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
				<soundCast>ThrowGrenade</soundCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<defaultProjectile>RI_Projectile_FlyGrenade</defaultProjectile>
				<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>
		<tools>
			<li>
				<label>Fly Grenade</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_FlyGrenade_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<color>(0.8,0.8,0.8,0.7)</color>
				</graphicData>
			</li>
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_FlyGrenade_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Smoke Bomb</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>1</ammoCountPerCharge>
				<baseReloadTicks>100</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="BaseGrenadeProjectile">
		<defName>RI_Projectile_FlyGrenade</defName>
		<label>Fly Grenade</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Projectile_FlyGrenade</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<speed>35</speed>
			<explosionRadius>2.1</explosionRadius >
			<damageDef>Bomb</damageDef>
			<damageAmountBase>10</damageAmountBase>
			<!-- Use default damage from explosion def -->
			<explosionDelay>40</explosionDelay>
		</projectile>
		<comps>
			<li Class="RI_Starch.RI_ThingComp.RI_CompProperties_TrailingEffect">
				<fleck>RI_Fleck_Tail</fleck>
				<frequency>1</frequency>
				<scale>0.9</scale>
				<shaking>0</shaking>
			</li>
		</comps>
	</ThingDef>

	<!--Ghost Fire Crossbow-->
	<ThingDef ParentName="RI_SecondWeapon_Range_Base">
		<defName>RI_Weapon_GhostFireCrossbow</defName>
		<label>Ghost fire crossbow【Second-rate】</label>
		<description>【Second-rate】Range weapon\n\nA crossbow with a ghostly fire attached to the energy array, hidden inside the mechanical structure, can shoot short bolts with extreme force. Consuming the spiritual crystal can trigger ghost fire, shooting crossbow with explosive burning effect.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_GhostFireCrossbow</texPath>
		</graphicData>
		<soundInteract>Bow_Large</soundInteract>
		<statBases>
			<MarketValue>3200</MarketValue>
			<Mass>14.0</Mass>
			<AccuracyTouch>0.7</AccuracyTouch>
			<AccuracyShort>0.8</AccuracyShort>
			<AccuracyMedium>0.9</AccuracyMedium>
			<AccuracyLong>0.8</AccuracyLong>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BetterGuns_Tag</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Arrow_GhostFireCrossbow</defaultProjectile>
				<warmupTime>2.1</warmupTime>
				<range>29.9</range>
				<soundCast>Bow_Recurve</soundCast>
				<burstShotCount>5</burstShotCount>
				<ticksBetweenBurstShots>7</ticksBetweenBurstShots>
			</li>
		</verbs>
		<tools>
			<li>
				<label>Crossbow Arm Strike</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_GhostFireCrossbow_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<color>(0.8,0.8,0.8,0.5)</color>
				</graphicData>
			</li>
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_Arrow_GhostFireCrossbow_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Rapid Fire</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>1</ammoCountPerCharge>
				<baseReloadTicks>100</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseProjectileNeolithic">
		<defName>RI_Arrow_GhostFireCrossbow</defName>
		<label>Ghost fire arrow</label>
		<thingClass>RI_Starch.RI_Projectile.RI_Projectile_Rot</thingClass>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_SteelArrow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile>
			<damageDef>Arrow</damageDef>
			<damageAmountBase>17</damageAmountBase>
			<stoppingPower>0.5</stoppingPower>
			<armorPenetrationBase>0.35</armorPenetrationBase>
			<speed>51</speed>
			<arcHeightFactor>5</arcHeightFactor>
			<shadowSize>1</shadowSize>
		</projectile>
		<fleck>RI_Fleck_Tail</fleck>
		<frequency>1</frequency>
		<scale>0.8</scale>
		<shaking>0.01</shaking>
	</ThingDef>

	<!--Iron Throwing Ball-->
	<ThingDef ParentName="RI_SecondWeapon_Range_Base">
		<defName>RI_Weapon_IronThrowingBall</defName>
		<label>Iron throwing-ball【Second-rate】</label>
		<description>【Second-rate】Range weapon\n\nA weapon in which each ball is the size of a fist and can automatically levitate or attack according to the owner's wishes, like an arm, but manipulating too many balls can be mentally taxing. It is said that someone can control nine iron balls at once, and its power is enough to empty the whole body of enemies in an instant.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_IronThrowingBall</texPath>
		</graphicData>
		<soundInteract>Bow_Large</soundInteract>
		<statBases>
			<MarketValue>1800</MarketValue>
			<Mass>9.0</Mass>
			<AccuracyTouch>0.9</AccuracyTouch>
			<AccuracyShort>0.9</AccuracyShort>
			<AccuracyMedium>0.5</AccuracyMedium>
			<AccuracyLong>0.3</AccuracyLong>
			<RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_BetterGuns_Tag</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Arrow_IronThrowingBall</defaultProjectile>
				<warmupTime>1.4</warmupTime>
				<range>15</range>
				<soundCast>Bow_Large</soundCast>
			</li>
		</verbs>
		<tools>
			<li>
				<label>limb</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<comps Inherit="False">
			<li Class="RI_MoteDraw.RI_CompPropertiesDrawExtra">
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_IronThrowingBall_de</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>MoteGlow</shaderType>
					<drawSize>1</drawSize>
					<color>(1,1,1,0.75)</color>
				</graphicData>
			</li>
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RI_Arrow_IronThrowingBall_Ability</abilityDef>
				<maxCharges>9</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Rapid Fire</chargeNoun>
				<ammoDef>RI_Resource_SpiritualCrystal</ammoDef>
				<ammoCountPerCharge>1</ammoCountPerCharge>
				<baseReloadTicks>100</baseReloadTicks>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Styleable"/>
			<li Class="CompProperties_Biocodable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="BaseProjectileNeolithic">
		<defName>RI_Arrow_IronThrowingBall</defName>
		<label>Iron ball</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Arrow_IronThrowingBall</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile>
			<damageDef>Blunt</damageDef>
			<damageAmountBase>30</damageAmountBase>
			<stoppingPower>5</stoppingPower>
			<armorPenetrationBase>0.4</armorPenetrationBase>
			<speed>50</speed>
			<arcHeightFactor>4</arcHeightFactor>
			<shadowSize>1</shadowSize>
		</projectile>
	</ThingDef>

</Defs>

