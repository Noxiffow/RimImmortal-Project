				<power>30</power>
				<cooldownTime>2.0</cooldownTime>
				<chanceFactor>9999</chanceFactor>

				<extraMeleeDamages>
					<li>
						<def>RI_Damage_ArmorBreak_breakBuilding</def>
						<amount>2</amount>
						<chance>0.7</chance>
					</li>
				</extraMeleeDamages>
			</li>
			<li>
				<label>Axe Blade</label>
				<capacities>
					<li>Cut</li>
					<li>Demolish</li>
				</capacities>
				<power>35</power>
				<cooldownTime>1.6</cooldownTime>
				<chanceFactor>999</chanceFactor>
				<extraMeleeDamages>
					<li>
						<def>RI_Damage_ArmorBreak_breakBuilding</def>
						<amount>2</amount>
						<chance>0.5</chance>
