<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef Name="RI_ArmorMachineableBase" ParentName="ApparelBase" Abstract="True">
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Machining</soundWorking>
			<recipeUsers>
				<li>RI_Building_SpiritForge</li>
			</recipeUsers>
			<researchPrerequisite>RI_MasterOfSmithing</researchPrerequisite>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
			<defaultIngredientFilter>
				<categories>
					<li>Root</li>
				</categories>
				<disallowedThingDefs>
					<li>Gold</li>
					<li>Silver</li>
					<li>Plasteel</li>
					<li>Jade</li>
					<li>Uranium</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
				</disallowedThingDefs>
			</defaultIngredientFilter>
		</recipeMaker>
	</ThingDef>

	<ThingDef Name="RI_ApparelArmorPowerBase" ParentName="RI_ArmorMachineableBase" Abstract="True">
		<techLevel>Spacer</techLevel>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/PowerArmor/PowerArmor</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<generateCommonality>2</generateCommonality>
		<statBases>
			<WorkToMake>60000</WorkToMake>
			<MaxHitPoints>12000</MaxHitPoints>
			<Mass>12</Mass>
			<Flammability>0.4</Flammability>
			<ArmorRating_Sharp>1.5</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Heat>2</ArmorRating_Heat>
			<Insulation_Cold>35</Insulation_Cold>
			<Insulation_Heat>130</Insulation_Heat>
			<EquipDelay>14</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.4</MoveSpeed>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
		</equippedStatOffsets>
		<thingCategories>
			<li>RI_Category_HelmetAndArmor</li>
		</thingCategories>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/PowerArmor/PowerArmor</wornGraphicPath>
			<layers>
				<li>Shell</li>
			</layers>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
			<useDeflectMetalEffect>true</useDeflectMetalEffect>
			<soundWear>Wear_PowerArmor</soundWear>
			<soundRemove>Remove_PowerArmor</soundRemove>
		</apparel>
		<comps>
			<li Class="CompProperties_Biocodable"/>
		</comps>
		<thingSetMakerTags>
			<li>RewardStandardHighFreq</li>
		</thingSetMakerTags>
		<!--Trade Tag-->
		<tradeTags>
			<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
	</ThingDef>

	<!--Candle Dragon Armor-->

	<ThingDef ParentName="RI_ApparelArmorPowerBase">
		<defName>RI_Apparel_FireDragonArmor</defName>
		<label>Fire dragon armor【First-rate】</label>
		<description>Beyond the Northwestern Sea, north of the Red Water, lies Zhangwei Mountain. There is a god with a human face and a snake's body, red in color, with straight eyes that face forward. When it blinks, it becomes dark, and when it opens its eyes, it becomes bright. It does not eat, sleep, or rest, and it serves as a messenger of wind and rain. It is called Zhuozhiyin, or the Zhu dragon.\n\nThis is a powerful armor inspired by ancient cultivators' heritages and forged using ancient myths. The armor's defense capabilities have reached an incredible level thanks to the built-in magical components that allow some attacks to be absorbed by the armor.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/FireDragonArmor/RI_Apparel_FireDragonArmor</texPath>
		</graphicData>
		<statBases>
			<WorkToMake>90000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
		</equippedStatOffsets>
		<costList>
			<Steel>100</Steel>
			<RI_Resource_SpiritCoreComponent>1</RI_Resource_SpiritCoreComponent>
			<RI_Resource_BlackSteel>30</RI_Resource_BlackSteel>
			<RI_Resource_AncientArmorRelic>5</RI_Resource_AncientArmorRelic>
			<RI_Talisman_Firefighter>1</RI_Talisman_Firefighter>
		</costList>
		<apparel>
			<tags>
				<li>RI_BestArmorTag</li>
			</tags>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/FireDragonArmor/RI_Apparel_FireDragonArmor</wornGraphicPath>
			<forceEyesVisibleForRotations>
				<li>1</li>
				<li>2</li>
				<li>3</li>
			</forceEyesVisibleForRotations>
			<useWornGraphicMask>true</useWornGraphicMask>
		</apparel>
		<recipeMaker>
			<displayPriority>155</displayPriority>
		</recipeMaker>
			<!--Trade Tag-->
		<tradeTags>
			<li>RI_AllWeapon_AllArmor_Tag</li>
		</tradeTags>
	</ThingDef>
	
