	<ThingDef ParentName="ArtableFurnitureBase">
		<defName>RI_Building_AncientChair</defName>
		<label>Ancient chair</label>
		<description>An ancient cultivator style chair, made of steel.</description>
		<graphicData>
			<texPath>Things/Building/Ancient/RI_Building_AncientChair</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(1,1)</drawSize>
			<damageData>
				<rectN>(0.25,0.234375,0.5,0.28125)</rectN>
				<rectS>(0.25,0.234375,0.5,0.28125)</rectS>
				<rectE>(0.28125,0.25,0.453125,0.25)</rectE>
				<rectW>(0.28125,0.25,0.453125,0.25)</rectW>
			</damageData>
			<shadowData>
				<volume>(0.23, 0.26, 0.23)</volume>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>8000</WorkToBuild>
			<Mass>3</Mass>
			<Flammability>1.0</Flammability>
			<Beauty>8</Beauty>
			<Comfort>0.70</Comfort>
		</statBases>
		<socialPropernessMatters>true</socialPropernessMatters>
		<designationCategory>RI_RimImmortals_Furniture</designationCategory>
		<costList>
			<Steel>20</Steel>
		</costList>
		<pathCost>30</pathCost>
		<fillPercent>0.35</fillPercent>
		<defaultPlacingRot>South</defaultPlacingRot>
		<uiOrder>2410</uiOrder>
		<building>
			<isSittable>true</isSittable>
			<paintable>true</paintable>
		</building>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<researchPrerequisites>
			<li>RI_AncientCultivatorRestoration</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Styleable" />
		</comps>
	</ThingDef>

	<ThingDef Name="RI_ShelfBase" ParentName="FurnitureBase" Abstract="True">
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.4</fillPercent>
		<castEdgeShadows>true</castEdgeShadows>
		<pathCost>50</pathCost>
		<defaultPlacingRot>South</defaultPlacingRot>
		<statBases>
			<Flammability>1.0</Flammability>
			<Beauty>0.5</Beauty>
		</statBases>
		<designationCategory>RI_RimImmortals_Furniture</designationCategory>
		<building>
			<preventDeteriorationOnTop>true</preventDeteriorationOnTop>
			<ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
			<maxItemsInCell>3</maxItemsInCell>
			<blueprintClass>Blueprint_Storage</blueprintClass>
			<paintable>true</paintable>
		</building>
		<inspectorTabs>
			<li>ITab_Storage</li>
		</inspectorTabs>
		<staticSunShadowHeight>0.5</staticSunShadowHeight>
		<surfaceType>Item</surfaceType>
		<canOverlapZones>false</canOverlapZones>
		<researchPrerequisites>
			<li>RI_AncientCultivatorRestoration</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Styleable" />
		</comps>
	</ThingDef>

	<ThingDef Name="RI_StorageShelfBase" ParentName="RI_ShelfBase" Abstract="True">
		<thingClass>Building_Storage</thingClass>
		<building>
			<storageGroupTag>Shelf</storageGroupTag>
			<fixedStorageSettings>
				<filter>
					<disallowNotEverStorable>true</disallowNotEverStorable>
					<categories>
						<li>Root</li>
					</categories>
					<disallowedCategories>
						<li>Chunks</li>
						<li>Plants</li>
						<li>Buildings</li>
					</disallowedCategories>
					<disallowedThingDefs MayRequire="Ludeon.RimWorld.Biotech">
						<li MayRequire="Ludeon.RimWorld.Biotech">Wastepack</li>
					</disallowedThingDefs>
					<specialFiltersToDisallow>
						<li>AllowLargeCorpses</li>
					</specialFiltersToDisallow>
				</filter>
			</fixedStorageSettings>
			<defaultStorageSettings>
				<priority>Preferred</priority>
				<filter>
					<categories>
						<li>Foods</li>
						<li>Manufactured</li>
						<li>ResourcesRaw</li>
						<li>Items</li>
						<li>Weapons</li>
						<li>Apparel</li>
						<li>BodyParts</li>
					</categories>
				</filter>
			</defaultStorageSettings>
		</building>
	</ThingDef>

	<ThingDef ParentName="RI_StorageShelfBase">
		<defName>RI_Building_AncientShelf</defName>
		<label>Ancient shelf</label>
		<description>An ancient cultivator style locker for storage, made of steel.</description>
		<graphicData>
			<texPath>Things/Building/Ancient/RI_Building_AncientShelf</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.2,1.2)</drawSize>
		</graphicData>
		<costList>
			<Steel>40</Steel>
		</costList>
		<statBases>
			<MaxHitPoints>400</MaxHitPoints>
			<Mass>8</Mass>
			<WorkToBuild>500</WorkToBuild>
			<StyleDominance MayRequire="Ludeon.RimWorld.Ideology">5</StyleDominance>
		</statBases>
		<size>(2,1)</size>
		<building>
			<relatedBuildCommands>
				<li>ShelfSmall</li>
			</relatedBuildCommands>
		</building>
	</ThingDef>

