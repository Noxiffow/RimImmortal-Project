			<texPath>Things/Building/Ancient/RI_Building_AncientTableA</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(1.3,2.3)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<uiIconScale>0.8</uiIconScale>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>750</WorkToBuild>
			<Mass>5</Mass>
			<Flammability>1.0</Flammability>
			<Beauty>0.5</Beauty>
		</statBases>
		<size>(1,2)</size>
		<costList>
			<Steel>30</Steel>
			<RI_Resource_SpiritualCrystal>1</RI_Resource_SpiritualCrystal>
		</costList>
	</ThingDef>

	<ThingDef ParentName="RI_AncientTableBase">
