<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef Abstract="True" Name="RI_AncientJunk" ParentName="BuildingBase">
		<category>Building</category>
		<graphicData>
			<graphicClass>Graphic_Random</graphicClass>
			<damageData>
				<rect>(0.1,0.1,1.8,1.8)</rect>
			</damageData>
			<shadowData>
				<volume>(1.39,0.5,1.25)</volume>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<rotatable>false</rotatable>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.50</fillPercent>
		<building>
			<claimable>false</claimable>
			<alwaysDeconstructible>true</alwaysDeconstructible>
		</building>
		<selectable>true</selectable>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<drawerType>MapMeshOnly</drawerType>
		<repairEffect>ConstructMetal</repairEffect>
	</ThingDef>

	<ThingDef ParentName="RI_AncientJunk">
		<defName>RI_Building_SpaceShipChunk</defName>
		<label>Black steel ship chunk</label>
		<description>Ship fragments that incorporate black steel can be recovered to obtain a small amount of black steel.</description>
		<graphicData>
			<texPath>Things/Building/Special/RI_Building_SpaceShipChunk</texPath>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<size>(2,2)</size>
		<statBases>
			<MaxHitPoints>1200</MaxHitPoints>
			<Flammability>0.1</Flammability>
			<Beauty>-5</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<RI_Resource_BlackSteel>15</RI_Resource_BlackSteel>
			<ComponentIndustrial>2</ComponentIndustrial>
		</killedLeavings>
		<costList>
			<ComponentIndustrial>4</ComponentIndustrial>
			<RI_Resource_BlackSteel>30</RI_Resource_BlackSteel>
		</costList>
	</ThingDef>

	<ThingDef ParentName="RI_AncientJunk">
		<defName>RI_Building_AncientJunk</defName>
		<label>Ancient cultivator junk</label>
		<description>A pile of rubbish, barely distinguishable as an ancient cultivator, can recover a small amount of steel and component parts.</description>
		<graphicData>
			<texPath>Things/Building/Special/RI_Building_AncientJunk</texPath>
			<drawSize>(3.4,3.4)</drawSize>
		</graphicData>
		<rotatable>false</rotatable>
		<size>(3,3)</size>
		<statBases>
			<MaxHitPoints>400</MaxHitPoints>
			<Flammability>0.1</Flammability>
			<Beauty>-5</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<Steel>200</Steel>
			<ComponentIndustrial>2</ComponentIndustrial>
		</killedLeavings>
		<costList>
			<ComponentIndustrial>6</ComponentIndustrial>
			<Steel>450</Steel>
		</costList>
	</ThingDef>

	<ThingDef ParentName="RI_AncientJunk">
		<defName>RI_Building_AncientWeaponBox</defName>
		<label>Ancient cultivator weapon box</label>
		<description>Ancient cultivator style storage box, this box is filled with weapons, from which you can recover ancient weapons that may be useful.</description>
		<graphicData>
			<texPath>Things/Building/Special/RI_Building_AncientWeaponBox</texPath>
			<drawSize>(2.25,2.25)</drawSize>
		</graphicData>
		<size>(2,2)</size>
		<rotatable>false</rotatable>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<Flammability>0.1</Flammability>
			<Beauty>-5</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<Steel>50</Steel>
			<RI_BlindBox_Weapon>1</RI_BlindBox_Weapon>
		</killedLeavings>
		<costList>
			<Steel>200</Steel>
			<RI_BlindBox_Weapon>2</RI_BlindBox_Weapon>
		</costList>
	</ThingDef>

	<ThingDef ParentName="RI_AncientJunk">
		<defName>RI_Building_AncientArmorBox</defName>
		<label>Ancient cultivator armor box</label>
		<description>Ancient cultivator style storage box, this box is filled with armor, from which you can recover ancient armor that might be useful.</description>
		<graphicData>
			<texPath>Things/Building/Special/RI_Building_AncientArmorBox</texPath>
			<drawSize>(2.25,2.25)</drawSize>
		</graphicData>
		<size>(2,2)</size>
		<rotatable>false</rotatable>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<Flammability>0.1</Flammability>
			<Beauty>-5</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<Steel>50</Steel>
			<RI_BlindBox_Armor>1</RI_BlindBox_Armor>
		</killedLeavings>
		<costList>
			<Steel>200</Steel>
			<RI_BlindBox_Armor>2</RI_BlindBox_Armor>
		</costList>
	</ThingDef>

</Defs>