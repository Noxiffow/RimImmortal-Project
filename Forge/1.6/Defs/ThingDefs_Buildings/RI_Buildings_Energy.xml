	<!--Ancient Cultivator Energy-Gathering Cauldron-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_InfiniteCrystal</defName>
		<label>Ancient-cultivator Juyuan Ding</label>
		<description>From the ancient cultivator of the creation, the researchers found Qi residue, and then reverse-study this ancient cultivator once cast giant Ding.\n\nThis Ding can absorb thin Qi from the atmosphere and condense it into a spirit crystal, which can be described as the creation of extraordinary workmanship.</description>
		<graphicData>
			<texPath>Things/Building/Special/RI_Building_InfiniteCrystal</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(3.55, 3.55)</drawSize>
			<shadowData>
				<volume>(1.8, 1.0, 0.2)</volume>
				<offset>(0.0, 0.0, -0.4)</offset>
			</shadowData>
		</graphicData>

		<costList>
			<Steel>200</Steel>
			<RI_Resource_LiquidJade>2</RI_Resource_LiquidJade>
			<RI_Resource_SpiritualCrystal>10</RI_Resource_SpiritualCrystal>
			<RI_Resource_DeviceCoreComponent>1</RI_Resource_DeviceCoreComponent>
		</costList>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<thingCategories>
			<li>BuildingsProduction</li>
		</thingCategories>
		<building>
			<destroySound>BuildingDestroyed_Metal_Big</destroySound>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
		</building>
		<researchPrerequisites>
			<li>RI_AncientCultivatorRestoration</li>
		</researchPrerequisites>
		<altitudeLayer>Building</altitudeLayer>
		<statBases>
			<MarketValue>2300</MarketValue>
			<MaxHitPoints>800</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<Beauty>3</Beauty>
			<Mass>40</Mass>
			<WorkToBuild>7000</WorkToBuild>
		</statBases>
		<thingSetMakerTags>
			<li>RewardStandardCore</li>
		</thingSetMakerTags>
		<tickerType>Normal</tickerType>
		<size>(2, 2)</size>
		<fillPercent>1.0</fillPercent>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<constructionSkillPrerequisite>7</constructionSkillPrerequisite>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<passability>Impassable</passability>
		<rotatable>false</rotatable>
		<canOverlapZones>false</canOverlapZones>
		<minifiedDef>MinifiedThing</minifiedDef>
		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>ExoticBuilding</li>
		</tradeTags>
		<!--Cannot be placed under a roof-->
		<canBeUsedUnderRoof>false</canBeUsedUnderRoof>
		<placeWorkers>
			<li>PlaceWorker_NotUnderRoof</li>
		</placeWorkers>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>500</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<!--Generated product-->
			<li Class="CompProperties_Spawner">
				<requiresPower>true</requiresPower>
				<thingToSpawn>RI_Resource_SpiritualCrystal</thingToSpawn>
				<spawnCount>5</spawnCount>
				<spawnIntervalRange>
					<min>300000</min>
					<max>350000</max>
				</spawnIntervalRange>
				<writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
				<showMessageIfOwned>true</showMessageIfOwned>
			</li>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>5</explosiveRadius>
				<explosiveDamageType>Flame</explosiveDamageType>
			</li>
		</comps>
	</ThingDef>

</Defs>