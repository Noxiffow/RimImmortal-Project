<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--"Crane-Song" Rapid-Fire Crossbow Cannon-->

	<ThingDef ParentName="BuildingBase">
		<defName>RI_Turret_SmallCrossbowTurret</defName>
		<label>"Crane Cry" auto-turret</label>
		<description>"Crane Cry" auto-turret is an automatic defense turret developed from basic magical treasure technology with military improvements. This turret boasts high firing speed and long range while being easy to maintain and not exploding upon destruction.\n\nThis turret consumes Spiritual crystal as ammunition but also contains power-consuming components, requiring electricity.</description>
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Security/RI_Turret_SmallCrossbowTurret_Base</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(2,2)</drawSize>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
			<shadowData>
				<volume>(0.27,0.25,0.27)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
		</graphicData>
		<uiIconPath>Things/Building/Security/RI_Turret_SmallCrossbowTurret_MenuIcon</uiIconPath>
		<uiIconScale>1.3</uiIconScale>
		<minifiedDef>MinifiedThing</minifiedDef>
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>false</rotatable>
		<thingCategories>
			<li>BuildingsSecurity</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>600</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<WorkToBuild>2000</WorkToBuild>
			<Mass>10</Mass>
			<Beauty>-5</Beauty>
			<ShootingAccuracyTurret>0.96</ShootingAccuracyTurret>
		</statBases>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>80</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_Refuelable">
				<fuelLabel>Shots until barrel change</fuelLabel>
				<fuelGizmoLabel>Crystal durability</fuelGizmoLabel>
				<outOfFuelMessage>Needs crystal</outOfFuelMessage>
				<fuelFilter>
					<thingDefs>
						<li>RI_Resource_SpiritualCrystal</li>
					</thingDefs>
				</fuelFilter>
				<fuelCapacity>100</fuelCapacity>
				<fuelMultiplier>4</fuelMultiplier>
				<!-- 1.333 steel per burst, 80 per full rearm -->
				<initialFuelPercent>1</initialFuelPercent>
				<autoRefuelPercent>0.5</autoRefuelPercent>
				<showFuelGizmo>true</showFuelGizmo>
				<minimumFueledThreshold>1</minimumFueledThreshold>
				<factorByDifficulty>false</factorByDifficulty>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
			</li>
			<li Class="CompProperties_Stunnable">
				<affectedDamageDefs>
					<li>Stun</li>
					<li>EMP</li>
				</affectedDamageDefs>
			</li>
		</comps>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.4</fillPercent>
		<hasTooltip>true</hasTooltip>
		<!--Cost-->
		<costList>
			<Steel>150</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
		</costList>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<designationCategory>Security</designationCategory>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<building>
			<combatPower>45</combatPower>
			<!-- same as a scavenger -->
			<ai_combatDangerous>true</ai_combatDangerous>
			<turretGunDef>RI_Gun_SmallCrossbowTurrent</turretGunDef>
			<turretBurstCooldownTime>4</turretBurstCooldownTime>
		</building>
		<placeWorkers>
			<li>PlaceWorker_TurretTop</li>
			<li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_QiBasedMilitaryScience</li>
		</researchPrerequisites>
	</ThingDef>

	<!--Crane-Song Turret Bullet-->
	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_SmallCrossbowTurret</defName>
		<label>Light bullet</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_SmallCrossbowTurret</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>17</damageAmountBase>
			<armorPenetrationBase>0.15</armorPenetrationBase>
			<speed>80</speed>
		</projectile>
	</ThingDef>

	<!--Crane-Song Turret-->
	<ThingDef ParentName="BaseWeaponTurret">
		<defName>RI_Gun_SmallCrossbowTurrent</defName>
		<label>"Crane Cry" auto-turret gun</label>
		<description>"Crane Cry" auto-turret gun.</description>
		<graphicData>
			<texPath>Things/Building/Security/RI_Gun_SmallCrossbowTurrent_Top</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<statBases>
			<AccuracyTouch>0.5</AccuracyTouch>
			<AccuracyShort>0.6</AccuracyShort>
			<AccuracyMedium>0.7</AccuracyMedium>
			<AccuracyLong>0.6</AccuracyLong>
			<RangedWeapon_Cooldown>4.2</RangedWeapon_Cooldown>
			<DeteriorationRate>0</DeteriorationRate>
			<Mass>5</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<defaultProjectile>RI_Bullet_SmallCrossbowTurret</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>35</range>
				<ticksBetweenBurstShots>7</ticksBetweenBurstShots>
				<burstShotCount>5</burstShotCount>
				<soundCast>RI_Sound_LaserGunShot_B</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<consumeFuelPerShot>0.5</consumeFuelPerShot>
			</li>
		</verbs>
	</ThingDef>

