			<texPath>Things/Building/Ancient/RI_Building_AncientShelfRuin</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.2,1.2)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Mass>8</Mass>
		</statBases>
		<size>(2,1)</size>
		<costList>
			<Steel>50</Steel>
		</costList>
	</ThingDef>

