	<!--特殊建筑-->

	<ThingDef ParentName="BuildingBase">
		<defName>RI_AncientCultivatorCryptosleepCasket</defName>
		<label>灵气逸散的建筑</label>
		<description>建筑中蕴含有极其深厚的灵气，不断向外逸散</description>
		<thingClass>WhoXiuXian.RI_Building_AncientCultivatorCryptosleepCasket</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Ancient/RI_Building_AncientCultivatorCryptosleepCasket</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(4.1,4.1)</drawSize>
			<shadowData>
				<volume>(0.83, 0.3, 1.7)</volume>
			</shadowData>
		</graphicData>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<Flammability>1.0</Flammability>
		</statBases>
		<tickerType>Normal</tickerType>
		<size>(3,3)</size>
		<costList>
			<Steel>180</Steel>
			<Uranium>5</Uranium>
		</costList>
		<killedLeavings>
			<ChunkSlagSteel>1</ChunkSlagSteel>
			<Steel>25</Steel>
			<Uranium>3</Uranium>
		</killedLeavings>
		<building>
			<ai_chillDestination>false</ai_chillDestination>
			<deconstructible>false</deconstructible>
			<claimable>false</claimable>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
		</building>
		<comps>
		</comps>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
	</ThingDef>

