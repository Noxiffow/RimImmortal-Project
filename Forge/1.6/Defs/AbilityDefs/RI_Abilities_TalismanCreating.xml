	<!--Forging Cultivation Method (TalismanCreating)-->

	<!--Noviciate — Artisan's Heart-->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_WorkFocus</defName>
		<label>Work focus</label>
		<description>&lt;color=#edad56&gt;This technique is learned by the Noviciate rank of the Forge method\n\n&lt;/color&gt;Qi cost: 25\n\nThe unique cultivation method of the Forge, while increasing the cultivation speed, solidifies the mind with the craftsman's heart and improves the cultivation speed.</description>
		<iconPath>Ability/TalismanCreating/RI_Ability_WorkFocus</iconPath>
		<cooldownTicksRange>3000</cooldownTicksRange>
		<targetRequired>False</targetRequired>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_Duration>2000</Ability_Duration>
		</statBases>
		<verbProperties>
			<warmupTime>0.3</warmupTime>
			<range>0</range>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCasting">
				<!--Selection visual effect-->
				<moteCastDef>RI_Ability_WorkFocus_Mote</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteSinging">
				<!--Cast visual effect-->
				<moteCastDef>RI_Ability_PhysicalStrengthen_Singing</moteCastDef>
				<!--Halo effect-->
			</li>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>RI_WorkDrive</hediffDef>
				<onlyBrain>True</onlyBrain>
				<applicableToMechs>False</applicableToMechs>
				<canTargetBaby>False</canTargetBaby>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<!--Consumes Qi-->
				<rEnergy>-25</rEnergy>
				<!--Consumes Qi-->
			</li>
		</comps>
	</AbilityDef>

	<!--Core Formation — Repair-->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_Repair</defName>
		<label>Repair</label>
		<description>&lt;color=#edad56&gt;This technique is learned by the Core formation rank of the Forge method\n\n&lt;/color&gt;Qi cost: 50\n\nQi breaks down surrounding matter and is used to fill damaged items, but only for dead objects.</description>
		<iconPath>Ability/TalismanCreating/RI_Ability_Repair</iconPath>
		<hotKey></hotKey>
		<cooldownTicksRange>1800</cooldownTicksRange>
		<targetRequired>False</targetRequired>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_Duration>100</Ability_Duration>
		</statBases>
		<verbProperties>
			<warmupTime>2</warmupTime>
			<range>5</range>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCasting">
				<!--Selection visual effect-->
				<moteCastDef>RI_Ability_Repair_Mote</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteSinging">
				<!--Cast visual effect-->
				<moteCastDef>RI_Ability_PhysicalStrengthen_Singing</moteCastDef>
				<!--Halo effect-->
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-50</rEnergy>
			</li>
			<li Class="RI_Talisman.CompProperties_RI_Repair">
				<moteCastDef>RI_Ability_RepairActive_Mote</moteCastDef>
				<radius>5</radius>
			</li>
		</comps>
	</AbilityDef>

	<!--Core Coagulation — Gun-Iron Reforge-->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_TurretAssemble</defName>
		<label>Turret assemble</label>
		<description>&lt;color=#edad56&gt;This technique is learned by the Core coagulation rank of the Forge method\n\n&lt;/color&gt;Qi cost: 100\n\nUsing Qi to break down some raw materials and reassemble them into a solid battery is a very practical exercise.</description>
		<iconPath>Ability/TalismanCreating/RI_Ability_TurretAssemble</iconPath>
		<targetRequired>True</targetRequired>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<statBases>
			<Ability_Duration>15</Ability_Duration>
			<Ability_EffectRadius>5</Ability_EffectRadius>
		</statBases>
		<verbProperties>
			<warmupTime>4</warmupTime>
			<range>5</range>
			<requireLineOfSight>True</requireLineOfSight>
			<targetParams>
				<canTargetLocations>True</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCasting">
				<!--Selection visual effect-->
				<moteCastDef>RI_Ability_TurretAssemble_Mote</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteSinging">
				<!--Cast visual effect-->
				<moteCastDef>RI_Ability_PhysicalStrengthen_Singing</moteCastDef>
				<!--Halo effect-->
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-100</rEnergy>
			</li>
			<li Class="RI_Talisman.CompProperties_RI_TurretAssemble">
				<turretDefStone>RI_Turret_StoneTower</turretDefStone>
				<turretDefSteel>RI_Turret_SteelCrossbow</turretDefSteel>
				<turretDefMecha>RI_Turret_StoneTower</turretDefMecha>
				<moteCastDef>RI_Ability_TurretAssembleActive_Mote</moteCastDef>
				<radius>5</radius>
			</li>
		</comps>
	</AbilityDef>

	<!--Spirit Constraint — Artisan's Inspiration-->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_WorkInsentive</defName>
		<label>Work insentive</label>
		<description>&lt;color=#edad56&gt;This technique is learned by the Spirit constraint rank of the Forge method\n\n&lt;/color&gt;Qi cost: 110\n\nOn the basis of the Work focus, exudes the Qi, so that people around can also be immersed in the craftsmanship.</description>
		<cooldownTicksRange>5000</cooldownTicksRange>
		<iconPath>Ability/TalismanCreating/RI_Ability_WorkInsentive</iconPath>
		<jobDef>CastAbilityOnThing</jobDef>
		<targetRequired>False</targetRequired>
		<hotKey></hotKey>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<stunTargetWhileCasting>True</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_EntropyGain>0</Ability_EntropyGain>
			<Ability_PsyfocusCost>0</Ability_PsyfocusCost>
			<Ability_Duration>1000</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>0.5</warmupTime>
			<range>9.9</range>
			<drawAimPie>False</drawAimPie>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetPawns>false</canTargetPawns>
