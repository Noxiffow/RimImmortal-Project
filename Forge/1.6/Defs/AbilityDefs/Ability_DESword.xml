<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<AbilityDef>
		<defName>RI_Ability_DESword</defName>
		<label>Poison shuttle</label>
		<description>Release a venomous shuttle to attack up to 3 enemies.</description>
		<iconPath>Ability/Weapon/RI_Ability_DESword</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<showOnCharacterCard>false</showOnCharacterCard>
		<cooldownTicksRange>520</cooldownTicksRange>
		<!--RangedWeapon_Cooldown>4.10</RangedWeapon_Cooldown-->
		<verbProperties>
			<verbClass>RI_Starch.RI_Verbs.Verb_Ability</verbClass>
			<defaultCooldownTime>2</defaultCooldownTime>
			<requireLineOfSight>true</requireLineOfSight>
			<range>27</range>
			<warmupTime>0.8</warmupTime>
			<soundCast>Psycast_Skip_Entry</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="RI_Starch.RI_Ability.RI_CompProperties_RatWhiskerSword">
				<range>30</range>
				<projectileDef>RI_Projectile_DESword</projectileDef>
				<maxTargets>3</maxTargets>
				<detectionRange>7</detectionRange>
				<cooldownTicks>990</cooldownTicks>
			</li>
		</comps>
	</AbilityDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseBullet">
		<defName>RI_Projectile_DESword</defName>
		<label>Flying shuttle</label>
		<thingClass>RI_Starch.RI_Projectile.FlyingSwordsMissile_df</thingClass>
		<graphicData>
			<texPath>Things/Projectile/RI_Weapon_DESword</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.3</drawSize>
			<shaderType>MoteGlow</shaderType>
		</graphicData>

		<fleck>RI_Fleck_Tail_Ability_PojunSword</fleck>
		<frequency>-1</frequency>
		<scale>0.45</scale>
		<shaking>0</shaking>
		<straightShoot>false</straightShoot>
		<maxTargets>3</maxTargets>
		<detectionRange>7</detectionRange>
		<tickDamage>false</tickDamage>
		<projectile>
			<soundImpact>Psycast_Skip_Entry</soundImpact>
			<damageDef>RI_BladeToxic_1</damageDef>
			<damageAmountBase>32</damageAmountBase>
			<armorPenetrationBase>0.56</armorPenetrationBase>
			<speed>24</speed>
			<spinRate>2</spinRate>
		</projectile>
	</ThingDef>

	<FleckDef ParentName="RI_Fleck_Tail">
		<defName>RI_Fleck_Tail_Ability_DESword</defName>
		<graphicData>
			<texPath>Effects/Normal/RI_GlowC</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(0.38,0.8,0.6)</color>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.02</fadeInTime>
		<solidTime>0.01</solidTime>
		<fadeOutTime>0.28</fadeOutTime>
		<growthRate>-0.9</growthRate>
	</FleckDef>

</Defs>