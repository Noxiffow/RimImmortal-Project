		<threats>
			<li>
				<def>SleepingMechanoids</def>
			</li>
			<!--<li>
				<def>SleepingInsects</def>
			</li>-->
		</threats>
	</ComplexLayoutDef>
	<!--组件 -->
	<GenStepDef>
		<defName>AncientComplex_Talismaker</defName>
		<linkWithSite>AncientComplex_Talismaker</linkWithSite>
		<order>310</order>
		<genStep Class="WhoXiuXian.GenStep_RandomAncientComplex" />
	</GenStepDef>

	<GenStepDef>
		<defName>AncientComplex_TalismakerWithCasket</defName>
		<linkWithSite>AncientComplex_TalismakerWithCasket</linkWithSite>
		<order>311</order>
		<genStep Class="WhoXiuXian.GenStep_RandomAncientComplex" />
	</GenStepDef>

	<RuleDef>
		<defName>AncientRandomComplex</defName>
		<symbol>ancientRandomComplex</symbol>
		<resolvers>
			<li Class="WhoXiuXian.SymbolResolver_Main">
