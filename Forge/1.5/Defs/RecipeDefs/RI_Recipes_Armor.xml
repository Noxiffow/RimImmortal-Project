	<!--==================================一品盔甲==================================-->
	
	<!--烛龙吞火盔【一品】-->
	<RecipeDef ParentName="RI_BestArmorRecipeBase">
		<defName>Make_FireDragonHelmet</defName>
		<label>make Fire dragon helmet【First-rate】</label>
		<description>make Fire dragon helmet.</description>
		<jobString>Making Fire dragon helmet</jobString>
		<workAmount>48000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>300</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_SpiritCoreComponent</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_BlackSteel</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_AncientArmorRelic</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>50</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Talisman_Firefighter</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>RI_Resource_SpiritCoreComponent</li>
				<li>RI_Resource_BlackSteel</li>
				<li>RI_Resource_AncientArmorRelic</li>
				<li>Plasteel</li>
				<li>RI_Talisman_Firefighter</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Apparel_FireDragonHelmet>1</RI_Apparel_FireDragonHelmet>
		</products>
		<displayPriority>801</displayPriority>
	</RecipeDef>

