<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<RecipeDef>
		<defName>Make_DeviceCoreComponent</defName>
		<label>make Device core circuit</label>
		<description>Make a Device core circuit.</description>
		<jobString>Making Device core circuit.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workAmount>5000</workAmount>
		<unfinishedThingDef>UnfinishedComponent</unfinishedThingDef>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_SpiritualCrystal</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_BlackSteel</li>
					</thingDefs>
				</filter>
				<count>15</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_SpiritualCrystal</li>
				<li>RI_Resource_BlackSteel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_DeviceCoreComponent>1</RI_Resource_DeviceCoreComponent>
		</products>
		<skillRequirements>
			<Crafting>7</Crafting>
		</skillRequirements>
		<workSkill>Crafting</workSkill>
		<displayPriority>0</displayPriority>
	</RecipeDef>

