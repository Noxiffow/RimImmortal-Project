	<!--苍血竹剑-->
	<ThingDef ParentName="RI_WeaponBase_JadeBamboo" MayRequire="RI.RimImmortal.Living">
		<defName>RI_Weapon_JadeBambooSword</defName>
		<label>Jade bamboo sword【Third-rate】</label>
		<description>【Third-rate】Range weapon\n\nGreen blood bamboo is a material that can carry spiritual energy very well. Weapons made of green blood bamboo and spiritual stone have limited damage in melee combat, but can trigger the energy blade to kill the enemy at long range.\n\nJade bamboo sword, can release a continuous energy blade.\n\n&lt;color=#FFFF00&gt;【Special effects】Basic projectile armor penetration +25%.&lt;/color&gt;</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_JadeBambooSword</texPath>
			<drawSize>2</drawSize>
		</graphicData>
		<equippedAngleOffset>-65</equippedAngleOffset>
		<statBases>
			<WorkToMake>5000</WorkToMake>
			<Mass>1</Mass>
			<AccuracyTouch>1</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
			<AccuracyMedium>0.50</AccuracyMedium>
			<AccuracyLong>0.30</AccuracyLong>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<RI_Resource_JadeBloodBamboo>40</RI_Resource_JadeBloodBamboo>
			<RI_Resource_SpiritualCrystal>3</RI_Resource_SpiritualCrystal>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_JadeBambooSwordBlade</defaultProjectile>
				<warmupTime>0.3</warmupTime>
				<range>15</range>
				<burstShotCount>3</burstShotCount>
				<soundCast>RI_SoundShot_EnergyBlade</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>18</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>17</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<!--额外的tag，给剑狂用-->
		<weaponTags>
			<li>RI_MagicalWeapon_Sword</li>
		</weaponTags>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_JadeBambooSwordBlade</defName>
		<label>Bamboo energy slash</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_JadeBambooSwordBlade</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>MoteGlow</shaderType>
