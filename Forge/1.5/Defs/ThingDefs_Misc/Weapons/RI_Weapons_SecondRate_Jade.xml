		<uiIconScale>1</uiIconScale>
		<soundInteract>Interact_Autopistol</soundInteract>
		<recipeMaker>
			<researchPrerequisite>RI_InitialApproach_ToolsStrengthen</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers>
				<li>RI_Building_EnergyForge</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
			<displayPriority>500</displayPriority>
		</recipeMaker>
		<weaponTags>
			<li>RI_MagicalWeapon</li>
			<li>RI_JadeBambooWeapons_Base</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedLight</li>
