				<cooldownTime>1</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>30</power>
				<cooldownTime>1</cooldownTime>
			</li>
		</tools>
		<recipeMaker Inherit="False">
