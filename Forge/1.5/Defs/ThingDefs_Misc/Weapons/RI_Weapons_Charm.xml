<Defs>

	<ThingDef ParentName="BaseGun" Name="RI_CharmBase" Abstract="True">
		<tickerType>Normal</tickerType>
		<techLevel>Spacer</techLevel>
		<smeltable>false</smeltable>
		<statBases>
			<Mass>0.1</Mass>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
		</statBases>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedAngleOffset>-65</equippedAngleOffset>
		<weaponClasses>
			<li>Ranged</li>
		</weaponClasses>
		<weaponTags>
			<li>RI_Charm</li>
		</weaponTags>
		<tradeTags>
			<li>RI_Charm</li>
		</tradeTags>
		<thingSetMakerTags>
			<li>SingleUseWeapon</li>
			<li>RewardStandardLowFreq</li>
		</thingSetMakerTags>
		<relicChance>0</relicChance>
		<tools>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2.6</cooldownTime>
			</li>
		</tools>
	</ThingDef>

	<ThingDef ParentName="RI_CharmBase">
		<defName>RI_Weapon_ThunderCharm</defName>
		<label>Thunder charm</label>
		<description>A special charm with a mysterious incantation engraved on it with a spiritual crystal. The Thunder charm can release thunder when activated.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponCharm/RI_Weapon_ThunderCharm</texPath>
		</graphicData>
		<statBases>
			<MarketValue>1300</MarketValue>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_ShootOneUse</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_ThunderCharm</defaultProjectile>
				<warmupTime>1</warmupTime>
				<ai_AvoidFriendlyFireRadius>8</ai_AvoidFriendlyFireRadius>
				<range>35.9</range>
				<burstShotCount>1</burstShotCount>
				<soundCast>InfernoCannon_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<onlyManualCast>true</onlyManualCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<muzzleFlashScale>14</muzzleFlashScale>
			</li>
		</verbs>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>7.8</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
			</li>
			<li Class="CompProperties_Biocodable"/>
		</comps>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_ThunderCharm</defName>
		<label>Thunder</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_FireCharm</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>RI_Talisman.RI_Projectile_ThunderCharm</thingClass>
		<projectile>
			<damageDef>Bomb</damageDef>
			<!-- Use default damage from explosion def -->
			<explosionRadius>3</explosionRadius>
			<speed>50</speed>
		</projectile>
	</ThingDef>

