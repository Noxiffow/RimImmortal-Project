	<ThingDef ParentName="SkyfallerBase">
		<defName>DropSword</defName>
		<label>DropSword</label>
		<thingClass>Skyfaller</thingClass>
		<graphicData>
			<texPath>Things/Projectile/RI_SkyFaller_SwrodCharm</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
			<drawSize>(10,20)</drawSize>
		</graphicData>
		<skyfaller>
			<shadowSize>(3, 3)</shadowSize>
			<explosionRadius>15.0</explosionRadius>
			<explosionDamage>Vaporize</explosionDamage>
			<explosionDamageFactor>3.0</explosionDamageFactor>
			<rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection>
			<speed>1.2</speed>
		</skyfaller>
	</ThingDef>
	
	<ThingDef ParentName="RI_CharmBase">
		<defName>RI_Weapon_SwordCharm</defName>
		<label>Light sword charm</label>
		<description>A special charm with a mysterious incantation engraved on it with a spiritual crystal. The light sword charm can be activated to summon a light sword from the spell, which is powerful, but only for a limited period of time.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponCharm/RI_Weapon_SwordCharm</texPath>
		</graphicData>
		<statBases>
			<MarketValue>1500</MarketValue>
		</statBases>
		<verbs>
			<li>
				<verbClass>RI_Starch.RI_Verbs.Verb_LightSwordCharm</verbClass>
				<range>15</range>
				<warmupTime>1</warmupTime>
				<soundCast>Psycast_Skip_Entry</soundCast>
				<targetable>true</targetable>
				<requireLineOfSight>false</requireLineOfSight>
				<drawAimPie>false</drawAimPie>
				<onlyManualCast>true</onlyManualCast>
				<defaultCooldownTime>1</defaultCooldownTime>
				<targetParams>
					<canTargetSelf>true</canTargetSelf>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<hasStandardCommand>true</hasStandardCommand>
				<muzzleFlashScale>14</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>11.7</power>
				<cooldownTime>1.6</cooldownTime>
			</li>
		</tools>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>7.8</explosiveRadius>
