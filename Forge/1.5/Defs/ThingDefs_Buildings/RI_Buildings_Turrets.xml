<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--=============== 石矩炮 ===============-->

	<ThingDef ParentName="BuildingBase">
		<defName>RI_Turret_StoneTower</defName>
		<label>Stone tower</label>
		<description>Turrets made of stones can only be generated by cultivators of the Tools. This kind of fortress can shoot stone balls from the center of the stone tower to attack the enemy.</description>
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Security/RI_Turret_StoneTower</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(2,2)</drawSize>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
			<shadowData>
				<volume>(0.27,0.25,0.27)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
		</graphicData>
		<uiIconPath>Things/Building/Security/TurretMini_MenuIcon</uiIconPath>
		<uiIconScale>0.90</uiIconScale>
		<minifiedDef>MinifiedThing</minifiedDef>
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>false</rotatable>
		<thingCategories>
			<li>BuildingsSecurity</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>60</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<WorkToBuild>1800</WorkToBuild>
			<Mass>8</Mass>
			<Beauty>-10</Beauty>
			<ShootingAccuracyTurret>0.96</ShootingAccuracyTurret>
		</statBases>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>20</costStuffCount>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Flickable"/>
		</comps>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.4</fillPercent>
		<hasTooltip>true</hasTooltip>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<building>
			<combatPower>45</combatPower>
			<!-- same as a scavenger -->
			<expandHomeArea>false</expandHomeArea>
			<ai_combatDangerous>true</ai_combatDangerous>
			<turretGunDef>RI_Gun_StoneTower</turretGunDef>
			<turretBurstCooldownTime>5</turretBurstCooldownTime>
		</building>
		<placeWorkers>
			<li>PlaceWorker_TurretTop</li>
			<li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_Stone</defName>
		<label>Stone ball</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_Stone</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>10</damageAmountBase>
			<speed>70</speed>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseWeaponTurret">
		<defName>RI_Gun_StoneTower</defName>
		<label>Stone tower</label>
		<description>Turrets made of stones can only be generated by cultivators of the Tools. This kind of fortress can shoot stone balls from the center of the stone tower to attack the enemy.</description>
		<graphicData>
			<texPath>Things/Building/Security/Empty</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<AccuracyTouch>0.80</AccuracyTouch>
			<AccuracyShort>0.60</AccuracyShort>
			<AccuracyMedium>0.35</AccuracyMedium>
			<AccuracyLong>0.25</AccuracyLong>
			<RangedWeapon_Cooldown>5</RangedWeapon_Cooldown>
			<DeteriorationRate>0</DeteriorationRate>
			<Mass>5</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<defaultProjectile>RI_Bullet_Stone</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>22</range>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
				<soundCast>GunShotA</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<consumeFuelPerShot>1</consumeFuelPerShot>
			</li>
		</verbs>
	</ThingDef>

	<!--=============== 锈弩车 ===============-->

	<ThingDef ParentName="BuildingBase" Name="RI_AutocannonTurret" Abstract="True">
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.5, 1.5)</drawSize>
			<drawOffset>(0,0,-0.1)</drawOffset>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
			<shadowData>
				<volume>(1.5,0.35,1.4)</volume>
				<offset>(0,0,-0.05)</offset>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>false</rotatable>
		<size>(2,2)</size>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0.7</Flammability>
			<WorkToBuild>15000</WorkToBuild>
			<Mass>80</Mass>
			<Beauty>-10</Beauty>
		</statBases>
		<tickerType>Normal</tickerType>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.5</fillPercent>
		<hasTooltip>true</hasTooltip>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<building>
			<expandHomeArea>false</expandHomeArea>
			<ai_combatDangerous>true</ai_combatDangerous>
			<turretTopDrawSize>2.7</turretTopDrawSize>
			<turretTopOffset>(0, 0.05)</turretTopOffset>
		</building>
		<placeWorkers>
			<li>PlaceWorker_TurretTop</li>
			<li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
		<uiIconScale>0.95</uiIconScale>
	</ThingDef>

	<ThingDef ParentName="RI_AutocannonTurret">
		<defName>RI_Turret_SteelCrossbow</defName>
		<label>Rust crossbow</label>
		<description>An iron crossbow made of scrap iron can only be generated by cultivators of the Tools. This turret shoot powerful iron bolts.</description>
		<graphicData>
			<texPath>Things/Building/Security/RI_Turret_SteelCrossbowBase</texPath>
		</graphicData>
		<uiIconPath>Things/Building/Security/Empty</uiIconPath>
		<statBases>
			<ShootingAccuracyTurret>0.96</ShootingAccuracyTurret>
		</statBases>
		<costList>
			<Steel>40</Steel>
		</costList>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
		</comps>
		<building>
			<expandHomeArea>false</expandHomeArea>
			<turretGunDef>RI_Gun_SteelCrossbow</turretGunDef>
			<turretBurstCooldownTime>4.5</turretBurstCooldownTime>
		</building>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_SteelArrow</defName>
		<label>Steel arrow</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Bullet_SteelArrow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>24</damageAmountBase>
			<speed>80</speed>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseWeaponTurret">
		<defName>RI_Gun_SteelCrossbow</defName>
		<label>Rust crossbow</label>
		<description>An iron crossbow made of scrap iron can only be generated by cultivators of the Tools. This turret shoot powerful iron bolts.</description>
		<graphicData>
			<texPath>Things/Building/Security/RI_Gun_SteelCrossbow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<AccuracyTouch>0.3</AccuracyTouch>
			<AccuracyShort>0.6</AccuracyShort>
			<AccuracyMedium>0.7</AccuracyMedium>
			<AccuracyLong>0.9</AccuracyLong>
			<RangedWeapon_Cooldown>4.5</RangedWeapon_Cooldown>
			<DeteriorationRate>0</DeteriorationRate>
			<Mass>30</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<defaultProjectile>RI_Bullet_SteelArrow</defaultProjectile>
				<warmupTime>0</warmupTime>
				<minRange>5</minRange>
				<range>32</range>
				<ticksBetweenBurstShots>15</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>Shot_Autocannon</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>12</muzzleFlashScale>
				<consumeFuelPerShot>1</consumeFuelPerShot>
			</li>
		</verbs>
	</ThingDef>

</Defs>