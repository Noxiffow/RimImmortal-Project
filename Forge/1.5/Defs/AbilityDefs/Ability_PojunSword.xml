<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<AbilityDef>
		<defName>RI_Ability_PojunSword</defName>
		<label>Fly sword</label>
		<description>The sword fly out and attack up to 8 enemies.</description>
		<iconPath>Ability/Weapon/RI_Ability_PojunSword</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<showOnCharacterCard>false</showOnCharacterCard>
		<cooldownTicksRange>720</cooldownTicksRange>
		<!--RangedWeapon_Cooldown>4.10</RangedWeapon_Cooldown-->
		<verbProperties>
			<verbClass>RI_Starch.RI_Verbs.Verb_Ability</verbClass>
			<defaultCooldownTime>2</defaultCooldownTime>
			<requireLineOfSight>true</requireLineOfSight>
			<range>50</range>
			<warmupTime>0.8</warmupTime>
			<soundCast>Psycast_Skip_Entry</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="RI_Starch.RI_Ability.RI_CompProperties_RatWhiskerSword">
				<range>50</range>
				<projectileDef>RI_Projectile_PojunSword</projectileDef>
				<maxTargets>8</maxTargets>
				<detectionRange>6</detectionRange>
				<cooldownTicks>1700</cooldownTicks>
			</li>
		</comps>
	</AbilityDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseBullet">
		<defName>RI_Projectile_PojunSword</defName>
		<label>Fly sword</label>
		<thingClass>RI_Starch.RI_Projectile.FlyingSwordsMissile_df</thingClass>
		<graphicData>
			<texPath>Things/Projectile/RI_Weapon_PojunSword</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.3</drawSize>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<fleck>RI_Fleck_Tail_Ability_PojunSword</fleck>
		<frequency>-1</frequency>
		<scale>0.45</scale>
		<shaking>0</shaking>
		<straightShoot>false</straightShoot>
		<maxTargets>8</maxTargets>
		<detectionRange>6</detectionRange>
		<projectile>
			<soundImpact>Psycast_Skip_Entry</soundImpact>
			<damageDef>Cut</damageDef>
			<damageAmountBase>8.3</damageAmountBase>
			<armorPenetrationBase>0.8</armorPenetrationBase>
			<speed>20</speed>
		</projectile>
	</ThingDef>

	<FleckDef ParentName="RI_Fleck_Tail">
		<defName>RI_Fleck_Tail_Ability_PojunSword</defName>
		<graphicData>
			<texPath>Effects/Normal/RI_GlowB</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(0.83,0.68,0.4)</color>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.02</fadeInTime>
		<solidTime>0.01</solidTime>
		<fadeOutTime>0.28</fadeOutTime>
		<growthRate>-0.9</growthRate>
	</FleckDef>

	<FleckDef Class="RI_Starch.RI_ThingDef.RI_FleckDef" ParentName="FleckBase_Thrown">
		<defName>RI_Fleck_Hit_Ability_PojunSword</defName>
		<graphicData>
			<texPath>Effects/GlassPearlUmbrella/RI_hit</texPath>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>0.05</solidTime>
		<fadeOutTime>0.7</fadeOutTime>
		<growthRate>-1.3</growthRate>
		<RotationAngle>180~180</RotationAngle>
		<VelocityAngle>0~360</VelocityAngle>
	</FleckDef>
</Defs>

