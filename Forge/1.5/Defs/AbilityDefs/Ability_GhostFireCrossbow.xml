<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<AbilityDef>
		<defName>RI_Arrow_GhostFireCrossbow_Ability</defName>
		<label>Ghost fire explode</label>
		<description>Fire 3 flaming arrow.</description>
		<iconPath>Ability/Weapon/RI_Arrow_GhostFireCrossbow_Ability</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
			<accuracyTouch>0.79</accuracyTouch>
			<accuracyShort>0.85</accuracyShort>
			<accuracyMedium>0.85</accuracyMedium>
			<accuracyLong>0.85</accuracyLong>
			<range>29.9</range>
			<burstShotCount>3</burstShotCount>
			<ticksBetweenBurstShots>1</ticksBetweenBurstShots>
			<defaultProjectile>RI_Bullet_GhostFireCrossbow</defaultProjectile>
			<verbClass>RI_Starch.RI_Ability.RI_Verb_AbilityBurst</verbClass>
			<warmupTime>2.1</warmupTime>
			<soundCast>Bow_Recurve</soundCast>
			<ai_IsWeapon>false</ai_IsWeapon>
		</verbProperties>
	</AbilityDef>

	<FleckDef ParentName="FleckBase">
		<defName>RI_GhostFireCrossbow</defName>
		<graphicData>
			<texPath>Effects/Damage/RI_GhostFireCrossbow</texPath>
			<drawSize>1.5</drawSize>
			<shaderType>TransparentPostLight</shaderType>
			<renderInstanced>true</renderInstanced>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>0</solidTime>
		<fadeOutTime>0.2</fadeOutTime>
	</FleckDef>

	<DamageDef ParentName="Flame">
		<defName>RI_GhostFireCrossbow</defName>
		<explosionColorCenter>(255, 255, 255)</explosionColorCenter>
		<explosionColorEdge>(200, 200, 200)</explosionColorEdge>
		<explosionCellFleck>RI_GhostFireCrossbow</explosionCellFleck>
		<soundExplosion>Explosion_Flame</soundExplosion>
	</DamageDef>

	<ThingDef Class="RI_Starch.RI_ThingDef.RI_Missile" ParentName="BaseProjectileNeolithic">
		<defName>RI_Bullet_GhostFireCrossbow</defName>
		<label>Ghost fire arrow</label>
		<thingClass>RI_Starch.RI_Projectile.RI_Projectile_Rot</thingClass>
		<tickerType>Normal</tickerType>
		<useHitPoints>False</useHitPoints>
		<graphicData>
			<texPath>Things/Projectile/RI_Arrow_GhostFireCrossbow</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile>
			<ai_IsIncendiary>true</ai_IsIncendiary>
			<explosionChanceToStartFire>1</explosionChanceToStartFire>
			<explosionRadius>2</explosionRadius >
			<damageDef>RI_GhostFireCrossbow</damageDef>
			<!-- Use default damage from explosion def -->
			<damageAmountBase>20</damageAmountBase>
			<armorPenetrationBase>0.35</armorPenetrationBase>
			<speed>49</speed>
			<arcHeightFactor>5</arcHeightFactor>
			<shadowSize>1</shadowSize>
		</projectile>
		<fleck>RI_Fleck_Tail_Long</fleck>
		<frequency>0</frequency>
		<scale>0.9</scale>
		<shaking>0.05</shaking>
		<color>(0.5,0.9,0.8)</color>
	</ThingDef>

</Defs>