<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 土行法门 -->

	<!-- 凝气境界——坤土 -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_EarthCultivation</defName>
		<label>Earth element cultivation</label>
		<description>&lt;color=#C9B954&gt;This technique is learned by the Noviciate rank of the Earth-element Path\n\n&lt;/color&gt;Spiritual energy acquisition efficiency +25%.\n\nEarth is associated with cultivation; it is the foundational cultivation method of the Earth element. It can enhance one’s physical resilience and defensive strength.</description>
		<iconPath>UI/Abilities/EarthElement/RI_Ability_EarthCultivation</iconPath>
		<jobDef>CastAbilityOnThingMelee</jobDef>
		<targetRequired>False</targetRequired>
		<canUseAoeToGetTargets>false</canUseAoeToGetTargets>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_EntropyGain>0</Ability_EntropyGain>
			<Ability_PsyfocusCost>0</Ability_PsyfocusCost>
			<Ability_Duration>99999</Ability_Duration>
		</statBases>
		<verbProperties>
			<violent>false</violent>
			<warmupTime>0.1</warmupTime>
			<range>0</range>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>RI_Hediff_EarthCultivationHediff</hediffDef>
				<psychic>True</psychic>
				<replaceExisting>True</replaceExisting>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCasting">
				<moteCastDef>RI_Ability_BodyTheory_Mote</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteSinging">
				<moteCastDef>RI_Ability_ElixirsStrengthen_Singing</moteCastDef>
			</li>
			<!--技能准备特效-->
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<moteCastDef>RI_Mote_Earth_Cultivation</moteCastDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>0</rEnergy>
			</li>
		</comps>
	</AbilityDef>

	<!-- 凝气境界——乾元生柱 -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_EarthSpiritColumn</defName>
		<label>Earth column</label>
		<description>&lt;color=#C9B954&gt;This technique is learned by the Foundation rank of the Earth-element Path\n\n&lt;/color&gt;Qi cost: 50\n\nCreates one Earth Column.\n\nThe Earth Column is a technique unique to Earth cultivation. By resonating with the Qi within the ground, it refines and condenses it into an Earth Column, which serves as a medium for channeling other spells.\n\nThe Earth Column can exist indefinitely and is capable of bearing heavy weight. If destroyed by external force, it leaves nothing behind. Most advanced Earth cultivation techniques require an Earth Column as a triggering medium.</description>
		<iconPath>UI/Abilities/EarthElement/RI_Ability_EarthSpiritColumn</iconPath>
		<!--1小时-->
		<cooldownTicksRange>2500</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayOrder>100</displayOrder>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<warmupStartSound>RI_Sound_EnergyPreparationA</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>7</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>RI_Sound_RockShock</soundCast>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-50</rEnergy>
			</li>
			<li Class="RI_FiveElements.CompProperties_AbilitySpawnOnNaturalTerrain">
				<thingDef>RI_Building_StoneColumn</thingDef>
				<allowOnBuildings>false</allowOnBuildings>
				<sendSkipSignal>true</sendSkipSignal>
			</li>
			<!--技能准备特效-->
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<moteCastDef>RI_Mote_Earth_Normal</moteCastDef>
			</li>
		</comps>
	</AbilityDef>

	<!-- 化丹境界——石甲护身 -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_StoneArmor</defName>
		<label>Stone armor</label>
		<description>&lt;color=#C9B954&gt;This technique is learned by the Core-formation rank of the Earth-element Path\n\n&lt;/color&gt;Qi cost: 90\n\nSelects an Earth Column within the target area as a medium and shatters it, causing nearby targets to be enveloped by stone fragments that automatically conform to their bodies, forming Stone Armor.\n\nThe Stone Armor redirects all incoming impact forces into the ground, providing powerful defensive protection for a short time. However, its heavy weight significantly reduces movement speed.</description>
		<iconPath>UI/Abilities/EarthElement/RI_Ability_StoneArmor</iconPath>
		<cooldownTicksRange>5000</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayOrder>200</displayOrder>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<warmupStartSound>RI_Sound_EnergyPreparationA</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>6.9</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>RI_Sound_RockShock</soundCast>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetBuildings>true</canTargetBuildings>
			</targetParams>
		</verbProperties>
		<statBases>
			<Ability_EffectRadius>1.5</Ability_EffectRadius>
		</statBases>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-90</rEnergy>
			</li>
			<li Class="RI_FiveElements.CompProperties_AbilityDetonateColumn">
				<thingDef>RI_Building_StoneColumn</thingDef>
				<radius>1.5</radius>
				<hediff>RI_Hediff_StoneArmorEffect</hediff>
				<targetingParameters>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetAnimals>true</canTargetAnimals>
					<canTargetMechs>true</canTargetMechs>
					<canTargetHumans>true</canTargetHumans>
					<onlyTargetColonists>true</onlyTargetColonists>
				</targetingParameters>
			</li>
			<!--技能准备特效-->
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<moteCastDef>RI_Mote_Earth_Normal</moteCastDef>
			</li>
		</comps>
	</AbilityDef>

	<!-- 结丹境界——岩碎 -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_FlyingSand</defName>
		<label>Rock crushing</label>
		<description>&lt;color=#C9B954&gt;This technique is learned by the Core-formation rank of the Earth-element Path\n\n&lt;/color&gt;Qi cost: 160\n\nSelects an Earth Column within the target area as a medium and detonates it. Countless shards of stone and grains of sand scatter outward, striking enemies in the area, clinging to their bodies, obscuring their vision, and slowing their movement speed.</description>
		<iconPath>UI/Abilities/EarthElement/RI_Ability_FlyingSand</iconPath>
		<cooldownTicksRange>2500</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayOrder>300</displayOrder>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<warmupStartSound>RI_Sound_EnergyPreparationA</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>0</range>
			<warmupTime>1</warmupTime>
			<soundCast>RI_Sound_RockShock</soundCast>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-160</rEnergy>
			</li>
			<li Class="RI_FiveElements.CompProperties_AbilityDetonateAllColumns">
				<thingDef>RI_Building_StoneColumn</thingDef>
				<selectionRadius>14</selectionRadius>
				<explosionRadius>6.9</explosionRadius>
				<damage>5</damage>
				<damageDef>Blunt</damageDef>
				<armorPenetration>0.2</armorPenetration>
				<hediff>RI_Hediff_FlyingSand</hediff>
				<targetingParameters>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetAnimals>true</canTargetAnimals>
					<canTargetMechs>true</canTargetMechs>
					<canTargetHumans>true</canTargetHumans>
					<onlyTargetColonists>false</onlyTargetColonists>
				</targetingParameters>
			</li>
			<!--技能准备特效-->
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<moteCastDef>RI_Mote_Earth_Normal</moteCastDef>
			</li>
		</comps>
	</AbilityDef>

