<Defs>

	<!--火行法门-->

	<!-- 离火 -->
	<AbilityDef  ParentName="RI_PsycastBase">
		<defName>RI_Ability_FireCultivation</defName>
		<label>Fire element cultivation</label>
		<description>&lt;color=#FF5832&gt;This technique is learned by the Noviciate rank of the Fire-element Path\n\n&lt;/color&gt;Spiritual energy acquisition efficiency +40%.\n\nThe fire rises, Fire element cultivation is the foundational method of fire cultivation. It can slightly enhance one’s five senses.</description>
		<iconPath>UI/Abilities/FireElement/RI_Ability_FireCultivation</iconPath>
		<targetRequired>False</targetRequired>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<warmupStartSound>RI_Sound_StartFire_A</warmupStartSound>
		<verbProperties>
			<violent>false</violent>
			<warmupTime>0</warmupTime>
			<range>0</range>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>RI_He_FireCultivationHediff</hediffDef>
				<psychic>True</psychic>
				<replaceExisting>True</replaceExisting>
				<onlyApplyToSelf>True</onlyApplyToSelf>
				<durationSecondsOverride>99999</durationSecondsOverride>
			</li>

			<!-- TODO 下面需要处理 -->
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<!--触发特效-->
				<moteCastDef>RI_Ability_Fire_Cultivation</moteCastDef>
			</li>

		</comps>
	</AbilityDef>

	<!-- 心炎 -->
	<AbilityDef  ParentName="RI_PsycastBase">
		<defName>RI_Ability_Fire_BurningSoul</defName>
		<label>Heart flame</label>
		<description>&lt;color=#FF5832&gt;This technique is learned by the Core-formation rank of the Fire-element Path\n\n&lt;/color&gt;Qi cost: 50\n\nAdd six layers of Life Fire.\n\nHeart Flame is a secret technique of the Fire method. Only those who pass this trial can continue their cultivation. Heart Flame operates through a special method of spiritual energy, starting from the heart and stirring one’s emotions, causing agitation. However, this stimulation also enhances combat abilities.\n\nIn addition, Heart Flame will create five Life Fires on the body, a product combining spiritual energy and emotions. Future cultivation methods will require consuming Life Fire to fuel their power.</description>
		<iconPath>UI/Abilities/FireElement/RI_Ability_Fire_BurningSoul</iconPath>
		<targetRequired>False</targetRequired>
		<cooldownTicksRange>300</cooldownTicksRange>
		<canUseAoeToGetTargets>False</canUseAoeToGetTargets>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<warmupStartSound>RI_Sound_StartFire_A</warmupStartSound>
		<verbProperties>
			<violent>false</violent>
			<warmupTime>0</warmupTime>
			<range>0</range>
			<requireLineOfSight>False</requireLineOfSight>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>RI_He_Fire_BurningSoul</hediffDef>
				<psychic>True</psychic>
				<replaceExisting>True</replaceExisting>
				<onlyApplyToSelf>True</onlyApplyToSelf>
				<durationSecondsOverride>750</durationSecondsOverride>
			</li>

			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-50</rEnergy>
			</li>
		</comps>
	</AbilityDef>

	<!-- 吹火 -->
	<!-- MayRequire="Biotech" -->
	<AbilityDef  ParentName="RI_PsycastBase">
		<defName>RI_Ability_Fire_Spew</defName>
		<label>Flame breath</label>
		<description>&lt;color=#FF5832&gt;This technique is learned by the Core-coagulation rank of the Fire-element Path\n\n&lt;/color&gt;Qi cost: 30\n\nConsume one layer of Life Fire to unleash flames.\n\nUsing one’s own Life Fire as the source and Qi as the fuel, a great burst of flames is expelled from the mouth.</description>
		<iconPath>UI/Abilities/FireElement/RI_Ability_Fire_Spew</iconPath>
		<!--冷却-->
		<cooldownTicksRange>5</cooldownTicksRange>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<warmupStartSound>RI_Sound_StartFire_A</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>9.5</range>
			<warmupTime>1</warmupTime>
			<soundCast>RI_Sound_FireBall_C</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityFireSpew">
				<range>13</range>
				<lineWidthEnd>3</lineWidthEnd>
				<filthDef>Filth_FlammableBile</filthDef>
				<effecterDef>Fire_Spew</effecterDef>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
			<li Class="RI_FiveElements.CompProperties_HediffAsEnergy">
				<hediffDef>RI_He_Fire_BurningSoul</hediffDef>
				<useEnergy>1</useEnergy>
				<disableReason>Need one Life fire</disableReason>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-30</rEnergy>
			</li>
		</comps>
	</AbilityDef>

	<!-- 炽飞雀 -->
	<AbilityDef  ParentName="RI_PsycastBase">
		<defName>RI_Ab_Fire_FireBall</defName>
		<label>Blazing sparrow</label>
		<description>&lt;color=#FF5832&gt;This technique is learned by the Core-consummation rank of the Fire-element Path\n\n&lt;/color&gt;Qi cost: 30\n\nConsume one layer of Life Fire to unleash three Blazing Sparrows.\n\nUsing one’s own Life Fire as the source, combined with precise spiritual energy control, the conjured flames are shaped into several fire sparrows and then released.\n\nThis technique serves as proof of one's mastery over fire manipulation, making it more of a display of skill than a purely practical ability.</description>
		<iconPath>UI/Abilities/FireElement/RI_Ab_Fire_FireBall</iconPath>
		<cooldownTicksRange>50</cooldownTicksRange>
		<!-- <category>TODO</category> -->
		<displayOrder>200</displayOrder>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>		
			<range>24.9</range>
			<warmupTime>0.2</warmupTime>
			<soundCast>RI_Sound_FireBall_A</soundCast>
			<accuracyTouch>1.0</accuracyTouch>
			<accuracyShort>1.0</accuracyShort>
			<accuracyMedium>0.95</accuracyMedium>
			<accuracyLong>0.9</accuracyLong>
			<burstShotCount>3</burstShotCount>
			<ticksBetweenBurstShots>15</ticksBetweenBurstShots>
			<defaultProjectile>RI_Ab_Fire_FireBall_Projectile</defaultProjectile>
			<verbClass>Verb_AbilityShoot</verbClass>
			<ai_IsWeapon>false</ai_IsWeapon>
			<onlyManualCast>true</onlyManualCast>
			<minRange>1.5</minRange>
		</verbProperties>
		<comps>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-30</rEnergy>
			</li>
			<!-- <li Class="CompProperties_AbilityLaunchProjectile">
				<projectileDef>RI_Ab_Fire_FireBall_Projectile</projectileDef>
			</li> -->
			<li Class="RI_FiveElements.CompProperties_HediffAsEnergy">
				<hediffDef>RI_He_Fire_BurningSoul</hediffDef>
				<useEnergy>1</useEnergy>
				<disableReason>Need one Life fire</disableReason>
			</li>
		</comps>
	</AbilityDef>

