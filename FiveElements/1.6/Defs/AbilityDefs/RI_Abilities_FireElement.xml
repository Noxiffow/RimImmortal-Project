	<!-- 焚绝 -->
	<AbilityDef  ParentName="RI_PsycastBase">
		<defName>RI_Ability_Fire_Impact</defName>
		<label>Burn off</label>
		<description>&lt;color=#FF5832&gt;This technique is learned by the Core-consummation rank of the Fire-element Path\n\n&lt;/color&gt;Qi cost: 60\n\nConsume one layer of Life Fire to unleash a flash explosion centered on oneself.\n\nBurn off is a unique skill that consumes one’s own Life Fire to trigger a flash explosion.\n\nThe cultivation process of this technique is rather dangerous and may easily cause self-inflicted harm. However, once mastered, it serves as a vital trump card for survival.</description>
		<iconPath>UI/Abilities/FireElement/RI_Ability_Fire_Impact</iconPath>
		<cooldownTicksRange>50</cooldownTicksRange>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<warmupStartSound>RI_Sound_FireBall_B</warmupStartSound>
		<targetRequired>False</targetRequired>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>9.5</range>
			<warmupTime>1</warmupTime>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="RI_FiveElements.CompProperties_AbilityRangeExplosion">
				<deviationRange>0</deviationRange>
				<explosionRange>9.5</explosionRange>
				<damage>19</damage>
				<damageTimes>2</damageTimes>
				<damageTypeOrder>1</damageTypeOrder>
				<armorPenetration>2</armorPenetration>
				<damageTypes>
					<li>Burn</li>
					<li>Flame</li>
				</damageTypes>
				<!-- TODO -->
				<!-- <effecterDef></effecterDef> -->
				<!-- 声音 -->
				<!--<explosionsound>RI_Sound_FireBall_C</explosionsound>-->
			</li>
			<li Class="RI_FiveElements.CompProperties_HediffAsEnergy">
				<hediffDef>RI_He_Fire_BurningSoul</hediffDef>
				<useEnergy>1</useEnergy>
				<disableReason>Need one Life fire</disableReason>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
				<rEnergy>-60</rEnergy>
			</li>
		</comps>
	</AbilityDef>

