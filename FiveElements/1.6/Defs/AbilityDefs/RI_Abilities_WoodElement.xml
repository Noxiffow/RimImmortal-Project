	<!-- Spirit core — forest guardian -->
	<!-- Target plants in range, transform them into mobile guards -->
	<!-- Target a fully-grown tree and transform it into a verdant creature. Its lifespan is limited, but grows stronger over time. (Two hediffs: Limited life + Verdant growth) -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_ForestGuardian</defName>
		<label>Forest guardian</label>
		<description>&lt;color=#7FCD44&gt;This technique is learned by the Strengthening foundation Realm of the Wood-element Path\n\n&lt;/color&gt;Qi cost: 500\n\nTransform Tree into Verdant creature.\n\nThrough the Vitality arts of the Wood Path, ordinary trees are granted vitality and transformed into powerful Verdant creatures.\n\nOrdinary tree——Verdant guard\nQingMing tree——QingMing dryad</description>
		<iconPath>UI/Abilities/WoodElement/RI_Ability_ForestGuardian</iconPath>
		<cooldownTicksRange>60000</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayOrder>300</displayOrder>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<!-- TODO: replace sound -->
		<warmupStartSound>AcidSpray_Warmup</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>3</range>
			<warmupTime>0.5</warmupTime>
			<!-- TODO: replace sound -->
			<soundCast>RI_Sound_PlantsGrowing</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<!-- Restores partial Qi energy -->
			 <li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
                <rEnergy>-500</rEnergy>
            </li> 
			<li Class="RI_FiveElements.CompProperties_PlantToPawn">
				<!-- Default creature type — verdant creature -->
				<defaultPawnKindDef>Dryad_Basic</defaultPawnKindDef>
				<!-- Creature corresponding to trees -->
				<treePawnKindDef>RI_Pawn_VerdantGuard</treePawnKindDef>
				<treeOnly>true</treeOnly>
				<!-- Radius -->
				<radius>5</radius>
				<!-- Visual effect mote -->
				<moteDef>RI_Mote_Wood_CreatePlantsBuilding</moteDef>
				<!-- Add hediff -->
				<hediffs>
					<li>
						<def>RI_He_Wood_LimitedLife</def>
						<severity>1</severity>
					</li>
					<li>
						<def>RI_He_Wood_Growth</def>
						<severity>0.01</severity>
					</li>
				</hediffs>
				<!-- Creature types for specific plants -->
				<plantToPawns>
					<li>
						<thingDef>RI_Tree_QingMing</thingDef>
						<pawnKindDef>RI_Pawn_QingMingDryad</pawnKindDef>
					</li>
				</plantToPawns>
			</li>
		</comps>
	</AbilityDef>

	<!-- Deity transformation — vitality graft -->
	<!-- Target a pawn to extend its limited lifespan -->
	<AbilityDef ParentName="RI_PsycastBase">
		<defName>RI_Ability_WoodLifeGive</defName>
		<label>Vitality grafting</label>
		<!-- Target verdant creatures in range and inject vitality; the cost is shared among units in range -->
		<description>&lt;color=#7FCD44&gt;This technique is learned by the Spirit constraint rank of the Wood-element Path\n\n&lt;/color&gt;Qi cost: 350\n\nGraft vitality into a Verdant Creature to extend its life.\n\nA secret technique of the Wood-Element Path, this method allows a cultivator to graft their own vitality into another being. Once a source of pride among practitioners, the art was lost due to the break in its lineage—its brilliance fading into silence. In the end, only flora most deeply bonded with a Wood-Element cultivator can still receive vitality through this method.\n\nThis once-legendary technique was created by Daoist Qingyu during the era of the sect wars. Tragically, it was also this very art that eventually led to his untimely death.</description>
		<iconPath>UI/Abilities/WoodElement/RI_Ability_WoodLifeGive</iconPath>
		<cooldownTicksRange>60000</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayOrder>300</displayOrder>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<!-- TODO: replace sound -->
		<warmupStartSound>AcidSpray_Warmup</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>3</range>
			<warmupTime>0.5</warmupTime>
			<!-- TODO: replace sound -->
			<soundCast>RocketswarmLauncher_Fire</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<!-- Restores partial Qi energy -->
			 <li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
                <rEnergy>-350</rEnergy>
            </li> 
			<li Class="RI_FiveElements.CompProperties_LifeToPawn">
				<!-- Minimum vitality supply -->
				<baseLife>0.35</baseLife>
				<!-- Vitality multiplier -->
				<lifeMultiplier>1</lifeMultiplier>
				<!-- Vitality consumption percentage -->
				<useVitality>2</useVitality>
				<!-- Radius -->
				<radius>3</radius>
				<!-- Visual effect mote -->
				<moteDef></moteDef>
			</li>
			<li Class="WhoXiuXian.Abilities.CompProperties_SpawnMoteCast">
				<!--Trigger effect-->
				<moteCastDef>RI_Mote_WoodLifeGive</moteCastDef>
			</li>
		</comps>
	</AbilityDef>

