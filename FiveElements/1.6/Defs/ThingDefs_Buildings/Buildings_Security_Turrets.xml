<Defs>

	<!--==================== Wood element plant turrets ======================== -->

	<!--<killedLeavings>
		<WoodLog>4</WoodLog>
	</killedLeavings>-->

	<!--<tradeability>None</tradeability>-->
	<!--<destroyOnDrop>true</destroyOnDrop>-->
	
	<!--Corn-cannon turret-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Turret_CornCannon</defName>
		<label>Corn-cannon</label>
		<description>A small organic sentry that fires rapid volleys of tiny thorns. Does not require power or fuel.</description>
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Security/PlantTurret/RI_Turret_CornCannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.8</drawSize>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
			<shadowData>
				<offset>(-0.13,-0.87,-0.1)</offset>
				<volume>(0.5,0.4,0.5)</volume>
			</shadowData>
		</graphicData>
		<minifiedDef IsNull="True" />
		<uiIconPath>Things/Building/Security/PlantTurret/RI_Turret_CornCannon</uiIconPath>
		<altitudeLayer>Building</altitudeLayer>
		<pathCost>40</pathCost>
		<constructEffect>ConstructWood</constructEffect>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<drawGUIOverlay>false</drawGUIOverlay>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<!--Half health due to small size and no wood-->
			<Flammability>1</Flammability>
			<WorkToBuild>1</WorkToBuild>
			<Mass>40</Mass>
			<!--Half mass-->
			<Beauty>0</Beauty>
			<ShootingAccuracyTurret>0.98</ShootingAccuracyTurret>
		</statBases>
		<tickerType>Normal</tickerType>
		<comps Inherit="False">
			<li Class="CompProperties_Refuelable">
				<!--Same life duration-->
				<consumeFuelOnlyWhenUsed>false</consumeFuelOnlyWhenUsed>
				<fuelConsumptionRate>3</fuelConsumptionRate>
				<destroyOnNoFuel>true</destroyOnNoFuel>
				<fuelCapacity>1</fuelCapacity>
				<fuelLabel>Life percentage left</fuelLabel>
				<initialFuelPercent>1</initialFuelPercent>
				<fuelMultiplier>100</fuelMultiplier>
				<fuelFilter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</fuelFilter>
			</li>
		</comps>
		<passability>PassThroughOnly</passability>
		<fillPercent>0</fillPercent>
		<hasTooltip>true</hasTooltip>

		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<!--<designationCategory>EcotechDesignation</designationCategory>-->
		<uiOrder>2650</uiOrder>
		<!--<specialDisplayRadius>16.9</specialDisplayRadius>-->
		<stealable>false</stealable>
		<rotatable>false</rotatable>
		<building>
			<artificialForMeditationPurposes>false</artificialForMeditationPurposes>
			<claimable>true</claimable>
			<ai_combatDangerous>true</ai_combatDangerous>
			<turretGunDef>RI_Gun_CornCannon</turretGunDef>
			<turretBurstCooldownTime>3.0</turretBurstCooldownTime>
			<playTargetAcquiredSound>false</playTargetAcquiredSound>
			<deconstructible>false</deconstructible>
			<destroySound>BuildingDestroyed_Wood_Small</destroySound>
		</building>
		<placeWorkers>
			<li>PlaceWorker_TurretTop</li>
			<li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
	</ThingDef>

	<!--Corn-cannon — gun-->
	<ThingDef ParentName="BaseWeaponTurret">
		<defName>RI_Gun_CornCannon</defName>
		<label>Corn cannon</label>
		<description>A rocketswarm tube of the type usually mounted on a rocketswarm launcher turret.</description>
		<graphicData>
			<texPath>Things/Building/Security/PlantTurret/RI_Gun_CornCannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.4</drawSize>
		</graphicData>
		<tickerType>Normal</tickerType>
		<altitudeLayer>Item</altitudeLayer>
		<soundInteract>Interact_Rifle</soundInteract>
		<tradeability>None</tradeability>
		<destroyOnDrop>true</destroyOnDrop>
		<statBases>
			<AccuracyTouch>0.5</AccuracyTouch>
			<AccuracyShort>0.5</AccuracyShort>
			<AccuracyMedium>0.6</AccuracyMedium>
			<AccuracyLong>0.7</AccuracyLong>
			<RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
			<Mass>4</Mass>
			<Flammability>3</Flammability>
			<DeteriorationRate>0</DeteriorationRate>
		</statBases>
		<weaponTags>
			<li>TurretGun</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Bullet_Rocket</defaultProjectile>
				<forcedMissRadius>2.9</forcedMissRadius>
				<warmupTime>5</warmupTime>
				<ai_AvoidFriendlyFireRadius>5</ai_AvoidFriendlyFireRadius>
				<range>30</range>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>InfernoCannon_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<onlyManualCast>true</onlyManualCast>
				<stopBurstWithoutLos>false</stopBurstWithoutLos>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<muzzleFlashScale>14</muzzleFlashScale>
			</li>
		</verbs>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>1.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RI_Bullet_Rocket</defName>
		<label>corn bomb</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Projectile_CornBomb</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Bomb</damageDef>
			<!-- Use default damage from explosion def -->
			<explosionRadius>1.9</explosionRadius>
			<speed>50</speed>
		</projectile>
	</ThingDef>

