<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Third-rate — Yan fire blade (requires Forge)-->
	<ThingDef ParentName="RI_MagicalWeapon_Sharp_Base" MayRequire="RI.RimImmortal.Living">
		<defName>RI_Weapon_SteelFireBlade</defName>
		<label>Yan fire blade【Third-rate】</label>
		<description>【Third-rate】sword weapon.\n\nSince the discovery of fire through flint, war has followed.\n\nThe Yan fire blade was an early self-defense weapon used by fire sects. Short in length, its blade resembles flowing flames, burning fiercely. This craftsmanship combines spell and tradition, allowing fire-element cultivators to dominate the battlefield.\n\n&lt;color=#FFFF00&gt;【Special effects】\nAttack have a chance to ignite.&lt;/color&gt;</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_SteelFireBlade</texPath>
			<drawSize>2</drawSize>
		</graphicData>
		<!--Icon texture-->
		<uiIconPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_SteelFireBlade_Icon</uiIconPath>
		<uiIconScale>1.35</uiIconScale>

		<!--Materials-->
		<costList>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
			<RI_Resource_DamascusIron MayRequire="RI.RimImmortal.Living">30</RI_Resource_DamascusIron>
		</costList>

		<statBases>
			<WorkToMake>9000</WorkToMake>
			<Mass>1.8</Mass>
		</statBases>
		<equippedAngleOffset>-65</equippedAngleOffset>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers>
				<li>ElectricSmithy</li>
				<li>FueledSmithy</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
			<displayPriority>410</displayPriority>
			<!--Requires Forge mod-->
			<researchPrerequisite MayRequire="RI.RimImmortal.Forge">RI_InitialApproach_FiveElements_Fire</researchPrerequisite>
		</recipeMaker>
		<!--Tags-->
		<weaponTags>
			<li>RI_Tag_MagicalWeapon_Sword</li>
			<li>RI_Tag_MagicalWeapon_Third</li>
			<li>RI_Tag_MagicalWeapon</li>
		</weaponTags>
		<tradeTags>
			<li>RI_ThirdWeapon_Tag</li>
		</tradeTags>
		<!--Weapon attack effects-->
		<tools>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>21</power>
				<cooldownTime>2</cooldownTime>
				<armorPenetration>0.2</armorPenetration>
				<extraMeleeDamages>
					<li>
						<def>Flame</def>
						<amount>10</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>21</power>
				<cooldownTime>2</cooldownTime>
				<armorPenetration>0.1</armorPenetration>
				<extraMeleeDamages>
					<li>
						<def>Flame</def>
						<amount>10</amount>
						<chance>0.5</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

	<!--Third-rate — HengYuan quarterstaff (requires Forge)-->
	<ThingDef ParentName="RI_MagicalWeapon_Blunt_Base" MayRequire="RI.RimImmortal.Living">
		<defName>RI_Weapon_EarthQuarterstaff</defName>
		<label>HengYuan quarterstaff【Third-rate】</label>
		<description>【Third-rate】blunt weapon.\n\nThe nature of earth is receptive; thus the virtuous bear all things.\n\nA sturdy staff formed by condensing earth and stone with spiritual energy. Well-balanced and durable, it is commonly used by earth-element cultivators for daily staff training.\n\n&lt;color=#FFFF00&gt;【Special effects】\nAttack with vertigo effect.&lt;/color&gt;</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_EarthQuarterstaff</texPath>
			<drawSize>2.2</drawSize>
		</graphicData>
		<!--Icon texture-->
		<uiIconPath>Things/Item/Equipment/WeaponMelee/RI_Weapon_EarthQuarterstaff</uiIconPath>
		<uiIconScale>1.1</uiIconScale>

		<!--Materials-->
		<costList>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
			<RI_Resource_BlackCorundum MayRequire="RI.RimImmortal.Living">20</RI_Resource_BlackCorundum>
			<RI_Resource_Mud MayRequire="RI.RimImmortal.Living">20</RI_Resource_Mud>
		</costList>

		<statBases>
			<WorkToMake>8000</WorkToMake>
			<Mass>2.5</Mass>
		</statBases>
		<equippedAngleOffset>-25</equippedAngleOffset>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers>
				<li>ElectricSmithy</li>
				<li>FueledSmithy</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
			<displayPriority>410</displayPriority>
			<!--Requires Forge mod-->
			<researchPrerequisite MayRequire="RI.RimImmortal.Forge">RI_InitialApproach_FiveElements_Earth</researchPrerequisite>
		</recipeMaker>
		<!--Tags-->
		<weaponTags>
			<li>RI_Tag_MagicalWeapon_Third</li>
			<li>RI_Tag_MagicalWeapon</li>
		</weaponTags>
		<tradeTags>
			<li>RI_ThirdWeapon_Tag</li>
		</tradeTags>
		<!--Weapon attack effects-->
		<tools>
			<li>
				<label>head</label>
				<labelUsedInLogging>false</labelUsedInLogging>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>19</power>
				<cooldownTime>2</cooldownTime>
				<armorPenetration>0.1</armorPenetration>
				<!--Requires Forge mod-->
				<extraMeleeDamages MayRequire="RI.RimImmortal.Forge">
					<li>
						<def>RI_Damage_Vertigo</def>
						<amount>4</amount>
						<chance>0.7</chance>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
	</ThingDef>

	<!--Third-rate — upas blood (requires Forge)-->
	<ThingDef ParentName="BaseWeaponNeolithic" MayRequire="RI.RimImmortal.Living">
		<defName>RI_Weapon_BambooPoisonBow</defName>
		<label>upas blood【Third-rate】</label>
		<description>【Third-rate】range weapon.\n\nA bamboo-crafted bow coated with a toxin refined by wood-element sects. This weapon is highly insidious. While ordinary poisons are ineffective against high-level cultivators, it is more than sufficient against common foes.\n\n&lt;color=#FFFF00&gt;【Special effects】\nThe arrow is poisoned.&lt;/color&gt;</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/RI_Weapon_BambooPoisonBow</texPath>
			<drawSize>1.3</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Bow_Small</soundInteract>

		<!--Materials-->
		<costList>
			<RI_Resource_RawBamboo MayRequire="RI.RimImmortal.Living">50</RI_Resource_RawBamboo>
			<RI_Resource_SpiritualCrystal>5</RI_Resource_SpiritualCrystal>
		</costList>

		<statBases>
			<WorkToMake>2400</WorkToMake>
			<Mass>0.3</Mass>
			<AccuracyTouch>0.55</AccuracyTouch>
			<AccuracyShort>0.85</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.45</AccuracyLong>
			<RangedWeapon_Cooldown>1.65</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>RI_Tag_BasicGun</li>
			<li>RI_MagicalWeapon</li>
		</weaponTags>
		<tradeTags>
			<li>RI_ThirdWeapon_Tag</li>
		</tradeTags>
		<weaponClasses>
			<li>Ranged</li>
			<li>RangedLight</li>
		</weaponClasses>
		<recipeMaker>
			<recipeUsers>
				<li>FueledSmithy</li>
				<li>ElectricSmithy</li>
			</recipeUsers>
			<!--Requires Forge mod-->
			<researchPrerequisite MayRequire="RI.RimImmortal.Forge">RI_InitialApproach_FiveElements_Wood</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<displayPriority>502</displayPriority>
		</recipeMaker>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RI_Projectile_PoisonArrow</defaultProjectile>
				<warmupTime>1.5</warmupTime>
				<range>25</range>
				<soundCast>Bow_Small</soundCast>
			</li>
		</verbs>
		<tools>
			<li>
				<label>limb</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<rotateInShelves>false</rotateInShelves>
	</ThingDef>

	<ThingDef ParentName="BaseProjectileNeolithic">
		<defName>RI_Projectile_PoisonArrow</defName>
		<label>poison arrow</label>
		<graphicData>
			<texPath>Things/Projectile/RI_Projectile_PoisonArrow</texPath>
			<drawSize>1.7</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>RI_Damage_PoisonArrow</damageDef>
			<damageAmountBase>7</damageAmountBase>
			<speed>45</speed>
		</projectile>
	</ThingDef>

	<DamageDef>
		<defName>RI_Damage_PoisonArrow</defName>
		<label>poison arrow damage</label>
		<workerClass>DamageWorker_AddInjury</workerClass>
		<externalViolence>true</externalViolence>
		<hediff>Stab</hediff>
		<additionalHediffs>
			<li>
				<hediff>ToxicBuildup</hediff>
				<severityPerDamageDealt>0.01</severityPerDamageDealt>
				<!-- Scales by body size -->
				<victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
			</li>
		</additionalHediffs>
	</DamageDef>

</Defs>
