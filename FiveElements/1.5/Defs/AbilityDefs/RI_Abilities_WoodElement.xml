    <!-- 供奉生机 -->
    <AbilityDef ParentName="RI_PsycastBase">
        <defName>RI_Ability_Wood_LifeOffer</defName>
        <label>life offer</label>
        <!-- 选中一个范围内的植物，摧毁它们以获取生命力 -->
        <!-- 青茎翠叶竞焚香​​，​​岂识真机在吾掌？​​​​一缕青烟通我座​​，​​诸天星斗尽归藏！ -->
        <!-- 唔，在外人面前可不能如此得意忘形... -->
        <description>Select a range of plants, annihilate them to harvest their life essence.
            "Verdant stems and emerald leaves compete in offering incense,\n
            Yet know not the true dao resides in my palm?\n
            A wisp of sacred smoke ascends to my throne,\n
            All celestial stars and constellations shall be gathered into my treasury!"
            en... I can't be so arrogant in front of outsiders.</description>
        <iconPath>UI/Abilities/Base/LG</iconPath>
        <cooldownTicksRange>60000</cooldownTicksRange>
        <aiCanUse>false</aiCanUse>
        <displayOrder>300</displayOrder>
        <sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
        <!-- TODO 替换声音 -->
        <warmupStartSound>AcidSpray_Warmup</warmupStartSound>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>13.9</range>
            <warmupTime>0.5</warmupTime>
            <!-- TODO 替换声音 -->
            <soundCast>RocketswarmLauncher_Fire</soundCast>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>
        <comps>
            <!-- 回复部分灵气 -->
            <!-- <li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
                <rEnergy>350</rEnergy>
            </li> -->
            <li Class="RI_FiveElements.CompProperties_PlantToLife">
                <!-- 每100%生长的植物转化为X点生机 -->
                <energyPerGrowed>0.05</energyPerGrowed>
                <!-- 摧毁植物 -->
                <destroyPlant>true</destroyPlant>
                <!-- 半径 -->
                <radius>5</radius>
                <!-- 特效Mote -->
                <moteDef></moteDef>
            </li>
        </comps>
    </AbilityDef>

    <!-- TODO 生命注射 -->
    <!-- 选中一个pawn，延长它有限的生命 -->
    <AbilityDef ParentName="RI_PsycastBase">
        <defName>RI_Ability_Wood_LifeGive</defName>
        <label>life give</label>
        <!-- 选中一个范围内树精，将生命力注入到它们身上,注入的生命将由范围内的单位分担 -->
        <description>Select a range of tree spirits, infuse them with life essence, which will be shared among the units within the range.</description>
        <iconPath>UI/Abilities/Base/LG</iconPath>
        <cooldownTicksRange>60000</cooldownTicksRange>
        <aiCanUse>false</aiCanUse>
        <displayOrder>300</displayOrder>
        <sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
        <!-- TODO 替换声音 -->
        <warmupStartSound>AcidSpray_Warmup</warmupStartSound>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>13.9</range>
            <warmupTime>0.5</warmupTime>
            <!-- TODO 替换声音 -->
            <soundCast>RocketswarmLauncher_Fire</soundCast>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>
        <comps>
            <!-- 回复部分灵气 -->
            <!-- <li Class="WhoXiuXian.Abilities.CompProperties__ReduceEnergy">
                <rEnergy>350</rEnergy>
            </li> -->
            <li Class="RI_FiveElements.CompProperties_LifeToPawn">
                <!-- 最小生命值供给 -->
                <baseLife>0.35</baseLife>
                <!-- 生机乘数 -->
                <lifeMultiplier>2</lifeMultiplier>
                <!-- 生机消耗百分比 -->
                <useVitality>0.5</useVitality> 
                <!-- 半径 -->
                <radius>5</radius>
                <!-- 特效Mote -->
                <moteDef></moteDef>
            </li>
        </comps>
    </AbilityDef> 

