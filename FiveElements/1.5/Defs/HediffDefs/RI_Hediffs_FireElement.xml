<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--火行Base-->
	<HediffDef Name="RI_FireMethodHediff_Base" Abstract="True">
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.97,0.58,0.17)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
	</HediffDef>

	<!--离火功法-->
	<HediffDef ParentName="RI_FireMethodHediff_Base">
		<defName>RI_He_FireCultivationHediff</defName>
		<label>Fire cultivation</label>
		<description>Fire element cultivation technique, refining the five senses to heightened clarity.</description>
		<stages>
			<li>
				<statOffsets>
					<GI_EnergyGainEff>0.5</GI_EnergyGainEff>
					<MentalBreakThreshold>0.25</MentalBreakThreshold>
					<ComfyTemperatureMax>5</ComfyTemperatureMax>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.1</offset>
					</li>
					<li>
						<capacity>Talking</capacity>
						<offset>0.1</offset>
					</li>
					<li>
						<capacity>Hearing</capacity>
						<offset>0.1</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.1</offset>
					</li>
					<li>
						<capacity>Eating</capacity>
						<offset>0.1</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>false</showRemainingTime>
				<disappearsAfterTicks>600000</disappearsAfterTicks>
			</li>
			<li>
				<compClass>WhoXiuXian.HediffComp_CultivationBase</compClass>
			</li>
		</comps>
	</HediffDef>

	<!-- 焚心 -->
	<HediffDef>
		<defName>RI_He_Fire_BurningSoul</defName>
		<label>Life fire</label>
		<description>Unique Fire technique, upon activation, enhances one's abilities and grants six layers of Life Fire.\n\nSubsequent Fire skills will consume Life Fire as fuel.</description>
		<hediffClass>RI_FiveElements.CachedHediff</hediffClass>
		<defaultLabelColor>(0.97,0.58,0.17)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<disappearsAfterTicks>9000</disappearsAfterTicks>
			</li>
		</comps>
		<initialSeverity>6</initialSeverity>
		<stages>
			<li>
				<label>One fire</label>
				<minSeverity>1</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.95</IncomingDamageFactor>
					<MoveSpeed>1.1</MoveSpeed>
					<MeleeDamageFactor>1.1</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.1</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
			<li>
				<label>Two fire</label>
				<minSeverity>2</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.9</IncomingDamageFactor>
					<MoveSpeed>1.2</MoveSpeed>
					<MeleeDamageFactor>1.2</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.2</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
			<li>
				<label>Three fire</label>
				<minSeverity>3</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.85</IncomingDamageFactor>
					<MoveSpeed>1.3</MoveSpeed>
					<MeleeDamageFactor>1.3</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.3</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
			<li>
				<label>Four fire</label>
				<minSeverity>4</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.8</IncomingDamageFactor>
					<MoveSpeed>1.4</MoveSpeed>
					<MeleeDamageFactor>1.4</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.4</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
			<li>
				<label>Five fire</label>
				<minSeverity>5</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.8</IncomingDamageFactor>
					<MoveSpeed>1.5</MoveSpeed>
					<MeleeDamageFactor>1.5</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.5</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
			<li>
				<label>Six fire</label>
				<minSeverity>6</minSeverity>
				<statFactors>
					<IncomingDamageFactor>0.8</IncomingDamageFactor>
					<MoveSpeed>1.6</MoveSpeed>
					<MeleeDamageFactor>1.6</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ArmorRating_Heat>0.3</ArmorRating_Heat>
					<MentalBreakThreshold>0.6</MentalBreakThreshold>
					<ComfyTemperatureMax>30</ComfyTemperatureMax>
				</statOffsets>
			</li>
		</stages>
		<!--附加特效-->
		<renderNodeProperties>
			<li Class="PawnRenderNodeProperties">
				<workerClass>PawnRenderNodeWorker_HediffEye</workerClass>
				<useGraphic>true</useGraphic>
				<drawSize>1</drawSize>
				<texPath>Things/Mote/RI_He_Fire_BurningSoul</texPath>
				<shaderTypeDef>MoteGlow</shaderTypeDef>
				<drawData>
					<defaultData>
						<layer>56</layer>
						<offset>(0, 2, 0)</offset>
					</defaultData>
				</drawData>
			</li>
		</renderNodeProperties>
	</HediffDef>

	<!--炎威-->
	<HediffDef ParentName="RI_FireMethodHediff_Base">
		<defName>RI_He_Fire_Shield</defName>
		<label>Majestic flame</label>
		<description>Ignite Life Fire to awaken one's combat prowess, while forging a protective flame barrier upon the body.</description>
		<comps>
			<!--一段时间后消失-->
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<disappearsAfterTicks>6000</disappearsAfterTicks>
			</li>
			<!--眼睛发光-->
			<li Class="RI_Starch.RI_HediffComp.RI_HediffCompProperties_eyesGlow">
				<EyeColor>(1.0,0.45,0.25)</EyeColor>
			</li>
		</comps>
		<stages>
			<li>
				<statFactors>
					<Flammability>0</Flammability>
				</statFactors>
				<damageFactors>
					<Burn>0.5</Burn>
					<Flame>0.5</Flame>
				</damageFactors>
				<statOffsets>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
					<ArmorRating_Heat>1</ArmorRating_Heat>
					<MentalBreakThreshold>1</MentalBreakThreshold>
					<ComfyTemperatureMax>50</ComfyTemperatureMax>
				</statOffsets>
			</li>
		</stages>
		<!--附加特效-->
		<renderNodeProperties>
			<li Class="PawnRenderNodeProperties">
				<workerClass>PawnRenderNodeWorker_HediffEye</workerClass>
				<useGraphic>true</useGraphic>
				<drawSize>2</drawSize>
				<texPath>Things/Mote/RI_Fire_Shield</texPath>
				<shaderTypeDef>MoteGlow</shaderTypeDef>
				<drawData>
					<defaultData>
						<layer>56</layer>
						<offset>(0, 2, 0)</offset>
					</defaultData>
				</drawData>
			</li>
			<li Class="PawnRenderNodeProperties_Eye">
				<workerClass>PawnRenderNodeWorker_HediffEye</workerClass>
				<parentTagDef>Head</parentTagDef>
				<useGraphic>true</useGraphic>
				<drawSize>1.125</drawSize>
				<texPath>Things/Pawn/Wounds/EyeGlow/eyeGlow</texPath>
				<color>(1.0,0.85,0.73,0.9)</color>
				<shaderTypeDef>MoteGlow</shaderTypeDef>
				<drawData>
					<defaultData>
						<layer>56</layer>
						<offset>(0, 0, 0.01)</offset>
					</defaultData>
					<dataWest>
						<flip>true</flip>
					</dataWest>
				</drawData>
			</li>
		</renderNodeProperties>
	</HediffDef>

	<!-- 乾阳焱火决 自身 -->
	<HediffDef ParentName="RI_FireMethodHediff_Base">
		<defName>RI_He_Fire_Ring_Self</defName>
		<label>Qianyang flame field</label>
		<description>The Qianyang Blazing Flame scorches Kunlun's crest, refining souls and burning all eight realms.\nThe Primal One Fire devours sun and moon, while the Samadhi Divine Flame melts gold and steel.</description>
		<duplicationAllowed>false</duplicationAllowed>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>5000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
				<canUseDecimalsShortForm>true</canUseDecimalsShortForm>
			</li>
			<li Class="RI_FiveElements.HediffCompProperties_GiveHediffsInRangeEx">
				<range>9.9</range>
				<mote>RI_Mote_Fire_Ring</mote>
				<hideMoteWhenNotDrafted>true</hideMoteWhenNotDrafted>
				<targetingParameters>
					<canTargetBuildings>False</canTargetBuildings>
					<canTargetAnimals>True</canTargetAnimals>
					<canTargetMechs>True</canTargetMechs>
					<canTargetHumans>True</canTargetHumans>
					<onlyTargetColonists>False</onlyTargetColonists>
					<canTargetMutants>True</canTargetMutants>
				</targetingParameters>
				<onlyPawnsInSameFaction>False</onlyPawnsInSameFaction>
				<hediff>RI_He_Fire_Ring_Target</hediff>
			</li>
		</comps>
		<!--附加特效-->
		<renderNodeProperties>
			<li Class="PawnRenderNodeProperties">
				<workerClass>PawnRenderNodeWorker_HediffEye</workerClass>
				<useGraphic>true</useGraphic>
				<drawSize>2.7</drawSize>
				<texPath>Things/Mote/RI_Fire_Ring_Self</texPath>
				<shaderTypeDef>MoteGlow</shaderTypeDef>
				<drawData>
					<defaultData>
						<layer>56</layer>
						<offset>(0, 2, 0)</offset>
					</defaultData>
				</drawData>
			</li>
		</renderNodeProperties>
	</HediffDef>

	<!-- 乾阳焱火决 目标 心火焚烧 -->
	<HediffDef ParentName="RI_FireMethodHediff_Base">
		<defName>RI_He_Fire_Ring_Target</defName>
		<label>Soul burning</label>
		<duplicationAllowed>false</duplicationAllowed>
		<description>Scorched by one's own Life Fire.</description>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>7500</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
				<canUseDecimalsShortForm>true</canUseDecimalsShortForm>
			</li>
			<li Class="RI_FiveElements.CompProperties_FireRingBurn">
				<burnInterval>60</burnInterval>
				<damageAmount>10</damageAmount>
				<makeBurn>True</makeBurn>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<Flammability>2</Flammability>
				</statOffsets>
				<damageFactors>
					<Burn>1</Burn>
					<Flame>1</Flame>
				</damageFactors>
			</li>
		</stages>
		<!--附加特效-->
		<renderNodeProperties>
			<li Class="PawnRenderNodeProperties">
				<workerClass>PawnRenderNodeWorker_HediffEye</workerClass>
				<useGraphic>true</useGraphic>
				<drawSize>2</drawSize>
				<texPath>Things/Mote/RI_Fire_FiringTarget</texPath>
				<shaderTypeDef>MoteGlow</shaderTypeDef>
				<drawData>
					<defaultData>
						<layer>56</layer>
						<offset>(0, 2, 0)</offset>
					</defaultData>
				</drawData>
			</li>
		</renderNodeProperties>
	</HediffDef>

	<ThingDef ParentName="MoteBase">
		<defName>RI_Mote_Fire_Ring</defName>
		<thingClass>MoteAttached</thingClass>
		<altitudeLayer>LightingOverlay</altitudeLayer>
		<drawOffscreen>true</drawOffscreen>
		<mote>
			<solidTime>9999999</solidTime>
			<needsMaintenance>true</needsMaintenance>
		</mote>
		<graphicData>
			<graphicClass>Graphic_Mote</graphicClass>
			<!-- TODO 替换 -->
			<texPath>Things/Mote/CombatCommandMask</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(255, 69, 0)</color>
			<drawSize>20</drawSize>
		</graphicData>
	</ThingDef>

	<ThingDef ParentName="MoteBase">
		<defName>RI_Mote_Fire_Ring_LinkLine</defName>
		<thingClass>MoteDualAttached</thingClass>
		<altitudeLayer>MoteLow</altitudeLayer>
		<mote>
			<fadeInTime>0.1</fadeInTime>
			<fadeOutTime>0.1</fadeOutTime>
			<solidTime>999999</solidTime>
			<needsMaintenance>True</needsMaintenance>
			<rotateTowardsTarget>True</rotateTowardsTarget>
			<scaleToConnectTargets>True</scaleToConnectTargets>
		</mote>
		<graphicData>
			<shaderType>MoteGlow</shaderType>
			<!-- TODO 替换 -->
			<texPath>Things/Mote/WorkCommandLinkLine</texPath>
		</graphicData>
	</ThingDef>

</Defs>