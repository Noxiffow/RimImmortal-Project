		</plant>
	</ThingDef>

	<!--桑树——收获得到桑叶-->
	<ThingDef ParentName="RI_TreeBase">
		<defName>RI_Plant_MulberryTree</defName>
		<label>Mulberry tree</label>
		<description>The mulberry tree is a deciduous tree, and its leaves are the primary food source for silkworms. In addition to this, various parts of the mulberry tree can be used in traditional medicine, making it an important economic crop.</description>
		<!--描述超链接-->
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_MulberryLeaf</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
