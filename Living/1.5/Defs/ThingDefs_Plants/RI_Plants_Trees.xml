	<!--铁木树-->
	<ThingDef ParentName="RI_TreeBase">
		<defName>RI_Plant_IronWoodTree</defName>
		<label>Iron wood tree</label>
		<description>Iron wood tree is a wonderfully genetically edited wood whose roots absorb metals from the soil, gradually giving the wood the hardness of steel. When mature, ironwood can be produced, which is a material with properties similar to steel.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_IronWood</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_IronWoodTree</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.35, 0.13)</volume>
				<offset>(-0.03,0,-0.44)</offset>
			</shadowData>
		</graphicData>
		<minifiedDef IsNull="True" />
		<plant>
			<dieIfLeafless>true</dieIfLeafless>
			<growDays>22</growDays>
			<harvestWork>500</harvestWork>
			<harvestYield>45</harvestYield>
			<harvestedThingDef>RI_Resource_IronWood</harvestedThingDef>
			<sowMinSkill>5</sowMinSkill>
			<wildClusterRadius>1</wildClusterRadius>
			<wildClusterWeight>1</wildClusterWeight>
			<visualSizeRange>1.7~2.1</visualSizeRange>
			<mustBeWildToSow>false</mustBeWildToSow>
			<harvestFailable>true</harvestFailable>
			<forceIsTree>true</forceIsTree>
			<sowResearchPrerequisites Inherit="False">
				<li>RI_HighLevelPlanting</li>
			</sowResearchPrerequisites>
		</plant>
	</ThingDef>

	<!--沙糖桔树-->

	<ThingDef ParentName="TreeBase">
		<defName>RI_Plant_SugarTangerine</defName>
		<label>Sugar tangerine tree</label>
		<description>Sugar tangerine tree grow more slowly and require more fertilizer, but they can produce these sweet fruits.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_Food_SugarTangerine</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_SugarTangerine</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.15, 0.3, 0.15)</volume>
				<offset>(0,0,-0.38)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<Beauty>5</Beauty>
			<BeautyOutdoors>2</BeautyOutdoors>
			<Nutrition>1.5</Nutrition>
		</statBases>
		<minifiedDef IsNull="True" />
		<ingestible />
		<plant>
			<dieIfLeafless>true</dieIfLeafless>
			<growDays>15</growDays>
			<visualSizeRange>1~2</visualSizeRange>
			<sowMinSkill>5</sowMinSkill>
			<sowTags>
				<li>Ground</li>
			</sowTags>
			<sowResearchPrerequisites Inherit="False">
				<li>RI_Planting</li>
			</sowResearchPrerequisites>
			<topWindExposure>0.15</topWindExposure>
