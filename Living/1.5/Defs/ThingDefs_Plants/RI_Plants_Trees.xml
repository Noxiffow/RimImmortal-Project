<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="PlantBase" Name="RI_TreeBase" Abstract="True">
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0.8</Flammability>
			<Nutrition>3.0</Nutrition>
			<Mass>100</Mass>
		</statBases>
		<altitudeLayer>Building</altitudeLayer>
		<selectable>true</selectable>
		<fillPercent>0.25</fillPercent>
		<minifiedDef>MinifiedTree</minifiedDef>
		<rotatable>false</rotatable>
		<graphicData>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.35, 0.13)</volume>
				<offset>(0,0,-0.42)</offset>
			</shadowData>
		</graphicData>
		<passability>PassThroughOnly</passability>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<ingestible>
			<foodType>Tree</foodType>
			<preferability>RawBad</preferability>
		</ingestible>
		<plant>
			<lifespanDaysPerGrowDays>9</lifespanDaysPerGrowDays>
			<fertilitySensitivity>0.5</fertilitySensitivity>
			<soundHarvesting>Harvest_Tree</soundHarvesting>
			<soundHarvestFinish>Harvest_Tree_Finish</soundHarvestFinish>
			<sowWork>4000</sowWork>
			<mustBeWildToSow>true</mustBeWildToSow>
			<harvestTag>Wood</harvestTag>
			<harvestMinGrowth>0.40</harvestMinGrowth>
			<harvestFailable>false</harvestFailable>
			<blockAdjacentSow>true</blockAdjacentSow>
			<treeLoversCareIfChopped>true</treeLoversCareIfChopped>
			<burnedThingDef>BurnedTree</burnedThingDef>
			<choppedThingDef>ChoppedStump</choppedThingDef>
			<smashedThingDef>SmashedStump</smashedThingDef>
			<treeCategory>Full</treeCategory>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<topWindExposure>0.25</topWindExposure>
			<wildClusterRadius>8</wildClusterRadius>
			<wildClusterWeight>24</wildClusterWeight>
			<wildOrder>3</wildOrder>
			<interferesWithRoof>true</interferesWithRoof>
		</plant>
	</ThingDef>

	<!--毛竹-->
	<ThingDef ParentName="RI_TreeBase">
		<defName>RI_Plant_MosoBamboo</defName>
		<label>Moso bamboo</label>
		<description>Moso bamboo is a fast-growing species of bamboo, which is cut down after maturity and is a lightweight building material.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_RawBamboo</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_MosoBamboo</texPath>
		</graphicData>
		<minifiedDef IsNull="True" />
		<ingestible />
		<plant>
			<growDays>3</growDays>
			<harvestWork>150</harvestWork>
			<harvestYield>30</harvestYield>
			<harvestedThingDef>RI_Resource_RawBamboo</harvestedThingDef>
			<wildClusterRadius>5</wildClusterRadius>
			<wildClusterWeight>15</wildClusterWeight>
			<leaflessGraphicPath>Things/Plant/TreeBamboo_Leafless</leaflessGraphicPath>
			<visualSizeRange>1.7~2.1</visualSizeRange>
			<mustBeWildToSow>false</mustBeWildToSow>
			<harvestFailable>true</harvestFailable>
			<forceIsTree>true</forceIsTree>
		</plant>
	</ThingDef>

	<!--檀木树-->
	<ThingDef ParentName="RI_TreeBase">
		<defName>RI_Plant_SandalwoodTree</defName>
		<label>Sandalwood tree</label>
		<description>Sandalwood tree can produce expensive sandalwood, a fine, fragrant wood that can make beautiful furniture.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_SandalWoodLog</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_SandalwoodTree</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.35, 0.13)</volume>
				<offset>(-0.03,0,-0.44)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<Beauty>1</Beauty>
			<BeautyOutdoors>1</BeautyOutdoors>
		</statBases>
		<minifiedDef IsNull="True" />
		<plant>
			<growDays>25</growDays>
			<harvestWork>500</harvestWork>
			<harvestYield>25</harvestYield>
			<harvestedThingDef>RI_Resource_SandalWoodLog</harvestedThingDef>
			<sowMinSkill>2</sowMinSkill>
			<wildClusterRadius>1</wildClusterRadius>
			<wildClusterWeight>1</wildClusterWeight>
			<visualSizeRange>1.7~2.1</visualSizeRange>
			<mustBeWildToSow>false</mustBeWildToSow>
			<harvestFailable>true</harvestFailable>
			<forceIsTree>true</forceIsTree>
			<sowResearchPrerequisites Inherit="False">
				<li>RI_Planting</li>
			</sowResearchPrerequisites>
		</plant>
	</ThingDef>

	<!--苍血竹-->
	<ThingDef ParentName="RI_TreeBase">
		<defName>RI_Plant_GreenBloodBamboo</defName>
		<label>Green blood bamboo</label>
		<description>Green blood bamboo is a wonderful bamboo, its growth is slow, but when mature bamboo will turn emerald green, and very strong, is a good material for making weapons.</description>
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_JadeBloodBamboo</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_GreenBloodBamboo</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.35, 0.13)</volume>
				<offset>(-0.03,0,-0.44)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<Beauty>2</Beauty>
			<BeautyOutdoors>2</BeautyOutdoors>
		</statBases>
		<minifiedDef IsNull="True" />
		<plant>
			<growDays>28</growDays>
			<harvestWork>500</harvestWork>
			<harvestYield>25</harvestYield>
			<harvestedThingDef>RI_Resource_JadeBloodBamboo</harvestedThingDef>
			<sowMinSkill>5</sowMinSkill>
			<wildClusterRadius>1</wildClusterRadius>
			<wildClusterWeight>1</wildClusterWeight>
			<visualSizeRange>1.7~2.1</visualSizeRange>
			<mustBeWildToSow>false</mustBeWildToSow>
