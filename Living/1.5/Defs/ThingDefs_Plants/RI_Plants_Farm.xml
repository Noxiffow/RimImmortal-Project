<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--茶树-->
	<ThingDef ParentName="PlantBase">
		<defName>RI_Plant_TeaPlant</defName>
		<label>Tea plant</label>
		<description>Tea plant can produce tea leaves, tea leaves can be made into tea.</description>
		<!--描述超链接-->
		<descriptionHyperlinks>
			<ThingDef>RI_Resource_TeaLeaf</ThingDef>
		</descriptionHyperlinks>
		<statBases>
			<MaxHitPoints>85</MaxHitPoints>
			<Nutrition>0.75</Nutrition>
			<BeautyOutdoors>0</BeautyOutdoors>
		</statBases>
		<graphicData>
			<texPath>Things/Plant/RI_Plant_TeaPlant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>20</pathCost>
		<ingestible />
		<plant>
			<fertilityMin>1</fertilityMin>
			<growDays>15</growDays>
			<harvestAfterGrowth>0.15</harvestAfterGrowth>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestTag>Standard</harvestTag>
			<harvestedThingDef>RI_Resource_TeaLeaf</harvestedThingDef>
			<harvestYield>10</harvestYield>
			<sowMinSkill>5</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<topWindExposure>0.1</topWindExposure>
			<visualSizeRange>0.5~1.5</visualSizeRange>
			<wildOrder>2</wildOrder>
			<immatureGraphicPath>Things/Plant/RI_Plant_TeaPlant</immatureGraphicPath>
			<purpose>Food</purpose>
			<humanFoodPlant>true</humanFoodPlant>
			<sowResearchPrerequisites Inherit="False">
				<li>RI_Planting</li>
			</sowResearchPrerequisites>
		</plant>
	</ThingDef>

