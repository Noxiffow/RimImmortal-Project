<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--========蚕卵箱对应的WorkGiverDef========-->

	<WorkGiverDef>
		<defName>TakeRI_Resource_SilkwormCocoon</defName>
		<label>Take silk worm cocoon</label>
		<giverClass>RI_Living.WorkGiver_TakeRI_Resource_SilkwormCocoon</giverClass>
		<workType>Hauling</workType>
		<verb>Take silk worm cocoon</verb>
		<gerund>Take silk worm cocoon</gerund>
		<priorityInType>20</priorityInType>
		<requiredCapacities>
			<li>Manipulation</li>
		</requiredCapacities>
		<canBeDoneByMechs>true</canBeDoneByMechs>
		<modExtensions>
			<li Class="RI_Living.Building_FermentationDefMod">
				<BuildingDef>RI_Building_SilkwormRearingBox</BuildingDef>
				<!--填对应的建筑，必需-->
			</li>
		</modExtensions>
	</WorkGiverDef>

	<WorkGiverDef>
		<defName>FillRI_Resource_SilkwormEgg</defName>
		<label>Fill worm egg</label>
		<giverClass>RI_Living.WorkGiver_RI_Resource_SilkwormEgg</giverClass>
		<workType>Hauling</workType>
		<verb>Fill worm egg</verb>
		<gerund>Fill worm egg</gerund>
		<priorityInType>19</priorityInType>
		<requiredCapacities>
			<li>Manipulation</li>
		</requiredCapacities>
		<canBeDoneByMechs>true</canBeDoneByMechs>
		<modExtensions>
			<li Class="RI_Living.Building_FermentationDefMod">
				<AddThingDef>RI_Resource_MulberryLeaf</AddThingDef>
				<!--通过这个modExtensions设置填充物是什么-->
				<BuildingDef>RI_Building_SilkwormRearingBox</BuildingDef>
				<!--填对应的建筑，必需-->
			</li>
		</modExtensions>
	</WorkGiverDef>


