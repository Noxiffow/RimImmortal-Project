			<forceShowRoomStats>true</forceShowRoomStats>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
			<paintable>true</paintable>
		</building>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<designationHotKey>Misc5</designationHotKey>
		<researchPrerequisites>
			<li>RI_BasicTechnology</li>
		</researchPrerequisites>
	</ThingDef>

