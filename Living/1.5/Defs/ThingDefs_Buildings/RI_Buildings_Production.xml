<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--简易灶台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_CookTable</defName>
		<label>Cooking stove</label>
		<description>A simple earthen stove built of fire-resistant brick. The stovetop is equipped with a pan and a steamer, enough to prepare most dishes.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_CookTable</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3.05,1.5)</drawSize>
			<shaderType>CutoutComplex</shaderType>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>

		<costStuffCount>50</costStuffCount>
		<costList>
			<WoodLog>15</WoodLog>
		</costList>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>

		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>2000</WorkToBuild>
			<MaxHitPoints>300</MaxHitPoints>
			<Flammability>1.0</Flammability>
			<Cleanliness>0</Cleanliness>
			<WorkTableWorkSpeedFactor>0.8</WorkTableWorkSpeedFactor>
		</statBases>
		<size>(2,1)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2100</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<recipes>
			<li>CookMealSurvival</li>
			<li>CookMealSurvivalBulk</li>
			<li>Make_Pemmican</li>
			<li>Make_PemmicanBulk</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFood</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFoodBulk</li>
		</recipes>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<isMealSource>true</isMealSource>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<artificialForMeditationPurposes>false</artificialForMeditationPurposes>
			<heatPerTickWhileWorking>0.10</heatPerTickWhileWorking>
			<paintable>true</paintable>
		</building>
		<comps>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>150.0</fuelConsumptionRate>
				<fuelCapacity>50.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
						<li>RI_Resource_RawBamboo</li>
					</thingDefs>
				</fuelFilter>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>4</heatPerSecond>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>RI_Building_KitchenCabinet</li>
				</linkableFacilities>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_Research_FoodRecipe</li>
		</researchPrerequisites>
	</ThingDef>

	<!--饮食备菜台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_FoodPrepareTable</defName>
		<label>Food Preparing table</label>
		<description>A table with cooking tools. It can be used for cooking, it can be used for making snacks, it is a work table that any restaurant will prepare for the chef.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_FoodPrepareTable</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(3.45,1.45)</drawSize>
			<shadowData>
				<volume>(2.9, 0.3, 0.5)</volume>
				<offset>(0, 0, 0)</offset>
			</shadowData>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<costList>
			<Steel>30</Steel>
		</costList>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
			<li>Woody</li>
		</stuffCategories>
		<recipes>
			<li>ButcherCorpseFlesh</li>
			<li>Make_Kibble</li>
			<li>RI_Recipe_CutWatermelon</li>
		</recipes>
		<costStuffCount>70</costStuffCount>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>2500</WorkToBuild>
			<MaxHitPoints>350</MaxHitPoints>
			<Flammability>1.0</Flammability>
			<Cleanliness>0</Cleanliness>
		</statBases>
		<size>(3,1)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<isMealSource>true</isMealSource>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<paintable>true</paintable>
		</building>
		<comps>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>RI_Building_KitchenCabinet</li>
				</linkableFacilities>
			</li>
		</comps>
		<designationHotKey>Misc2</designationHotKey>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_Research_FoodRecipe</li>
		</researchPrerequisites>
	</ThingDef>

	<!--现代猛火灶台-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_ModernCookingStove</defName>
		<label>Modern cooking stove</label>
		<description>A fire stove, with a very strong firepower, can be in a short period of time to produce food. It is equipped with sinks that run water all the time to cool the metal cooktop itself.</description>
		<thingClass>Building_WorkTable_HeatPush</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_ModernCookingStove</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3.59,1.5)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<constructEffect>ConstructMetal</constructEffect>
		<costList>
			<Steel>80</Steel>
			<ComponentIndustrial>2</ComponentIndustrial>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>2000</WorkToBuild>
			<MaxHitPoints>180</MaxHitPoints>
			<Flammability>1.0</Flammability>
			<Cleanliness>0</Cleanliness>
			<WorkTableWorkSpeedFactor>1.1</WorkTableWorkSpeedFactor>
		</statBases>
		<size>(3,1)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2110</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<recipes>
			<li>CookMealSurvival</li>
			<li>CookMealSurvivalBulk</li>
			<li>Make_Pemmican</li>
			<li>Make_PemmicanBulk</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFood</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFoodBulk</li>
		</recipes>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>350</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>3</heatPerSecond>
			</li>
		</comps>
		<building>
			<isMealSource>true</isMealSource>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<heatPerTickWhileWorking>0.15</heatPerTickWhileWorking>
		</building>
		<designationHotKey>Misc8</designationHotKey>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_Electric</li>
		</researchPrerequisites>
	</ThingDef>

