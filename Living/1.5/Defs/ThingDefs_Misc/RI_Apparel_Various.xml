<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--短衫-->
	<ThingDef ParentName="RI_Living_BasicApparel_Base">
		<defName>RI_Apparel_InsideApparel</defName>
		<label>Inside-shirt</label>
		<description>A simple inside-shirt.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_InsideApparel/RI_Apparel_InsideApparel</texPath>
		</graphicData>
		<costStuffCount>40</costStuffCount>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<WorkToMake>1600</WorkToMake>
			<Mass>0.25</Mass>
			<StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.22</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.10</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/RI_Apparel_InsideApparel/RI_Apparel_InsideApparel</wornGraphicPath>
			<layers>
				<li>OnSkin</li>
			</layers>
			<tags>
				<li>RI_Tag_ApparelBasic</li>
			</tags>
			<defaultOutfitTags>
				<li>Worker</li>
				<li>Soldier</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<recipeMaker>
			<researchPrerequisite>RI_Research_MakingCloth</researchPrerequisite>
			<displayPriority>16</displayPriority>
		</recipeMaker>
	</ThingDef>

