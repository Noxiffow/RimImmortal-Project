				<filter>
					<categories>
						<li>MeatRaw</li>
					</categories>
				</filter>
				<count>1.2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>PlantFoodRaw</li>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
		</fixedIngredientFilter>
		<products>
			<RI_Food_StirFriedMeat>4</RI_Food_StirFriedMeat>
		</products>
	</RecipeDef>

	<!--蛋炒饭-->
	<RecipeDef ParentName="RI_FoodRecipeBulk_Base">
