<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 所有烹饪的菜x4的前置 -->
	<ThingDef Name="RI_FoodRecipeBulk_Base" ParentName="CookMealBase" Abstract="True">
		<workSpeedStat>CookSpeed</workSpeedStat>
		<requiredGiverWorkType>Cooking</requiredGiverWorkType>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_CookMeal</soundWorking>
		<allowMixingIngredients>true</allowMixingIngredients>
		<ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
		<workSkill>Cooking</workSkill>
		<recipeUsers>
			<li>RI_Building_CookTable</li>
			<li>RI_Building_ModernCookingStove</li>
		</recipeUsers>
		<defaultIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>EggsFertilized</li>
			</disallowedCategories>
			<disallowedThingDefs>
				<li>InsectJelly</li>
				<li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
			</disallowedThingDefs>
		</defaultIngredientFilter>
		<skillRequirements>
			<Cooking>4</Cooking>
		</skillRequirements>
	</ThingDef>

	<!--炒素-->
	<RecipeDef ParentName="RI_FoodRecipeBulk_Base">
		<defName>RI_Recipe_CookStirFriedVegeBulk</defName>
		<label>Cook fried vege x4</label>
		<description>A simple stir-fry with a variety of vegetables.</description>
		<jobString>Cooking fried vege</jobString>
		<workAmount>1200</workAmount>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>PlantFoodRaw</li>
					</categories>
				</filter>
				<count>1.2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>MeatRaw</li>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
		</fixedIngredientFilter>
		<products>
			<RI_Food_StirFriedVege>4</RI_Food_StirFriedVege>
		</products>
	</RecipeDef>

	<!--炒肉-->
	<RecipeDef ParentName="RI_FoodRecipeBulk_Base">
		<defName>RI_Recipe_CookStirFriedMeatBulk</defName>
		<label>Cook fried meat x4</label>
		<description>Slices meat and make a simple stir-fry.</description>
		<jobString>Cooking fried meat</jobString>
		<workAmount>1200</workAmount>
