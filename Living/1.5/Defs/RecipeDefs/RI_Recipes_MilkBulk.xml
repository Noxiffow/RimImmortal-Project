<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--制作奶豆腐-->
	<RecipeDef ParentName="RI_MilkRecipe_Base">
		<defName>RI_Recipe_CookByaslagBulk</defName>
		<label>Cook byaslag x4</label>
		<description>Make some byaslag through fermentation and boiling milk.</description>
		<jobString>Cooking byaslag</jobString>
		<workAmount>2400</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Milk</li>
					</thingDefs>
				</filter>
				<count>1.6</count>
			</li>
		</ingredients>
		<products>
			<RI_Food_Byaslag>12</RI_Food_Byaslag>
		</products>
	</RecipeDef>

