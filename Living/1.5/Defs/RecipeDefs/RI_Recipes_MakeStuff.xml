	<!--把铁木整成钢铁？-->
	<RecipeDef>
		<defName>RI_MakeIronWoodToSteel</defName>
		<label>Extract steel from iron wood</label>
		<description>The iron wood is fired slowly at a specific temperature to remove the fibers, leaving some metal that resembles steel.</description>
		<jobString>Extracting steel</jobString>
		<workAmount>8000</workAmount>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workSkill>Crafting</workSkill>
		<researchPrerequisite>RI_Smithing</researchPrerequisite>
		<recipeUsers>
			<li>FueledSmithy</li>
			<li>ElectricSmithy</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_IronWood</li>
					</thingDefs>
				</filter>
				<count>50</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_IronWood</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Steel>30</Steel>
		</products>
	</RecipeDef>

