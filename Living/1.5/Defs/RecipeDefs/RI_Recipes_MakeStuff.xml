	<!--制作酒曲-->
	<RecipeDef ParentName="CookMealBase">
		<defName>Make_RI_Resource_WineYeast</defName>
		<label>make Wine yeast</label>
		<description>Fermented grain to make wine yeast.</description>
		<jobString>making Wine yeast</jobString>
		<researchPrerequisite>RI_Research_Brewing</researchPrerequisite>
		<workAmount>600</workAmount>
		<recipeUsers>
			<li>Brewery</li>
			<li>RI_Building_FoodPrepareTable</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>PlantFoodRaw</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
