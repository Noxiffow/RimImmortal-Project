	<!--培养蚕Cultivate more silkworm-->
	<RecipeDef>
		<defName>RI_Recipe_CultivateSilkworm</defName>
		<label>Cultivate more silkworm</label>
		<description>After the cocoons hatch into moths, feed them mulberry leaves to allow them to mate and lay eggs, so as to expand the population.</description>
