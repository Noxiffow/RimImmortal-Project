			<li>HandTailoringBench</li>
			<li>ElectricTailoringBench</li>
		</recipeUsers>
	</RecipeDef>

	<!--织造丝绸-->
	<RecipeDef ParentName="RI_RecipeBase_Silk">
		<defName>RI_MakeSilk</defName>
		<label>Weave silk</label>
		<description>Make silk from silkworm cocoons.</description>
		<jobString>Weaving silk</jobString>
		<workAmount>2000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_SilkwormCocoon</li>
					</thingDefs>
				</filter>
				<count>25</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_SilkwormCocoon</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_Silk>20</RI_Resource_Silk>
		</products>
	</RecipeDef>

