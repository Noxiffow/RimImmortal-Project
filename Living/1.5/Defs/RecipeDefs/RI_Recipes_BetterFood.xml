			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Food_CookedRice</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<products>
			<RI_Food_StuffedRoastDuck>1</RI_Food_StuffedRoastDuck>
		</products>
	</RecipeDef>

