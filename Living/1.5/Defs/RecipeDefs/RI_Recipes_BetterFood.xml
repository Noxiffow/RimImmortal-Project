<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 肉菜大菜的前置 不按营养值计算-->
	<RecipeDef Name="RI_MeatFoodRecipe_Base" ParentName="CookMealBase" Abstract="True">
		<workSpeedStat>CookSpeed</workSpeedStat>
		<requiredGiverWorkType>Cooking</requiredGiverWorkType>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_CookMeal</soundWorking>
		<allowMixingIngredients>true</allowMixingIngredients>
		<workSkill>Cooking</workSkill>
		<recipeUsers>
			<li>RI_Building_CookTable</li>
			<li>RI_Building_ModernCookingStove</li>
		</recipeUsers>
		<defaultIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>EggsFertilized</li>
			</disallowedCategories>
			<disallowedThingDefs>
				<li>InsectJelly</li>
				<li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
			</disallowedThingDefs>
		</defaultIngredientFilter>
		<skillRequirements>
			<Cooking>5</Cooking>
		</skillRequirements>
		<researchPrerequisite>RI_Research_BetterFood</researchPrerequisite>
	</RecipeDef>

	<!--东坡肉-->
	<RecipeDef ParentName="RI_MeatFoodRecipe_Base">
		<defName>RI_Recipe_CookDongPoPork</defName>
		<label>Cook soysauced DongPo pork</label>
		<description>Use pork, pearls and spices to braise DongPo pork, a brilliant red and fragrant meat dish.</description>
		<jobString>Cook soysauced DongPo pork</jobString>
		<workAmount>700</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Pig</li>
					</thingDefs>
				</filter>
				<count>25</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_PearlSpice</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<products>
			<RI_Food_DongPoPork>1</RI_Food_DongPoPork>
		</products>
	</RecipeDef>

	<!--小鸡炖蘑菇-->
	<RecipeDef ParentName="RI_MeatFoodRecipe_Base">
		<defName>RI_Recipe_CookChickenWithMushroom</defName>
		<label>Cook chicken with mushroom</label>
		<description>Braised with chicken and mushrooms, a classic meat dish, delicious.</description>
		<jobString>Cook chicken with mushroom</jobString>
		<workAmount>700</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Chicken</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RawFungus</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_PearlSpice</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<products>
			<RI_Food_ChickenWithMushroom>1</RI_Food_ChickenWithMushroom>
		</products>
	</RecipeDef>

	<!--八宝鸭-->
