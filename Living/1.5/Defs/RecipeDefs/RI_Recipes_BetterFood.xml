	<!--制作月饼-->
	<RecipeDef ParentName="RI_MeatFoodRecipe_Base">
		<defName>RI_Recipe_CookMooncake</defName>
		<label>Cook mooncake</label>
		<description>The dough and ingredients are made into cakes and then baked to get mooncakes.</description>
		<jobString>Cook mooncake</jobString>
		<ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
		<workAmount>700</workAmount>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>PlantFoodRaw</li>
					</categories>
				</filter>
				<count>0.4</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RawRice</li>
					</thingDefs>
				</filter>
				<count>0.2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>MeatRaw</li>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
		</fixedIngredientFilter>
		<products>
			<RI_Food_Mooncake>4</RI_Food_Mooncake>
		</products>
	</RecipeDef>

