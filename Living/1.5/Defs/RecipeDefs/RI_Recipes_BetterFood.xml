		<label>Cook stuffed roast duck</label>
		<description>Duck meat, pearl spices and rice are used to make stuffed duck, a steamed meat dish filled with ingredients in the duck, which is very luxurious.</description>
		<jobString>Cook stuffed roast duck</jobString>
		<workAmount>700</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Duck</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_PearlSpice</li>
