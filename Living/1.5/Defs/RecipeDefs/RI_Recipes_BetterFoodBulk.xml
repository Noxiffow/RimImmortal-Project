		<workAmount>2000</workAmount>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>MeatRaw</li>
					</categories>
				</filter>
				<count>1.6</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RawRice</li>
					</thingDefs>
				</filter>
				<count>0.8</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>PlantFoodRaw</li>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
		</fixedIngredientFilter>
		<products>
			<RI_Food_Meatmooncake>16</RI_Food_Meatmooncake>
		</products>
	</RecipeDef>

</Defs>
