<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--东坡肉 x4-->
	<RecipeDef ParentName="RI_MeatFoodRecipe_Base">
		<defName>RI_Recipe_CookDongPoPorkBulk</defName>
		<label>Cook soysauced DongPo pork x4</label>
		<description>Use pork, pearls and spices to braise DongPo pork, a brilliant red and fragrant meat dish.</description>
		<jobString>Cook soysauced DongPo pork</jobString>
		<workAmount>1200</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Meat_Pig</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_PearlSpice</li>
					</thingDefs>
				</filter>
				<count>8</count>
			</li>
		</ingredients>
		<products>
			<RI_Food_DongPoPork>4</RI_Food_DongPoPork>
		</products>
	</RecipeDef>

