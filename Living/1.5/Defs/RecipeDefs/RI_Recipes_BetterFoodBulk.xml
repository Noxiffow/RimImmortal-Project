	<!--制作月饼x4-->
	<RecipeDef ParentName="RI_MeatFoodRecipe_Base">
		<defName>RI_Recipe_CookMooncakeBulk</defName>
		<label>Cook mooncake x4</label>
		<description>The dough and ingredients are made into cakes and then baked to get mooncakes.</description>
		<jobString>Cook mooncake</jobString>
		<ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
		<workAmount>2000</workAmount>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>PlantFoodRaw</li>
					</categories>
				</filter>
				<count>1.6</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RawRice</li>
					</thingDefs>
				</filter>
				<count>0.8</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
			<disallowedCategories>
				<li>MeatRaw</li>
				<li>AnimalProductRaw</li>
			</disallowedCategories>
		</fixedIngredientFilter>
		<products>
			<RI_Food_Mooncake>16</RI_Food_Mooncake>
		</products>
	</RecipeDef>

	<!--制作鲜肉月饼x4-->
