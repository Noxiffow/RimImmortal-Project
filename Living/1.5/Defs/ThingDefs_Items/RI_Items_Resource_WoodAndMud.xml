				<MaxHitPoints>0.8</MaxHitPoints>
				<Beauty>6</Beauty>
				<Flammability>1</Flammability>
				<WorkToMake>0.9</WorkToMake>
				<WorkToBuild>0.9</WorkToBuild>
				<DoorOpenSpeed>1.2</DoorOpenSpeed>
			</statFactors>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<isTechHediff>false</isTechHediff>
		<thingCategories>
			<li>RI_Category_WoodStone</li>
		</thingCategories>
		<weaponClasses>
			<li>Melee</li>
			<li>MeleeBlunt</li>
			<li>Neolithic</li>
		</weaponClasses>
		<tools>
			<li>
				<label>log</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>11</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<allowedArchonexusCount>150</allowedArchonexusCount>
