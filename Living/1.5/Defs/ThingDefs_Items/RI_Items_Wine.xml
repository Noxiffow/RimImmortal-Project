			<RI_Resource_WineYeast>1</RI_Resource_WineYeast>
		</costList>
	</ThingDef>

	<!--猴儿酿——无法酿造，只能买-->
	<ThingDef ParentName="RI_WineBase">
		<defName>RI_Alcohol_MonkeyWine</defName>
		<label>Monkey's wine</label>
		<description>Monkey's wine is a mysterious fruit wine. Legend has it that a group of monkeys, having gained intelligence, gathered fruits into hollow trees, letting them ferment naturally, thus creating this brew.\n\nIt carries a rich fruity aroma and an alcohol content between 3% and 5%. Some drunkards claim the wine possesses various wondrous effects, though such tales are difficult to verify.</description>
		<descriptionHyperlinks>
			<HediffDef>RI_Hediff_MonkeyWine</HediffDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Item/Drug/RI_Alcohol_MonkeyWine</texPath>
		</graphicData>
		<statBases>
			<MarketValue>120</MarketValue>
		</statBases>
		<ingestible>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>RI_Hediff_MonkeyWine</hediffDef>
					<severity>0.75</severity>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholHigh</hediffDef>
					<severity>0.15</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		<tradeTags>
			<li>Artifact</li>
			<li>RI_Alcohol</li>
		</tradeTags>
	</ThingDef>


</Defs>