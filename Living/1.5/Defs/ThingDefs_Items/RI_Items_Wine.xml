	<!--银芝药酒-->
	<ThingDef ParentName="RI_WineBase" MayRequire="RI.RimImmortal.Core">
		<defName>RI_Alcohol_LingzhiBrandy</defName>
		<label>Lingzhi brandy</label>
		<description>Silver Ganoderma Elixir is said to originate from the secret recipe of an immortal fond of drinking. In his twilight years, he freely shared the formula.\n\nThis medicinal liquor incorporates Ganoderma and Silver-Core Ginseng, resulting in a dry taste with a slight herbal note. The alcohol content is around 20%.\n\nIts unique feature is the ability to lightly enhance a cultivator’s sensitivity to Qi, as well as relieve pain and promote blood circulation — qualities that have provided countless drunken cultivators a fine excuse to buy more.</description>
		<descriptionHyperlinks>
			<HediffDef>RI_Hediff_LingzhiBrandy</HediffDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Item/Drug/RI_Alcohol_LingzhiBrandy</texPath>
		</graphicData>
		<statBases>
			<MarketValue>60</MarketValue>
		</statBases>
		<recipeMaker>
			<researchPrerequisite>RI_Research_Brewing</researchPrerequisite>
		</recipeMaker>
		<!--假装有原料-->
		<costList>
			<RI_Resource_LingzhiBrandyFermentedLiquor>1</RI_Resource_LingzhiBrandyFermentedLiquor>
		</costList>
		<ingestible>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>RI_Hediff_LingzhiBrandy</hediffDef>
					<severity>0.75</severity>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholHigh</hediffDef>
					<severity>0.3</severity>
					<toleranceChemical>Alcohol</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholTolerance</hediffDef>
					<toleranceChemical>Alcohol</toleranceChemical>
					<severity>0.015</severity>
					<divideByBodySize>true</divideByBodySize>
					<multiplyByGeneToleranceFactors>true</multiplyByGeneToleranceFactors>
				</li>
			</outcomeDoers>
		</ingestible>
		<tradeTags>
			<li>RI_Alcohol</li>
		</tradeTags>
	</ThingDef>

	<!--银芝药酒发酵液-->
	<ThingDef ParentName="RI_FermentedLiquorBase" MayRequire="RI.RimImmortal.Core">
		<defName>RI_Resource_LingzhiBrandyFermentedLiquor</defName>
		<label>Fermentation liquid of "Lingzhi brandy"</label>
		<description>Fermentation liquid of "Lingzhi brandy", cooked Lingzhi, Silver Ginseng, and rice are mixed together, then fermented with wine yeast.</description>
		<costList>
			<RI_Resource_LingZhi>3</RI_Resource_LingZhi>
