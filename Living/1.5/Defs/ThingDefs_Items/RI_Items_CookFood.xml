	<!--三角粽子-->
	<ThingDef ParentName="RI_Dessert_Base">
		<defName>RI_Food_TriangleZongZi</defName>
		<label>Triangle ZongZi</label>
		<description>Zongzi is a traditional food made by steaming glutinous rice wrapped in bamboo or reed leaves. Due to regional differences in culinary habits, the fillings of zongzi vary widely.\n\nIn ancient times, zongzi was used as an offering to deities. Over time, it gradually evolved into a festive delicacy loved by many.\n\nThis type of zongzi is triangular in shape.</description>
		<graphicData>
			<texPath>Things/Item/Meal/RI_Food_TriangleZongZi</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<DeteriorationRate>10</DeteriorationRate>
			<MarketValue>10</MarketValue>
			<Mass>0.1</Mass>
			<WorkToMake>450</WorkToMake>
			<Nutrition>0.5</Nutrition>
		</statBases>
		<ingestible>
			<preferability>MealSimple</preferability>
			<optimalityOffsetHumanlikes>21</optimalityOffsetHumanlikes>
			<!--人类喜好-->
			<optimalityOffsetFeedingAnimals>-10</optimalityOffsetFeedingAnimals>
			<!--喂食喜好-->
			<tasteThought>RI_Thought_EatZongZi</tasteThought>
			<ingestEffect>EatVegetarian</ingestEffect>
			<ingestSound>Meal_Eat</ingestSound>
		</ingestible>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>15</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<allowedArchonexusCount>50</allowedArchonexusCount>
	</ThingDef>

