<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--布料啥的前置-->
	<ThingDef Abstract="True" Name="RI_SilkBase" ParentName="ResourceBase">
		<graphicData>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>30</minRewardCount>
		<stuffProps>
			<categories>
				<li>Fabric</li>
			</categories>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<thingCategories>
			<li>RI_Category_Fabric</li>
		</thingCategories>
		<allowedArchonexusCount>50</allowedArchonexusCount>
	</ThingDef>

	<!--丝绸-->
	<ThingDef ParentName="RI_SilkBase">
		<defName>RI_Resource_Silk</defName>
		<label>Silk</label>
		<description>Silk is a very beautiful, soft, high-quality fabric. It's made of natural fibers from silkworm cocoons.\n\nToday, this process is also scattered in various star regions with human activities. The convenient storage of silkworm eggs, so that silk even in some remote planets, do not worry about finding buyers, with its production of clothing, has always been the preference of the rich and powerful.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_Silk</texPath>
		</graphicData>
		<statBases>
			<StuffPower_Armor_Sharp>0.4</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.1</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.2</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>21</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>30</StuffPower_Insulation_Heat>
			<MaxHitPoints>95</MaxHitPoints>
			<MarketValue>8.5</MarketValue>
			<Mass>0.03</Mass>
			<Flammability>1</Flammability>
			<DeteriorationRate>1</DeteriorationRate>
		</statBases>
		<stuffProps>
			<statFactors>
				<Flammability>1</Flammability>
				<Beauty>5</Beauty>
			</statFactors>
			<color>(153,199,178)</color>
			<commonality>0.3</commonality>
		</stuffProps>
		<tradeTags>
			<li>ExoticMisc</li>
		</tradeTags>
	</ThingDef>

	<!--火浣布-->
	<ThingDef ParentName="RI_SilkBase">
		<defName>RI_Resource_FireCloth</defName>
		<label>Fire-proof cloth</label>
		<description>A cloth made from the wool of an animal called a fire rat is a very rare material. It is said that the material can be made into a fire-resistant clothing, which itself can block the heat, while having ultra-high blunt force defense.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_FireCloth</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>170</MaxHitPoints>
			<MarketValue>12</MarketValue>
			<Mass>0.025</Mass>
			<Flammability>0</Flammability>
			<DeteriorationRate>3</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.5</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>1.8</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>1.2</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>0</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>230</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.05</commonality>
			<color>(171,82,58)</color>
			<statFactors>
				<Flammability>0.3</Flammability>
				<MaxHitPoints>2</MaxHitPoints>
				<Beauty>3</Beauty>
			</statFactors>
		</stuffProps>
	</ThingDef>

	<!--冰蚕丝-->
	<ThingDef ParentName="RI_SilkBase">
		<defName>RI_Resource_IceSilk</defName>
		<label>Ice silk</label>
		<description>An ice silkworm knows no cold.\n\nThis soft, cool silk comes from the silk of the ice silkworm, and is a very rare material. Clothing made of ice silk can prevent the cold from entering the body, while having ultra-high sharp weapon defense, and is very lightweight.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_IceSilk</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>170</MaxHitPoints>
			<MarketValue>13</MarketValue>
			<Mass>0.025</Mass>
			<Flammability>0.7</Flammability>
			<DeteriorationRate>2</DeteriorationRate>
			<StuffPower_Armor_Sharp>1.9</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.6</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.1</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>70</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>0</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.05</commonality>
			<color>(175,203,227)</color>
			<statFactors>
				<Flammability>0.3</Flammability>
				<MaxHitPoints>2</MaxHitPoints>
				<Beauty>3</Beauty>
			</statFactors>
		</stuffProps>
	</ThingDef>

