<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--布料啥的前置-->
	<ThingDef Abstract="True" Name="RI_Base_Fabric" ParentName="ResourceBase">
		<graphicData>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>30</minRewardCount>
		<stuffProps>
			<categories>
				<li>Fabric</li>
			</categories>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<thingCategories>
			<li>RI_Category_Fabric</li>
		</thingCategories>
		<allowedArchonexusCount>100</allowedArchonexusCount>
	</ThingDef>

	<!--丝绸-->
	<ThingDef ParentName="RI_Base_Fabric">
		<defName>RI_Resource_Silk</defName>
		<label>silk</label>
		<description>Silk is a high-quality fabric with a smooth texture and an elegant appearance, woven from silkworm thread.\n\nAs early as the Stone Age, people raised silkworms, reeled silk, and spun thread. This craft eventually gave rise to long-distance international trade routes centered on silk, known as the Silk Road.\n\nToday, the technique has spread with humanity across various star systems. Silkworm eggs are easy to store, and even on remote planets there are those who make their living through sericulture and weaving.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_Silk</texPath>
		</graphicData>
		<statBases>
			<StuffPower_Armor_Sharp>0.4</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.1</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.2</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>21</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>30</StuffPower_Insulation_Heat>
			<MaxHitPoints>95</MaxHitPoints>
			<MarketValue>12</MarketValue>
			<Mass>0.03</Mass>
			<Flammability>1</Flammability>
			<DeteriorationRate>1</DeteriorationRate>
		</statBases>
		<stuffProps>
			<statFactors>
				<Flammability>1</Flammability>
				<Beauty>5</Beauty>
			</statFactors>
			<color>(153,199,178)</color>
			<commonality>0.2</commonality>
		</stuffProps>
		<tradeTags>
			<li>ExoticMisc</li>
		</tradeTags>
	</ThingDef>

	<!--火浣皮-->
	<ThingDef ParentName="RI_Base_Fabric">
		<defName>RI_Resource_FireCloth</defName>
		<label>fire rat leather</label>
		<description>Fire rat leather comes from the fire rat and is a rare and valuable material.\n\nIt insulates against intense heat while also absorbing impact, providing protection against blunt weapons.\n\nIn ancient times, fire-rinsed hide was offered as tribute to the emperor, and the demand once nearly drove the fire rat to extinction.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_FireCloth</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>170</MaxHitPoints>
			<MarketValue>15</MarketValue>
			<Mass>0.025</Mass>
			<Flammability>0</Flammability>
			<DeteriorationRate>3</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.5</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>1.8</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>1.2</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>0</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>230</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.05</commonality>
			<color>(171,82,58)</color>
			<statFactors>
				<Flammability>0.3</Flammability>
				<MaxHitPoints>2</MaxHitPoints>
				<Beauty>3</Beauty>
			</statFactors>
		</stuffProps>
	</ThingDef>

	<!--冰蚕丝-->
	<ThingDef ParentName="RI_Base_Fabric">
		<defName>RI_Resource_IceSilk</defName>
		<label>ice silk</label>
		<description>“The ice silkworm knows no cold; the fire rat knows no heat.”\n\nThis soft and cooling fabric is woven from the silk spun by ice silkworms and is considered a precious material.\n\nGarments made from ice silk prevent cold qi from entering the body and also provide good resistance against cutting.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_IceSilk</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>170</MaxHitPoints>
			<MarketValue>16</MarketValue>
			<Mass>0.025</Mass>
			<Flammability>0.7</Flammability>
			<DeteriorationRate>2</DeteriorationRate>
			<StuffPower_Armor_Sharp>1.9</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.6</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.1</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>70</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>0</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.05</commonality>
			<color>(175,203,227)</color>
			<statFactors>
				<Flammability>0.3</Flammability>
				<MaxHitPoints>2</MaxHitPoints>
				<Beauty>3</Beauty>
			</statFactors>
		</stuffProps>
	</ThingDef>

	<!--金丝-->
	<ThingDef ParentName="RI_Base_Fabric">
		<defName>RI_Resource_GoldenSilk</defName>
		<label>golden silk</label>
		<description>Golden silk is made by heating gold, drawing it into fine threads, and weaving it into fabric. Generally, only the imperial court and the nobility could afford to use it in this way.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_GoldenSilk</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>80</MaxHitPoints>
			<MarketValue>21</MarketValue>
			<Mass>0.01</Mass>
			<Flammability>0.1</Flammability>
			<DeteriorationRate>1</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.8</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.3</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.1</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>11</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>6</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.01</commonality>
			<color>(214,185,56)</color>
			<statFactors>
				<Flammability>0.7</Flammability>
				<MaxHitPoints>1.3</MaxHitPoints>
				<Beauty>12</Beauty>
			</statFactors>
		</stuffProps>
		<tradeTags>
			<li>ExoticMisc</li>
		</tradeTags>
	</ThingDef>

	<!--银丝-->
	<ThingDef ParentName="RI_Base_Fabric">
		<defName>RI_Resource_SilverSilk</defName>
		<label>silver silk</label>
		<description>Silver silk is produced by heating silver, stretching it into threads, and weaving them into cloth.\n\nThere is also a craft that interweaves gold and silver threads into intricate patterns, then embellishes them with gemstones to create lavish decorative designs.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_SilverSilk</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>80</MaxHitPoints>
			<MarketValue>18</MarketValue>
			<Mass>0.025</Mass>
			<Flammability>0.7</Flammability>
			<DeteriorationRate>3</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.94</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.26</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.90</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>22</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>22</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<commonality>0.02</commonality>
			<color>(223,222,227)</color>
			<statFactors>
				<Flammability>0.3</Flammability>
				<MaxHitPoints>2</MaxHitPoints>
				<Beauty>9</Beauty>
			</statFactors>
		</stuffProps>
		<tradeTags>
			<li>ExoticMisc</li>
		</tradeTags>
	</ThingDef>

</Defs>
