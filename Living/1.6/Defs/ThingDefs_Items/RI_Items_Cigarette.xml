<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ==================== 1. Chemical substance definition ==================== -->
	<!-- Must define a unique chemical to prevent tolerance overlap with vanilla smokeleaf -->
	<ChemicalDef>
		<defName>RI_Chemical_Cigarette</defName>
		<label>cigarette</label>
		<addictionHediff>RI_Hediff_PremiumTobaccoAddiction</addictionHediff>
		<toleranceHediff>RI_Hediff_PremiumTobaccoTolerance</toleranceHediff>
		<onGeneratedAddictedToleranceChance>0.01</onGeneratedAddictedToleranceChance>
	</ChemicalDef>

	<!--Requirements-->
	<NeedDef ParentName="DrugAddictionNeedBase">
		<defName>RI_Need_PremiumTobacco</defName>
		<needClass>Need_Chemical</needClass>
		<label>cigarette</label>
		<description>Because of a cigarette addiction, this person needs to smoke regularly to avoid withdrawal symptoms.</description>
		<listPriority>25</listPriority>
	</NeedDef>

	<!-- Cloud blossom cigarette -->
	<ThingDef ParentName="DrugBase">
		<defName>RI_Drug_YunHuaCigarette</defName>
		<label>YunHua cigarette</label>
		<description>Human relationships are like flowers seen through the mist—impossible to grasp, yet impossible to live without.\n\nYunhua cigarettes are expensive, high-end cigarettes. Whether one actually enjoys smoking them hardly matters. In certain situations, they serve as a token of courtesy—a kind of social pass.</description>

		<graphicData>
			<!-- Cigarette texture path; suggest a red classic cigarette box or single cigarette -->
			<texPath>Things/Item/Drug/RI_Drug_YunHuaCigarette</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>

		<rotatable>false</rotatable>
		<tradeTags>
			<li>Drugs</li>
			<li>ExoticMisc</li>
		</tradeTags>
		<stackLimit>10</stackLimit>
		<statBases>
			<WorkToMake>500</WorkToMake>
			<!-- [Very high price] Vanilla smokeleaf costs 11; set to 85 here — one pack rivals advanced components -->
			<MarketValue>140</MarketValue>
			<!--Contribution value-->
			<RoyalFavorValue>0.4</RoyalFavorValue>
			<Mass>0.1</Mass>
			<DeteriorationRate>2</DeteriorationRate>
			<Flammability>1.5</Flammability>
			<!-- Flammable -->
		</statBases>

		<techLevel>Industrial</techLevel>

		<ingestible>
			<!-- Used as recreational drug -->
			<foodType>Plant, Processed</foodType>
			<joyKind>Chemical</joyKind>
			<!-- Very high recreation boost (0.9 = nearly fills recreation bar per cigarette) -->
			<joy>0.8</joy>
			<baseIngestTicks>720</baseIngestTicks>
			<nurseable>true</nurseable>
			<drugCategory>Social</drugCategory>
			<ingestSound>Ingest_Smoke</ingestSound>
			<ingestEffect>Smoke_Joint</ingestEffect>
			<ingestEffectEat>EatVegetarian</ingestEffectEat>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.27,0,0.08)</offset>
					<behind>true</behind>
				</northDefault>
				<east>
					<offset>(0.45,0,0.08)</offset>
				</east>
				<south>
					<offset>(0.27,0,0.08)</offset>
				</south>
				<west>
					<offset>(-0.50,0,0.08)</offset>
					<flip>true</flip>
				</west>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Smoke {0}</ingestCommandString>
			<ingestReportString>Smoking {0}.</ingestReportString>
			<ingestReportStringEat>Consuming {0}.</ingestReportStringEat>

			<outcomeDoers>
				<!-- 1. Gives high state after use -->
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>RI_Hediff_ChunghwaHigh</hediffDef>
					<severity>1.0</severity>
					<toleranceChemical>RI_Chemical_Cigarette</toleranceChemical>
				</li>
				<!-- 2. Adds minimal tolerance -->
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>RI_Hediff_PremiumTobaccoTolerance</hediffDef>
					<severity>0.02</severity>
					<divideByBodySize>true</divideByBodySize>
				</li>
			</outcomeDoers>
		</ingestible>

		<comps>
			<li Class="CompProperties_Drug">
				<chemical>RI_Chemical_Cigarette</chemical>
				<!-- [Extremely low addiction] Vanilla smokeleaf is 0.02; this is 0.005 (0.5% chance), requires very high tolerance to trigger -->
				<addictiveness>0.005</addictiveness>
				<minToleranceToAddict>0.45</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.1</existingAddictionSeverityOffset>
				<needLevelOffset>0.9</needLevelOffset>
				<listOrder>200</listOrder>
			</li>
		</comps>
	</ThingDef>

	<!-- ==================== 4. Post-smoke mood bonus (Thought) ==================== -->
	<ThoughtDef>
		<defName>RI_Thought_ChunghwaHigh</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>RI_Hediff_ChunghwaHigh</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>blow a cloud</label>
				<description>After a cigarette, than live immortal.</description>
				<baseMoodEffect>18</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>

	<!--Withdrawal thought-->
	<ThoughtDef>
		<defName>SmokeleafWithdrawal</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>SmokeleafAddiction</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
		<stages>
			<li>
				<visible>false</visible>
			</li>
			<li>
				<label>Just one cigarette</label>
				<description>I really need one cigarette.</description>
				<baseMoodEffect>-20</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>

</Defs>
