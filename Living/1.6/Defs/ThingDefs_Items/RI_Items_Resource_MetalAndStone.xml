<Defs>

	<!--镔铁-->
	<ThingDef ParentName="ResourceBase">
		<defName>RI_Resource_DamascusIron</defName>
		<label>pattern steel</label>
		<description>It is a kind of high-quality steel obtained by repeatedly forging compressed steel and adding other metals to it. The color of iron is snow-white, and the silk pattern is inserted into it. It is very beautiful and has very good elasticity and hardness, suitable for making weapons.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_DamascusIron</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<soundInteract>Metal_Drop</soundInteract>
		<soundDrop>Metal_Drop</soundDrop>
		<statBases>
			<MarketValue>12</MarketValue>
			<Mass>0.4</Mass>
			<StuffPower_Armor_Sharp>1.2</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.6</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.3</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>3</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>1</StuffPower_Insulation_Heat>
			<SharpDamageMultiplier>1.1</SharpDamageMultiplier>
			<BluntDamageMultiplier>0.7</BluntDamageMultiplier>
		</statBases>
		<useHitPoints>false</useHitPoints>
		<healthAffectsPrice>false</healthAffectsPrice>
		<thingCategories>
			<li>RI_Category_Ore</li>
		</thingCategories>
		<burnableByRecipe>false</burnableByRecipe>
		<smeltable>true</smeltable>
		<stuffProps>
			<categories>
				<li>Metallic</li>
			</categories>
			<appearance>Metal</appearance>
			<commonality>0.25</commonality>
			<constructEffect>ConstructMetal</constructEffect>
			<color>(175,199,219)</color>
			<soundImpactBullet>BulletImpact_Metal</soundImpactBullet>
			<soundMeleeHitSharp>MeleeHit_Metal_Sharp</soundMeleeHitSharp>
			<soundMeleeHitBlunt>MeleeHit_Metal_Blunt</soundMeleeHitBlunt>
			<soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Metal</soundImpactMelee>
			<statFactors>
				<MaxHitPoints>1.5</MaxHitPoints>
				<Beauty>2</Beauty>
				<Flammability>0.3</Flammability>
			</statFactors>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<allowedArchonexusCount>80</allowedArchonexusCount>
	</ThingDef>

	<!--乌刚玉-->
	<ThingDef ParentName="ResourceBase">
		<defName>RI_Resource_BlackCorundum</defName>
		<label>dark corundum</label>
		<description>Dark corundum is a small amount of emerald-like stone excavated from the mountains. Its hardness is very high, and the appearance is also quite good, but it is relatively rare, so that its price continues to rise. This material is like a piece of inky ice, and it is said that some body-hugging jewelry made with it has a calming effect.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_BlackCorundum</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<useHitPoints>false</useHitPoints>
		<healthAffectsPrice>false</healthAffectsPrice>
		<soundInteract>ChunkRock_Drop</soundInteract>
		<soundDrop>ChunkRock_Drop</soundDrop>
		<statBases>
			<MarketValue>18</MarketValue>
			<MaxHitPoints>300</MaxHitPoints>
			<Mass>2.1</Mass>
			<StuffPower_Armor_Sharp>1.9</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>1.3</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.8</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>0</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>0</StuffPower_Insulation_Heat>
			<SharpDamageMultiplier>2.3</SharpDamageMultiplier>
			<BluntDamageMultiplier>1.6</BluntDamageMultiplier>
		</statBases>
		<thingCategories>
			<li>RI_Category_Ore</li>
		</thingCategories>
		<deepCommonality>0.5</deepCommonality>
