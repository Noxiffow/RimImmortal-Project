<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Royal tribute wine (disabled) -->
	<ThingDef ParentName="DrugBase">
		<defName>RI_Drug_ImperialWine</defName>
		<label>Imperial tribute</label>
		<description>A long-established sauce-aroma baijiu with a rich heritage. It is expensive, and in ancient times it was typically presented as tribute for the emperor's enjoyment. The liquor is mellow and full-bodied, with a deep aroma that lingers—truly a premium among baijiu.\n\nA bottle like this, placed in the home, speaks more about the owner's taste than any decoration ever could.</description>
		<descriptionHyperlinks>
			<HediffDef>AlcoholHigh</HediffDef>
			<HediffDef>AlcoholTolerance</HediffDef>
			<HediffDef>AlcoholAddiction</HediffDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Item/Drug/RI_Drug_ImperialWine</texPath>
			<!-- Remember to prepare the texture -->
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<rotatable>false</rotatable>
		<tradeTags>
			<li>Drugs</li>
			<li>ExoticMisc</li>
		</tradeTags>
		<stackLimit>10</stackLimit>
		<statBases>
			<MarketValue>300</MarketValue>
			<Mass>0.5</Mass>
			<!--Contribution value-->
			<RoyalFavorValue>1</RoyalFavorValue>
			<DeteriorationRate>0.5</DeteriorationRate>
			<Flammability>0.5</Flammability>
			<!-- High-proof alcohol is flammable -->
		</statBases>
		<techLevel>Industrial</techLevel>
		<ingestible>
			<foodType>Fluid, Processed</foodType>
			<joyKind>Chemical</joyKind>
			<joy>0.6</joy>
			<!-- Provides large recreation boost (beer is only 0.17) -->
			<drugCategory>Social</drugCategory>
			<ingestSound>Ingest_Beer</ingestSound>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.18,0,0)</offset>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestCommandString>drink {0}</ingestCommandString>
			<ingestReportString>drinking {0}</ingestReportString>
			<chairSearchRadius>25</chairSearchRadius>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholHigh</hediffDef>
					<severity>0.35</severity>
					<!-- Strong: one bottle equals three beers (beer is 0.15) -->
					<toleranceChemical>Alcohol</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholTolerance</hediffDef>
					<severity>0.04</severity>
					<divideByBodySize>true</divideByBodySize>
				</li>
			</outcomeDoers>
		</ingestible>
		<comps>
			<li Class="CompProperties_Drug">
				<chemical>Alcohol</chemical>
				<addictiveness>0.015</addictiveness>
				<!-- Addiction rate slightly higher than beer -->
				<minToleranceToAddict>0.25</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.1</existingAddictionSeverityOffset>
				<needLevelOffset>0.9</needLevelOffset>
				<listOrder>10</listOrder>
			</li>
		</comps>
		<allowedArchonexusCount>50</allowedArchonexusCount>
	</ThingDef>

</Defs>
