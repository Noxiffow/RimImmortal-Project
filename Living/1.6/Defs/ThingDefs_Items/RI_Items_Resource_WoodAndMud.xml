<Defs>

	<!--Sandalwood-->
	<ThingDef ParentName="ResourceVerbBase">
		<defName>RI_Resource_SandalWoodLog</defName>
		<label>sandalwood</label>
		<description>Sandalwood is a fine-grained, fragrant, and valuable hardwood. Its excellent qualities make sandalwood furniture expensive.\n\nWhen burned, sandalwood releases a pleasant aroma. Scholars and refined gentlemen often burn it as incense at home, bathing in the woody fragrance to relax body and mind.</description>
		<graphicData>
			<texPath>Things/Item/Resource/RI_Resource_SandalWoodLog</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<equippedAngleOffset>-20</equippedAngleOffset>
		<soundInteract>Wood_Drop</soundInteract>
		<soundDrop>Wood_Drop</soundDrop>
		<statBases>
			<MarketValue>11</MarketValue>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>0.5</Mass>
			<Flammability>1.0</Flammability>
			<DeteriorationRate>0.5</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.6</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.6</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.30</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>3</StuffPower_Insulation_Heat>
			<SharpDamageMultiplier>0.45</SharpDamageMultiplier>
			<BluntDamageMultiplier>0.95</BluntDamageMultiplier>
		</statBases>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>10</minRewardCount>
		<stuffProps>
			<stuffAdjective>Sandal wood</stuffAdjective>
			<categories>
				<li>Woody</li>
			</categories>
			<commonality>0.05</commonality>
			<color>(122,72,55)</color>
			<constructEffect>ConstructWood</constructEffect>
			<appearance>Planks</appearance>
			<soundImpactBullet>BulletImpact_Wood</soundImpactBullet>
			<soundMeleeHitSharp>MeleeHit_Wood</soundMeleeHitSharp>
