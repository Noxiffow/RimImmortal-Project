<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--挥棒子咻一声-->
	<SoundDef>
		<defName>RI_Sound_WaveSoundA</defName>
		<context>MapOnly</context>
		<maxSimultaneous>1</maxSimultaneous>
		<subSounds>
			<li>
				<grains>
					<li Class="AudioGrain_Clip">
						<clipPath>RI_Sound_WaveSoundA</clipPath>
					</li>
				</grains>
				<volumeRange>7~12</volumeRange>
			</li>
		</subSounds>
	</SoundDef>

