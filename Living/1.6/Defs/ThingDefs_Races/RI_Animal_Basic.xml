	<!-- ========================== Sky hound ============================ -->

	<ThingDef ParentName="AnimalThingBase">
		<defName>RI_Animal_TianDog</defName>
		<label>Tian dog</label>
		<devNote>Tian dog</devNote>
		<description>There is a beast, called the Tian dog, whose shape is like a fox with a white head, and whose voice is qute, which can ward off evil.\n\nThis is a medium size dog, its appearance is cute, IQ is not low, very loyal, and its combat effectiveness is slightly higher than ordinary dogs, so it is often raised by some women.</description>
		<statBases>
			<MoveSpeed>6.0</MoveSpeed>
			<MarketValue>480</MarketValue>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<ComfyTemperatureMax>50</ComfyTemperatureMax>
			<FilthRate>2</FilthRate>
			<Wildness>0</Wildness>
		</statBases>
		<tools>
			<li>
				<label>left claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>11</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>11</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
			</li>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>16</power>
				<cooldownTime>2.5</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
		</tools>
		<race>
			<animalType>Canine</animalType>
			<body>QuadrupedAnimalWithPawsAndTail</body>
			<petness>1</petness>
			<baseBodySize>0.86</baseBodySize>
			<baseHungerRate>0.5</baseHungerRate>
			<baseHealthScale>1.2</baseHealthScale>
			<foodType>OmnivoreAnimal, OvivoreAnimal, CarnivoreAnimalStrict</foodType>
			<leatherDef>Leather_Dog</leatherDef>
			<nameOnTameChance>1</nameOnTameChance>
			<trainability>Advanced</trainability>
			<nuzzleMtbHours>10</nuzzleMtbHours>
			<gestationPeriodDays>10</gestationPeriodDays>
			<soundEating>PredatorSmall_Eat</soundEating>
			<litterSizeCurve>
				<points>
					<li>(0.5, 0)</li>
					<li>(1, 1)</li>
					<li>(2, 1.7)</li>
					<li>(2.5, 0.7)</li>
					<li>(3, 0)</li>
				</points>
			</litterSizeCurve>
			<lifeExpectancy>80</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.25</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.5</minAge>
					<soundWounded>Pawn_Dog_Injured</soundWounded>
					<soundDeath>Pawn_Dog_Death</soundDeath>
					<soundCall>Pawn_Dog_Call</soundCall>
					<soundAngry>Pawn_Dog_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<headPosPerRotation>
				<li>(0.02, 0, 0.25)</li>
				<li>(0.24, 0, 0.11)</li>
				<li>(0.02, 0, -0.16)</li>
				<li>(-0.24, 0, 0.11)</li>
			</headPosPerRotation>
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
			<li>AnimalPet</li>
		</tradeTags>
	</ThingDef>

