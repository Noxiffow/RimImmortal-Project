	<!--Make synthetic fiber-->
	<RecipeDef ParentName="RI_RecipeBase_HeatPress">
		<defName>RI_Recipe_PressSynthread</defName>
		<label>heat pressed synthread</label>
		<description>By means of heat pressing, silk fibers are tightly bonded with chemical compounds to produce synthetic fiber.</description>
		<jobString>heat pressing synthread</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>RI_Resource_Silk</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Neutroamine</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>RI_Resource_Silk</li>
				<li>Neutroamine</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
