		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>WoodLog</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_ThinWood>12</RI_Resource_ThinWood>
		</products>
	</RecipeDef>

