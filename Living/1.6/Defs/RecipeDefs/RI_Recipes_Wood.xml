<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Chop log — requires Melee 1-->
	<RecipeDef>
		<defName>RI_Recipe_ChopWoodLog</defName>
		<label>chop woodlog</label>
		<description>Chop raw logs. This requires a bit of technique.</description>
		<jobString>chopping wood</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>RI_Sound_ChopKaA</soundWorking>
		<skillRequirements>
			<Melee>1</Melee>
		</skillRequirements>
		<workSkill>Melee</workSkill>
		<displayPriority>1</displayPriority>
		<workAmount>50</workAmount>
		<recipeUsers>
			<li>CraftingSpot</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>WoodLog</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_ThinWood>5</RI_Resource_ThinWood>
		</products>
	</RecipeDef>

	<!--Saw wood base-->
	<RecipeDef Name="RI_RecipeBase_SawWood" Abstract="True">
		<!--Description-->
		<jobString>sawing wood</jobString>
		<description>Saw timber into flat wood planks. Different types of wood yield different amounts of planks.</description>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>RI_Sound_SawOffWoodA</soundWorking>
		<workSkill>Crafting</workSkill>
		<skillRequirements>
			<Crafting>1</Crafting>
		</skillRequirements>
		<recipeUsers>
			<li>RI_Building_SawHorse</li>
		</recipeUsers>
		<displayPriority>1</displayPriority>
		<researchPrerequisite>RI_BasicTechnology</researchPrerequisite>
	</RecipeDef>

	<!--Saw off log-->
	<RecipeDef ParentName="RI_RecipeBase_SawWood">
		<defName>RI_Recipe_SawOffThinWood</defName>
		<label>saw off wood</label>
		<workAmount>200</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>WoodLog</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RI_Resource_ThinWood>12</RI_Resource_ThinWood>
		</products>
	</RecipeDef>

