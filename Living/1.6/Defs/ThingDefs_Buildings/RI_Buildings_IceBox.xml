<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Marrow ice cellar-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_IceMarrowBox</defName>
		<label>Ice marrow box</label>
		<description>An intricately crafted metal ice box. Unlike ordinary ice boxes, it absorbs heat from the surrounding environment, lowering room temperature and enabling the creation of cold storage.</description>
		<category>Building</category>
		<graphicData>
			<texPath>Things/Building/Misc/RI_Building_IceMarrowBox</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.1,1.1)</drawSize>
			<drawRotated>false</drawRotated>
			<allowFlip>false</allowFlip>
			<addTopAltitudeBias>true</addTopAltitudeBias>
			<shadowData>
				<volume>(0.9,0.3,0.9)</volume>
			</shadowData>
			<damageData>
				<rect>(0.2,0,0.6,0.1)</rect>
			</damageData>
		</graphicData>
		<rotatable>false</rotatable>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<tickerType>Normal</tickerType>
		<drawerType>RealtimeOnly</drawerType>
		<fillPercent>0.40</fillPercent>
		<statBases>
			<MaxHitPoints>180</MaxHitPoints>
			<WorkToBuild>300</WorkToBuild>
			<Flammability>0.5</Flammability>
		</statBases>
		<selectable>true</selectable>

		<costList>
			<RI_Resource_IceMarrow>10</RI_Resource_IceMarrow>
		</costList>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>

		<building>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
		</building>
		<soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
		<placeWorkers>
			<li>PlaceWorker_CoolerSimple</li>
		</placeWorkers>
		<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		<comps>
			<!--Emits blue glow-->
			<li Class="CompProperties_Glower">
				<glowRadius>2</glowRadius>
				<glowColor>(104,223,224)</glowColor>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>-20</heatPerSecond>
				<heatPushMinTemperature>-12</heatPushMinTemperature>
			</li>
			<!--Efficiency: consumes 1 marrow per day-->
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>1</fuelConsumptionRate>
				<fuelCapacity>10</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>RI_Resource_IceMarrow</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>1</initialFuelPercent>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
		</comps>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<!--Unlocked by research-->
		<researchPrerequisites>
			<li>RI_CarpentryAndCrafting</li>
		</researchPrerequisites>
	</ThingDef>

</Defs>