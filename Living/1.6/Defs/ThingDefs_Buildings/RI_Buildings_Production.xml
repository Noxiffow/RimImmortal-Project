	<!-- Industrial — heat press -->
	<!--Can make synthetic fiber; other possible uses TBD-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_HotPressMachine</defName>
		<label>heat press</label>
		<description>A machine that applies high heat and pressure simultaneously, allowing materials to bond tightly in a controlled environment and form new materials.\n\nThis machine is used to produce certain industrial materials.\n\nThis machine is dangerous. Do not put your head inside while it is operating.</description>
		<thingClass>Building_WorkTable_HeatPush</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_HotPressMachine</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.87,2.87)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<constructEffect>ConstructMetal</constructEffect>
		<costList>
			<Steel>160</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>2000</WorkToBuild>
			<MaxHitPoints>180</MaxHitPoints>
			<Flammability>1.0</Flammability>
		</statBases>
		<size>(2,2)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2110</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<recipes>
			<li>RI_Recipe_MakePlywood</li>
			<li>RI_Recipe_MakePlywoodBulk</li>
			<li>RI_Recipe_MakePlywoodBamboo</li>
			<li>RI_Recipe_MakePlywoodBambooBulk</li>
			<li>RI_Recipe_PressSynthread</li>
			<li>RI_Recipe_PressSynthreadBulk</li>
			<li>RI_Recipe_MakeIronWoodSteel</li>
			<li>RI_Recipe_MakeIronWoodSteelBulk</li>
		</recipes>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>500</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>8</heatPerSecond>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
		</comps>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<workTableRoomRole>Workshop</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_Electric</li>
		</researchPrerequisites>
	</ThingDef>

	<!--Industrial drill-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_IndustrialDrilling</defName>
		<label>industrial drilling</label>
		<description>An industrial drilling machine used to extract minerals from deep beneath the surface, with a larger operational range. If no mineral deposits are detected, the drill will continuously produce chunks of stone.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Building/Production/RI_Building_IndustrialDrilling</texPath>
			<drawSize>(5.75,5.75)</drawSize>
			<drawRotated>false</drawRotated>
			<shadowData>
				<volume>(0.52, 0.53, 0.09)</volume>
				<offset>(0,0,-0.43)</offset>
			</shadowData>
		</graphicData>
		<size>(2,2)</size>
		<altitudeLayer>Building</altitudeLayer>
		<!--Impassable-->
		<passability>Impassable</passability>
		<blockWind>true</blockWind>
		<fillPercent>1</fillPercent>
		<hasInteractionCell>true</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<!-- Larger! -->
		<specialDisplayRadius>6.9</specialDisplayRadius>
		<rotatable>true</rotatable>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<uiIconOffset>(0, 0.03)</uiIconOffset>
		<uiIconScale>0.85</uiIconScale>
		<minifiedDef>MinifiedThing</minifiedDef>
		<building>
			<uninstallWork>1800</uninstallWork>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
		</building>
		<thingCategories>
			<li>BuildingsProduction</li>
		</thingCategories>
		<costList>
			<Steel>210</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<placeWorkers>
			<li>PlaceWorker_DeepDrill</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
			<li>PlaceWorker_InvalidOverSubstructure</li>
		</placeWorkers>
		<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		<researchPrerequisites>
			<li>DeepDrilling</li>
			<li>RI_Electric</li>
		</researchPrerequisites>
		<statBases>
			<MaxHitPoints>600</MaxHitPoints>
			<WorkToBuild>14000</WorkToBuild>
			<Flammability>0.4</Flammability>
			<Beauty>-10</Beauty>
			<Mass>70</Mass>
		</statBases>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>500</basePowerConsumption>
			</li>
			<li Class="CompProperties_DeepDrill" />
			<li Class="CompProperties_CreatesInfestations" />
		</comps>
	</ThingDef>

</Defs>