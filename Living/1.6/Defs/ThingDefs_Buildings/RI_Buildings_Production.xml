<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--Brick kiln-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_BrickKiln</defName>
		<label>kiln</label>
		<description>A large brick-built kiln fueled by firewood. It reaches extremely high internal temperatures.</description>
		<thingClass>Building_WorkTable_HeatPush</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_BrickKiln</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(5.7,5.6)</drawSize>
			<shadowData>
				<volume>(1.95,0.5,1.3)</volume>
			</shadowData>
			<damageData>
				<rect>(0.3,0.1,2.4,1.8)</rect>
			</damageData>
		</graphicData>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>150</costStuffCount>
		<altitudeLayer>Building</altitudeLayer>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>4500</WorkToBuild>
			<MaxHitPoints>300</MaxHitPoints>
			<Cleanliness>-20</Cleanliness>
			<Beauty>-10</Beauty>
		</statBases>
		<size>(3,3)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<fillPercent>1</fillPercent>
		<passability>Impassable</passability>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-2)</interactionCellOffset>
		<interactionCellIcon>DiningChair</interactionCellIcon>
		<surfaceType>Item</surfaceType>
		<canOverlapZones>false</canOverlapZones>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<recipes>
			<!--Fire bricks-->
			<li>RI_MakeBlackBrick</li>
			<li>RI_MakeBlackBrickBulk</li>
			<li>RI_MakeBlackBrickTen</li>
			<li>RI_MakeRedBrick</li>
			<li>RI_MakeRedBrickBulk</li>
			<li>RI_MakeRedBrickTen</li>
			<!--Kiln work-->
			<li>ExtractMetalFromSlag</li>
			<li>SmeltOrDestroyThing</li>
			<li>SmeltWeapon</li>
			<li>SmeltApparel</li>
			<li>DestroyWeapon</li>
			<li>DestroyApparel</li>
		</recipes>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<comps>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>80.0</fuelConsumptionRate>
				<fuelCapacity>50.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
						<li>RI_Resource_RawBamboo</li>
					</thingDefs>
				</fuelFilter>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>6</glowRadius>
				<glowColor>(217,112,33,0)</glowColor>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>15</heatPerSecond>
			</li>
		</comps>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<heatPerTickWhileWorking>0.3</heatPerTickWhileWorking>
			<workTableRoomRole>Workshop</workTableRoomRole>
			<forceShowRoomStats>true</forceShowRoomStats>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
			<paintable>true</paintable>
		</building>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<designationHotKey>Misc5</designationHotKey>
		<researchPrerequisites>
			<li>RI_CarpentryAndCrafting</li>
		</researchPrerequisites>
	</ThingDef>

	<!--Dig mud pit-->
	<ThingDef ParentName="BuildingBase">
		<defName>RI_Building_MudDigWhole</defName>
		<label>digging pit</label>
		<description>A crude excavation pit that can be built on soil, used to extract materials such as dirt.\n\nIn some regions, forcing juvenile offenders to dig pits was a common form of punishment.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_MudDigWhole</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(3,3)</drawSize>
		</graphicData>
		<altitudeLayer>FloorEmplacement</altitudeLayer>
		<statBases>
			<WorkToBuild>500</WorkToBuild>
			<WorkTableWorkSpeedFactor>0.8</WorkTableWorkSpeedFactor>
			<Cleanliness>-10</Cleanliness>
			<Beauty>-5</Beauty>
		</statBases>
		<scatterableOnMapGen>false</scatterableOnMapGen>
		<useHitPoints>false</useHitPoints>
		<size>(3,3)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2000</uiOrder>
		<passability>PassThroughOnly</passability>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,0)</interactionCellOffset>
		<terrainAffordanceNeeded>Diggable</terrainAffordanceNeeded>
		<surfaceType>Item</surfaceType>
		<recipes>
			<li>RI_DigMud</li>
			<li>RI_DigMudBulk</li>
		</recipes>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<sowTag>SupportPlantsOnly</sowTag>
			<canPlaceOverImpassablePlant>false</canPlaceOverImpassablePlant>
			<ai_chillDestination>false</ai_chillDestination>
			<wakeDormantPawnsOnConstruction>false</wakeDormantPawnsOnConstruction>
			<workTableNotInRoomRoleFactor>1</workTableNotInRoomRoleFactor>
			<artificialForMeditationPurposes>false</artificialForMeditationPurposes>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
		</building>
		<comps>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_ReportWorkSpeed">
				<workSpeedStat>WorkTableWorkSpeedFactor</workSpeedStat>
			</li>
		</comps>
		<designationHotKey>Misc1</designationHotKey>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_ReportWorkSpeedPenalties</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
	</ThingDef>

	<!--Electric kiln-->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_ElectricKiln</defName>
		<label>electric kiln</label>
		<description>An electrically heated kiln developed during the industrial era. However, traditional brick kilns fueled by firewood were not immediately phased out due to their large capacity and low construction cost.\n\nOnly later, as factories demanded higher standards for cleanliness and precise temperature control, did electric kilns fully replace traditional kilns.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/RI_Building_ElectricKiln</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(4.47,4.4)</drawSize>
			<shadowData>
				<volume>(2.8, 0.35, 0.59)</volume>
				<offset>(0, 0, 0.08)</offset>
			</shadowData>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>

		<costList>
			<Steel>150</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>

		<recipes>
			<!--Fire bricks-->
			<li>RI_MakeBlackBrick</li>
			<li>RI_MakeBlackBrickBulk</li>
			<li>RI_MakeBlackBrickTen</li>
			<li>RI_MakeRedBrick</li>
			<li>RI_MakeRedBrickBulk</li>
			<li>RI_MakeRedBrickTen</li>
			<!--Kiln work-->
			<li>ExtractMetalFromSlag</li>
			<li>SmeltOrDestroyThing</li>
			<li>SmeltWeapon</li>
			<li>SmeltApparel</li>
			<li>DestroyWeapon</li>
			<li>DestroyApparel</li>
		</recipes>
		<constructEffect>ConstructMetal</constructEffect>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.8</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>4000</WorkToBuild>
			<MaxHitPoints>400</MaxHitPoints>
			<Flammability>0.8</Flammability>
			<WorkTableWorkSpeedFactor>1.5</WorkTableWorkSpeedFactor>
			<Cleanliness>-1</Cleanliness>
			<Beauty>0</Beauty>
		</statBases>
		<size>(3,2)</size>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2510</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<workTableRoomRole>Workshop</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>520</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>3</heatPerSecond>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>RI_Electric</li>
		</researchPrerequisites>
	</ThingDef>

	<!-- Medieval — sawhorse -->
	<ThingDef ParentName="BenchBase">
		<defName>RI_Building_SawHorse</defName>
		<label>saw horses</label>
		<description>Two wooden frames placed side by side, resembling the legs of a horse. Logs rest across them like a horse’s body, hence the name “saw horses.”\n\nA simple workbench used to cut logs into planks.</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Production/SawHorse/RI_Building_SawHorse</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(2.5,2.5)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<costStuffCount>30</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
		</stuffCategories>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>1200</WorkToBuild>
			<MaxHitPoints>150</MaxHitPoints>
			<Flammability>0.8</Flammability>
			<Cleanliness>-2</Cleanliness>
		</statBases>
		<size>(2,1)</size>
		<researchPrerequisites>
			<li>RI_CarpentryAndCrafting</li>
		</researchPrerequisites>
		<designationCategory>RI_RimImmortals_Group</designationCategory>
		<uiOrder>2100</uiOrder>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
			<paintable>true</paintable>
			<workTableRoomRole>Workshop</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
		</building>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
	</ThingDef>

